      <PropertyValue Property="LongDescription" String="Gets the account assignment details of all the accounting lines of all the items, in all the purchase requisitions in the system.Note that if there are many purchase requisitions in the system, this operation might take a while."/>
      <PropertyValue Property="ReadByKeyRestrictions">
       <Record>
        <PropertyValue Property="Description" String="Gets the account assignment details of a particular accounting line of an item in a purchase requisition"/>
        <PropertyValue Property="LongDescription" String="Gets the account assignment details of a particular accounting line of an item in a purchase requisition, using the purchase requisition number, item number, and serial number of the accounting line provided."/>
       </Record>
      </PropertyValue>
     </Record>
    </Annotation>
   </Annotations>
