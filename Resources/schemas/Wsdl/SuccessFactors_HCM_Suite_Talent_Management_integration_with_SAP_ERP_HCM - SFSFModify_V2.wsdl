				</sequence>
			</complexType>
			<!--//////////////////////////////////////// -->
			<!--Generic result type of modifying operations, as standard explicit -->
			<!--types are equal -->
			<!-- /////////////////////////////////////// -->
			<complexType name="ModifyResult">
