           <PropertyValue Property="LongDescription" String="Adds an item to a purchase requisition using the purchase requisition number provided. It is mandatory to pass the purchase requisition number, &quot; PurchaseRequisition&quot;, in the request body."/>
          </Record>
         </PropertyValue>
