				</xs:restriction>
			</xs:simpleType>
			<xs:simpleType name="CiudadType">
				<xs:annotation>
					<xs:documentation>Ciudad</xs:documentation>
				</xs:annotation>
				<xs:restriction base="xs:string">
					<xs:maxLength value="20" />
				</xs:restriction>
			</xs:simpleType>
			<xs:simpleType name="FonoType">
				<xs:annotation>
					<xs:documentation>Fono</xs:documentation>
