					</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:normalizedString">
					<xsd:minLength value="1"/>
					<xsd:maxLength value="2"/>
					<xsd:enumeration value="A">
						<xsd:annotation>
							<xsd:documentation>Contracted In (Standard)</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="B">
						<xsd:annotation>
							<xsd:documentation>Contracted In (Reduced)</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="C">
						<xsd:annotation>
							<xsd:documentation>Contracted In (No EES)</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="C1">
						<xsd:annotation>
							<xsd:documentation>Contracted Out (No EES)</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="D">
						<xsd:annotation>
							<xsd:documentation>Contracted Out (Standard)</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="E">
						<xsd:annotation>
							<xsd:documentation>Contracted Out (Reduced)</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="F">
						<xsd:annotation>
							<xsd:documentation>Contracted Out (COMP)</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="G">
						<xsd:annotation>
							<xsd:documentation>Contracted Out (COMP)</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="J">
						<xsd:annotation>
							<xsd:documentation>Contracted in Deferred</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="L">
						<xsd:annotation>
							<xsd:documentation>Contracted out (COSR) Deferred</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="N">
						<xsd:annotation>
							<xsd:documentation>NI N Mariners COSR</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="O">
						<xsd:annotation>
							<xsd:documentation>NI O Mariners COSR Wife</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="P">
						<xsd:annotation>
							<xsd:documentation>NIC Holiday Reclaim</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="Q">
						<xsd:annotation>
							<xsd:documentation>NI Q Mariners Contracted In Deferred</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="R">
						<xsd:annotation>
							<xsd:documentation>NI R Mariners Contracted In</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="S">
						<xsd:annotation>
							<xsd:documentation>Contracted Out (COMP) Deferred</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="T">
						<xsd:annotation>
							<xsd:documentation>NI T Mariners Contracted In Wife</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="W">
						<xsd:annotation>
							<xsd:documentation>NI W Mariners Pensioner</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="X">
						<xsd:annotation>
							<xsd:documentation>Exempt</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="AUTaxAnnualLeaveLoadingExemptType">
				<xsd:annotation>
					<xsd:documentation>
						<ccts:DictionaryEntryName xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> A/L Loading Tax Exempt </ccts:DictionaryEntryName>
						<ccts:DefinitionText xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> The amount of tax exempt leave loading that has already been
					paid to the employee under the rules of the Australian Tax system.
						</ccts:DefinitionText>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:decimal"/>
			</xsd:simpleType>
			<xsd:simpleType name="NZTaxSTCSecondaryIncomeType">
				<xsd:annotation>
					<xsd:documentation>
						<ccts:DictionaryEntryName xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> STC Secondary Income for Student Loan </ccts:DictionaryEntryName>
						<ccts:DefinitionText xmlns:ccts="urn:un:unece:uncefact:documentation:1.1">
							<![CDATA[ •Activated when the Tax Code is 'A' - STC and Supplementary
					Tax Code is 'S' -Student Loan •When ticked, the Student Loan Override % will be
					calculated on every dollar earned. ]]>
						</ccts:DefinitionText>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:decimal">
					<xsd:totalDigits value="5"/>
					<xsd:minInclusive value="0"/>
					<xsd:maxInclusive value="99999"/>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="AUTaxFileNumberType">
				<xsd:annotation>
					<xsd:documentation>
						<ccts:DictionaryEntryName xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> Tax File Number </ccts:DictionaryEntryName>
						<ccts:DefinitionText xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> Unique number for a person&apos;s tax information. Not mandatory
					but usually provided to payroll when person starts employment.
						</ccts:DefinitionText>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:integer">
					<xsd:totalDigits value="9"/>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="BEIPCiAmount2Type">
				<xsd:annotation>
					<xsd:documentation>
						<ccts:DictionaryEntryName xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> Payment Amount 2 </ccts:DictionaryEntryName>
						<ccts:DefinitionText xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> Payment Amount 2 </ccts:DefinitionText>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:decimal">
					<xsd:totalDigits value="15"/>
					<xsd:fractionDigits value="2"/>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="NZTaxContHolEndDateType">
				<xsd:annotation>
					<xsd:documentation>
						<ccts:DictionaryEntryName xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> Date Contribution Holiday Ends </ccts:DictionaryEntryName>
						<ccts:DefinitionText xmlns:ccts="urn:un:unece:uncefact:documentation:1.1">
							<![CDATA[ the end date of the Contribution Holiday. This field is not
					required unless the Kiwisaver option "C" has been selected. This information is
					for your records only and is not sent to IRD. ]]>
						</ccts:DefinitionText>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:date"/>
			</xsd:simpleType>
			<xsd:simpleType name="AlternateIDType">
				<xsd:annotation>
					<xsd:documentation source="http://www.ngahr.com/ngapexxml" xml:lang="en">
						<ccts:DictionaryEntryName xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> NGA Alternate system ID </ccts:DictionaryEntryName>
						<ccts:DefinitionText xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> ID of the employee used by any system other than the main HRIS
					system (such as a benefits or pension system). </ccts:DefinitionText>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="oa:StringType"/>
			</xsd:simpleType>
			<xsd:simpleType name="GBTaxP45StudentLoanType">
				<xsd:annotation>
					<xsd:documentation>
						<ccts:DictionaryEntryName xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> Student loan indicator </ccts:DictionaryEntryName>
						<ccts:DefinitionText xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> Student loan indicator. Only applies to P45 source
						</ccts:DefinitionText>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:normalizedString">
					<xsd:minLength value="1"/>
					<xsd:maxLength value="1"/>
					<xsd:enumeration value="Y">
						<xsd:annotation>
							<xsd:documentation>Yes</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="N">
						<xsd:annotation>
							<xsd:documentation>No</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="BEIDDebtorType">
				<xsd:annotation>
					<xsd:documentation>
						<ccts:DictionaryEntryName xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> Debtor </ccts:DictionaryEntryName>
						<ccts:DefinitionText xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> Debtor </ccts:DefinitionText>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:normalizedString">
					<xsd:enumeration value="0">
						<xsd:annotation>
							<xsd:documentation>Declaration created by the employer being the only debtor.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="1">
						<xsd:annotation>
							<xsd:documentation>Declaration done by the employer being the principal debtor.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="2">
						<xsd:annotation>
							<xsd:documentation>Declaration done by a replacing fund or third party being
						the only substituting debtor.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="3">
						<xsd:annotation>
							<xsd:documentation>Declaration done by a fund or third party being the
						principal debtor.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="4">
						<xsd:annotation>
							<xsd:documentation>Multiple debtors and the employer makes current declaration.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="5">
						<xsd:annotation>
							<xsd:documentation>Multiple debtors and a fund / third party makes current
						declaration.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="NZTaxESCTComplyingFundType">
				<xsd:annotation>
					<xsd:documentation>
						<ccts:DictionaryEntryName xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> ESCT Rate Threshold Complying Fund </ccts:DictionaryEntryName>
						<ccts:DefinitionText xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> Value used for calculation of ESCT Tax Rate
						</ccts:DefinitionText>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:decimal">
					<xsd:fractionDigits fixed="true" value="2"/>
					<xsd:totalDigits value="10"/>
					<xsd:minInclusive value="0"/>
					<xsd:maxInclusive value="9999999999"/>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="BEIPWagetype3Type">
				<xsd:annotation>
					<xsd:documentation>
						<ccts:DictionaryEntryName xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> Payment Wagetype 3 </ccts:DictionaryEntryName>
						<ccts:DefinitionText xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> Payment Wagetype 3 </ccts:DefinitionText>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:normalizedString">
