			<xsd:simpleType name="PayScaleGroupType">
				<xsd:annotation>
					<xsd:documentation>
						<ccts:DictionaryEntryName xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> NGA Pay Scale Group </ccts:DictionaryEntryName>
						<ccts:DefinitionText xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> A pay scale group is a criterion used for grading job
					evaluation. They can consists out of multiple levels. </ccts:DefinitionText>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="oa:StringType"/>
