                  Transaction Set must be transmitted for the identified
                  product.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SOP">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Store in Original
                  Packaging</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The product may NOT be
                  repackaged and must be stored in its original packaging.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SRT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Store at Room
                  Temperature</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The product must be stored at
                  room temperature</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SSN">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Smell Sensitive</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Smell
                  sensitive</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="STR">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Stacking
                  Restricted</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Stacking
                  restricted</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SW">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Stretch Wrap</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identified product is
                  wrapped in stretch wrap.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="TRD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transit or Cross Docking
                  Delivery</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identified product is to
                  be delivered via a transit or cross docking facility.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="UI">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Unitised</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identified product is
                  bound together with other products for handling and transportation as one
                  unit.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="UIS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Use Only After Mixing With an
                  Isotonic Solution</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">To keep the intrinsic
                  qualities of the product, it must be used only after mixing with an isotonic
                  solution</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="UNP">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Unpack</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identified product is to
                  be unpacked from the identified package.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="UPR">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Upright/standing </xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identified product should
                  be kept in an upright or standing position.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="UST">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Unstackable</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Unstackable</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="VAL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Valuable Cargo</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Valuable
                  cargo</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="WNA">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Weapons Not
                  Allowed</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">No weapons allowed at
                  delivery / pick-up location (e.g. airports).</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
