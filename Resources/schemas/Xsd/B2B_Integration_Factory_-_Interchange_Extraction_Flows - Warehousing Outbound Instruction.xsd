         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="TransactionalItemCertificationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information about certification standards to which the transactional trade item complies.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="itemCertificationAgency" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Item Certification Agency</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Name of the organization issuing the certification standard or other requirement being met.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: General Universal Certifying Agency</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="itemCertificationStandard" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Item Certification Standard</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Name of the certification standard. Free text. Example: Organic product.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Organic product</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="itemCertificationValue" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Item Certification Value</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The product’s certification standard value. E.g. DE-OKO-006</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: DE-OKO-006</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="TransactionalItemDataCarrierAndIdentificationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Provides information about GS1 Identifier and Data Carriers associated with the trade item.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="gs1TransactionalItemIdentificationKey" minOccurs="0"
            type="GS1ItemIdentificationKeyCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gs 1 Transactional Item Identification Key</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Specifies the type of GS1 Identification Key.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dataCarrier" minOccurs="0" type="DataCarrierTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Data Carrier</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A means to represent data in a machine readable form.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="TransactionalItemDataType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Dynamic characteristics used to specify individual instances of a trade item, such as the best before date, batch number or serial number.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="availableForSaleDate" minOccurs="0" type="xsd:date">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Available For Sale Date</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Dynamic characteristics used to specify individual instances of a trade item, such as the best before date, batch number or serial number.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="batchNumber" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Batch Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A batch unites products or items that have undergone or are grouped together to undergo the same transformation process, not necessarily a production process.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: XYZHD867354</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="bestBeforeDate" minOccurs="0" type="xsd:date">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Best Before Date</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The date before which the product is best used or consumed. It is a statement about quality.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-09-15</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="countryOfOrigin" minOccurs="0" type="CountryCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Country Of Origin</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Country from which the goods are supplied.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="itemExpirationDate" minOccurs="0" type="xsd:date">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Item Expiration Date</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The date after which the product should not be used or consumed. Its meaning is determined based on the trade item context (e.g., for food, the date will indicate the possibility of a direct health risk resulting from use of the product after the date, for pharmaceutical products, it will indicate the possibility of an indirect health risk resulting from the ineffectiveness of the product after the date). It is often referred to as "use by date" or "maximum durability date.”</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-09-15</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="lotNumber" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Lot Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A distinctive combination of numbers and/or letters from which the complete history of the manufacture, processing, packaging, coding and distribution of a batch can be determined.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: FGAE45265/12</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="packagingDate" minOccurs="0" type="xsd:date">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Packaging Date</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The date on which the packaging of a product took place.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-01-15</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="productionDate" minOccurs="0" type="xsd:date">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Production Date</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The date that the product was produced.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-01-15</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="productQualityIndication" minOccurs="0" type="QuantityType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Product Quality Indication</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Value used to indicate the quality, such as grade or strength, of a specific batch of products.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sellByDate" minOccurs="0" type="xsd:date">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sell By Date</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The date before or on which, the product should be sold.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-09-15</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="serialNumber" minOccurs="0" maxOccurs="unbounded">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Serial Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A unique identifier assigned to a specific trade item.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 987654321WE</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="shelfLife" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Shelf Life</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The length of time a material, substance, product, or reagent can be stored under specified environmental conditions and continue to meet all applicable specification requirements and/or remain suitable for its intended function.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1 year</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="tradeItemQuantity" minOccurs="0" type="QuantityType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Trade Item Quantity</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 12</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The total number of individual trade items being specified.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="itemInContactWithFoodProduct" minOccurs="0" type="xsd:boolean">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Item In Contact With Food Product</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">States weather or not the trade item can come into contact with food products.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: TRUE</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transactionalItemWeight" minOccurs="0" maxOccurs="unbounded"
            type="UnitMeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transactional Item Weight</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Weight is a measurement of the gravitational force acting on a transactional object.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transactionalItemVolume" minOccurs="0" maxOccurs="unbounded"
            type="UnitMeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transactional Item Volume</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information on the volume of the specified items.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="serialNumberRange" minOccurs="0" maxOccurs="unbounded"
            type="StringRangeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Serial Number Range</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The difference or interval between the minimum and maximum value of the serial numbers expressed as a string</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transactionalItemDimensions" minOccurs="0" maxOccurs="unbounded"
            type="DimensionType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transactional Item Dimensions</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Dimensions of the transactional trade item: depth, height, width</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transactionalItemLogisticUnitInformation" minOccurs="0"
            type="TransactionalItemLogisticUnitInformationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transactional Item Logistic Unit Information</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transactionalItemDataCarrierAndIdentification" minOccurs="0"
            type="TransactionalItemDataCarrierAndIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transactional Item Data Carrier And Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Provides information about GS1 Identifier and Data Carriers associated with the trade item.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="tradeItemWaste" minOccurs="0" maxOccurs="unbounded"
            type="WasteDetailsType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Trade Item Waste</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Provides details of waste generated by the trade item.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"/>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transactionalItemOrganicInformation" minOccurs="0"
            type="TransactionalItemOrganicInformationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transactional Item Organic Information</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="avpList" minOccurs="0" type="Ecom_AttributeValuePairListType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Avp List</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="TransactionalItemLogisticUnitInformationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Specifies packaging parameters for transport and storage purposes.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="numberOfLayers" minOccurs="0" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Number Of Layers</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number of layers of a product or products within a package, container, pallet, etc.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 5</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="numberOfUnitsPerLayer" minOccurs="0" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Number Of Units Per Layer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number of units of a product or package within one layer of a package, container, pallet, etc.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 20</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="numberOfUnitsPerPallet" minOccurs="0" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Number Of Units Per Pallet</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The number of units contained on a pallet calculated by multiplying the number of units per layer by the number of layers on a pallet.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 100</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="packagingTerms" minOccurs="0" type="PackagingTermsCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Packaging Terms</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Specifies packaging terms and conditions.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="packageTypeCode" minOccurs="0" type="PackageTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Package Type Code</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="maximumStackingFactor" type="xsd:nonNegativeInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Maximum Stacking Factor</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A factor that determines the maximum stacking for the product. Indicates the number of levels the product may be stacked.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 10</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="returnablePackageTransportCostPayment" minOccurs="0"
            type="TransportChargesPaymentMethodCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Returnable Package Transport Cost Payment</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dimensionsOfLogisticUnit" minOccurs="0" maxOccurs="unbounded"
            type="DimensionType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dimensions Of Logistic Unit</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information specifying the physical dimensions of a specific logistic unit.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="TransactionalItemOrganicInformationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Provides information about whether or not the trade item is organic, with optional organic certification information.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="isTradeItemOrganic" type="xsd:boolean">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Is Trade Item Organic</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information about whether or not the trade item is organic.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: TRUE</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="organicCertification" minOccurs="0"
            type="TransactionalItemCertificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Organic Certification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Specifies information about the organic trade item certification.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="TransactionalPartyInRoleType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">The identification of a party, by GLN, in a specific party role.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">Identification of and additional information about a party involved in a business transaction, such as “order” or “invoice”. </xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">Information used to identify a party or location.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="gln" minOccurs="0" type="GLNType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gln</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="additionalPartyIdentification" minOccurs="0" maxOccurs="unbounded"
            type="AdditionalPartyIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Additional Party Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifier of the party or location, specified in addition to the GLN.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="address" minOccurs="0" type="AddressType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Address</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Address of the party involved in the business transaction.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="contact" minOccurs="0" maxOccurs="unbounded" type="ContactType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Contact</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Person or department that can be contacted regarding the business transaction.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dutyFeeTaxRegistration" minOccurs="0" maxOccurs="unbounded"
            type="DutyFeeTaxRegistrationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Duty Fee Tax Registration</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="organisationDetails" minOccurs="0" type="OrganisationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Organisation Details</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information about the legal organisation of the party involved in the business transaction.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="financialInstitutionInformation" minOccurs="0" maxOccurs="unbounded"
            type="FinancialInstitutionInformationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Financial Institution Information</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information on the financial institution(s) where the party holds an account.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="avpList" minOccurs="0" type="Ecom_AttributeValuePairListType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Avp List</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="partyRoleCode" type="PartyRoleCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Party Role Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:PartyRoleCode</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: BRAND_OWNER</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A code that identifies the role of a party in a business transaction.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="TransactionalPartyType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Identification of and additional information about a party involved in a business transaction, such as “order” or “invoice”. </xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">Information used to identify a party or location.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="gln" minOccurs="0" type="GLNType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gln</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="additionalPartyIdentification" minOccurs="0" maxOccurs="unbounded"
            type="AdditionalPartyIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Additional Party Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifier of the party or location, specified in addition to the GLN.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="address" minOccurs="0" type="AddressType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Address</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Address of the party involved in the business transaction.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="contact" minOccurs="0" maxOccurs="unbounded" type="ContactType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Contact</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Person or department that can be contacted regarding the business transaction.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dutyFeeTaxRegistration" minOccurs="0" maxOccurs="unbounded"
            type="DutyFeeTaxRegistrationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Duty Fee Tax Registration</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="organisationDetails" minOccurs="0" type="OrganisationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Organisation Details</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information about the legal organisation of the party involved in the business transaction.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="financialInstitutionInformation" minOccurs="0" maxOccurs="unbounded"
            type="FinancialInstitutionInformationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Financial Institution Information</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information on the financial institution(s) where the party holds an account.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="avpList" minOccurs="0" type="Ecom_AttributeValuePairListType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Avp List</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="TransactionalReferenceType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Reference to associated information in support of related business processes. E.g. a purchase order, a return authorization number.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">Information identifying a piece of information, such as an object or document.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="entityIdentification">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Entity Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The unique identifier of the piece of information, such as the object id or the document id.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: ABCDE00001</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="contentOwner" minOccurs="0" type="Ecom_PartyIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Content Owner</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="creationDateTime" minOccurs="0" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Creation Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date and time of creation of the referenced document.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15T11:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="revisionNumber" minOccurs="0" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Revision Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number to be used for identification and referencing of subsequent updates to a business document.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="lineItemNumber" minOccurs="0" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Line Item Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number specifying a line in the referenced document.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="referencedDocumentUrl" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Referenced Document Url</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An URI pointing to the on-line location where the referenced document is stored.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: http://www.company/documentABC</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transactionalReferenceTypeCode"
            type="TransactionalReferenceTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transactional Reference Type Code</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="TransactionalReferenceTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:TransactionalReferenceTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: AAB</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a transactional reference type. Allowed code values are specified in GS1 Code List TransactionalReferenceTypeCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="TransactionalReferenceTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="TransactionalTradeItemType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">A trade item is any item (product or service) upon which there is a need to retrieve pre-defined information and that may be priced, or ordered, or invoiced at any point in any supply chain.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">Provides the GTIN as the unique identifier for the item and optionally additional formats of non GTIN identifiers for the item.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="gtin" minOccurs="0" type="GTINType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gtin</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="additionalTradeItemIdentification" minOccurs="0" maxOccurs="unbounded"
            type="AdditionalTradeItemIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Additional Trade Item Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Alternative means to the Global Trade Item Number to identify a trade item.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="tradeItemQuantity" minOccurs="0" type="QuantityType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Trade Item Quantity</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1500</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Specification of the number of units of the trade item. To be applied when no other quantity information, such as the requested quantity or the billed quantity, is present.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="tradeItemDescription" minOccurs="0" type="Description200Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Trade Item Description</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Describe trade item</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Textual description of the trade item.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="productVariantIdentifier" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Product Variant Identifier</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Text identifying a variant of the product, for example for promotional reasons.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Christmas edition</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="itemTypeCode" minOccurs="0" type="ItemTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Item Type Code</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="tradeItemDataOwner" minOccurs="0" type="TradeItemDataOwnerCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Trade Item Data Owner</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Specifies who owns the set of trade item transactional data.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="butterFatReference" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Butter Fat Reference</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A reference number assigned by custom authorities to butter based fat products.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 3871DUGN</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transactionalItemData" minOccurs="0" maxOccurs="unbounded"
            type="TransactionalItemDataType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transactional Item Data</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="colour" minOccurs="0" maxOccurs="unbounded" type="ColourType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Colour</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information specifying the colour of the trade item.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="size" minOccurs="0" maxOccurs="unbounded" type="SizeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Size</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The physical dimensions or proportions of the transactional trade item depicted as a code or a description.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="tradeItemClassification" minOccurs="0"
            type="TradeItemClassificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Trade Item Classification</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="avpList" minOccurs="0" type="Ecom_AttributeValuePairListType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Avp List</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="TransportCargoCharacteristicsType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information on a load of goods being transported.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="cargoTypeCode" type="CargoTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Cargo Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the classification of a type of cargo for example hazardous cargo.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="harmonizedSystemCode" minOccurs="0" type="HarmonizedSystemCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Harmonized System Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the cargo according to the Harmonised Commodity Description and Coding System (HS) of tariff nomenclature, developed and maintained by the World Customs Organization (WCO).</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="cargoTypeDescription" minOccurs="0" type="Description200Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Cargo Type Description</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Describe cargo type</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Free text specifying the classification of a type of cargo.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="countryOfOriginCode" minOccurs="0" type="CountryCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Country Of Origin Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The country where this transport cargo has been manufactured.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="finalDestinationCountry" minOccurs="0" type="CountryCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Final Destination Country</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The country considered to be the final destination for this transport cargo, for regulatory compliance purposes.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="totalGrossVolume" minOccurs="0" type="MeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Total Gross Volume</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 343000000</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A measure of the volume, normally calculated by multiplying the maximum length, width, and height of the packaged goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="totalGrossWeight" minOccurs="0" type="MeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Total Gross Weight</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1500</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A measure of the mass of the goods including the weight of transport packaging, and potentially the weight of any transport equipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="totalTransportNetWeight" minOccurs="0" type="MeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Total Transport Net Weight</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1200</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A measure of the mass of the goods excluding the weight of transport packaging and excluding the weight of any transport equipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="totalChargeableWeight" minOccurs="0" type="MeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Total Chargeable Weight</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1500</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Measure of the weight on which freight charges may be calculated for this transport cargo.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="declaredWeightForCustoms" minOccurs="0" type="MeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Declared Weight For Customs</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1500</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Measure of the weight of the goods for customs declaration purposes.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="totalLoadingLength" minOccurs="0" type="MeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Total Loading Length</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 700</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Measure of the total length the goods occupy in a transport means / on a piece of transport equipment. E.g. Loading metres in a truck or trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="associatedInvoiceAmount" minOccurs="0" type="AmountType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Associated Invoice Amount</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 20000</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The commercial value of the cargo.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="declaredValueForCustoms" minOccurs="0" type="AmountType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Declared Value For Customs</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 20000</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The monetary value declared for customs purposes for this transport cargo.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="totalPackageQuantity" minOccurs="0" type="QuantityType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Total Package Quantity</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 70</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Total number of logistic units (e.g. pallets) in this transport cargo.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="totalItemQuantity" minOccurs="0" type="QuantityType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Total Item Quantity</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 140</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The number of trade items on which freight charges may be calculated for this transport cargo.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="TransportChargesPaymentMethodCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Specifies who will pay transport cost.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:TransportChargesPaymentMethodCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: TP</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="TransportChargesPaymentMethodCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="TransportEquipmentType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Transport equipment is a piece of equipment used to hold, protect or secure cargo for logistics purposes. Transport Equipment is to be moved using Transport Means.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="transportEquipmentTypeCode" type="CodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transport Equipment Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the transport equipment size and type.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="returnableAssetTypeIdentification" minOccurs="0"
            type="Ecom_ReturnableAssetIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Returnable Asset Type Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The returnable asset identifier for the type of transport equipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="individualReturnableAssetIdentification" minOccurs="0"
            maxOccurs="unbounded" type="Ecom_ReturnableAssetIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Individual Returnable Asset Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The returnable asset identifier for an individual piece of transport equipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="individualAssetIdentification" minOccurs="0" maxOccurs="unbounded"
            type="Ecom_IndividualAssetIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Individual Asset Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The individual asset identifier for an individual piece of transport equipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="TransportInstructionStatusReasonCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 195</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a transport instruction status reason. Allowed code values are specified in GS1 Code List TransportInstructionStatusReasonCode.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl: 	TransportStatusReasonCode</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="TransportInstructionStatusReasonCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="TransportMeansType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">A transport means is a particular device (with its own engine/power) used to convey goods or other objects from place to place during logistics cargo movements.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="transportMeansType" type="TransportMeansTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transport Means Type</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the type of vehicle, aircraft, vessel or other device used for the transport of goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transportMeansID" minOccurs="0" type="IdentifierType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transport Means I D</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: 059AGV</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The unique identifier of a particular means of transport. E.g. A license plate number or vessel id.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transportMeansName" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transport Means Name</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The name, expressed as text, of a particular means of transport. E.g. The vessel name.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: Truck</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="communicationChannel" minOccurs="0" maxOccurs="unbounded"
            type="CommunicationChannelType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Communication Channel</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The channel or manner in which a communication can be made with the transport means. E.g. telephone or email.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="TransportMeansTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:TransportMeansTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 31</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a transport means type. Allowed code values are specified in GS1 Code List TransportMeansTypeCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="TransportMeansTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="TransportModeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:TransportModeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 30</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a transport mode. Allowed code values are specified in GS1 Code List TransportModeCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="TransportModeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="TransportPartyRoleCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:TransportPartyRoleCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: CARRIER</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a transport party role. Allowed code values are specified in GS1 Code List TransportPartyRoleCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="TransportPartyRoleCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="TransportPaymentMethodCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:TransportPaymentMethodCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: PU</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a transport payment method. Allowed code values are specified in GS1 Code List TransportPaymentMethodCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="TransportPaymentMethodCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="TransportReferenceType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition"> Reference to associated information in support of related business processes. E.g. a purchase order, a bank account number.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">Information identifying a piece of information, such as an object or document.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="entityIdentification">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Entity Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The unique identifier of the piece of information, such as the object id or the document id.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: ABCDE00001</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="contentOwner" minOccurs="0" type="Ecom_PartyIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Content Owner</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="creationDateTime" minOccurs="0" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Creation Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date and time of creation of the referenced document.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15T11:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="revisionNumber" minOccurs="0" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Revision Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number to be used for identification and referencing of subsequent updates to a business document.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="lineItemNumber" minOccurs="0" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Line Item Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number specifying a line in the referenced document.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="referencedDocumentUrl" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Referenced Document Url</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An URI pointing to the on-line location where the referenced document is stored.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: http://www.company/documentABC</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transportReferenceTypeCode" type="TransportReferenceTypeCodeType">
            <xsd:annotation>
