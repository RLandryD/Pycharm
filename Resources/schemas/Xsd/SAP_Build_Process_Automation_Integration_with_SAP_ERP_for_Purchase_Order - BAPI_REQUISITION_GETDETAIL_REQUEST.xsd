<xsd:schema attributeFormDefault="unqualified" elementFormDefault="qualified" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
	<xsd:element name="BAPI_REQUISITION_GETDETAIL">
		<xsd:complexType>
			<xsd:all>
				<xsd:element name="ACCOUNT_ASSIGNMENT" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>Also Provide Account Assignment Data</xsd:documentation>
					</xsd:annotation>
					<xsd:simpleType>
						<xsd:restriction base="xsd:string">
							<xsd:maxLength value="1"/>
						</xsd:restriction>
					</xsd:simpleType>
				</xsd:element>
				<xsd:element name="ITEM_TEXTS" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>Also Provide Texts</xsd:documentation>
					</xsd:annotation>
					<xsd:simpleType>
						<xsd:restriction base="xsd:string">
							<xsd:maxLength value="1"/>
						</xsd:restriction>
					</xsd:simpleType>
				</xsd:element>
				<xsd:element name="NUMBER">
					<xsd:annotation>
						<xsd:documentation>Purchase Requisition Number</xsd:documentation>
					</xsd:annotation>
					<xsd:simpleType>
						<xsd:restriction base="xsd:string">
							<xsd:maxLength value="10"/>
						</xsd:restriction>
					</xsd:simpleType>
				</xsd:element>
				<xsd:element name="PREQ_ITEM" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>Item number of purchase requisition</xsd:documentation>
					</xsd:annotation>
					<xsd:simpleType>
						<xsd:restriction base="xsd:string">
							<xsd:maxLength value="5"/>
							<xsd:pattern value="\d+"/>
						</xsd:restriction>
					</xsd:simpleType>
				</xsd:element>
				<xsd:element name="SERVICES" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>Also Provide Service Items</xsd:documentation>
					</xsd:annotation>
					<xsd:simpleType>
						<xsd:restriction base="xsd:string">
							<xsd:maxLength value="1"/>
						</xsd:restriction>
					</xsd:simpleType>
				</xsd:element>
				<xsd:element name="SERVICE_TEXTS" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>Also Provide Service Texts</xsd:documentation>
					</xsd:annotation>
					<xsd:simpleType>
						<xsd:restriction base="xsd:string">
							<xsd:maxLength value="1"/>
						</xsd:restriction>
					</xsd:simpleType>
				</xsd:element>
				<xsd:element name="REQUISITION_ACCOUNT_ASSIGNMENT" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>Account Assignment Data</xsd:documentation>
					</xsd:annotation>
					<xsd:complexType>
						<xsd:sequence>
							<xsd:element name="item" type="BAPIEBKN" minOccurs="0" maxOccurs="unbounded"/>
						</xsd:sequence>
					</xsd:complexType>
				</xsd:element>
				<xsd:element name="REQUISITION_CONTRACT_LIMITS" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>Limits with Contract Reference</xsd:documentation>
					</xsd:annotation>
					<xsd:complexType>
						<xsd:sequence>
							<xsd:element name="item" type="BAPIESUC" minOccurs="0" maxOccurs="unbounded"/>
						</xsd:sequence>
					</xsd:complexType>
				</xsd:element>
				<xsd:element name="REQUISITION_ITEMS">
					<xsd:annotation>
						<xsd:documentation>Item Data</xsd:documentation>
					</xsd:annotation>
					<xsd:complexType>
						<xsd:sequence>
							<xsd:element name="item" type="BAPIEBAN" minOccurs="0" maxOccurs="unbounded"/>
						</xsd:sequence>
					</xsd:complexType>
				</xsd:element>
				<xsd:element name="REQUISITION_LIMITS" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>Limits</xsd:documentation>
					</xsd:annotation>
					<xsd:complexType>
						<xsd:sequence>
							<xsd:element name="item" type="BAPIESUH" minOccurs="0" maxOccurs="unbounded"/>
						</xsd:sequence>
					</xsd:complexType>
				</xsd:element>
				<xsd:element name="REQUISITION_SERVICES" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>Services</xsd:documentation>
					</xsd:annotation>
					<xsd:complexType>
						<xsd:sequence>
							<xsd:element name="item" type="BAPIESLL" minOccurs="0" maxOccurs="unbounded"/>
						</xsd:sequence>
					</xsd:complexType>
				</xsd:element>
				<xsd:element name="REQUISITION_SERVICES_TEXTS" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>Long Texts for Service Line</xsd:documentation>
					</xsd:annotation>
					<xsd:complexType>
						<xsd:sequence>
							<xsd:element name="item" type="BAPIESLLTX" minOccurs="0" maxOccurs="unbounded"/>
						</xsd:sequence>
					</xsd:complexType>
				</xsd:element>
				<xsd:element name="REQUISITION_SRV_ACCASS_VALUES" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>Value/Link to Service Account Assignment</xsd:documentation>
					</xsd:annotation>
					<xsd:complexType>
						<xsd:sequence>
							<xsd:element name="item" type="BAPIESKL" minOccurs="0" maxOccurs="unbounded"/>
						</xsd:sequence>
					</xsd:complexType>
				</xsd:element>
				<xsd:element name="REQUISITION_TEXT" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>Texts</xsd:documentation>
					</xsd:annotation>
					<xsd:complexType>
						<xsd:sequence>
							<xsd:element name="item" type="BAPIEBANTX" minOccurs="0" maxOccurs="unbounded"/>
						</xsd:sequence>
					</xsd:complexType>
				</xsd:element>
				<xsd:element name="RETURN" minOccurs="0">
					<xsd:annotation>
						<xsd:documentation>Return Messages</xsd:documentation>
					</xsd:annotation>
					<xsd:complexType>
						<xsd:sequence>
							<xsd:element name="item" type="BAPIRETURN" minOccurs="0" maxOccurs="unbounded"/>
						</xsd:sequence>
					</xsd:complexType>
				</xsd:element>
			</xsd:all>
		</xsd:complexType>
	</xsd:element>
	<xsd:simpleType name="genericDate">
		<xsd:restriction base="xsd:string">
			<xsd:pattern value="....-..-.."/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="genericTime">
		<xsd:restriction base="xsd:string">
			<xsd:pattern value="..:..:.."/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="time">
		<xsd:union memberTypes="xsd:time genericTime" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
	</xsd:simpleType>
	<xsd:simpleType name="date">
		<xsd:union memberTypes="xsd:date genericDate" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
	</xsd:simpleType>
	<xsd:complexType name="BAPIESKL">
		<xsd:annotation>
			<xsd:documentation>Communication Structure: Acct. Assgt. Values: Service Line</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PCKG_NO" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Package number</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="10"/>
						<xsd:pattern value="\d+"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="LINE_NO" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Line Number</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="10"/>
						<xsd:pattern value="\d+"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="SERNO_LINE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Seq. Number of Acc. Assignment Specification: Service Line</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="2"/>
						<xsd:pattern value="\d+"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="DELETE_IND" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Deletion Indicator</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="1"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="INACTIVE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Inactive account assignment specification</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="1"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="QUANTITY" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Quantity</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:decimal">
						<xsd:totalDigits value="13"/>
						<xsd:fractionDigits value="3"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="PERCENTAGE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Percentage for Account Assignment Value Distribution</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:decimal">
						<xsd:totalDigits value="4"/>
						<xsd:fractionDigits value="1"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="NET_VALUE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Net value</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:decimal">
						<xsd:totalDigits value="23"/>
						<xsd:fractionDigits value="4"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="SERIAL_NO" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Sequential Number of Account Assignment</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="2"/>
						<xsd:pattern value="\d+"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="HPACKNO" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Highest package number</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="10"/>
						<xsd:pattern value="\d+"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="BAPIESLL">
		<xsd:annotation>
			<xsd:documentation>Communication Structure: Service Line</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="PCKG_NO" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Package number</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="10"/>
						<xsd:pattern value="\d+"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="LINE_NO" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Internal line number</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="10"/>
						<xsd:pattern value="\d+"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="EXT_LINE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Line Number</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="10"/>
						<xsd:pattern value="\d+"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="OUTL_LEVEL" type="xsd:unsignedByte" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Hierarchy level of group</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OUTL_NO" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Outline Level</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="8"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="OUTL_IND" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Indicator: Outline line</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="1"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="SUBPCKG_NO" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Subpackage number</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="10"/>
						<xsd:pattern value="\d+"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="DELETE_IND" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Deletion Indicator</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="1"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="SERVICE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Activity Number</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="18"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="SERV_TYPE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Short Description of Service Type</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="3"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="EDITION" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Edition of Service Type</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="4"/>
						<xsd:pattern value="\d+"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="SSC_ITEM" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Standard Service Catalog Item</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="18"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="EXT_SERV" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Supplier&apos;s Service Number</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="18"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="QUANTITY" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Quantity with Sign</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:decimal">
						<xsd:totalDigits value="13"/>
						<xsd:fractionDigits value="3"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="BASE_UOM" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Base Unit of Measure</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="3"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="UOM_ISO" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>ISO code for unit of measurement</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="3"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="OVF_TOL" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Overfulfillment Tolerance</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:decimal">
						<xsd:totalDigits value="3"/>
						<xsd:fractionDigits value="1"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="OVF_UNLIM" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Unlimited Overfulfillment</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="1"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="PRICE_UNIT" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Price unit</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:decimal">
						<xsd:totalDigits value="5"/>
						<xsd:fractionDigits value="0"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="GROSS_VAL" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Gross value</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:decimal">
						<xsd:totalDigits value="23"/>
						<xsd:fractionDigits value="4"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="NET_VALUE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Net value</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:decimal">
						<xsd:totalDigits value="23"/>
						<xsd:fractionDigits value="4"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="FROM_LINE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Lower Limit</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="6"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="TO_LINE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Upper Limit</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="6"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="SHORT_TEXT" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Short Text</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="40"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="DISTRIB" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Distribution indicator for multiple account assignment</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="1"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="PERS_NO" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Personnel Number</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="8"/>
						<xsd:pattern value="\d+"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="WAGETYPE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Wage Type</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="4"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="PLN_PCKG" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Source package number</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="10"/>
						<xsd:pattern value="\d+"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="PLN_LINE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Entry: Planned package line</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="10"/>
						<xsd:pattern value="\d+"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="CON_PCKG" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Entry: Unplanned from contract</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="10"/>
						<xsd:pattern value="\d+"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="CON_LINE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Entry: Unplanned from contract</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="10"/>
						<xsd:pattern value="\d+"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="TMP_PCKG" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Entry: Unplanned service from model specifications</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="10"/>
						<xsd:pattern value="\d+"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="TMP_LINE" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Entry: Unplanned service from model specifications</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:string">
						<xsd:maxLength value="10"/>
						<xsd:pattern value="\d+"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<xsd:element name="SSC_LIM" minOccurs="0">
				<xsd:annotation>
