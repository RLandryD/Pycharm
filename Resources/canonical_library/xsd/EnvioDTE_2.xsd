					<xsd:enumeration value="DOLAR CAN" />
					<xsd:enumeration value="DOLAR HK" />
					<xsd:enumeration value="DOLAR NZ" />
					<xsd:enumeration value="DOLAR SIN" />
					<xsd:enumeration value="DOLAR TAI" />
					<xsd:enumeration value="DOLAR USA" />
					<xsd:enumeration value="DRACMA" />
					<xsd:enumeration value="ESCUDO" />
					<xsd:enumeration value="EURO" />
					<xsd:enumeration value="FLORIN" />
					<xsd:enumeration value="FRANCO BEL" />
					<xsd:enumeration value="FRANCO FR" />
					<xsd:enumeration value="FRANCO SZ" />
