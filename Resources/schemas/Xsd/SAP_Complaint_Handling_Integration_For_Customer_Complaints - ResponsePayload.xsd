            <xs:sequence>
                <xs:element minOccurs="1" maxOccurs="unbounded" name="result">
                    <xs:complexType>
                        <xs:sequence>
                            <xs:element name="code" type="xs:string" />
                            <xs:element minOccurs="0" maxOccurs="unbounded" name="texts">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element minOccurs="0" name="locale" type="xs:string" />
                                        <xs:element minOccurs="0" name="description" type="xs:string" />
