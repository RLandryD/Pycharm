<?xml version="1.0" encoding="UTF-8"?>
<bpmn2:definitions xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1">
    <bpmn2:collaboration id="Collaboration_1" name="Default Collaboration">
        <bpmn2:extensionElements>
            <ifl:property><key>namespaceMapping</key><value></value></ifl:property>
            <ifl:property><key>httpSessionHandling</key><value>None</value></ifl:property>
            <ifl:property><key>accessControlMaxAge</key><value></value></ifl:property>
            <ifl:property><key>returnExceptionToSender</key><value>false</value></ifl:property>
            <ifl:property><key>log</key><value>All events</value></ifl:property>
            <ifl:property><key>corsEnabled</key><value></value></ifl:property>
            <ifl:property><key>exposedHeaders</key><value></value></ifl:property>
            <ifl:property><key>componentVersion</key><value>1.2</value></ifl:property>
            <ifl:property><key>allowedHeaderList</key><value>Subject</value></ifl:property>
            <ifl:property><key>ServerTrace</key><value>false</value></ifl:property>
            <ifl:property><key>allowedOrigins</key><value></value></ifl:property>
            <ifl:property><key>accessControlAllowCredentials</key><value></value></ifl:property>
            <ifl:property><key>allowedHeaders</key><value></value></ifl:property>
            <ifl:property><key>allowedMethods</key><value></value></ifl:property>
            <ifl:property><key>cmdVariantUri</key><value>ctype::IFlowVariant/cname::IFlowConfiguration/version::1.2.2</value></ifl:property>
        </bpmn2:extensionElements>
        <bpmn2:participant id="Participant_Process_1" ifl:type="IntegrationProcess" name="Integration Process" processRef="Process_1">
            <bpmn2:extensionElements/>
        </bpmn2:participant>
        <bpmn2:participant id="Participant_1" ifl:type="EndpointSender" name="Sender">
            <bpmn2:extensionElements/>
        </bpmn2:participant>
        <bpmn2:messageFlow id="MessageFlow_5" name="Mail" sourceRef="Participant_1" targetRef="StartEvent_2">
            <bpmn2:extensionElements>
                <ifl:property><key>server</key><value>{{Mail_Address}}</value></ifl:property>
                <ifl:property><key>Description</key><value></value></ifl:property>
                <ifl:property><key>archiveMailFolder</key><value>{{Archive_Folder}}</value></ifl:property>
                <ifl:property><key>auth</key><value>{{Authentication}}</value></ifl:property>
                <ifl:property><key>ComponentNS</key><value>sap</value></ifl:property>
                <ifl:property><key>selectionReadFlag</key><value>{{Mail Selection}}</value></ifl:property>
                <ifl:property><key>ssl</key><value>{{Protection}}</value></ifl:property>
                <ifl:property><key>timeout</key><value>{{Time_Out}}</value></ifl:property>
                <ifl:property><key>Name</key><value>Mail</value></ifl:property>
                <ifl:property><key>TransportProtocolVersion</key><value>1.9.0</value></ifl:property>
                <ifl:property><key>ComponentSWCVName</key><value>external</value></ifl:property>
                <ifl:property><key>postProcessing</key><value>mark_and_archive</value></ifl:property>
                <ifl:property><key>locationId</key><value></value></ifl:property>
                <ifl:property><key>maxMessagesPerPoll</key><value>{{Max_Messages}}</value></ifl:property>
                <ifl:property><key>MessageProtocol</key><value>Not Applicable</value></ifl:property>
                <ifl:property><key>ComponentSWCVId</key><value>1.9.0</value></ifl:property>
                <ifl:property><key>direction</key><value>Sender</value></ifl:property>
                <ifl:property><key>ComponentType</key><value>Mail</value></ifl:property>
                <ifl:property><key>lockDuration</key><value>{{Timeout_Minutes}}</value></ifl:property>
                <ifl:property><key>proxyType</key><value>none</value></ifl:property>
                <ifl:property><key>componentVersion</key><value>1.9</value></ifl:property>
                <ifl:property><key>removeAttachments</key><value>0</value></ifl:property>
                <ifl:property><key>forwardOriginalMail</key><value>0</value></ifl:property>
                <ifl:property><key>system</key><value>Sender</value></ifl:property>
                <ifl:property><key>folder</key><value>{{SII_Mail_Folder}}</value></ifl:property>
                <ifl:property><key>scheduleKey</key><value>{{Scheduler}}</value></ifl:property>
                <ifl:property><key>TransportProtocol</key><value>IMAP</value></ifl:property>
                <ifl:property><key>tokenCredential</key><value>{{OAuth_Code}}</value></ifl:property>
                <ifl:property><key>cmdVariantUri</key><value>ctype::AdapterVariant/cname::sap:Mail/tp::IMAP/mp::Not Applicable/direction::Sender/version::1.9.0</value></ifl:property>
                <ifl:property><key>user</key><value>{{Credentials}}</value></ifl:property>
                <ifl:property><key>MessageProtocolVersion</key><value>1.9.0</value></ifl:property>
            </bpmn2:extensionElements>
        </bpmn2:messageFlow>
    </bpmn2:collaboration>
    <bpmn2:process id="Process_1" name="Integration Process">
        <bpmn2:extensionElements>
            <ifl:property><key>transactionTimeout</key><value>30</value></ifl:property>
            <ifl:property><key>componentVersion</key><value>1.2</value></ifl:property>
            <ifl:property><key>cmdVariantUri</key><value>ctype::FlowElementVariant/cname::IntegrationProcess/version::1.2.1</value></ifl:property>
            <ifl:property><key>transactionalHandling</key><value>Not Required</value></ifl:property>
        </bpmn2:extensionElements>
        <bpmn2:subProcess id="SubProcess_28" name="Exception Subprocess 1">
            <bpmn2:extensionElements>
                <ifl:property><key>componentVersion</key><value>1.0</value></ifl:property>
                <ifl:property><key>activityType</key><value>ErrorEventSubProcessTemplate</value></ifl:property>
                <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::ErrorEventSubProcessTemplate/version::1.0.2</value></ifl:property>
            </bpmn2:extensionElements>
        <bpmn2:callActivity id="CallActivity_32" name="Exception handling">
            <bpmn2:extensionElements>
                <ifl:property><key>bodyType</key><value>expression</value></ifl:property>
                <ifl:property><key>propertyTable</key><value></value></ifl:property>
                <ifl:property><key>headerTable</key><value></value></ifl:property>
                <ifl:property><key>wrapContent</key><value></value></ifl:property>
                <ifl:property><key>componentVersion</key><value>1.5</value></ifl:property>
                <ifl:property><key>activityType</key><value>Enricher</value></ifl:property>
                <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::Enricher/version::1.5.1</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_31</bpmn2:incoming>
            <bpmn2:outgoing>SequenceFlow_33</bpmn2:outgoing>
        </bpmn2:callActivity>
        <bpmn2:startEvent id="StartEvent_29" name="Error Start 1">
            <bpmn2:extensionElements>
                <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::ErrorStartEvent</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:outgoing>SequenceFlow_31</bpmn2:outgoing>
            <bpmn2:errorEventDefinition>
                <bpmn2:extensionElements>
                    <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::ErrorStartEvent</value></ifl:property>
                </bpmn2:extensionElements>
            </bpmn2:errorEventDefinition>
        </bpmn2:startEvent>
        <bpmn2:endEvent id="EndEvent_30" name="End 2">
            <bpmn2:extensionElements>
                <ifl:property><key>componentVersion</key><value>1.1</value></ifl:property>
                <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::MessageEndEvent/version::1.1.0</value></ifl:property>
                <ifl:property><key>activityType</key><value>EndEvent</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_33</bpmn2:incoming>
            <bpmn2:messageEventDefinition/>
        </bpmn2:endEvent>
        <bpmn2:sequenceFlow id="SequenceFlow_33" sourceRef="CallActivity_32" targetRef="EndEvent_30"/>
        <bpmn2:sequenceFlow id="SequenceFlow_31" sourceRef="StartEvent_29" targetRef="CallActivity_32"/>
        </bpmn2:subProcess>
        <bpmn2:exclusiveGateway id="ExclusiveGateway_13" name="Check file found" default="SequenceFlow_16">
            <bpmn2:extensionElements>
                <ifl:property><key>componentVersion</key><value>1.1</value></ifl:property>
                <ifl:property><key>activityType</key><value>ExclusiveGateway</value></ifl:property>
                <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::ExclusiveGateway/version::1.1.2</value></ifl:property>
                <ifl:property><key>throwException</key><value>false</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_14</bpmn2:incoming>
            <bpmn2:outgoing>SequenceFlow_16</bpmn2:outgoing>
            <bpmn2:outgoing>SequenceFlow_17</bpmn2:outgoing>
        </bpmn2:exclusiveGateway>
        <bpmn2:callActivity id="CallActivity_8" name="Variable Properties ">
            <bpmn2:extensionElements>
                <ifl:property><key>bodyType</key><value>expression</value></ifl:property>
                <ifl:property><key>propertyTable</key><value>&lt;row&gt;&lt;cell id=&#x27;Action&#x27;&gt;Create&lt;/cell&gt;&lt;cell id=&#x27;Type&#x27;&gt;constant&lt;/cell&gt;&lt;cell id=&#x27;Value&#x27;&gt;{{targetFolder}}&lt;/cell&gt;&lt;cell id=&#x27;Default&#x27;&gt;&lt;/cell&gt;&lt;cell id=&#x27;Name&#x27;&gt;targetFolder&lt;/cell&gt;&lt;cell id=&#x27;Datatype&#x27;&gt;&lt;/cell&gt;&lt;/row&gt;&lt;row&gt;&lt;cell id=&#x27;Action&#x27;&gt;Create&lt;/cell&gt;&lt;cell id=&#x27;Type&#x27;&gt;constant&lt;/cell&gt;&lt;cell id=&#x27;Value&#x27;&gt;{{attachmentPattern}}&lt;/cell&gt;&lt;cell id=&#x27;Default&#x27;&gt;&lt;/cell&gt;&lt;cell id=&#x27;Name&#x27;&gt;attachmentNamePattern&lt;/cell&gt;&lt;cell id=&#x27;Datatype&#x27;&gt;&lt;/cell&gt;&lt;/row&gt;</value></ifl:property>
                <ifl:property><key>headerTable</key><value></value></ifl:property>
                <ifl:property><key>wrapContent</key><value></value></ifl:property>
                <ifl:property><key>componentVersion</key><value>1.5</value></ifl:property>
                <ifl:property><key>activityType</key><value>Enricher</value></ifl:property>
                <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::Enricher/version::1.5.1</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_27</bpmn2:incoming>
            <bpmn2:outgoing>SequenceFlow_11</bpmn2:outgoing>
        </bpmn2:callActivity>
        <bpmn2:endEvent id="EndEvent_2" name="End">
            <bpmn2:extensionElements>
                <ifl:property><key>componentVersion</key><value>1.1</value></ifl:property>
                <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::MessageEndEvent/version::1.1.0</value></ifl:property>
                <ifl:property><key>activityType</key><value>EndEvent</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_17</bpmn2:incoming>
            <bpmn2:messageEventDefinition/>
        </bpmn2:endEvent>
        <bpmn2:endEvent id="EndEvent_18" name="End 1">
            <bpmn2:extensionElements>
                <ifl:property><key>componentVersion</key><value>1.1</value></ifl:property>
                <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::MessageEndEvent/version::1.1.0</value></ifl:property>
                <ifl:property><key>activityType</key><value>EndEvent</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_19</bpmn2:incoming>
            <bpmn2:messageEventDefinition/>
        </bpmn2:endEvent>
        <bpmn2:startEvent id="StartEvent_2" name="Start">
            <bpmn2:extensionElements>
                <ifl:property><key>componentVersion</key><value>1.0</value></ifl:property>
                <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::MessageStartEvent/version::1.0</value></ifl:property>
                <ifl:property><key>activityType</key><value>StartEvent</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:outgoing>SequenceFlow_27</bpmn2:outgoing>
            <bpmn2:messageEventDefinition/>
        </bpmn2:startEvent>
        <bpmn2:callActivity id="CallActivity_10" name="Filter XML file attachments">
            <bpmn2:extensionElements>
                <ifl:property><key>scriptFunction</key><value></value></ifl:property>
                <ifl:property><key>scriptBundleId</key><value></value></ifl:property>
                <ifl:property><key>componentVersion</key><value>1.1</value></ifl:property>
                <ifl:property><key>activityType</key><value>Script</value></ifl:property>
                <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::GroovyScript/version::1.1.2</value></ifl:property>
                <ifl:property><key>subActivityType</key><value>GroovyScript</value></ifl:property>
                <ifl:property><key>script</key><value>script2.groovy</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_11</bpmn2:incoming>
            <bpmn2:outgoing>SequenceFlow_14</bpmn2:outgoing>
        </bpmn2:callActivity>
        <bpmn2:callActivity id="CallActivity_15" name="Write XML to Data Store">
            <bpmn2:extensionElements>
                <ifl:property><key>visibility</key><value>global</value></ifl:property>
                <ifl:property><key>alert</key><value>{{Retention Alerting in d}}</value></ifl:property>
                <ifl:property><key>encrypt</key><value>true</value></ifl:property>
                <ifl:property><key>expire</key><value>{{Expiration Period in d}}</value></ifl:property>
                <ifl:property><key>messageId</key><value>${property.attName}</value></ifl:property>
                <ifl:property><key>componentVersion</key><value>1.7</value></ifl:property>
                <ifl:property><key>override</key><value>true</value></ifl:property>
                <ifl:property><key>activityType</key><value>DBstorage</value></ifl:property>
                <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::put/version::1.7.1</value></ifl:property>
                <ifl:property><key>operation</key><value>put</value></ifl:property>
                <ifl:property><key>storageName</key><value>${property.dataStoreName}</value></ifl:property>
                <ifl:property><key>includeMessageHeaders</key><value>false</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_16</bpmn2:incoming>
            <bpmn2:outgoing>SequenceFlow_19</bpmn2:outgoing>
        </bpmn2:callActivity>
        <bpmn2:sequenceFlow id="SequenceFlow_16" name="Yes" sourceRef="ExclusiveGateway_13" targetRef="CallActivity_15"/>
        <bpmn2:sequenceFlow id="SequenceFlow_17" name="No" sourceRef="ExclusiveGateway_13" targetRef="EndEvent_2">
            <bpmn2:extensionElements><ifl:property><key>expressionType</key><value>NonXML</value></ifl:property></bpmn2:extensionElements>
            <bpmn2:conditionExpression>${property.found} = &#x27;false&#x27;</bpmn2:conditionExpression>
        </bpmn2:sequenceFlow>
        <bpmn2:sequenceFlow id="SequenceFlow_11" sourceRef="CallActivity_8" targetRef="CallActivity_10"/>
        <bpmn2:sequenceFlow id="SequenceFlow_27" sourceRef="StartEvent_2" targetRef="CallActivity_8"/>
        <bpmn2:sequenceFlow id="SequenceFlow_14" sourceRef="CallActivity_10" targetRef="ExclusiveGateway_13"/>
        <bpmn2:sequenceFlow id="SequenceFlow_19" sourceRef="CallActivity_15" targetRef="EndEvent_18"/>
    </bpmn2:process>
    <bpmndi:BPMNDiagram id="BPMNDiagram_1" name="Default Collaboration Diagram">
        <bpmndi:BPMNPlane bpmnElement="Collaboration_1" id="BPMNPlane_1">
            <bpmndi:BPMNShape bpmnElement="Participant_Process_1" id="BPMNShape_Participant_Process_1">
                <dc:Bounds height="375.0" width="1141.0" x="215.0" y="60.0"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="SubProcess_28" id="BPMNShape_SubProcess_28"><dc:Bounds height="110.0" width="170.0" x="285.0" y="255.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="ExclusiveGateway_13" id="BPMNShape_ExclusiveGateway_13"><dc:Bounds height="40.0" width="40.0" x="890.0" y="140.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="CallActivity_8" id="BPMNShape_CallActivity_8"><dc:Bounds height="60.0" width="100.0" x="500.0" y="130.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="EndEvent_2" id="BPMNShape_EndEvent_2"><dc:Bounds height="32.0" width="32.0" x="1074.0" y="294.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="EndEvent_18" id="BPMNShape_EndEvent_18"><dc:Bounds height="32.0" width="32.0" x="1254.0" y="144.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="StartEvent_2" id="BPMNShape_StartEvent_2"><dc:Bounds height="32.0" width="32.0" x="354.0" y="144.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="CallActivity_10" id="BPMNShape_CallActivity_10"><dc:Bounds height="60.0" width="100.0" x="680.0" y="130.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="CallActivity_15" id="BPMNShape_CallActivity_15"><dc:Bounds height="60.0" width="100.0" x="1040.0" y="130.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="Participant_1" id="BPMNShape_Participant_1"><dc:Bounds height="140.0" width="100.0" x="80.0" y="110.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_16" id="BPMNEdge_SequenceFlow_16" sourceElement="BPMNShape_ExclusiveGateway_13" targetElement="BPMNShape_CallActivity_15"><di:waypoint x="930.0" xsi:type="dc:Point" y="160.0"/><di:waypoint x="1040.0" xsi:type="dc:Point" y="160.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_17" id="BPMNEdge_SequenceFlow_17" sourceElement="BPMNShape_ExclusiveGateway_13" targetElement="BPMNShape_EndEvent_2"><di:waypoint x="930.0" xsi:type="dc:Point" y="160.0"/><di:waypoint x="1074.0" xsi:type="dc:Point" y="310.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_11" id="BPMNEdge_SequenceFlow_11" sourceElement="BPMNShape_CallActivity_8" targetElement="BPMNShape_CallActivity_10"><di:waypoint x="600.0" xsi:type="dc:Point" y="160.0"/><di:waypoint x="680.0" xsi:type="dc:Point" y="160.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_27" id="BPMNEdge_SequenceFlow_27" sourceElement="BPMNShape_StartEvent_2" targetElement="BPMNShape_CallActivity_8"><di:waypoint x="386.0" xsi:type="dc:Point" y="160.0"/><di:waypoint x="500.0" xsi:type="dc:Point" y="160.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_14" id="BPMNEdge_SequenceFlow_14" sourceElement="BPMNShape_CallActivity_10" targetElement="BPMNShape_ExclusiveGateway_13"><di:waypoint x="780.0" xsi:type="dc:Point" y="160.0"/><di:waypoint x="890.0" xsi:type="dc:Point" y="160.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_19" id="BPMNEdge_SequenceFlow_19" sourceElement="BPMNShape_CallActivity_15" targetElement="BPMNShape_EndEvent_18"><di:waypoint x="1140.0" xsi:type="dc:Point" y="160.0"/><di:waypoint x="1254.0" xsi:type="dc:Point" y="160.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="MessageFlow_5" id="BPMNEdge_MessageFlow_5" sourceElement="BPMNShape_Participant_1" targetElement="BPMNShape_StartEvent_2"><di:waypoint x="180.0" xsi:type="dc:Point" y="180.0"/><di:waypoint x="354.0" xsi:type="dc:Point" y="160.0"/></bpmndi:BPMNEdge>
        </bpmndi:BPMNPlane>
    </bpmndi:BPMNDiagram>
