				<xsd:sequence>
					<xsd:element name="UnplannedDeliveryCost" type="Amount" minOccurs="0"/>
					<xsd:element name="UnplannedDeliveryCostTaxCode" type="TaxCode_GFN" minOccurs="0"/>
