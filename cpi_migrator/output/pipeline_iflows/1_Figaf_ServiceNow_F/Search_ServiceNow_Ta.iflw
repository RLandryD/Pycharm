<?xml version="1.0" encoding="UTF-8"?>
<!--
  SCENARIO iFlow: Search ServiceNow Tasks
  Display Name : OUT_Figaf_ServiceNow_Search_ServiceNow_Ta
  Package      : 1_Figaf_ServiceNow_Finance
  Strategy     : BROWNFIELD: Lift-and-shift. Mapping '' ported directly.
  Complexity   : LOW (score: 6)
  Effort       : 1 day(s)
  Sender       : Figaf (HTTPS)
  Receiver     : ServiceNow (HTTP)
  Batch        : No
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Search_ServiceNow_Ta"
             name="OUT_Figaf_ServiceNow_Search_ServiceNow_Ta">
  <process id="Search_ServiceNow_Ta_process" ifl:type="IntegrationFlow">

    <startEvent id="Start_SC" name="From Interface Separation">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Search_ServiceNow_Ta</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>



    <!-- PROCESSDIRECT: Forward to Outbound Delivery -->
    <serviceTask id="CallOutbound_1" name="→ Outbound Delivery" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/outbound/1_Figaf_ServiceNow_F</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_SC"/>
    <sequenceFlow sourceRef="Start_SC" targetRef="CallOutbound_1"/>
    
    
    <sequenceFlow sourceRef="CallOutbound_1" targetRef="End_SC"/>
  </process>
</definitions>