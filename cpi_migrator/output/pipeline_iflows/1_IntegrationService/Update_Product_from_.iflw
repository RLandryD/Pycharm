<?xml version="1.0" encoding="UTF-8"?>
<!--
  SCENARIO iFlow: Update Product from YaaS to C4C
  Display Name : OUT_IntegrationService_C4CProduct_Update_Product_from_
  Package      : 1_IntegrationService_C4CProduct_Integration
  Strategy     : GREENFIELD: Clean cloud-native rebuild. No legacy mapping reuse.
  Complexity   : HIGH (score: 84)
  Effort       : 25.7 day(s)
  Sender       : IntegrationService (HTTPS)
  Receiver     : C4CProduct (HTTP)
  Batch        : No
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Update_Product_from_"
             name="OUT_IntegrationService_C4CProduct_Update_Product_from_">
  <process id="Update_Product_from__process" ifl:type="IntegrationFlow">

    <startEvent id="Start_SC" name="From Interface Separation">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Update_Product_from_</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>



    <!-- PROCESSDIRECT: Forward to Outbound Delivery -->
    <serviceTask id="CallOutbound_1" name="→ Outbound Delivery" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/outbound/1_IntegrationService</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_SC"/>
    <sequenceFlow sourceRef="Start_SC" targetRef="CallOutbound_1"/>
    
    
    <sequenceFlow sourceRef="CallOutbound_1" targetRef="End_SC"/>
  </process>
</definitions>