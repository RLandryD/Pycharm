<edmx:Edmx xmlns:edmx="http://schemas.microsoft.com/ado/2007/06/edmx" Version="1.0">
    <edmx:DataServices xmlns:m="http://schemas.microsoft.com/ado/2007/08/dataservices/metadata" m:DataServiceVersion="2.0">
        <Schema xmlns="http://schemas.microsoft.com/ado/2008/09/edm" xmlns:s="http://schemas.sap.com/commerce" Namespace="HybrisCommerceOData" s:schema-version="1">
            <EntityType Name="BaseSite">
                <Key>
                    <PropertyRef Name="integrationKey"/>
                </Key>
                <Property Name="uid" Nullable="false" Type="Edm.String" s:IsUnique="true"/>
                <Property Name="integrationKey" Nullable="false" Type="Edm.String" s:Alias="BaseSite_uid"/>
                <NavigationProperty FromRole="BaseSite" Name="gigyaConfig" Nullable="true" Relationship="HybrisCommerceOData.FK_BaseSite_gigyaConfig" ToRole="GigyaConfig"/>
            </EntityType>
            <EntityType Name="GigyaConfig">
                <Key>
                    <PropertyRef Name="integrationKey"/>
                </Key>
                <Property Name="gigyaApiKey" Nullable="false" Type="Edm.String"/>
                <Property Name="gigyaDataCenter" Nullable="true" Type="Edm.String"/>
                <Property Name="gigyaUserKey" Nullable="true" Type="Edm.String"/>
                <Property Name="code" Nullable="true" Type="Edm.String" s:IsUnique="true"/>
                <Property Name="gigyaSiteSecret" Nullable="true" Type="Edm.String"/>
                <Property Name="integrationKey" Nullable="false" Type="Edm.String" s:Alias="GigyaConfig_code"/>
            </EntityType>
            <Association Name="FK_BaseSite_gigyaConfig">
                <End Multiplicity="0..1" Role="BaseSite" Type="HybrisCommerceOData.BaseSite"/>
                <End Multiplicity="0..1" Role="GigyaConfig" Type="HybrisCommerceOData.GigyaConfig"/>
            </Association>
            <EntityContainer Name="Container" m:IsDefaultEntityContainer="true">
                <EntitySet EntityType="HybrisCommerceOData.BaseSite" Name="BaseSites"/>
                <EntitySet EntityType="HybrisCommerceOData.GigyaConfig" Name="GigyaConfigs"/>
                <AssociationSet Association="HybrisCommerceOData.FK_BaseSite_gigyaConfig" Name="BaseSite_GigyaConfigs">
                    <End EntitySet="BaseSites" Role="BaseSite"/>
                    <End EntitySet="GigyaConfigs" Role="GigyaConfig"/>
                </AssociationSet>
            </EntityContainer>
        </Schema>
    </edmx:DataServices>
</edmx:Edmx>
