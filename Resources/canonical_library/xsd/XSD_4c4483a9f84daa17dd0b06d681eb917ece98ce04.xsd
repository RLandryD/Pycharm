                    <xs:element type="xs:string" name="uiSaveTimeStamp" minOccurs="0" maxOccurs="1"/>
                    <xs:element type="xs:byte" name="division" minOccurs="0" maxOccurs="1"/>
                    <xs:element type="xs:string" name="referenceCustomerNumber" minOccurs="0" maxOccurs="1"/>
                    <xs:element type="xs:short" name="salesOrganization" minOccurs="0" maxOccurs="1"/>
                    <xs:element type="xs:long" name="faxNumber" minOccurs="0" maxOccurs="1"/>
                    <xs:element type="xs:byte" name="distributionChannel" minOccurs="0" maxOccurs="1"/>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
              <xs:element name="iDoc_DEBMAS">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element type="xs:string" minOccurs="0" maxOccurs="1" name="changedBy"/>
                    <xs:element type="xs:string" minOccurs="0" maxOccurs="1" name="changedAt"/>
                    <xs:element name="E1KNA1M"/>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>   
            </xs:sequence>
          </xs:complexType>
        </xs:element>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
</xs:schema>