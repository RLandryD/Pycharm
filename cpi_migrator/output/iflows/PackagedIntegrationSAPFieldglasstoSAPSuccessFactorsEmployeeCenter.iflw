                <ifl:property><key>wrapContent</key><value>&lt;EMEvent&gt;
&lt;EMEvent&gt;
&lt;id&gt;1&lt;/id&gt;
&lt;eventType&gt;WARNING&lt;/eventType&gt;
&lt;eventTime&gt;${body.replaceAll(&#x27;GMT&#x27;,&#x27;Z&#x27;)}&lt;/eventTime&gt;
&lt;eventName&gt;Integration Execution Status Messages&lt;/eventName&gt;
&lt;eventDescription&gt;User ${property.userIds} is closed in Fieldglass and absent in Employee Central. The user will not be processed further.&lt;/eventDescription&gt;
&lt;process&gt;
&lt;EMMonitoredProcess&gt;
&lt;processType&gt;INTEGRATION&lt;/processType&gt;
&lt;processInstanceName&gt;Packaged Integration FieldGlass To SF EC_${date:now:yyyy-MM-dd&#x27;T&#x27;HH:mm:ss}&lt;/processInstanceName&gt;
&lt;processInstanceId&gt;${property.SAP_MessageProcessingLogID}&lt;/processInstanceId&gt;
&lt;processDefinitionName&gt;Packaged Integration FieldGlass To SF EC&lt;/processDefinitionName&gt;
&lt;processDefinitionId&gt;Packaged Integration FieldGlass To SF EC&lt;/processDefinitionId&gt;
&lt;moduleName&gt;MODULE_ECT&lt;/moduleName&gt;
&lt;firstEventTime&gt;${date:now:yyyy-MM-dd&#x27;T&#x27;HH:mm:ssz}&lt;/firstEventTime&gt;
&lt;lastEventTime&gt;${date:now:yyyy-MM-dd&#x27;T&#x27;HH:mm:ssz}&lt;/lastEventTime&gt;
&lt;monitoredProcessId&gt;1&lt;/monitoredProcessId&gt;
&lt;/EMMonitoredProcess&gt;
&lt;/process&gt;
&lt;/EMEvent&gt;
&lt;/EMEvent&gt;</value></ifl:property>
