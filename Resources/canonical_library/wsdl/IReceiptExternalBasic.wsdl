      <wsdl:fault wsaw:Action="http://www.altinn.no/services/Intermediary/Receipt/2009/10/IReceiptExternalBasic/GetReceiptBasicAltinnFaultFault" name="AltinnFaultFault" message="tns:IReceiptExternalBasic_GetReceiptBasic_AltinnFaultFault_FaultMessage"/>
    </wsdl:operation>
    <wsdl:operation name="GetReceiptBasicV2">
      <wsdl:documentation>&lt;summary&gt;&#13;
            This operations enables the retrieval of a receipt based on a number of different inputs. Input values have the following&#13;
            priority: ReceiptId, WorkFlowReference, any other reference.&#13;
            If the receipt is a child receipt, then the parent receipt is also retrieved. If the given party have access to the parent, then&#13;
            the parent receipt will be returned with the original receipt as one of the sub receipts.&#13;
            &lt;/summary&gt;&#13;
            &lt;remarks&gt;&#13;
            The operation will throw an exception if no receipt is found.&#13;
            &lt;/remarks&gt;&#13;
            &lt;param name="systemUserName"&gt;System user name is the relevant agency system name that is registered in Altinn - mandatory parameter.&lt;/param&gt;&#13;
            &lt;param name="systemPassword"&gt;System password is the password for the corresponding registered agency system - mandatory parameter.&lt;/param&gt;&#13;
            &lt;param name="receipt"&gt;Receipt search criteria.&lt;/param&gt;&#13;
            &lt;returns&gt;The identified receipt.&lt;/returns&gt;</wsdl:documentation>
      <wsdl:input wsaw:Action="http://www.altinn.no/services/Intermediary/Receipt/2009/10/IReceiptExternalBasic/GetReceiptBasicV2" message="tns:IReceiptExternalBasic_GetReceiptBasicV2_InputMessage"/>
      <wsdl:output wsaw:Action="http://www.altinn.no/services/Intermediary/Receipt/2009/10/IReceiptExternalBasic/GetReceiptBasicV2Response" message="tns:IReceiptExternalBasic_GetReceiptBasicV2_OutputMessage"/>
