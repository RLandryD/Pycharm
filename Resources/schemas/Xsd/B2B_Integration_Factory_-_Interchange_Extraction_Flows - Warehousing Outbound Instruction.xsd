         <xsd:documentation xml:lang="en-US" source="Definition">Specifies method of delivery.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:DeliveryMethodCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: HOME_DELIVERY</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="DeliveryMethodCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
