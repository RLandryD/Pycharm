<?xml version="1.0" encoding="UTF-8"?><xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified" version="1.0">
    <xs:element name="order-headers">
        <xs:complexType>
            <xs:sequence>
                <xs:element maxOccurs="unbounded" name="order-header">
                    <xs:complexType>
                        <xs:sequence>
                            <xs:element minOccurs="0" name="acknowledged-at" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>acknowledged_at</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="acknowledged-flag" type="xs:boolean">
                                <xs:annotation>
                                    <xs:documentation>Has PO been acknowledged by Supplier?</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="attachments">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="unbounded" minOccurs="0" name="attachment" type="Attachment"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element minOccurs="0" name="change-type">
                                <xs:annotation>
                                    <xs:documentation>Last type of change on PO, it represents whether PO was changed through change request or through revise</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:enumeration value="change"/>
                                        <xs:enumeration value="revision"/>
                                        <xs:enumeration value="confirmation"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="classification">
                                <xs:annotation>
                                    <xs:documentation>Classification</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:enumeration value="msp"/>
                                        <xs:enumeration value="supplier"/>
                                        <xs:enumeration value="vms"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="confirm-by-hrs" type="xs:integer">
                                <xs:annotation>
                                    <xs:documentation>Confirm by</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="coupa-accelerate-status">
                                <xs:annotation>
                                    <xs:documentation>Status indicating whether the invoice has discount payment terms via Static Discounting</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:enumeration value="accelerated"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="created-at" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>Date record was created in Coupa.</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="created-by" type="UserSimple"/>
                            <xs:element minOccurs="0" name="currency" type="Currency"/>
                            <xs:element minOccurs="0" name="current-integration-history-records">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="unbounded" minOccurs="0" name="current-integration-history-record" type="IntegrationHistoryRecord"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element minOccurs="0" name="estimated-tax-amount">
                                <xs:annotation>
                                    <xs:documentation>Estimated Tax Amount</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:decimal">
                                        <xs:totalDigits value="30"/>
                                        <xs:fractionDigits value="6"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="exported" type="xs:boolean">
                                <xs:annotation>
                                    <xs:documentation>Indicates if transaction has been exported</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="hide-price" type="OrderHeader"/>
                            <xs:element minOccurs="0" name="id" type="xs:integer">
                                <xs:annotation>
                                    <xs:documentation>Coupa's internal ID</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="internal-revision" type="xs:integer">
                                <xs:annotation>
                                    <xs:documentation>Internal Revision Number - Increases each time a change is made to a PO whether that change is internal or causes the PO to be resent to the supplier.</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="invoice-stop" type="xs:boolean">
                                <xs:annotation>
                                    <xs:documentation>Invoice Stop flag</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="last-exported-at" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>Date and time transaction was last exported in the format YYYY-MM-DDTHH:MM:SS+HH:MMZ</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="milestones">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="unbounded" minOccurs="0" name="milestone" type="Procurement-Milestone"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element minOccurs="0" name="order-confirmation-level" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>Confirmation Level</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="order-header-confirmations">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="unbounded" minOccurs="0" name="order-header-confirmation" type="OrderHeaderConfirmation"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element minOccurs="0" name="order-lines">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="unbounded" minOccurs="0" name="order-line" type="OrderLine"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element minOccurs="0" name="payment-method">
                                <xs:annotation>
                                    <xs:documentation>payment_method</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="payment-term" type="PaymentTerm"/>
                            <xs:element minOccurs="0" name="pcard" type="Pcard"/>
                            <xs:element minOccurs="0" name="po-number">
                                <xs:annotation>
                                    <xs:documentation>PO Number</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="20"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="price-hidden" type="xs:boolean">
                                <xs:annotation>
                                    <xs:documentation>Hide Price from supplier. True or False</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="reason-insight-events">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="unbounded" minOccurs="0" name="reason-insight-event" type="OrderHeader"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element minOccurs="0" name="recurring-rules">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="unbounded" minOccurs="0" name="recurring-rule" type="Procurement-RecurringRule"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element minOccurs="0" name="requester" type="UserSimple"/>
                            <xs:element minOccurs="0" name="requisition-header" type="RequisitionHeader"/>
                            <xs:element minOccurs="0" name="ship-to-address" type="Address"/>
                            <xs:element minOccurs="0" name="ship-to-attention">
                                <xs:annotation>
                                    <xs:documentation>Ship to attention</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="ship-to-user" type="UserSimple"/>
                            <xs:element minOccurs="0" name="shipping-term" type="ShippingTerm"/>
                            <xs:element minOccurs="0" name="status">
                                <xs:annotation>
                                    <xs:documentation>PO Status</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:enumeration value="buyer_hold"/>
                                        <xs:enumeration value="cancelled"/>
                                        <xs:enumeration value="closed"/>
                                        <xs:enumeration value="currency_hold"/>
                                        <xs:enumeration value="draft"/>
                                        <xs:enumeration value="error"/>
                                        <xs:enumeration value="expensed"/>
                                        <xs:enumeration value="issued"/>
                                        <xs:enumeration value="supplier_hold"/>
                                        <xs:enumeration value="supplier_window_hold"/>
                                        <xs:enumeration value="exported"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="supplier" type="Supplier"/>
                            <xs:element minOccurs="0" name="supplier-site" type="SupplierSite"/>
                            <xs:element minOccurs="0" name="total-with-estimated-tax">
                                <xs:annotation>
                                    <xs:documentation>Total With Estimated Tax</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:decimal">
                                        <xs:totalDigits value="30"/>
                                        <xs:fractionDigits value="6"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="transmission-emails" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>Tranmission Email comma seperated list</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="transmission-method-override">
                                <xs:annotation>
                                    <xs:documentation>Transmission Method Override</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:enumeration value="supplier_default"/>
                                        <xs:enumeration value="email"/>
                                        <xs:enumeration value="do_not_transmit"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="transmission-status">
                                <xs:annotation>
                                    <xs:documentation>Transmission Status</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:enumeration value="created"/>
                                        <xs:enumeration value="deferred"/>
                                        <xs:enumeration value="deferred_processing"/>
                                        <xs:enumeration value="pending_manual"/>
                                        <xs:enumeration value="pending_manual_cancel"/>
                                        <xs:enumeration value="awaiting_online_purchase"/>
                                        <xs:enumeration value="scheduled_for_email"/>
                                        <xs:enumeration value="sent_via_email"/>
                                        <xs:enumeration value="scheduled_for_cxml"/>
                                        <xs:enumeration value="scheduled_for_xml"/>
                                        <xs:enumeration value="sent_via_cxml"/>
                                        <xs:enumeration value="sent_via_xml"/>
                                        <xs:enumeration value="sent_manually"/>
                                        <xs:enumeration value="purchased_online"/>
                                        <xs:enumeration value="transmission_failure"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="type">
                                <xs:annotation>
                                    <xs:documentation>Type of Order</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:enumeration value="ExternalOrderHeader"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="updated-at" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>Last Updated at Date</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="updated-by" type="UserSimple"/>
                            <xs:element minOccurs="0" name="user-group-members">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="unbounded" minOccurs="0" name="user-group-member" type="UserGroup"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element minOccurs="0" name="user-members">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="unbounded" minOccurs="0" name="user-member" type="UserSimple"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element minOccurs="0" name="version" type="xs:integer">
                                <xs:annotation>
                                    <xs:documentation>PO Supplier Version Number - Increase each time a PO is changed and triggers a resend to the supplier.</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="custom-fields">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element minOccurs="0" name="purchaseorderscustomfield" type="xs:string"/>
                                        <xs:element minOccurs="0" name="sap_integration_messages" type="xs:string"/>
                                        <xs:element minOccurs="0" name="patient_id" type="LookupValue"/>
                                        <xs:element minOccurs="0" name="custom_field_7" type="LookupValue"/>
                                        <xs:element minOccurs="0" name="bill_only" type="xs:boolean"/>
                                        <xs:element minOccurs="0" name="spend_load_id" type="xs:string"/>
                                        <xs:element minOccurs="0" name="sap_document_number" type="xs:string"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                        </xs:sequence>
                    </xs:complexType>
                </xs:element>
            </xs:sequence>
        </xs:complexType>
    </xs:element>
    <xs:complexType name="Attachment">
        <xs:sequence>
            <xs:element minOccurs="0" name="created-at" type="xs:string">
                <xs:annotation>
                    <xs:documentation>Automatically created by Coupa in the format YYYY-MM-DDTHH:MM:SS+HH:MMZ</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element minOccurs="0" name="created-by" type="UserSimple1"/>
