   <Annotations Target="API_INSPECTIONCATALOG_SRV_01.API_INSPECTIONCATALOG_SRV_01_Entities/A_InspectionCatalog" xmlns="http://docs.oasis-open.org/odata/ns/edm">
      <Annotation Term="Capabilities.ReadRestrictions">
        <Record>
          <PropertyValue Property="Description" String="Reads all selected set codes and code groups of catalog type."/>
          <PropertyValue Property="LongDescription" String="Reads all codes and their code groups that are contained in plant-specific selected sets. You can retrieve administration data and valuation data."/>
          <PropertyValue Property="ReadByKeyRestrictions">
            <Record>
              <PropertyValue Property="Description" String="Reads a specific selected set code of catalog type."/>
              <PropertyValue Property="LongDescription" String="Reads a specific code that is contained in a plant-specific selected set. You can retrieve administration data and valuation data."/>
            </Record>
          </PropertyValue>
        </Record>
      </Annotation>
  </Annotations>
