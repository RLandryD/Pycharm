<?xml version='1.0' encoding='UTF-8'?>
<edmx:Edmx xmlns:edmx="http://schemas.microsoft.com/ado/2007/06/edmx" Version="1.0">
    <edmx:DataServices m:DataServiceVersion="1.0" xmlns:m="http://schemas.microsoft.com/ado/2007/08/dataservices/metadata">
        <Schema Namespace="HybrisCommerceOData" xmlns="http://schemas.microsoft.com/ado/2008/09/edm" s:schema-version="1" xmlns:s="http://schemas.sap.com/commerce">
            <EntityType Name="DocumentStatus">
                <Key>
                    <PropertyRef Name="integrationKey"/>
                </Key>
                <Property Name="code" Type="Edm.String" s:IsUnique="true" Nullable="false"/>
                <Property Name="integrationKey" Type="Edm.String" Nullable="false" s:Alias="DocumentStatus_code"/>
            </EntityType>
            <EntityType Name="B2BUnit">
                <Key>
                    <PropertyRef Name="integrationKey"/>
                </Key>
                <Property Name="uid" Type="Edm.String" s:IsUnique="true" Nullable="false"/>
                <Property Name="integrationKey" Type="Edm.String" Nullable="false" s:Alias="B2BUnit_uid"/>
            </EntityType>
            <EntityType Name="B2BDocumentType">
                <Key>
                    <PropertyRef Name="integrationKey"/>
                </Key>
                <Property Name="code" Type="Edm.String" s:IsUnique="true" Nullable="false"/>
                <Property Name="integrationKey" Type="Edm.String" Nullable="false" s:Alias="B2BDocumentType_code"/>
            </EntityType>
            <EntityType Name="Currency">
                <Key>
                    <PropertyRef Name="integrationKey"/>
                </Key>
                <Property Name="isocode" Type="Edm.String" s:IsUnique="true" Nullable="false"/>
                <Property Name="integrationKey" Type="Edm.String" Nullable="false" s:Alias="Currency_isocode"/>
            </EntityType>
            <EntityType Name="PartnerAddress">
                <Key>
                    <PropertyRef Name="integrationKey"/>
                </Key>
                <Property Name="poBox" Type="Edm.String" Nullable="true"/>
                <Property Name="partnerFunction" Type="Edm.String" s:IsUnique="true" Nullable="true"/>
                <Property Name="streetHouseNumber1" Type="Edm.String" Nullable="true"/>
                <Property Name="poBoxPostalCode" Type="Edm.String" Nullable="true"/>
                <Property Name="streetHouseNumber2" Type="Edm.String" Nullable="true"/>
                <Property Name="countryKey" Type="Edm.String" Nullable="true"/>
                <Property Name="postalCode" Type="Edm.String" Nullable="true"/>
                <Property Name="partner" Type="Edm.String" Nullable="true"/>
                <Property Name="city" Type="Edm.String" Nullable="true"/>
                <Property Name="integrationKey" Type="Edm.String" Nullable="false" s:Alias="B2BDocumentType_code|PartnerAddress_partnerFunction|SapB2BDocument_documentNumber"/>
                <NavigationProperty Name="sapB2BDocument" Relationship="HybrisCommerceOData.FK_PartnerAddress_sapB2BDocument" FromRole="PartnerAddress" ToRole="SapB2BDocument" s:IsUnique="true" Nullable="true"/>
            </EntityType>
            <EntityType Name="Material">
                <Key>
                    <PropertyRef Name="integrationKey"/>
                </Key>
                <Property Name="grossValue" Type="Edm.String" Nullable="true"/>
                <Property Name="matDesc" Type="Edm.String" Nullable="true"/>
                <Property Name="matNo" Type="Edm.String" Nullable="true"/>
                <Property Name="matPosNo" Type="Edm.String" s:IsUnique="true" Nullable="true"/>
                <Property Name="netValue" Type="Edm.String" Nullable="true"/>
                <Property Name="quantity" Type="Edm.String" Nullable="true"/>
                <Property Name="unit" Type="Edm.String" Nullable="true"/>
                <Property Name="integrationKey" Type="Edm.String" Nullable="false" s:Alias="B2BDocumentType_code|Material_matPosNo|SapB2BDocument_documentNumber"/>
                <NavigationProperty Name="sapB2BDocument" Relationship="HybrisCommerceOData.FK_Material_sapB2BDocument" FromRole="Material" ToRole="SapB2BDocument" s:IsUnique="true" Nullable="true"/>
            </EntityType>
            <EntityType Name="SapB2BDocument">
                <Key>
                    <PropertyRef Name="integrationKey"/>
                </Key>
                <Property Name="amount" Type="Edm.Decimal" Nullable="false"/>
                <Property Name="billAddress" Type="Edm.String" Nullable="true"/>
                <Property Name="date" Type="Edm.DateTime" Nullable="true"/>
                <Property Name="documentNumber" Type="Edm.String" s:IsUnique="true" Nullable="false"/>
                <Property Name="dueDate" Type="Edm.DateTime" Nullable="true"/>
                <Property Name="grandTotal" Type="Edm.String" Nullable="true"/>
                <Property Name="grossWeight" Type="Edm.String" Nullable="true"/>
                <Property Name="netWeight" Type="Edm.String" Nullable="true"/>
                <Property Name="orderDate" Type="Edm.String" Nullable="true"/>
                <Property Name="orderNumber" Type="Edm.String" Nullable="true"/>
                <Property Name="overAllTax" Type="Edm.String" Nullable="true"/>
                <Property Name="payerAddress" Type="Edm.String" Nullable="true"/>
                <Property Name="termsOfDelivery" Type="Edm.String" Nullable="true"/>
                <Property Name="termsOfPayment" Type="Edm.String" Nullable="true"/>
                <Property Name="units" Type="Edm.String" Nullable="true"/>
                <Property Name="integrationKey" Type="Edm.String" Nullable="false" s:Alias="B2BDocumentType_code|SapB2BDocument_documentNumber"/>
                <NavigationProperty Name="currency" Relationship="HybrisCommerceOData.FK_SapB2BDocument_currency" FromRole="SapB2BDocument" ToRole="Currency" Nullable="false"/>
                <NavigationProperty Name="documentType" Relationship="HybrisCommerceOData.FK_SapB2BDocument_documentType" FromRole="SapB2BDocument" ToRole="B2BDocumentType" s:IsUnique="true" Nullable="false"/>
                <NavigationProperty Name="unit" Relationship="HybrisCommerceOData.FK_SapB2BDocument_unit" FromRole="SapB2BDocument" ToRole="B2BUnit" Nullable="false"/>
            </EntityType>
            <Association Name="FK_PartnerAddress_sapB2BDocument">
                <End Type="HybrisCommerceOData.PartnerAddress" Multiplicity="0..1" Role="PartnerAddress"/>
                <End Type="HybrisCommerceOData.SapB2BDocument" Multiplicity="0..1" Role="SapB2BDocument"/>
            </Association>
            <Association Name="FK_SapB2BDocument_currency">
                <End Type="HybrisCommerceOData.SapB2BDocument" Multiplicity="0..1" Role="SapB2BDocument"/>
                <End Type="HybrisCommerceOData.Currency" Multiplicity="0..1" Role="Currency"/>
            </Association>
            <Association Name="FK_SapB2BDocument_documentType">
                <End Type="HybrisCommerceOData.SapB2BDocument" Multiplicity="0..1" Role="SapB2BDocument"/>
                <End Type="HybrisCommerceOData.B2BDocumentType" Multiplicity="0..1" Role="B2BDocumentType"/>
            </Association>
            <Association Name="FK_SapB2BDocument_unit">
                <End Type="HybrisCommerceOData.SapB2BDocument" Multiplicity="0..1" Role="SapB2BDocument"/>
                <End Type="HybrisCommerceOData.B2BUnit" Multiplicity="0..1" Role="B2BUnit"/>
            </Association>
            <Association Name="FK_Material_sapB2BDocument">
                <End Type="HybrisCommerceOData.Material" Multiplicity="0..1" Role="Material"/>
                <End Type="HybrisCommerceOData.SapB2BDocument" Multiplicity="0..1" Role="SapB2BDocument"/>
            </Association>
            <EntityContainer Name="Container" m:IsDefaultEntityContainer="true">
                <EntitySet Name="DocumentStatuses" EntityType="HybrisCommerceOData.DocumentStatus"/>
                <EntitySet Name="B2BUnits" EntityType="HybrisCommerceOData.B2BUnit"/>
                <EntitySet Name="B2BDocumentTypes" EntityType="HybrisCommerceOData.B2BDocumentType"/>
                <EntitySet Name="Currencies" EntityType="HybrisCommerceOData.Currency"/>
                <EntitySet Name="PartnerAddresses" EntityType="HybrisCommerceOData.PartnerAddress"/>
                <EntitySet Name="Materials" EntityType="HybrisCommerceOData.Material"/>
                <EntitySet Name="SapB2BDocuments" EntityType="HybrisCommerceOData.SapB2BDocument"/>
                <AssociationSet Name="PartnerAddress_SapB2BDocuments" Association="HybrisCommerceOData.FK_PartnerAddress_sapB2BDocument">
                    <End EntitySet="PartnerAddresses" Role="PartnerAddress"/>
                    <End EntitySet="SapB2BDocuments" Role="SapB2BDocument"/>
                </AssociationSet>
                <AssociationSet Name="SapB2BDocument_Currencies" Association="HybrisCommerceOData.FK_SapB2BDocument_currency">
                    <End EntitySet="SapB2BDocuments" Role="SapB2BDocument"/>
                    <End EntitySet="Currencies" Role="Currency"/>
                </AssociationSet>
                <AssociationSet Name="SapB2BDocument_B2BDocumentTypes" Association="HybrisCommerceOData.FK_SapB2BDocument_documentType">
                    <End EntitySet="SapB2BDocuments" Role="SapB2BDocument"/>
                    <End EntitySet="B2BDocumentTypes" Role="B2BDocumentType"/>
                </AssociationSet>
                <AssociationSet Name="SapB2BDocument_B2BUnits" Association="HybrisCommerceOData.FK_SapB2BDocument_unit">
                    <End EntitySet="SapB2BDocuments" Role="SapB2BDocument"/>
                    <End EntitySet="B2BUnits" Role="B2BUnit"/>
                </AssociationSet>
                <AssociationSet Name="Material_SapB2BDocuments" Association="HybrisCommerceOData.FK_Material_sapB2BDocument">
                    <End EntitySet="Materials" Role="Material"/>
                    <End EntitySet="SapB2BDocuments" Role="SapB2BDocument"/>
                </AssociationSet>
            </EntityContainer>
        </Schema>
    </edmx:DataServices>
</edmx:Edmx>