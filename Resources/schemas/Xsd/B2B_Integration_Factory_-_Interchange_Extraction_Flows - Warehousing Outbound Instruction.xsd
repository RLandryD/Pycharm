         <xsd:element name="inventorySubLocation" type="InventorySubLocationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inventory Sub Location</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
