<xs:schema attributeFormDefault="unqualified" elementFormDefault="qualified" xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <xs:element name="profile">
    <xs:complexType>
      <xs:sequence>
        <xs:element type="xs:string" name="activities"/>
        <xs:element type="xs:string" name="address"/>
        <xs:element type="xs:byte" name="age"/>
        <xs:element type="xs:string" name="bio"/>
        <xs:element type="xs:byte" name="birthDay"/>
        <xs:element type="xs:byte" name="birthMonth"/>
        <xs:element type="xs:short" name="birthYear"/>
        <xs:element name="certifications">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="element">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element type="xs:string" name="authority"/>
                    <xs:element type="xs:string" name="endDate"/>
                    <xs:element type="xs:string" name="name"/>
                    <xs:element type="xs:string" name="number"/>
                    <xs:element type="xs:string" name="startDate"/>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element type="xs:string" name="city"/>
        <xs:element type="xs:string" name="country"/>
        <xs:element name="education">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="element">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element type="xs:string" name="degree"/>
                    <xs:element type="xs:short" name="endYear"/>
                    <xs:element type="xs:string" name="fieldOfStudy"/>
                    <xs:element type="xs:string" name="school"/>
                    <xs:element type="xs:string" name="schoolType"/>
                    <xs:element type="xs:short" name="startYear"/>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element type="xs:string" name="educationLevel"/>
        <xs:element type="xs:string" name="email"/>
        <xs:element name="favorites">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="element">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element type="xs:string" name="activities.category"/>
                    <xs:element type="xs:string" name="activities.id"/>
                    <xs:element type="xs:string" name="activities.name"/>
                    <xs:element type="xs:string" name="books.category"/>
                    <xs:element type="xs:string" name="books.id"/>
                    <xs:element type="xs:string" name="books.name"/>
                    <xs:element type="xs:string" name="interests.category"/>
                    <xs:element type="xs:string" name="interests.id"/>
                    <xs:element type="xs:string" name="interests.name"/>
                    <xs:element type="xs:string" name="movies.category"/>
                    <xs:element type="xs:string" name="movies.id"/>
                    <xs:element type="xs:string" name="movies.name"/>
                    <xs:element type="xs:string" name="music.category"/>
                    <xs:element type="xs:string" name="music.id"/>
                    <xs:element type="xs:string" name="music.name"/>
                    <xs:element type="xs:string" name="television.category"/>
                    <xs:element type="xs:string" name="television.id"/>
                    <xs:element type="xs:string" name="television.name"/>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element type="xs:string" name="firstName"/>
        <xs:element type="xs:short" name="followersCount"/>
        <xs:element type="xs:byte" name="followingCount"/>
        <xs:element type="xs:string" name="gender"/>
        <xs:element type="xs:string" name="hometown"/>
        <xs:element type="xs:string" name="honors"/>
        <xs:element type="xs:string" name="industry"/>
        <xs:element type="xs:string" name="interestedIn"/>
        <xs:element type="xs:string" name="interests"/>
        <xs:element type="xs:string" name="languages"/>
        <xs:element name="lastLoginLocation">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="element">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element type="xs:string" name="city"/>
                    <xs:element type="xs:float" name="coordinates.lat"/>
                    <xs:element type="xs:float" name="coordinates.lon"/>
                    <xs:element type="xs:string" name="country"/>
                    <xs:element type="xs:string" name="state"/>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element type="xs:string" name="lastName"/>
        <xs:element name="likes">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="element">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element type="xs:string" name="category"/>
                    <xs:element type="xs:string" name="id"/>
                    <xs:element type="xs:string" name="name"/>
                    <xs:element type="xs:string" name="time"/>
                    <xs:element type="xs:byte" name="timestamp"/>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element type="xs:string" name="locale"/>
        <xs:element type="xs:string" name="name"/>
        <xs:element type="xs:string" name="nickname"/>
