            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SR">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sales representative or
                  department</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The sales representative or
                  department contact within an organization.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="TA">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Traffic
                  administrator</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The traffic administrator
                  contact within an organization.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="TD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Test contact</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Department/person responsible
                  for testing contact.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="TR">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transport
                  contact</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Department/person in charge
