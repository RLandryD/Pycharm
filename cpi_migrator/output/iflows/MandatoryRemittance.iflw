<?xml version="1.0" encoding="UTF-8"?>
<bpmn2:definitions xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1">
    <bpmn2:collaboration id="Collaboration_1" name="Default Collaboration">
        <bpmn2:extensionElements>
            <ifl:property><key>routeid</key><value>MyProject</value></ifl:property>
            <ifl:property><key>errorStrategy</key><value>None</value></ifl:property>
            <ifl:property><key>namespaceMapping</key><value>xmlns:p1=http://sap.com/xi/APPL/GS/CL;xmlns:n1=http://www.sii.cl/SiiLce;xmlns:test=http://sapcd.com/test;xmlns:test2=http://sapcd.com/test</value></ifl:property>
            <ifl:property><key>traceLevel</key><value>Message Body and Header</value></ifl:property>
            <ifl:property><key>returnExceptionToSender</key><value>false</value></ifl:property>
        </bpmn2:extensionElements>
        <bpmn2:participant id="Participant_Process_1" ifl:type="IntegrationProcess" name="Integration Process" processRef="Process_1">
            <bpmn2:extensionElements/>
        </bpmn2:participant>
        <bpmn2:participant id="Participant_1" ifl:type="EndpointSender" name="Sender">
            <bpmn2:extensionElements/>
        </bpmn2:participant>
        <bpmn2:messageFlow id="MessageFlow_1" name="" sourceRef="Participant_1" targetRef="StartEvent_1">
            <bpmn2:extensionElements>
                <ifl:property><key>Name</key><value>MAND_REM</value></ifl:property>
                <ifl:property><key>Description</key><value>Mandatory Remittance for Balance Sheet, General Ledger and Daily Register</value></ifl:property>
                <ifl:property><key>ComponentType</key><value>SOAP</value></ifl:property>
                <ifl:property><key>TransportProtocol</key><value>HTTP</value></ifl:property>
                <ifl:property><key>TransportProtocolVersion</key><value>1.0.6</value></ifl:property>
                <ifl:property><key>MessageProtocol</key><value>SOAP 1.x</value></ifl:property>
                <ifl:property><key>MessageProtocolVersion</key><value>1.2.2</value></ifl:property>
                <ifl:property><key>componentVersion</key><value>1.2</value></ifl:property>
                <ifl:property><key>ComponentNS</key><value>sap</value></ifl:property>
                <ifl:property><key>ComponentSWCVId</key><value>1.3.3</value></ifl:property>
                <ifl:property><key>ComponentSWCVName</key><value>1.3.3</value></ifl:property>
                <ifl:property><key>address</key><value>/s4hana/glo/chilesignmandrem</value></ifl:property>
                <ifl:property><key>soapWsdlURL</key><value>/wsdl/MandatoryRemittance.wsdl</value></ifl:property>
                <ifl:property><key>soapServiceName</key><value>p1:ClMandatoryRemittance</value></ifl:property>
                <ifl:property><key>soapWsdlPortName</key><value>p1:MandatoryRemittanceSOAP</value></ifl:property>
                <ifl:property><key>soapOptions</key><value>cxfRobust</value></ifl:property>
                <ifl:property><key>senderAuthType</key><value>RoleBased</value></ifl:property>
                <ifl:property><key>userRole</key><value>ESBMessaging.send</value></ifl:property>
                <ifl:property><key>WSSecurity</key><value>None</value></ifl:property>
                <ifl:property><key>WSSecurityType</key><value>VerifyMessage</value></ifl:property>
                <ifl:property><key>SaveIncomingSignedMessage</key><value>0</value></ifl:property>
                <ifl:property><key>CheckTimeStamp</key><value>0</value></ifl:property>
                <ifl:property><key>SenderBasicSecurityProfileCompliant</key><value>1</value></ifl:property>
                <ifl:property><key>PrivateKeyAliasResponseSigning</key><value></value></ifl:property>
                <ifl:property><key>PublicKeyAliasResponseEncryption</key><value></value></ifl:property>
                <ifl:property><key>InitiatorTokenIncludeStrategy</key><value>AlwaysToRecipient</value></ifl:property>
                <ifl:property><key>X509TokenAssertion</key><value>WssX509V3Token10</value></ifl:property>
                <ifl:property><key>RecipientTokenIncludeStrategy</key><value>Never</value></ifl:property>
                <ifl:property><key>AlgorithmSuiteAssertion</key><value>Basic128Rsa15</value></ifl:property>
                <ifl:property><key>maximumBodySize</key><value>40</value></ifl:property>
                <ifl:property><key>maximumAttachmentSize</key><value>100</value></ifl:property>
            </bpmn2:extensionElements>
        </bpmn2:messageFlow>
    </bpmn2:collaboration>
    <bpmn2:process id="Process_1" name="Integration Process">
        <bpmn2:extensionElements>
            <ifl:property><key>transactionTimeout</key><value>30</value></ifl:property>
            <ifl:property><key>componentVersion</key><value>1.2</value></ifl:property>
            <ifl:property><key>cmdVariantUri</key><value>ctype::FlowElementVariant/cname::IntegrationProcess/version::1.2.1</value></ifl:property>
            <ifl:property><key>transactionalHandling</key><value>Not Required</value></ifl:property>
        </bpmn2:extensionElements>
        <bpmn2:startEvent id="StartEvent_1" name="Start">
            <bpmn2:extensionElements>
                <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::MessageStartEvent/version::1.0</value></ifl:property>
                <ifl:property><key>componentVersion</key><value>1.0</value></ifl:property>
                <ifl:property><key>activityType</key><value>StartEvent</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:outgoing>SequenceFlow_1</bpmn2:outgoing>
            <bpmn2:messageEventDefinition/>
        </bpmn2:startEvent>
        <bpmn2:endEvent id="EndEvent_1" name="End">
            <bpmn2:extensionElements>
                <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::MessageEndEvent/version::1.1.0</value></ifl:property>
                <ifl:property><key>componentVersion</key><value>1.1.0</value></ifl:property>
                <ifl:property><key>activityType</key><value>EndEvent</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_9</bpmn2:incoming>
            <bpmn2:messageEventDefinition/>
        </bpmn2:endEvent>
        <bpmn2:callActivity id="CallActivity_1" name="Content Modifier">
            <bpmn2:extensionElements>
                <ifl:property><key>activityType</key><value>Enricher</value></ifl:property>
                <ifl:property><key>componentVersion</key><value>1.2</value></ifl:property>
                <ifl:property><key>wrapContent</key><value>&lt;n0:MandatoryRemittanceResponse xmlns:n0=&quot;http://sap.com/xi/APPL/GS/CL&quot;&gt;
&lt;SignedMandatoryRemittanceData&gt;${in.body}&lt;/SignedMandatoryRemittanceData&gt;
&lt;/n0:MandatoryRemittanceResponse&gt;</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_8</bpmn2:incoming>
            <bpmn2:outgoing>SequenceFlow_9</bpmn2:outgoing>
        </bpmn2:callActivity>
        <bpmn2:callActivity id="CallActivity_2" name="NamespaceFilter">
            <bpmn2:extensionElements>
                <ifl:property><key>activityType</key><value>Filter</value></ifl:property>
                <ifl:property><key>xpathType</key><value>String</value></ifl:property>
                <ifl:property><key>wrapContent</key><value>/p1:MandatoryRemittance/MandatoryRemittanceData/text()</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_1</bpmn2:incoming>
            <bpmn2:outgoing>SequenceFlow_4</bpmn2:outgoing>
        </bpmn2:callActivity>
        <bpmn2:callActivity id="CallActivity_5" name="MandatoryRemittanceSigner">
            <bpmn2:extensionElements>
                <ifl:property><key>activityType</key><value>XMLDigitalSignMessage</value></ifl:property>
                <ifl:property><key>Activity_Name</key><value>MandatoryRemittanceSigner</value></ifl:property>
                <ifl:property><key>signatureAlgorithm</key><value>SHA1/RSA</value></ifl:property>
                <ifl:property><key>signatureType</key><value>Detached XML signatures</value></ifl:property>
                <ifl:property><key>parentNodeSpecification</key><value>Specified by Name and Namespace</value></ifl:property>
                <ifl:property><key>canonicalizationMethod</key><value>Inclusive XML Canonicalization</value></ifl:property>
                <ifl:property><key>transformMethod</key><value>Inclusive XML Canonicalization</value></ifl:property>
                <ifl:property><key>prefixForXmlSignatureNamespace</key><value></value></ifl:property>
                <ifl:property><key>keyInfoContent</key><value>X509CertificateAndKeyValue</value></ifl:property>
                <ifl:property><key>addKeyInfoReference</key><value>false</value></ifl:property>
                <ifl:property><key>xadesAddSigningCertificate</key><value>None</value></ifl:property>
                <ifl:property><key>xadesSigningCertificateDigestAlgorithm</key><value>SHA-256</value></ifl:property>
                <ifl:property><key>xadesEpesSignaturePolicy</key><value>None</value></ifl:property>
                <ifl:property><key>xadesEpesDigestAlgorithm</key><value>SHA-256</value></ifl:property>
                <ifl:property><key>signatureXMLNamespacePrefix</key><value></value></ifl:property>
                <ifl:property><key>signatureCommitment</key><value></value></ifl:property>
                <ifl:property><key>privateKeyAlias</key><value>chilesignaturekey</value></ifl:property>
                <ifl:property><key>digestAlgorithm</key><value>SHA1</value></ifl:property>
                <ifl:property><key>schemaResourceUri</key><value>xsd/LceEnvioOblig_v10.xsd</value></ifl:property>
                <ifl:property><key>outputEncoding</key><value>ISO-8859-1</value></ifl:property>
                <ifl:property><key>xadesAddSigningTime</key><value>false</value></ifl:property>
                <ifl:property><key>xpathToIdAttribute</key><value>&lt;row&gt;&lt;cell&gt;/n1:LceEnvioOblig/n1:DocumentoEnvioOblig/@ID&lt;/cell&gt;&lt;/row&gt;&lt;row&gt;&lt;cell&gt;/n1:LceEnvioOblig/n1:DocumentoEnvioOblig/n1:LceCoCierre/n1:LceDiccionario/n1:DocumentoDiccionario/@ID&lt;/cell&gt;&lt;/row&gt;&lt;row&gt;&lt;cell&gt;/n1:LceEnvioOblig/n1:DocumentoEnvioOblig/n1:LceCoCierre/n1:LceBalance/n1:DocumentoBalance/@ID&lt;/cell&gt;&lt;/row&gt;&lt;row&gt;&lt;cell&gt;/n1:LceEnvioOblig/n1:DocumentoEnvioOblig/n1:LceCoCierre/n1:LceDiarioRes/n1:DocumentoDiarioRes/@ID&lt;/cell&gt;&lt;/row&gt;&lt;row&gt;&lt;cell&gt;/n1:LceEnvioOblig/n1:DocumentoEnvioOblig/n1:LceCoCierre/n1:LceMayorRes/n1:DocumentoMayorRes/@ID&lt;/cell&gt;&lt;/row&gt;</value></ifl:property>
                <ifl:property><key>omitXmlDeclaration</key><value>false</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_12</bpmn2:incoming>
            <bpmn2:outgoing>SequenceFlow_11</bpmn2:outgoing>
        </bpmn2:callActivity>
        <bpmn2:callActivity id="CallActivity_3" name="NodeFilter">
            <bpmn2:extensionElements>
                <ifl:property><key>activityType</key><value>Filter</value></ifl:property>
                <ifl:property><key>xpathType</key><value>Node</value></ifl:property>
                <ifl:property><key>wrapContent</key><value>/n1:LceEnvioOblig</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_4</bpmn2:incoming>
            <bpmn2:outgoing>SequenceFlow_12</bpmn2:outgoing>
        </bpmn2:callActivity>
        <bpmn2:callActivity id="CallActivity_4" name="Encoder">
            <bpmn2:extensionElements>
                <ifl:property><key>activityType</key><value>Encoder</value></ifl:property>
                <ifl:property><key>encoderType</key><value>Base64 Encode</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_11</bpmn2:incoming>
            <bpmn2:outgoing>SequenceFlow_8</bpmn2:outgoing>
        </bpmn2:callActivity>
        <bpmn2:sequenceFlow id="SequenceFlow_1" sourceRef="StartEvent_1" targetRef="CallActivity_2"/>
        <bpmn2:sequenceFlow id="SequenceFlow_9" sourceRef="CallActivity_1" targetRef="EndEvent_1"/>
        <bpmn2:sequenceFlow id="SequenceFlow_4" sourceRef="CallActivity_2" targetRef="CallActivity_3"/>
        <bpmn2:sequenceFlow id="SequenceFlow_11" sourceRef="CallActivity_5" targetRef="CallActivity_4"/>
        <bpmn2:sequenceFlow id="SequenceFlow_12" sourceRef="CallActivity_3" targetRef="CallActivity_5"/>
        <bpmn2:sequenceFlow id="SequenceFlow_8" sourceRef="CallActivity_4" targetRef="CallActivity_1"/>
    </bpmn2:process>
    <bpmndi:BPMNDiagram id="BPMNDiagram_1" name="Default Collaboration Diagram">
        <bpmndi:BPMNPlane bpmnElement="Collaboration_1" id="BPMNPlane_1">
            <bpmndi:BPMNShape bpmnElement="Participant_Process_1" id="BPMNShape_Participant_Process_1">
                <dc:Bounds height="200.0" width="1252.0" x="284.0" y="60.0"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="StartEvent_1" id="BPMNShape_StartEvent_1"><dc:Bounds height="32.0" width="32.0" x="354.0" y="144.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="EndEvent_1" id="BPMNShape_EndEvent_1"><dc:Bounds height="32.0" width="32.0" x="1434.0" y="144.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="CallActivity_1" id="BPMNShape_CallActivity_1"><dc:Bounds height="60.0" width="100.0" x="1220.0" y="130.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="CallActivity_2" id="BPMNShape_CallActivity_2"><dc:Bounds height="60.0" width="100.0" x="500.0" y="130.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="CallActivity_5" id="BPMNShape_CallActivity_5"><dc:Bounds height="60.0" width="100.0" x="860.0" y="130.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="CallActivity_3" id="BPMNShape_CallActivity_3"><dc:Bounds height="60.0" width="100.0" x="680.0" y="130.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="CallActivity_4" id="BPMNShape_CallActivity_4"><dc:Bounds height="60.0" width="100.0" x="1040.0" y="130.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="Participant_1" id="BPMNShape_Participant_1"><dc:Bounds height="140.0" width="100.0" x="80.0" y="110.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_1" id="BPMNEdge_SequenceFlow_1" sourceElement="BPMNShape_StartEvent_1" targetElement="BPMNShape_CallActivity_2"><di:waypoint x="386.0" xsi:type="dc:Point" y="160.0"/><di:waypoint x="500.0" xsi:type="dc:Point" y="160.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_9" id="BPMNEdge_SequenceFlow_9" sourceElement="BPMNShape_CallActivity_1" targetElement="BPMNShape_EndEvent_1"><di:waypoint x="1320.0" xsi:type="dc:Point" y="160.0"/><di:waypoint x="1434.0" xsi:type="dc:Point" y="160.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_4" id="BPMNEdge_SequenceFlow_4" sourceElement="BPMNShape_CallActivity_2" targetElement="BPMNShape_CallActivity_3"><di:waypoint x="600.0" xsi:type="dc:Point" y="160.0"/><di:waypoint x="680.0" xsi:type="dc:Point" y="160.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_11" id="BPMNEdge_SequenceFlow_11" sourceElement="BPMNShape_CallActivity_5" targetElement="BPMNShape_CallActivity_4"><di:waypoint x="960.0" xsi:type="dc:Point" y="160.0"/><di:waypoint x="1040.0" xsi:type="dc:Point" y="160.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_12" id="BPMNEdge_SequenceFlow_12" sourceElement="BPMNShape_CallActivity_3" targetElement="BPMNShape_CallActivity_5"><di:waypoint x="780.0" xsi:type="dc:Point" y="160.0"/><di:waypoint x="860.0" xsi:type="dc:Point" y="160.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_8" id="BPMNEdge_SequenceFlow_8" sourceElement="BPMNShape_CallActivity_4" targetElement="BPMNShape_CallActivity_1"><di:waypoint x="1140.0" xsi:type="dc:Point" y="160.0"/><di:waypoint x="1220.0" xsi:type="dc:Point" y="160.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="MessageFlow_1" id="BPMNEdge_MessageFlow_1" sourceElement="BPMNShape_Participant_1" targetElement="BPMNShape_StartEvent_1"><di:waypoint x="180.0" xsi:type="dc:Point" y="180.0"/><di:waypoint x="354.0" xsi:type="dc:Point" y="160.0"/></bpmndi:BPMNEdge>
        </bpmndi:BPMNPlane>
    </bpmndi:BPMNDiagram>
