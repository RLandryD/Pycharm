<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema">
   <xsd:element name="warehousingOutboundInstructionMessage"
      type="WarehousingOutboundInstructionMessageType"/>
   <xsd:complexType name="WarehousingDeliveryInstructionCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: PRIORITY_DESPATCH</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:WarehousingDeliveryInstructionCode</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="WarehousingDeliveryInstructionCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="WarehousingDespatchTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: WAREHOUSE_SHIPMENT</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:WarehousingDespatchTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="WarehousingDespatchTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="WarehousingOutboundInstructionMessageType">
      <xsd:sequence>
         <xsd:element name="sh_StandardBusinessDocumentHeader" type="StandardBusinessDocumentHeader">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Standard Business Document Header</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="warehousingOutboundInstruction" maxOccurs="10000"
            type="WarehousingOutboundInstructionType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Warehousing Outbound Instruction</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="WarehousingOutboundInstructionShipmentItemType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">A shipment item is collection of trade items and related logistic units that can each be identified (uniquely) within a shipment.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="lineItemNumber" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Line Item Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The sequence number for this shipment item.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="associatedInvoicePrice" minOccurs="0" type="AmountType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Associated Invoice Price</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The unit price of the trade item excluding taxes.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="parentLineItemNumber" minOccurs="0" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Parent Line Item Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The number of line item containing information about the parent of the current item. It allows establishing hierarchical link between the two items.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 3</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="note" minOccurs="0" type="Description500Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Note</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Free text used to convey information that is not processed by applications. Only meant to present the information to a user as on a screen, in a browser, etc.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transactionalTradeItem" type="TransactionalTradeItemType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transactional Trade Item</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information on the trade item contained in the shipment.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="logisticUnit" minOccurs="0" maxOccurs="unbounded"
            type="LogisticUnitType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Logistic Unit</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information on the logistic unit quantity of the trade item contained in it.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="shipTo" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Ship To</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The physical location to where goods will be or have been shipped.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="inventoryLocation" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inventory Location</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identification of the location where the goods are stored.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="ultimateConsignee" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Ultimate Consignee</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifies the party that is the final destination of the goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="inventorySubLocation" minOccurs="0" type="InventorySubLocationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inventory Sub Location</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identification of the inventory sub-location where goods are stored.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="administrativeUnit" minOccurs="0" maxOccurs="unbounded"
            type="AdministrativeUnitType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Administrative Unit</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">On or more administrative units related to the shipment item.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transactionalReference" minOccurs="0" maxOccurs="unbounded"
            type="TransactionalReferenceType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transactional Reference</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">One or more references to associated information in support of related business processes. E.g. a purchase order, a return authorization number.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transportCargoCharacteristics" minOccurs="0"
            type="TransportCargoCharacteristicsType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transport Cargo Characteristics</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Aggregate information on the goods that are contained in this shipment item.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="packageTotal" minOccurs="0" maxOccurs="unbounded"
            type="PackageTotalType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Package Total</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Aggregate information per type of package contained in the shipment item.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="handlingInstruction" minOccurs="0" maxOccurs="unbounded"
            type="HandlingInstructionType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Handling Instruction</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">One or more instructions on the way to treat the goods during transport and storage.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="inventoryDutyFeeTaxStatus" minOccurs="0" maxOccurs="unbounded"
            type="InventoryDutyFeeTaxStatusType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inventory Duty Fee Tax Status</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The duty, fee and / or tax status related to the goods.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="avpList" minOccurs="0" type="Ecom_AttributeValuePairListType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Avp List</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="plannedDespatchQuantity" type="QuantityType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Planned Despatch Quantity</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The quantity that is ordered / planned to be despatched.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="deliveryInstructionCode" minOccurs="0" maxOccurs="unbounded"
            type="WarehousingDeliveryInstructionCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Delivery Instruction Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying special order / delivery conditions.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="crossDockIndicator" minOccurs="0" type="xsd:boolean">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Cross Dock Indicator</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Indication whether or not the shipped item needs to be taken from a cross-docked receipt instead of from stock.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="inboundLogisticUnitReference" minOccurs="0" maxOccurs="unbounded"
            type="Ecom_LogisticUnitIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inbound Logistic Unit Reference</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Reference to the cross-docked logistic unit from which the item has to be taken.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="inboundShipmentReference" minOccurs="0"
            type="Ecom_ShipmentIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inbound Shipment Reference</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Reference to the cross-docked receipt from which the item has to be taken.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="inlineServiceInstruction" minOccurs="0" maxOccurs="unbounded"
            type="WarehousingServiceInstructionType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inline Service Instruction</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Instruction specifying a service to be carried out by the logistic services seller during the inbound process.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="WarehousingOutboundInstructionShipmentType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">A shipment is an identifiable collection of one or more Trade Items available to be transported together from the shipper (Original Consignor/Shipper), to the receiver (Final/Ultimate Consignee).</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="note" minOccurs="0" type="Description500Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Note</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Free text used to convey information that is not processed by applications. Only meant to present the information to a user as on a screen, in a browser, etc.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="shipmentIdentification" minOccurs="0"
            type="Ecom_ShipmentIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Shipment Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information used to identify the shipment.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="shipper" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Shipper</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A party which engages in shipping this shipment of goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="receiver" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Receiver</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A party which engages in receiving this shipment of goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="buyer" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Buyer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifies the party to which products or services are sold.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="seller" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Seller</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifies the party which sells products or services to a buyer.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="shipFrom" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Ship From</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The physical location from where goods will be or have been shipped.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="shipTo" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Ship To</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The physical location to where goods will be or have been shipped.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="inventoryLocation" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inventory Location</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identification of the location (premises) where the goods will be stored.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="ultimateConsignee" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Ultimate Consignee</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifies the party that is the final destination for the shipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="logisticUnit" minOccurs="0" maxOccurs="unbounded"
            type="LogisticUnitType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Logistic Unit</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The logistic units contained in the shipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="administrativeUnit" minOccurs="0" maxOccurs="unbounded"
            type="AdministrativeUnitType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Administrative Unit</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">On or more administrative units related to the shipment.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="deliveryTerms" minOccurs="0" type="DeliveryTermsType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Delivery Terms</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The applicable legal, customs, financial and insurance terms that have been agreed for the shipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transactionalReference" minOccurs="0" maxOccurs="unbounded"
            type="TransactionalReferenceType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transactional Reference</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">One or more references to associated information in support of related business processes. E.g. a purchase order, a return authorization number.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transportCargoCharacteristics" minOccurs="0"
            type="TransportCargoCharacteristicsType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transport Cargo Characteristics</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Aggregate information on the goods that are contained in this shipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="packageTotal" minOccurs="0" maxOccurs="unbounded"
            type="PackageTotalType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Package Total</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Aggregate information per type of package contained in the shipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="handlingInstruction" minOccurs="0" maxOccurs="unbounded"
            type="HandlingInstructionType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Handling Instruction</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">One or more instructions on the way to treat the goods during transport and storage.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="warehousingDespatchTypeCode" type="WarehousingDespatchTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Warehousing Despatch Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the type of despatch for the shipment, for example picked from stock or cross-docked.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="warehousingDeliveryInstructionCode" minOccurs="0" maxOccurs="unbounded"
            type="WarehousingDeliveryInstructionCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Warehousing Delivery Instruction Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying special order / delivery conditions.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="plannedDespatch" minOccurs="0" type="LogisticEventType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Planned Despatch</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Details on the date and time the goods need to be despatched.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="plannedDelivery" minOccurs="0" type="LogisticEventType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Planned Delivery</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Details on the date and time the goods need to be delivered.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="carrierPickUpDropOffDetails" minOccurs="0"
            type="CarrierPickUpDropOffDetailsType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Carrier Pick Up Drop Off Details</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Details on the carrier that will deliver the goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="shipmentTransportationInformation" minOccurs="0"
            type="ShipmentTransportationInformationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Shipment Transportation Information</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Instructions on the way the shipment needs to be transported.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="inlineServiceInstruction" minOccurs="0" maxOccurs="unbounded"
            type="WarehousingServiceInstructionType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inline Service Instruction</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Details on one or more services to be performed by the logistic services seller during outbound processing.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="warehousingOutboundInstructionShipmentItem" minOccurs="0"
            maxOccurs="unbounded" type="WarehousingOutboundInstructionShipmentItemType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Warehousing Outbound Instruction Shipment Item</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Details on the items that need to be shipped.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="WarehousingOutboundInstructionType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Message that supports the warehouse outbound process, and enables a Logistic Services Client (LSC) to inform his Logistic Services Provider (LSP) that goods need to be shipped.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">Used to specify basic information about the content of the message including version number, creation date and time and AVP placeholder.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">Used to specify basic information about the content of the message including version number, creation date and time.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="creationDateTime" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Creation Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date and time when the document was created.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15T11:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="documentStatusCode" type="DocumentStatusEnumerationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Document Status Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="documentActionCode" minOccurs="0" type="DocumentActionEnumerationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Document Action Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="documentStructureVersion" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Document Structure Version</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Specification of the version of the standard on which the structure of the document is based.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 3.3</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="lastUpdateDateTime" minOccurs="0" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Last Update Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date and time when the document was last updated.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-05T11:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="revisionNumber" minOccurs="0" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Revision Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number to be used for identification and referencing of subsequent updates to a business document.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 3</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="extension" minOccurs="0" type="ExtensionType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Extension</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="documentEffectiveDate" minOccurs="0" type="DateOptionalTimeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Document Effective Date</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The date that the document becomes effective from commercial or legal point of view.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="avpList" minOccurs="0" type="Ecom_AttributeValuePairListType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Avp List</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The transmission of non-standard data done in a simple, flexible, and easy to use method.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="warehousingOutboundInstructionIdentification"
            type="Ecom_EntityIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Warehousing Outbound Instruction Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identification of the warehousing outbound instruction document.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="logisticServicesBuyer" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Logistic Services Buyer</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="logisticServicesSeller" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Logistic Services Seller</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A party that provides logistics services to another party.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="warehousingOutboundInstructionShipment" maxOccurs="unbounded"
            type="WarehousingOutboundInstructionShipmentType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Warehousing Outbound Instruction Shipment</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information on the shipments that need to be prepared by the logistics services seller.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="BusinessScope">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Description of the complete business
        environment in which the SBDH and SBD will be processed. The business scope provides a basis
        to determine which rules are applicable to the transaction involving the enclosed business
        documents.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="sh_Scope" minOccurs="0" maxOccurs="unbounded" type="Scope">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Scope</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="BusinessService">
      <xsd:sequence>
         <xsd:element name="sh_BusinessServiceName" minOccurs="0" type="xsd:string">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Business Service Name</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_ServiceTransaction" minOccurs="0" type="ServiceTransaction">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Service Transaction</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="ContactInformation">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Name of the contact person or
        department for the sending or receiving Party</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="sh_Contact" type="xsd:string">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Contact</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Name of contact person or
            department</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Additional rules: GS1 SBDH usage rule: The
            element ‘Contact’, although optional, SHOULD be used, if possible.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: John Doe</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_EmailAddress" minOccurs="0" type="xsd:string">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Email Address</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Additional rules: The element ‘EmailAddress, although
            optional, SHOULD be used, if possible.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: John_Doe@purchasing.XYZretailer.com</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_FaxNumber" minOccurs="0" type="xsd:string">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Fax Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Additional rules: A number format agreed upon between the
            ‘Sender’ and ‘Receiver’ SHOULD be used. Number format expressed using [RFC3966] ‘The tel
            URI for Telephone Numbers’ MAY be used.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: +1-212-555-1213</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_TelephoneNumber" minOccurs="0" type="xsd:string">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Telephone Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Additional rules: A number format agreed upon between the
            ‘Sender’ and ‘Receiver’ SHOULD be used. Number format expressed using [RFC3966] ‘The tel
            URI for Telephone Numbers’ MAY be used.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: +1-212-555-2122</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_ContactTypeIdentifier" minOccurs="0" type="xsd:string">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Contact Type Identifier</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Role of the
            identifier.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: EDI co-ordinator</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="CorrelationInformation">
      <xsd:sequence>
         <xsd:element name="sh_RequestingDocumentCreationDateTime" minOccurs="0" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Requesting Document Creation Date Time</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_RequestingDocumentInstanceIdentifier" minOccurs="0" type="xsd:string">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Requesting Document Instance Identifier</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_ExpectedResponseDateTime" minOccurs="0" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Expected Response Date Time</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="DocumentIdentification">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Identification information for the
        document</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="sh_Standard" type="xsd:string">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Standard</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The name of the document standard
            contained in the payload</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Additional rules: GS1 SBDH usage rule: The
            value of the element ‘Standard’ MUST be set to the value ‘GS1’.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: GS1</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_TypeVersion" type="xsd:string">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Type Version</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Version information of the
            document included in the payload of SBDH. This is the 'complete' version of the document
            itself and is different than the ‘HeaderVersion’.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Additional rules:  GS1 SBDH usage rule: The
            value of the element ‘TypeVersion’ MUST be set the version number of the root schema of
            the XML business document contained in the payload of the message. Every GS1 standard
            schema has version information in the ‘xsd:version’ attribute of the ‘xsd:schema’ tag of
            the schema and also in the schema annotation tag. The SBDH specification requires that
            all documents sent with one header have the same version number. </xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 3.3</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_InstanceIdentifier" type="xsd:string">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Instance Identifier</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Description which contains
            reference information which uniquely identifies this instance of the Standard Business
            Document (SBD) between the ‘Sender’ and the ‘Receiver’. This identifier identifies this
            document as being distinct from others.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: MSG-1645000099</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_Type" type="xsd:string">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Type</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">This element identifies the type
            of the document.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Additional rules: GS1 SBDH usage rule: The
            value of the ‘Type’ element of ‘DocumentIdentification’ element MUST be set to the name
            of the XML element that defines the root of the business document. This is the name of
            the global XML element declared in the root schema for the business document in
            consideration.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Order</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_MultipleType" minOccurs="0" type="xsd:boolean">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Multiple Type</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Flag to indicate that there is more than one
            type of business document in the payload of the SBDH.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Additional rules: GS1 SBDH usage rule: The value of the
            ‘MultiType’ element of ‘DocumentIdentification’ element MUST be set to 'false’ as the
            GS1 XML design allows only one type of business documents to be sent within one
            message.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: False</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_CreationDateAndTime" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Creation Date And Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date and time of the SBDH document
            creation.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Additional rules: The value of the ‘CreationDateAndTime’
            element MUST be set to the date and time when the ‘document originating application’ or
            the parser created the document. This value will typically be populated by the trading
            partner and will typically differ from the time stamping of the message by the
            communications software.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15T11:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="Manifest">
      <xsd:sequence>
         <xsd:element name="sh_NumberOfItems" type="xsd:integer">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Number Of Items</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_ManifestItem" maxOccurs="unbounded" type="ManifestItem">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Manifest Item</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="ManifestItem">
      <xsd:sequence>
         <xsd:element name="sh_MimeTypeQualifierCode" type="MimeTypeQualifier">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Mime Type Qualifier Code</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_UniformResourceIdentifier" type="xsd:anyURI">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Uniform Resource Identifier</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_Description" minOccurs="0" type="xsd:string">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Description</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_LanguageCode" minOccurs="0" type="Language">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Language Code</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="Partner">
      <xsd:sequence>
         <xsd:element name="sh_Identifier" type="PartnerIdentification">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Identifier</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_ContactInformation" minOccurs="0" maxOccurs="unbounded"
            type="ContactInformation">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Contact Information</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="PartnerIdentification">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">A unique identification key for the
        sending or receiving party</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Additional rules: GS1 SBDH usage rule: The value
        of the ‘Identifier’ element of ‘PartnerIdentification’ type MUST be a GLN. The use of GLN as
        the identifier is mandatory with GS1 standards.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 8712345000004</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="xsd:string">
            <xsd:attribute name="Authority" type="xsd:string">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Authority agency of the
              identification key</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 Additional rules: GS1 SBDH usage rule: The
              ‘Authority’ attribute, although optional, MUST be used and its value must be set to
              ‘GS1’.</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: GS1</xsd:documentation>
               </xsd:annotation>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="Scope">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Additional rules: GS1 SBDH usage rule: The ‘Scope’ element MAY
        be used to provide information about the guideline(s) or set of processing rules that are
        applicable to this instance of the business document. For each individual guideline or set
        of processing rules a different ‘Scope’ element MUST be used.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="sh_Type" type="xsd:string">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Type</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_InstanceIdentifier" type="xsd:string">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Instance Identifier</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_Identifier" minOccurs="0" type="xsd:string">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Identifier</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_ScopeInformation" minOccurs="0" maxOccurs="unbounded"
            type="xsd:string">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Scope Information</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="ServiceTransaction">
      <xsd:attribute name="TypeOfServiceTransaction" use="optional" type="TypeOfServiceTransaction"/>
      <xsd:attribute name="IsNonRepudiationRequired" type="xsd:string"/>
      <xsd:attribute name="IsAuthenticationRequired" type="xsd:string"/>
      <xsd:attribute name="IsNonRepudiationOfReceiptRequired" type="xsd:string"/>
      <xsd:attribute name="IsIntegrityCheckRequired" type="xsd:string"/>
      <xsd:attribute name="IsApplicationErrorResponseRequested" type="xsd:string"/>
      <xsd:attribute name="TimeToAcknowledgeReceipt" type="xsd:string"/>
      <xsd:attribute name="TimeToAcknowledgeAcceptance" type="xsd:string"/>
      <xsd:attribute name="TimeToPerform" type="xsd:string"/>
      <xsd:attribute name="Recurrence" type="xsd:string"/>
   </xsd:complexType>
   <xsd:complexType name="StandardBusinessDocument">
      <xsd:sequence>
         <xsd:element name="sh_StandardBusinessDocumentHeader" minOccurs="0"
            type="StandardBusinessDocumentHeader">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Standard Business Document Header</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="extensionElement" type="xsd:string" minOccurs="0" maxOccurs="unbounded"
         />
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="StandardBusinessDocumentHeader">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">The UN/CEFACT standard, containing
        information about the routing and processing of the business document. It also identifies
        the message set that is sent together with on SBDH and the version number of the document(s)
        contained.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="sh_HeaderVersion" type="xsd:string">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Header Version</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Version number of the SBDH
            standard used.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1.0</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_Sender" maxOccurs="unbounded" type="Partner">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Sender</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Sender of the message, party
            representing the organization which created the standard business
            document.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_Receiver" maxOccurs="unbounded" type="Partner">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Receiver</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Receiver of the message, party
            representing the organization which receives the standard business
            document.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_DocumentIdentification" type="DocumentIdentification">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Document Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_Manifest" minOccurs="0" type="Manifest">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Manifest</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sh_BusinessScope" minOccurs="0" type="BusinessScope">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sh_ Business Scope</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="AdditionalConsignmentIdentificationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Additional identification for a consignment.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: NCM20876</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="String80Type">
            <xsd:attribute name="additionalConsignmentIdentificationTypeCode" use="required"
               type="AdditionalConsignmentIdentificationTypeCode">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the type of additional consignment identification being provided.</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: CARRIER_ASSIGNED</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:AdditionalConsignmentIdentificationTypeCode</xsd:documentation>
