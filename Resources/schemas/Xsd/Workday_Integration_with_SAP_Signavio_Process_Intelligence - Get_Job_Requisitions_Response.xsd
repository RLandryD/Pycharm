</xsd:extension>
</xsd:simpleContent>
</xsd:complexType>
<xsd:complexType name="Job_Requisition_StatusObjectIDType">
<xsd:annotation>
<xsd:documentation>Contains a unique identifier for an instance of an object.</xsd:documentation>
</xsd:annotation>
<xsd:simpleContent>
<xsd:extension base="xsd:string">
<xsd:attribute name="type" type="wd:Job_Requisition_StatusReferenceEnumeration" use="required">
<xsd:annotation>
