<?xml version="1.0" encoding="UTF-8"?>
<!--
  PIPELINE STEP 3: Interface Separation iFlow
  Package  : 1_SRC_TGT_Finance
  Purpose  : Routes to the correct scenario-specific iFlow
             based on SAP_InterfaceName header set by Receiver Determination.
  Internal : ProcessDirect address /pd/InterfaceSeparation_1_SRC_TGT_Finance
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Interface_Separation_1_SRC_TGT_Finance"
             name="Interface_Separation_1_SRC_TGT_Finance">
  <process id="IfaceSep_1_SRC_TGT_Finance_process" ifl:type="IntegrationFlow">

    <startEvent id="Start_IS" name="From Receiver Determination">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/pd/InterfaceSeparation_1_SRC_TGT_Finance</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>

    <!-- ROUTER: Branch to scenario-specific iFlow -->
    <exclusiveGateway id="Router_1" name="Route by Interface Name"/>

    <sequenceFlow id="route_0" sourceRef="Router_1"
      targetRef="Call_Replicate_Cost_Centr_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Replicate Cost Centre from SAP S4HANA Public Cloud Edition to S4HANA Private Cloud' -->
    </sequenceFlow>
    <serviceTask id="Call_Replicate_Cost_Centr_1"
      name="→ Replicate Cost Centre from SAP S4HANA Public Cloud Edition to S4HANA Private Cloud" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Replicate_Cost_Centr</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_1" sourceRef="Router_1"
      targetRef="Call_Replicate_WBS_Code_f_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Replicate WBS Code from S4HANA Public Cloud Edition to S4HANA Private Cloud' -->
    </sequenceFlow>
    <serviceTask id="Call_Replicate_WBS_Code_f_1"
      name="→ Replicate WBS Code from S4HANA Public Cloud Edition to S4HANA Private Cloud" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Replicate_WBS_Code_f</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_2" sourceRef="Router_1"
      targetRef="Call_Replicate_Profit_Cen_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Replicate Profit Center from SAP S4HANA Public Cloud Edition to S4HANA Private Cloud' -->
    </sequenceFlow>
    <serviceTask id="Call_Replicate_Profit_Cen_1"
      name="→ Replicate Profit Center from SAP S4HANA Public Cloud Edition to S4HANA Private Cloud" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Replicate_Profit_Cen</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_3" sourceRef="Router_1"
      targetRef="Call_Replicate_Business_P_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Replicate Business Partner from S4HANA Private Cloud to SAP S4HANA Public Cloud Edition' -->
    </sequenceFlow>
    <serviceTask id="Call_Replicate_Business_P_1"
      name="→ Replicate Business Partner from S4HANA Private Cloud to SAP S4HANA Public Cloud Edition" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Replicate_Business_P</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_4" sourceRef="Router_1"
      targetRef="Call_Replicate_Business_P_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Replicate Business Partner Confirmation from SAP S4HANA Public Cloud Edition to S4HANA Private Cloud' -->
    </sequenceFlow>
    <serviceTask id="Call_Replicate_Business_P_1"
      name="→ Replicate Business Partner Confirmation from SAP S4HANA Public Cloud Edition to S4HANA Private Cloud" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Replicate_Business_P</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_5" sourceRef="Router_1"
      targetRef="Call_Replicate_Business_P_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Replicate Business Partner Attachment from S4HANA Private Cloud to S4HANA Public Cloud Edition' -->
    </sequenceFlow>
    <serviceTask id="Call_Replicate_Business_P_1"
      name="→ Replicate Business Partner Attachment from S4HANA Private Cloud to S4HANA Public Cloud Edition" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Replicate_Business_P</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_6" sourceRef="Router_1"
      targetRef="Call_Runnable_Monster_Bra_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Runnable Monster Branching Exc' -->
    </sequenceFlow>
    <serviceTask id="Call_Runnable_Monster_Bra_1"
      name="→ Runnable Monster Branching Exc" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Runnable_Monster_Bra</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_7" sourceRef="Router_1"
      targetRef="Call_Scale_300_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Scale_300' -->
    </sequenceFlow>
    <serviceTask id="Call_Scale_300_1"
      name="→ Scale_300" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Scale_300</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_8" sourceRef="Router_1"
      targetRef="Call_RCI093_Clear_CustomF_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'RCI093_Clear_CustomFields' -->
    </sequenceFlow>
    <serviceTask id="Call_RCI093_Clear_CustomF_1"
      name="→ RCI093_Clear_CustomFields" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/RCI093_Clear_CustomF</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_9" sourceRef="Router_1"
      targetRef="Call_RCI093_SuccessFactor_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'RCI093_SuccessFactors_to_OpenText_SuccessFactors' -->
    </sequenceFlow>
    <serviceTask id="Call_RCI093_SuccessFactor_1"
      name="→ RCI093_SuccessFactors_to_OpenText_SuccessFactors" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/RCI093_SuccessFactor</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_IS"/>
    <sequenceFlow sourceRef="Start_IS" targetRef="Router_1"/>
  </process>
</definitions>