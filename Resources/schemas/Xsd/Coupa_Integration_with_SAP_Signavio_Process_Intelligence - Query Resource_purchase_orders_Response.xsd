                    <xs:restriction base="xs:string">
                        <xs:maxLength value="255"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="file-file-name" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>file name</xs:documentation>
                </xs:annotation>
