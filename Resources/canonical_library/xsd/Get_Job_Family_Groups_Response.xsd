            <xsd:element minOccurs="0" name="Response_Group" type="wd:Job_Family_Group_Response_GroupType">
                <xsd:annotation>
                    <xsd:documentation>Contains settings to control the type and amount of data returned by the request.</xsd:documentation>
                </xsd:annotation>
            </xsd:element>
            <xsd:element minOccurs="0" name="Response_Results" type="wd:Response_ResultsType"/>
