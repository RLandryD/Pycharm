			<wsdl:input name="SendDebitNoteInput">
				<soap:body use="literal" />
			</wsdl:input>
			<wsdl:output name="SendDebitNoteOutput">
				<soap:body use="literal" />
			</wsdl:output>
		</wsdl:operation>
	</wsdl:binding>
	<wsdl:service name="eDocPeruDocumentTransmission">
		<wsdl:port binding="tns:eDocPeruDocumentTransmissionSOAP"
			name="eDocPeruDocumentTransmissionSOAP">
			<soap:address location="http://endpointaddress" />
		</wsdl:port>
	</wsdl:service>
</wsdl:definitions>
