											sistema que
											realiza la solicitud)
										</xs:documentation>
									</xs:annotation>
									<xs:simpleType>
										<xs:restriction base="xs:string">
											<xs:minLength value="1" />
											<xs:whiteSpace value="collapse" />
										</xs:restriction>
									</xs:simpleType>
								</xs:attribute>
								<xs:attribute name="tipo" use="required">
									<xs:annotation>
