         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:PartyRoleCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: BUYER</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="PartyRoleCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
