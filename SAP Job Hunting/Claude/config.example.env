# config.env — Copy this file and fill in your real values.
# This file is read by layer3/message_engine.py for email sending.

# ─────────────────────────────────────────────
# SMTP Configuration
# ─────────────────────────────────────────────

# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your_app_password   ← use an App Password, not your real password
#                                    (Google Account → Security → App passwords)

# Outlook/Hotmail example:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587

# Zoho example:
#   SMTP_HOST=smtp.zoho.com
#   SMTP_PORT=465

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# ─────────────────────────────────────────────
# Sender identity
# ─────────────────────────────────────────────
SENDER_NAME=Your Full Name
SENDER_EMAIL=your_email@gmail.com

# ─────────────────────────────────────────────
# CV file path (absolute or relative to project root)
# ─────────────────────────────────────────────
# Example: CV_PATH=/home/youruser/Documents/YourName_CV_SAP_CPI.pdf
CV_PATH=

# ─────────────────────────────────────────────
# SendGrid (optional alternative to SMTP)
# If set, layer3 will prefer SendGrid over SMTP
# ─────────────────────────────────────────────
# SENDGRID_KEY=SG.xxxxxxxxxxxxxxxxxxxx
