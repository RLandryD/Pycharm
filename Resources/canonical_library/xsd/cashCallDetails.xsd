              <xs:element name="fundAmount" type="xs:string" minOccurs="0"/>
              <xs:element name="jvFunction" type="xs:string" minOccurs="0"/>
              <xs:element name="opMonth" type="xs:string" minOccurs="0"/>
              <xs:element name="status" type="xs:string" minOccurs="0"/>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
      </xs:sequence>
    </xs:complexType>
