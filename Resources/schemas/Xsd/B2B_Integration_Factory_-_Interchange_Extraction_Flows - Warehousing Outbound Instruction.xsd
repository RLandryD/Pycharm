            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Event Identifier</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The sequence number for this event.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
