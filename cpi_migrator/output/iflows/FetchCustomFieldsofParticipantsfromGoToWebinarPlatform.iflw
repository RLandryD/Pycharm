<?xml version="1.0" encoding="UTF-8"?>
<bpmn2:definitions xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1">
    <bpmn2:collaboration id="Collaboration_1" name="Default Collaboration">
        <bpmn2:extensionElements>
            <ifl:property><key>namespaceMapping</key><value>xmlns:ns0=http://sap.com/xi/XI/SplitAndMerge</value></ifl:property>
            <ifl:property><key>allowedHeaderList</key><value></value></ifl:property>
            <ifl:property><key>httpSessionHandling</key><value>None</value></ifl:property>
            <ifl:property><key>ServerTrace</key><value>false</value></ifl:property>
            <ifl:property><key>returnExceptionToSender</key><value>false</value></ifl:property>
            <ifl:property><key>log</key><value>All events</value></ifl:property>
            <ifl:property><key>componentVersion</key><value>1.1</value></ifl:property>
            <ifl:property><key>cmdVariantUri</key><value>ctype::IFlowVariant/cname::IFlowConfiguration/version::1.1.15</value></ifl:property>
        </bpmn2:extensionElements>
        <bpmn2:participant id="Participant_Process_1" ifl:type="IntegrationProcess" name="Integration Process" processRef="Process_1">
            <bpmn2:extensionElements/>
        </bpmn2:participant>
        <bpmn2:participant id="Participant_1" ifl:type="EndpointSender" name="Sender">
            <bpmn2:extensionElements/>
        </bpmn2:participant>
        <bpmn2:messageFlow id="MessageFlow_7" name="ProcessDirect" sourceRef="Participant_1" targetRef="StartEvent_2">
            <bpmn2:extensionElements>
                <ifl:property><key>ComponentType</key><value>ProcessDirect</value></ifl:property>
                <ifl:property><key>Description</key><value></value></ifl:property>
                <ifl:property><key>address</key><value>{{EVENT_EXT_IFLOW_PATH}}</value></ifl:property>
                <ifl:property><key>ComponentNS</key><value>sap</value></ifl:property>
                <ifl:property><key>Vendor</key><value>SAP</value></ifl:property>
                <ifl:property><key>componentVersion</key><value>1.1</value></ifl:property>
                <ifl:property><key>Name</key><value>ProcessDirect</value></ifl:property>
                <ifl:property><key>TransportProtocolVersion</key><value>1.1.1</value></ifl:property>
                <ifl:property><key>ComponentSWCVName</key><value>external</value></ifl:property>
                <ifl:property><key>system</key><value>Sender</value></ifl:property>
                <ifl:property><key>TransportProtocol</key><value>Not Applicable</value></ifl:property>
                <ifl:property><key>cmdVariantUri</key><value>ctype::AdapterVariant/cname::ProcessDirect/vendor::SAP/tp::Not Applicable/mp::Not Applicable/direction::Sender/version::1.1.1</value></ifl:property>
                <ifl:property><key>MessageProtocol</key><value>Not Applicable</value></ifl:property>
                <ifl:property><key>MessageProtocolVersion</key><value>1.1.1</value></ifl:property>
                <ifl:property><key>ComponentSWCVId</key><value>1.1.1</value></ifl:property>
                <ifl:property><key>direction</key><value>Sender</value></ifl:property>
            </bpmn2:extensionElements>
        </bpmn2:messageFlow>
    </bpmn2:collaboration>
    <bpmn2:process id="Process_1" name="Integration Process">
        <bpmn2:extensionElements>
            <ifl:property><key>transactionTimeout</key><value>30</value></ifl:property>
            <ifl:property><key>componentVersion</key><value>1.2</value></ifl:property>
            <ifl:property><key>cmdVariantUri</key><value>ctype::FlowElementVariant/cname::IntegrationProcess/version::1.2.1</value></ifl:property>
            <ifl:property><key>transactionalHandling</key><value>Not Required</value></ifl:property>
        </bpmn2:extensionElements>
        <bpmn2:callActivity id="CallActivity_545" name="Filter Root Node">
            <bpmn2:extensionElements>
                <ifl:property><key>xpathType</key><value>Nodelist</value></ifl:property>
                <ifl:property><key>wrapContent</key><value>/ns0:Messages/ns0:Message1/root</value></ifl:property>
                <ifl:property><key>componentVersion</key><value>1.0</value></ifl:property>
                <ifl:property><key>activityType</key><value>Filter</value></ifl:property>
                <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::Filter/version::1.0.4</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_13</bpmn2:incoming>
            <bpmn2:outgoing>SequenceFlow_546</bpmn2:outgoing>
        </bpmn2:callActivity>
        <bpmn2:endEvent id="EndEvent_2" name="End">
            <bpmn2:extensionElements>
                <ifl:property><key>componentVersion</key><value>1.1</value></ifl:property>
                <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::MessageEndEvent/version::1.1.0</value></ifl:property>
                <ifl:property><key>activityType</key><value>EndEvent</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_16</bpmn2:incoming>
            <bpmn2:messageEventDefinition/>
        </bpmn2:endEvent>
        <bpmn2:callActivity id="CallActivity_12" name="Map Participants">
            <bpmn2:extensionElements>
                <ifl:property><key>mappinguri</key><value>dir://mmap/src/main/resources/mapping/Attendee_Extension_Mapping.mmap</value></ifl:property>
                <ifl:property><key>mappingname</key><value>Attendee_Extension_Mapping</value></ifl:property>
                <ifl:property><key>mappingType</key><value>MessageMapping</value></ifl:property>
                <ifl:property><key>mappingpath</key><value>src/main/resources/mapping/Attendee_Extension_Mapping</value></ifl:property>
                <ifl:property><key>componentVersion</key><value>1.0</value></ifl:property>
                <ifl:property><key>activityType</key><value>Mapping</value></ifl:property>
                <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::MessageMapping/version::1.0.1</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_3</bpmn2:incoming>
            <bpmn2:outgoing>SequenceFlow_13</bpmn2:outgoing>
        </bpmn2:callActivity>
        <bpmn2:callActivity id="CallActivity_15" name="XML to JSON Converter">
            <bpmn2:extensionElements>
                <ifl:property><key>xmlJsonUseStreaming</key><value>true</value></ifl:property>
                <ifl:property><key>xmlJsonSuppressRootElement</key><value>false</value></ifl:property>
                <ifl:property><key>xmlJsonPathTable</key><value>&lt;row&gt;&lt;cell&gt;root/attendees/interactions&lt;/cell&gt;&lt;cell&gt;&lt;/cell&gt;&lt;/row&gt;&lt;row&gt;&lt;cell&gt;root/attendees/questionanswers&lt;/cell&gt;&lt;cell&gt;&lt;/cell&gt;&lt;/row&gt;&lt;row&gt;&lt;cell&gt;root/attendees&lt;/cell&gt;&lt;cell&gt;&lt;/cell&gt;&lt;/row&gt;&lt;row&gt;&lt;cell&gt;root/attendees/survey&lt;/cell&gt;&lt;cell&gt;&lt;/cell&gt;&lt;/row&gt;&lt;row&gt;&lt;cell&gt;root/attendees/poll&lt;/cell&gt;&lt;cell&gt;&lt;/cell&gt;&lt;/row&gt;&lt;row&gt;&lt;cell&gt;root/attendees/poll/pollanswer&lt;/cell&gt;&lt;cell&gt;&lt;/cell&gt;&lt;/row&gt;&lt;row&gt;&lt;cell&gt;root/attendees/survey/response&lt;/cell&gt;&lt;cell&gt;&lt;/cell&gt;&lt;/row&gt;&lt;row&gt;&lt;cell&gt;root/attendees/survey/response/surveyanswername&lt;/cell&gt;&lt;cell&gt;&lt;/cell&gt;&lt;/row&gt;</value></ifl:property>
                <ifl:property><key>jsonOutputEncoding</key><value></value></ifl:property>
                <ifl:property><key>jsonNamespaceMapping</key><value></value></ifl:property>
                <ifl:property><key>componentVersion</key><value>1.0</value></ifl:property>
                <ifl:property><key>xmlJsonConvertAllElements</key><value>specific</value></ifl:property>
                <ifl:property><key>activityType</key><value>XmlToJsonConverter</value></ifl:property>
                <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::XmlToJsonConverter/version::1.0.6</value></ifl:property>
                <ifl:property><key>useNamespaces</key><value>true</value></ifl:property>
                <ifl:property><key>jsonNamespaceSeparator</key><value>:</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SequenceFlow_546</bpmn2:incoming>
            <bpmn2:outgoing>SequenceFlow_16</bpmn2:outgoing>
        </bpmn2:callActivity>
        <bpmn2:startEvent id="StartEvent_2" name="Start">
            <bpmn2:extensionElements>
                <ifl:property><key>componentVersion</key><value>1.0</value></ifl:property>
                <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::MessageStartEvent/version::1.0</value></ifl:property>
                <ifl:property><key>activityType</key><value>StartEvent</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:outgoing>SequenceFlow_3</bpmn2:outgoing>
            <bpmn2:messageEventDefinition/>
        </bpmn2:startEvent>
        <bpmn2:sequenceFlow id="SequenceFlow_546" sourceRef="CallActivity_545" targetRef="CallActivity_15"/>
        <bpmn2:sequenceFlow id="SequenceFlow_13" sourceRef="CallActivity_12" targetRef="CallActivity_545"/>
        <bpmn2:sequenceFlow id="SequenceFlow_16" sourceRef="CallActivity_15" targetRef="EndEvent_2"/>
        <bpmn2:sequenceFlow id="SequenceFlow_3" sourceRef="StartEvent_2" targetRef="CallActivity_12"/>
    </bpmn2:process>
    <bpmndi:BPMNDiagram id="BPMNDiagram_1" name="Default Collaboration Diagram">
        <bpmndi:BPMNPlane bpmnElement="Collaboration_1" id="BPMNPlane_1">
            <bpmndi:BPMNShape bpmnElement="Participant_Process_1" id="BPMNShape_Participant_Process_1">
                <dc:Bounds height="400.0" width="1200.0" x="240.0" y="80.0"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="CallActivity_545" id="BPMNShape_CallActivity_545"><dc:Bounds height="60.0" width="100.0" x="680.0" y="130.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="EndEvent_2" id="BPMNShape_EndEvent_2"><dc:Bounds height="32.0" width="32.0" x="1074.0" y="144.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="CallActivity_12" id="BPMNShape_CallActivity_12"><dc:Bounds height="60.0" width="100.0" x="500.0" y="130.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="CallActivity_15" id="BPMNShape_CallActivity_15"><dc:Bounds height="60.0" width="100.0" x="860.0" y="130.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="StartEvent_2" id="BPMNShape_StartEvent_2"><dc:Bounds height="32.0" width="32.0" x="354.0" y="144.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="Participant_1" id="BPMNShape_Participant_1"><dc:Bounds height="140.0" width="100.0" x="80.0" y="110.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_546" id="BPMNEdge_SequenceFlow_546" sourceElement="BPMNShape_CallActivity_545" targetElement="BPMNShape_CallActivity_15"><di:waypoint x="780.0" xsi:type="dc:Point" y="160.0"/><di:waypoint x="860.0" xsi:type="dc:Point" y="160.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_13" id="BPMNEdge_SequenceFlow_13" sourceElement="BPMNShape_CallActivity_12" targetElement="BPMNShape_CallActivity_545"><di:waypoint x="600.0" xsi:type="dc:Point" y="160.0"/><di:waypoint x="680.0" xsi:type="dc:Point" y="160.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_16" id="BPMNEdge_SequenceFlow_16" sourceElement="BPMNShape_CallActivity_15" targetElement="BPMNShape_EndEvent_2"><di:waypoint x="960.0" xsi:type="dc:Point" y="160.0"/><di:waypoint x="1074.0" xsi:type="dc:Point" y="160.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_3" id="BPMNEdge_SequenceFlow_3" sourceElement="BPMNShape_StartEvent_2" targetElement="BPMNShape_CallActivity_12"><di:waypoint x="386.0" xsi:type="dc:Point" y="160.0"/><di:waypoint x="500.0" xsi:type="dc:Point" y="160.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="MessageFlow_7" id="BPMNEdge_MessageFlow_7" sourceElement="BPMNShape_Participant_1" targetElement="BPMNShape_StartEvent_2"><di:waypoint x="180.0" xsi:type="dc:Point" y="180.0"/><di:waypoint x="354.0" xsi:type="dc:Point" y="160.0"/></bpmndi:BPMNEdge>
        </bpmndi:BPMNPlane>
    </bpmndi:BPMNDiagram>
</bpmn2:definitions>
