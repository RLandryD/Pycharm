    <Property Name="ProjectID" Type="Edm.String" Nullable="false" MaxLength="40" sap:unicode="false" sap:label="Project ID" sap:heading="Customer Project ID" sap:quickinfo="Commercial Project ID" sap:updatable="false" sap:sortable="false">
     <Documentation>
      <Summary>Identifies a customer or internal project.</Summary>
      <LongDescription/>
     </Documentation>
    </Property>
    <Property Name="WorkPackageID" Type="Edm.String" Nullable="false" MaxLength="50" sap:unicode="false" sap:label="Work Package ID" sap:heading="Plan Item" sap:quickinfo="Plan Item" sap:updatable="false" sap:sortable="false"/>
    <Property Name="WorkPackageName" Type="Edm.String" Nullable="false" MaxLength="60" sap:unicode="false" sap:label="Work Package Name" sap:heading="Plan Item Description" sap:quickinfo="Plan Item Description" sap:updatable="false" sap:sortable="false"/>
    <Property Name="Workitem" Type="Edm.String" Nullable="false" MaxLength="10" sap:unicode="false" sap:label="Work Item ID" sap:updatable="false" sap:sortable="false">
     <Documentation>
      <Summary>Defines a specific activity performed in a work package.</Summary>
      <LongDescription>You assign work items to a work package from a predefined list of work items or you create user-defined ones in a work package. Thereafter, you assign them to resources to plan activities for the team.You define work items in the configuration activity Define Work Items.</LongDescription>
     </Documentation>
    </Property>
    <Property Name="Workitemname" Type="Edm.String" MaxLength="40" sap:unicode="false" sap:label="Work Item Desc." sap:heading="Work Item Name" sap:quickinfo="Work Item Name" sap:updatable="false" sap:sortable="false"/>
   </EntityType>
   <EntityType Name="Demand" sap:label="Demands" sap:content-version="1">
    <Key>
