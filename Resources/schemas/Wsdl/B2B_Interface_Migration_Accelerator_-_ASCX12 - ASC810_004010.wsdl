"L_SAC"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acad1ff311e18bb90026b9aa16ff</xsd:appinfo></xsd:annotation><xsd:complexType><xsd:sequence><xsd:element minOccurs="0" name="S_SAC"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3aca11ff311e1a1e90026b9aa16ff</xsd:appinfo><xsd:documentation>Service, Promotion, Allowance, or Charge Information. To request or identify a service, promotion, allowance, or charge; to specify the amount or percentage for the service, promotion, allowance, or charge</xsd:documentation></xsd:annotation><xsd:complexType><xsd:sequence><xsd:element name="D_248"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ac911ff311e1822f0026b9aa16ff</xsd:appinfo><xsd:documentation>SAC01| Allowance or Charge Indicator. NOTES: If SAC01 is "A" or "C", then at least one of SAC05, SAC07, or SAC08 is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="1"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_1300"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ac921ff311e1abcc0026b9aa16ff</xsd:appinfo><xsd:documentation>SAC02| Service, Promotion, Allowance, or Charge Code. NOTES: R0203 - At least one of SAC02 or SAC03 is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="4"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_559"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ac931ff311e183680026b9aa16ff</xsd:appinfo><xsd:documentation>SAC03| Agency Qualifier Code. NOTES: P0304 - If either SAC03 or SAC04 is present, then the other is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_1301"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ac941ff311e18b570026b9aa16ff</xsd:appinfo><xsd:documentation>SAC04| Agency Service, Promotion, Allowance, or Charge Code. NOTES: SAC04 may be used to uniquely identify the service, promotion, allowance, or charge. In addition, it may be used in conjunction to further the code in SAC02.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="10"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_610"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ac951ff311e1b5da0026b9aa16ff</xsd:appinfo><xsd:documentation>SAC05| Amount. NOTES: SAC05 is the total amount for the service, promotion, allowance, or charge. If SAC05 is present with SAC07 or SAC08, then SAC05 takes precedence.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="15"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_378"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ac961ff311e1cf7d0026b9aa16ff</xsd:appinfo><xsd:documentation>SAC06| Allowance/Charge Percent Qualifier. NOTES: P0607 - If either SAC06 or SAC07 is present, then the other is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="1"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_332"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ac971ff311e182d60026b9aa16ff</xsd:appinfo><xsd:documentation>SAC07| Percent</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="6"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_118"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ac981ff311e1beca0026b9aa16ff</xsd:appinfo><xsd:documentation>SAC08| Rate. NOTES: SAC08 is the allowance or charge rate per unit.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="9"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_355"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ac991ff311e1b9f60026b9aa16ff</xsd:appinfo><xsd:documentation>SAC09| Unit or Basis for Measurement Code. NOTES: P0910 - If either SAC09 or SAC10 is present, then the other is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_380"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ac9a1ff311e1c30b0026b9aa16ff</xsd:appinfo><xsd:documentation>SAC10| Quantity. NOTES: SAC10 and SAC11 is the quantity basis when the allowance or charge quantity is different from the purchase order or invoice quantity. SAC10 and SAC11 used together indicate a quantity range, which could be a dollar amount, ...</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="15"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_380_2"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ac9b1ff311e1c6850026b9aa16ff</xsd:appinfo><xsd:documentation>SAC11| Quantity. NOTES: C1110 - If SAC11 is present, then SAC10 is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="15"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_331"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ac9c1ff311e1a88d0026b9aa16ff</xsd:appinfo><xsd:documentation>SAC12| Allowance or Charge Method of Handling Code</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_127"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ac9d1ff311e1943b0026b9aa16ff</xsd:appinfo><xsd:documentation>SAC13| Reference Identification. NOTES: L130204 - If SAC13 is present, then at least one of SAC02 or SAC04 is required. SAC13 is used in conjunction with SAC02 or SAC04 to provide a specific reference number as identified by the code used.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="30"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_770"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ac9e1ff311e1c0cd0026b9aa16ff</xsd:appinfo><xsd:documentation>SAC14| Option Number. NOTES: C1413 - If SAC14 is present, then SAC13 is required. SAC14 is used in conjunction with SAC13 to identify an option when there is more than one option of the promotion.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="20"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_352"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ac9f1ff311e1ae230026b9aa16ff</xsd:appinfo><xsd:documentation>SAC15| Description</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="80"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_819"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3aca01ff311e1c5920026b9aa16ff</xsd:appinfo><xsd:documentation>SAC16| Language Code. NOTES: C1615 - If SAC16 is present, then SAC15 is required. SAC16 is used to identify the language being used in SAC15.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="2"/><xsd:maxLength value="3"/></xsd:restriction></xsd:simpleType></xsd:element></xsd:sequence></xsd:complexType></xsd:element><xsd:element maxOccurs="10" minOccurs="0" name="S_TXI"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acac1ff311e190b70026b9aa16ff</xsd:appinfo><xsd:documentation>Tax Information. To specify tax information</xsd:documentation></xsd:annotation><xsd:complexType><xsd:sequence><xsd:element name="D_963"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3aca21ff311e19c340026b9aa16ff</xsd:appinfo><xsd:documentation>TXI01| Tax Type Code. NOTES: R020306 - At least one of TXI02, TXI03 or TXI06 is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_782"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3aca31ff311e1a98a0026b9aa16ff</xsd:appinfo><xsd:documentation>TXI02| Monetary Amount. NOTES: TXI02 is the monetary amount of the tax.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="18"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_954"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3aca41ff311e1bb9c0026b9aa16ff</xsd:appinfo><xsd:documentation>TXI03| Percent. NOTES: TXI03 is the tax percent expressed as a decimal.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="10"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_955"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3aca51ff311e1c5f40026b9aa16ff</xsd:appinfo><xsd:documentation>TXI04| Tax Jurisdiction Code Qualifier. NOTES: P0405 - If either TXI04 or TXI05 is present, then the other is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_956"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3aca61ff311e19f4a0026b9aa16ff</xsd:appinfo><xsd:documentation>TXI05| Tax Jurisdiction Code</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="10"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_441"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3aca71ff311e1bceb0026b9aa16ff</xsd:appinfo><xsd:documentation>TXI06| Tax Exempt Code</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="1"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_662"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3aca81ff311e1c6000026b9aa16ff</xsd:appinfo><xsd:documentation>TXI07| Relationship Code. NOTES: TXI07 is a code indicating the relationship of the price or amount to the associated segment.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="1"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_828"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3aca91ff311e1a8120026b9aa16ff</xsd:appinfo><xsd:documentation>TXI08| Dollar Basis For Percent. NOTES: C0803 - If TXI08 is present, then TXI03 is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="9"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_325"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acaa1ff311e19e7b0026b9aa16ff</x