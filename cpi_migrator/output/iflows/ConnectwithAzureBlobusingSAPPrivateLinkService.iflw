            <bpmndi:BPMNShape bpmnElement="CallActivity_4" id="BPMNShape_CallActivity_4"><dc:Bounds height="60.0" width="100.0" x="940.0" y="136.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="EndEvent_2" id="BPMNShape_EndEvent_2"><dc:Bounds height="32.0" width="32.0" x="1220.0" y="150.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_3" id="BPMNEdge_SequenceFlow_3" sourceElement="BPMNShape_StartEvent_2" targetElement="BPMNShape_CallActivity_1"><di:waypoint x="322.0" xsi:type="dc:Point" y="166.0"/><di:waypoint x="400.0" xsi:type="dc:Point" y="166.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_4" id="BPMNEdge_SequenceFlow_4" sourceElement="BPMNShape_CallActivity_1" targetElement="BPMNShape_CallActivity_2"><di:waypoint x="500.0" xsi:type="dc:Point" y="166.0"/><di:waypoint x="580.0" xsi:type="dc:Point" y="166.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_5" id="BPMNEdge_SequenceFlow_5" sourceElement="BPMNShape_CallActivity_2" targetElement="BPMNShape_CallActivity_3"><di:waypoint x="680.0" xsi:type="dc:Point" y="166.0"/><di:waypoint x="760.0" xsi:type="dc:Point" y="166.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_6" id="BPMNEdge_SequenceFlow_6" sourceElement="BPMNShape_CallActivity_3" targetElement="BPMNShape_CallActivity_4"><di:waypoint x="860.0" xsi:type="dc:Point" y="166.0"/><di:waypoint x="940.0" xsi:type="dc:Point" y="166.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="SequenceFlow_7" id="BPMNEdge_SequenceFlow_7" sourceElement="BPMNShape_CallActivity_4" targetElement="BPMNShape_EndEvent_2"><di:waypoint x="1040.0" xsi:type="dc:Point" y="166.0"/><di:waypoint x="1220.0" xsi:type="dc:Point" y="166.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNShape bpmnElement="Participant_Recv_1" id="BPMNShape_Participant_Recv_1"><dc:Bounds height="60.0" width="100.0" x="400.0" y="330.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNEdge bpmnElement="MessageFlow_R1" id="BPMNEdge_MessageFlow_R1" sourceElement="BPMNShape_CallActivity_1" targetElement="BPMNShape_Participant_Recv_1"><di:waypoint x="450.0" xsi:type="dc:Point" y="196.0"/><di:waypoint x="450.0" xsi:type="dc:Point" y="330.0"/></bpmndi:BPMNEdge>
            <bpmndi:BPMNShape bpmnElement="Participant_Recv_2" id="BPMNShape_Participant_Recv_2"><dc:Bounds height="60.0" width="100.0" x="940.0" y="330.0"/></bpmndi:BPMNShape>
            <bpmndi:BPMNEdge bpmnElement="MessageFlow_R2" id="BPMNEdge_MessageFlow_R2" sourceElement="BPMNShape_CallActivity_4" targetElement="BPMNShape_Participant_Recv_2"><di:waypoint x="990.0" xsi:type="dc:Point" y="196.0"/><di:waypoint x="990.0" xsi:type="dc:Point" y="330.0"/></bpmndi:BPMNEdge>
