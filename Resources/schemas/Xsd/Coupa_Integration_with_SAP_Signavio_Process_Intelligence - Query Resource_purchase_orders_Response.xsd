                    <xs:restriction base="xs:string">
                        <xs:maxLength value="255"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="file-file-size" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>file size</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:string">
                        <xs:maxLength value="255"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="file-url" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>URL to attached file</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="id" type="xs:integer" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Coupa unique identifier</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="intent" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>intent</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:string">
                        <xs:maxLength value="40"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="linked-to" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>link to specific feature</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:string">
                        <xs:maxLength value="255"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="text" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>text</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="type" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>type</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:string">
                        <xs:maxLength value="255"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="updated-at" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Automatically created by Coupa in the format YYYY-MM-DDTHH:MM:SS+HH:MMZ</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="updated-by" type="UserSimple1" minOccurs="0"/>
            <xs:element name="url" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>url</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:string">
                        <xs:maxLength value="255"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
