<xsd:annotation>
<xsd:documentation>The date the project ended.</xsd:documentation>
<xsd:appinfo>
<wd:Validation>
<wd:Validation_Message>The End Date must be on or after the Start Date</wd:Validation_Message>
</wd:Validation>
</xsd:appinfo>
</xsd:annotation>
</xsd:element>
<xsd:element maxOccurs="1" minOccurs="0" name="Project_Leader" type="xsd:string">
