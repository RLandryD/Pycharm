		<wsdl:operation name="DebitNote">
			<wsdl:input message="tns:SendDebitNoteRequest" name="SendDebitNoteInput"></wsdl:input>
			<wsdl:output message="tns:SendDocumentResponse" name="SendDebitNoteOutput"></wsdl:output>
		</wsdl:operation>
	</wsdl:portType>
	<wsdl:binding name="eDocPeruDocumentTransmissionSOAP"
		type="tns:eDocPeruDocumentTransmission">
		<soap:binding style="document" transport="http://schemas.xmlsoap.org/soap/http" />
		<wsdl:operation name="Invoice">
			<soap:operation soapAction="http://www.sap.com/eDocument/Peru/DocumentTransmission/v1.0/Invoice" />
			<wsdl:input name="SendInvoiceInput">
				<soap:body use="literal" />
			</wsdl:input>
			<wsdl:output name="SendInvoiceOutput">
				<soap:body use="literal" />
			</wsdl:output>
		</wsdl:operation>
		<wsdl:operation name="CreditNote">
			<soap:operation soapAction="http://www.sap.com/eDocument/Peru/DocumentTransmission/v1.0/CreditNote" />
			<wsdl:input name="SendCreditNoteInput">
