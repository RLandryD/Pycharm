               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: DHTO43578842</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="legalRegistrationType" type="LegalRegistrationCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Legal Registration Type</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the type of legal register.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="legalRegistrationAdditionalInformation" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Legal Registration Additional Information</xsd:documentation>
