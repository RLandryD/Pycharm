   <EntityType Name="A_ServiceConfirmationItemTextType" sap:label="Text of Service Confirmation Item" sap:content-version="1">
    <Key>
     <PropertyRef Name="ServiceConfirmation"/>
     <PropertyRef Name="ServiceConfirmationItem"/>
     <PropertyRef Name="Language"/>
     <PropertyRef Name="LongTextID"/>
    </Key>
    <Property Name="ServiceConfirmation" Type="Edm.String" Nullable="false" MaxLength="10" sap:display-format="UpperCase" sap:label="ID" sap:quickinfo="Transaction ID">
     <Documentation>
      <Summary>Number which identifies the transaction document. It is unique for the respective business transaction category.</Summary>
      <LongDescription/>
     </Documentation>
    </Property>
    <Property Name="ServiceConfirmationItem" Type="Edm.String" Nullable="false" MaxLength="6" sap:display-format="NonNegative" sap:label="Item Number in Doc." sap:heading="Item Number in Document" sap:quickinfo="Shortened Item Number in Document"/>
    <Property Name="Language" Type="Edm.String" Nullable="false" MaxLength="2" sap:label="Language Key" sap:heading="Language">
     <Documentation>
      <Summary>The language key indicates</Summary>
      <LongDescription>- the language in which texts are displayed,- the language in which you enter texts,- the language in which the system prints texts.</LongDescription>
     </Documentation>
    </Property>
    <Property Name="LongTextID" Type="Edm.String" Nullable="false" MaxLength="4" sap:display-format="UpperCase" sap:label="Text ID" sap:heading="ID">
     <Documentation>
      <Summary>The text ID defines the various types of texts related to a text object. For example, the object "TEXT" (standard texts) can have the following text IDs:</Summary>
      <LongDescription>ST for user-specific standard texts (individual texts)SYST for cross-application system textsvarious IDs for specific application departments. You must have the appropriate access authorization in order to access these texts.</LongDescription>
     </Documentation>
    </Property>
    <Property Name="LongText" Type="Edm.String" sap:label="String" sap:sortable="false" sap:filterable="false"/>
   </EntityType>
