         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:ApplicationResponseStatusEnumeration</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="ERROR">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Error</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An error
