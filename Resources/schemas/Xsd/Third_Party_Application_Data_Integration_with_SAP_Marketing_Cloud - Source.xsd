<xs:schema attributeFormDefault="unqualified" elementFormDefault="qualified" xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <xs:element name="ContactInteractions">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="ContactInteraction">
          <xs:complexType>
            <xs:sequence>
              <xs:element type="xs:string" name="ContactID"/>
              <xs:element name="InteractionTags">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="InteractionTag" maxOccurs="unbounded" minOccurs="0">
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element type="xs:string" name="TagOrigin"/>
                          <xs:element type="xs:string" name="ContactID"/>
                          <xs:element type="xs:string" name="InteractionType"/>
                          <xs:element type="xs:string" name="ContactOrigin"/>
                          <xs:element type="xs:string" name="TagType"/>
                          <xs:element type="xs:dateTime" name="InteractionTimeStampUTC"/>
                          <xs:element type="xs:string" name="CommunicationMedium"/>
                          <xs:element type="xs:string" name="TagName"/>
                        </xs:sequence>
                      </xs:complexType>
                    </xs:element>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
              <xs:element name="InteractionInterests">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="InteractionInterest" maxOccurs="unbounded" minOccurs="0">
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element type="xs:string" name="ContactID"/>
                          <xs:element type="xs:string" name="ItemOfInterest"/>
                          <xs:element type="xs:string" name="InteractionType"/>
                          <xs:element type="xs:string" name="ContactOrigin"/>
                          <xs:element type="xs:dateTime" name="InteractionTimeStampUTC"/>
                          <xs:element type="xs:string" name="CommunicationMedium"/>
                        </xs:sequence>
                      </xs:complexType>
                    </xs:element>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
              <xs:element type="xs:string" name="InteractionType"/>
              <xs:element type="xs:string" name="ContactOrigin"/>
              <xs:element type="xs:dateTime" name="InteractionTimeStampUTC"/>
              <xs:element type="xs:string" name="CommunicationMedium"/>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
</xs:schema>