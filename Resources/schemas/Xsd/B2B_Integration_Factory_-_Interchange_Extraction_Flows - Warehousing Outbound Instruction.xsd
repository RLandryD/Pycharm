               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 70</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="currentHolderRegistration" minOccurs="0" type="IdentifierType">
