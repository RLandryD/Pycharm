   </xsd:complexType>
   <xsd:complexType name="AdditionalTradeItemIdentificationTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the type of additional trade item identification being provided.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:AdditionalTradeItemIdentificationTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: BUYER_ASSIGNED</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="AdditionalTradeItemIdentificationTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="AddressType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">The location at which a particular organization or person may be found or reached.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="city" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">City</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Text specifying the name of the city.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Brussels</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="cityCode" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">City Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifier for a city, expressed as a short code rather than the full name.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: BRU</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="countryCode" minOccurs="0" type="CountryCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Country Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the country for the address.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="countyCode" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">County Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A code that identifies a county. A county is a territorial division in some countries, forming the chief unit of local administration. In the US, a county is a political and administrative division of a state.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: WA</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="crossStreet" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Cross Street</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A street intersecting a main street (usually at right angles) and continuing on both sides of it.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Rose Alley</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="currencyOfPartyCode" minOccurs="0" type="CurrencyCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Currency Of Party Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the currency of an addressed party.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="languageOfThePartyCode" minOccurs="0" type="LanguageCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Language Of The Party Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the language of an addressed party.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="name" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Name</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The name of the party expressed in text.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Chocolate Masters</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="pOBoxNumber" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">P O Box Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The number that identifies a PO box. A PO box is a box in a post office or other postal service location assigned to an organization where postal items may be kept.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 572</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="postalCode" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Postal Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Text specifying the postal code for an address.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1050</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="provinceCode" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Province Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Text specifying a province in abbreviated format.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: SK</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="state" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">State</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">One of the constituent units of a nation having a federal government.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Delaware</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="streetAddressOne" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Street Address One</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The first free form line of an address, This first part is printed on paper as the first line below the name. For example, the name of the street and the number in the street or the name of a building.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Avenue Louise 326</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="streetAddressTwo" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Street Address Two</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The second free form line of an address, This second part is printed on paper as the second line below the name. The second free form line complements the first free form line to locate the party e.g. floor number, name of a building, suite number.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Newton Suite 420</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="streetAddressThree" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Street Address Three</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The third free form line of an address. This third part is printed on paper as the third line below the name. The third free form line complements the first and second free form lines where necessary.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Floor 5</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="geographicalCoordinates" minOccurs="0"
            type="GeographicalCoordinatesType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Geographical Coordinates</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Geographical coordinates for the address.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="AllowanceChargeTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a type of allowance or charge. Allowed code values are specified in GS1 Code List AllowanceChargeTypeCode.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:AllowanceChargeTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: ADR</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="AllowanceChargeTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="AmountRangeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Provides the difference or interval between the minimum and maximum value amount including the associated currency.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="maximumAmount" minOccurs="0" type="AmountType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Maximum Amount</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Defines the upper limit required to qualify for the amount.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="minimumAmount" minOccurs="0" type="AmountType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Minimum Amount</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Defines the lower limit required to qualify for the amount.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1200</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="AmountType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">How much there is or how many there are of something that you can quantify.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="xsd:float">
            <xsd:attribute name="currencyCode" use="required" type="CurrencyCode">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the currency of the amount.</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: The ISO 4217 code list can be acquired from the following website: www.iso.org</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: EUR</xsd:documentation>
               </xsd:annotation>
            </xsd:attribute>
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2008</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="BarCodeTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a bar code type. Allowed code values are specified in GS1 Code List BarCodeTypeCode.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: EAN_13</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:BarCodeTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="BarCodeTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="CodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Generic code data type not linked to a specific code list. Besides the code value the code data type allows to specify additional information such as the responsible code list agency and the code list identification.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="String80Type">
            <xsd:attribute name="codeDescription">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">A description for the code value provided.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="80"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
            <xsd:attribute name="codeListAgencyCode">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">A code representing the agency which manages the code list for example 5 for ISO.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="80"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
            <xsd:attribute name="codeListAgencyCodeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">The snapshot of the Code List Agency code list at a certain point in time.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
            <xsd:attribute name="codeListAgencyName">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">A name of the agency which manages the code list for example ISO.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="80"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
            <xsd:attribute name="codeListName">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">The name of the code list which provides the code value.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="80"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
            <xsd:attribute name="codeListURI" type="xsd:string">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">A string that refers to the location of the code list which provides the code value.</xsd:documentation>
               </xsd:annotation>
            </xsd:attribute>
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="ColourCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">A code depicting the colour of an object according to a specific code list. The applied code list is specified as additional information together with the colour code.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="String80Type">
            <xsd:attribute name="colourCodeListCode" use="required" type="ColourCodeListCode">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a colour code list. Allowed code values are specified in GS1 Code List ColourCodeListCode.</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:ColourCodeListCode</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1</xsd:documentation>
               </xsd:annotation>
            </xsd:attribute>
            <xsd:attribute name="colourCodeListDescription">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">A description of the colour code list used to populate the colour code, for example National Retail Federation – Standard Colour &amp; Size Codes.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="80"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">The version of the applied colour code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
            <xsd:attribute name="colourCodeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">The version of the ColourCodeListCode code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="ColourType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information specifying a colour in text and / or coded format.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="colourCode" minOccurs="0" type="ColourCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Colour Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A code depicting the colour of an object according to a specified list of code lists. Each industry needs to determine which code agency is will use.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="colourDescription" minOccurs="0" maxOccurs="unbounded"
            type="Description80Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Colour Description</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A description of a colour of an object.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="CommunicationChannelCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a communication channel. Allowed code values are specified in GS1 Code List CommunicationChannelCode.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: EMAIL</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:CommunicationChannelCode</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="CommunicationChannelCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="CommunicationChannelType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">The channel or manner in which a communication can be made, such as telephone or email.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="communicationChannelCode" type="CommunicationChannelCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Communication Channel Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the type of communication channel, for example TELEPHONE.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="communicationValue">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Communication Value</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Text identifying the endpoint for the communication channel, for example a telephone number or an e-mail address.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: john.brown@ultimatetrucks.com</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="communicationChannelName" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Communication Channel Name</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The name of a specific communication channel for example Facebook, Twitter, etc.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: #ChocolateMaster</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="ConsignmentIdentificationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information used to identify a consignment.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="ginc" type="GINCType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Ginc</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="additionalConsignmentIdentification" minOccurs="0" maxOccurs="unbounded"
            type="AdditionalConsignmentIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Additional Consignment Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Additional identification key used to identify a consignment.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="ContactType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information on an individual or department acting as point of contact for an organization.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="contactTypeCode" minOccurs="0" type="ContactTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Contact Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the function or role of a contact.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="personName" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Person Name</xsd:documentation>
