					<xsd:element name="Attachment" type="tns:AttachmentInfoType"></xsd:element>
				</xsd:sequence>
			</xsd:complexType>
			
			<xsd:simpleType name="emailAddressType">
				<xsd:restriction base="xsd:string">
					<xsd:pattern value="[^@]+@[^\.]+\..+" />
				</xsd:restriction>
			</xsd:simpleType>

