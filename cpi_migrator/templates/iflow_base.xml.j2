<?xml version="1.0" encoding="UTF-8"?>
<!--
  Generated by SAP CPI Migration Scaffolder
  ──────────────────────────────────────────
  Source interface       : {{ interface.name }}
  Namespace              : {{ interface.namespace }}
  Original sender        : {{ interface.sender_system }} ({{ interface.sender_adapter }})
  Original receiver      : {{ interface.receiver_system }} ({{ interface.receiver_adapter }})
{% if target_label %}
  Destination target     : {{ target_label }}
  CPI sender adapter     : {{ effective_sender_adapter }}
  CPI receiver adapter   : {{ effective_receiver_adapter }}
{% endif %}
  Complexity             : {{ complexity }} (score: {{ score }})
  Effort estimate        : {{ effort_days }} day(s)
  Pattern                : {{ pattern }}
{% if compatibility_warnings %}
  Compatibility warnings :
{% for w in compatibility_warnings %}    ⚠ {{ w }}
{% endfor %}{% endif %}
{% if hub_matches %}
  Pre-built Hub content  :
{% for m in hub_matches %}    • [{{ m.artifact_type }}] {{ m.title }}  → {{ m.url }}
{% endfor %}{% endif %}
{% if notes %}
  Migration notes        :
{% for note in notes %}    - {{ note }}
{% endfor %}{% endif %}
-->
<definitions
  xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  id="{{ iflow_id }}"
  name="{{ interface.name | truncate(100, True, '') }}"
  targetNamespace="http://www.sap.com/ifl/{{ iflow_id }}">

  <process id="{{ iflow_id }}_process" ifl:type="IntegrationFlow">

    <!-- ═══════════════════════════════════════
         START EVENT — Sender: {{ interface.sender_system }}
         Original adapter : {{ interface.sender_adapter }}
         CPI adapter      : {{ effective_sender_adapter }}
    ═══════════════════════════════════════ -->
    <startEvent id="StartEvent_1" name="Start">
      <extensionElements>
        <ifl:property><ifl:key>componentVersion</ifl:key><ifl:value>1.0.0</ifl:value></ifl:property>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>{{ effective_sender_adapter }}</ifl:value></ifl:property>
      </extensionElements>
    </startEvent>

    <!-- ═══════════════════════════════════════
         SENDER CHANNEL — {{ effective_sender_adapter }}
         TODO: Configure address, credentials, adapter-specific parameters
    ═══════════════════════════════════════ -->

{% if interface.mapping_program %}
    <!-- ═══════════════════════════════════════
         MESSAGE MAPPING
         Original : {{ interface.mapping_program }}
         TODO: Re-implement in CPI Message Mapping editor
    ═══════════════════════════════════════ -->
    <serviceTask
      id="MessageMapping_1"
      name="{{ interface.mapping_program | truncate(60, True, '…') }}"
      ifl:type="MessageMapping">
      <extensionElements>
        <ifl:property>
          <ifl:key>mappingUri</ifl:key>
          <ifl:value>mapping:///{{ interface.mapping_program | replace(' ', '_') }}</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
{% endif %}

{% if interface.has_bpm %}
    <!-- ═══════════════════════════════════════
         BPM / ccBPM REPLACEMENT  ⚠ HIGH COMPLEXITY
         TODO: Redesign as sequential CPI iFlow steps.
         Patterns to consider:
           - Sequential steps   → serviceTask chain
           - Parallel branches  → parallel gateway
           - Loop / retry       → router + counter pattern
           - Correlation        → CPI data store + correlation ID
    ═══════════════════════════════════════ -->
    <serviceTask id="ProcessStep_1" name="[REDESIGN] BPM Step 1" ifl:type="ProcessCall">
      <extensionElements>
        <ifl:property>
          <ifl:key>localCallableProcess</ifl:key>
          <ifl:value><!-- TODO: Create local subprocess --></ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
{% endif %}

{% if interface.has_multi_mapping %}
    <!-- ═══════════════════════════════════════
         MULTI-MAPPING REPLACEMENT
         TODO: Implement as Multicast + individual Message Mappings
         or a Splitter → Router pattern.
    ═══════════════════════════════════════ -->
    <parallelGateway id="Multicast_1" name="Multicast (Multi-Mapping)">
      <extensionElements>
        <ifl:property><ifl:key>parallelCount</ifl:key><ifl:value>2</ifl:value></ifl:property>
      </extensionElements>
    </parallelGateway>
{% endif %}

    <!-- ═══════════════════════════════════════
         RECEIVER CHANNEL — {{ effective_receiver_adapter }}
         System: {{ interface.receiver_system }}
         TODO: Configure endpoint URL, credentials, adapter-specific parameters
{% if effective_receiver_adapter != interface.receiver_adapter %}
         Note: Original adapter '{{ interface.receiver_adapter }}' mapped to
               '{{ effective_receiver_adapter }}' for {{ target_label }}
{% endif %}
    ═══════════════════════════════════════ -->

    <!-- ═══════════════════════════════════════
         END EVENT
    ═══════════════════════════════════════ -->
    <endEvent id="EndEvent_1" name="End"/>

    <!-- SEQUENCE FLOWS -->
    <sequenceFlow id="Flow_Start" sourceRef="StartEvent_1"
{% if interface.has_bpm %}
      targetRef="ProcessStep_1"/>
    <sequenceFlow id="Flow_BPM_End" sourceRef="ProcessStep_1" targetRef="EndEvent_1"/>
{% elif interface.mapping_program %}
      targetRef="MessageMapping_1"/>
    <sequenceFlow id="Flow_Map_End" sourceRef="MessageMapping_1" targetRef="EndEvent_1"/>
{% else %}
      targetRef="EndEvent_1"/>
{% endif %}

  </process>

  <ifl:iFlowMetadata>
    <ifl:description>
Migrated from PI/PO: {{ interface.name }}
Namespace  : {{ interface.namespace }}
Sender     : {{ interface.sender_system }} / {{ interface.sender_adapter }} → CPI: {{ effective_sender_adapter }}
Receiver   : {{ interface.receiver_system }} / {{ interface.receiver_adapter }} → CPI: {{ effective_receiver_adapter }}
Complexity : {{ complexity }} (score: {{ score }}, effort: {{ effort_days }}d)
Pattern    : {{ pattern }}
{% if target_label %}Target     : {{ target_label }}{% endif %}
    </ifl:description>
    <ifl:version>1.0.0</ifl:version>
    <ifl:vendor>SAP</ifl:vendor>
  </ifl:iFlowMetadata>

</definitions>
