                  <xs:sequence>
                    <xs:element type="xs:string" minOccurs="0" maxOccurs="1" name="changedBy"/>
                    <xs:element type="xs:string" minOccurs="0" maxOccurs="1" name="changedAt"/>
                  </xs:sequence>
                </xs:complexType>
