			<xsd:simpleType name="FechaType">
				<xsd:annotation>
					<xsd:documentation> Fecha entre 2000-01-01 y 2050-12-31
					</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:date">
					<xsd:minInclusive value="2000-01-01" />
					<xsd:maxInclusive value="2050-12-31" />
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="FechaHoraType" final="restriction">
				<xsd:annotation>
					<xsd:documentation> FechaType + hora entre 00:00 y 23:59;
					</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:dateTime">
					<xsd:minInclusive value="2000-01-01T00:00:00"
						fixed="true" />
					<xsd:maxInclusive value="2050-12-31T23:59:59" />
				</xsd:restriction>
			</xsd:simpleType>
<xsd:simpleType name="TipoTransCOMPRA">
		<xsd:annotation>
			<xsd:documentation>Tipo de Transacción para el comprador</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:nonNegativeInteger">
			<xsd:enumeration value="1">
				<xsd:annotation>
					<xsd:documentation>Del Giro</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="2">
				<xsd:annotation>
					<xsd:documentation>Supermercados y Similares</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="3">
				<xsd:annotation>
					<xsd:documentation>Adquisición o Construcción de Bienes inmuebles, BBRR</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="4">
				<xsd:annotation>
					<xsd:documentation>Activo Fijo</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="5">
				<xsd:annotation>
					<xsd:documentation>Compra IVA Uso Común o no Recuperable</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="6"/>
			<xsd:enumeration value="7"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="TipoTransVENTA">
		<xsd:annotation>
			<xsd:documentation>Tipo de Transacción para el vendedor</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:positiveInteger">
			<xsd:enumeration value="1">
				<xsd:annotation>
					<xsd:documentation>Del Giro</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="2">
				<xsd:annotation>
					<xsd:documentation>Ventas que no son del Giro (Activo Fijo y Otros)</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="3">
				<xsd:annotation>
					<xsd:documentation>Venta de Bienes inmuebles, BBRR</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
			<xsd:enumeration value="4">
				<xsd:annotation>
					<xsd:documentation>NCE MR * (solo NCE</xsd:documentation>
				</xsd:annotation>
			</xsd:enumeration>
		</xsd:restriction>
	</xsd:simpleType>
			<!-- DTE_v10.xsd -->

			<xsd:complexType name="DTEDefType">
				<xsd:annotation>
					<xsd:documentation>Documento Tributario Electronico
					</xsd:documentation>
				</xsd:annotation>
				<xsd:sequence>
					<xsd:choice>
						<xsd:element name="Documento">
							<xsd:annotation>
								<xsd:documentation>Informacion Tributaria del DTE
								</xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:sequence>
									<xsd:element name="Encabezado">
										<xsd:annotation>
											<xsd:documentation>Identificacion y Totales del Documento
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="IdDoc">
													<xsd:annotation>
														<xsd:documentation>Identificacion del DTE
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="TipoDTE" type="DTEType">
																<xsd:annotation>
																	<xsd:documentation>Tipo de DTE</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="Folio" type="FolioType">
																<xsd:annotation>
																	<xsd:documentation>Folio del Documento Electronico
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="FchEmis" type="FechaType">
																<xsd:annotation>
																	<xsd:documentation>Fecha Emision Contable del DTE
																		(AAAA-MM-DD)
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="IndNoRebaja" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Nota de Credito sin Derecho a
																		Descontar
																		Debito
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:enumeration value="1">
																			<xsd:annotation>
																				<xsd:documentation>Nota de Credito sin Derecho a
																					Descontar Debito
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="TipoDespacho" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Indica Modo de Despacho de los
																		Bienes
																		que Acompanan al DTE
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:enumeration value="1">
																			<xsd:annotation>
																				<xsd:documentation>Despacho por Cuenta del Comprador
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="2">
																			<xsd:annotation>
																				<xsd:documentation>Despacho por Cuenta del Emisor a
																					Instalaciones del Comprador
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="3">
																			<xsd:annotation>
																				<xsd:documentation>Despacho por Cuenta del Emisor a
																					Otras Instalaciones
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="IndTraslado" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Incluido en Guias de Despacho para
																		Especifiicar el Tipo de Traslado de Productos
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:enumeration value="1">
																			<xsd:annotation>
																				<xsd:documentation>Operacion Constituye Venta
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="2">
																			<xsd:annotation>
																				<xsd:documentation>Venta por Efectuar
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="3">
																			<xsd:annotation>
																				<xsd:documentation>Consignacion</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="4">
																			<xsd:annotation>
																				<xsd:documentation>Promocion o Donacion (RUT Emisor
																					=
																					RUT Receptor)
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="5">
																			<xsd:annotation>
																				<xsd:documentation>Traslado Interno
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="6">
																			<xsd:annotation>
																				<xsd:documentation>Otros Traslados que no
																					Constituyen
																					Venta
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="7">
																			<xsd:annotation>
																				<xsd:documentation>Guia de Devolucion
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="8" />
																		<xsd:enumeration value="9" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="TpoImpresion" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Tipo de impresión N (Normal) o T
																		(Ticket)
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:length value="1" />
																		<xsd:enumeration value="N" />
																		<xsd:enumeration value="T" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="IndServicio" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Indica si Transaccion Corresponde a
																		la
																		Prestacion de un Servicio
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:enumeration value="1">
																			<xsd:annotation>
																				<xsd:documentation>Facturacion de Servicios
																					Periodicos
																					Domiciliarios
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="2">
																			<xsd:annotation>
																				<xsd:documentation>Facturacion de Otros Servicios
																					Periodicos
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="3">
																			<xsd:annotation>
																				<xsd:documentation>Factura de Servicio
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="MntBruto" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Indica el Uso de Montos Brutos en
																		Detalle
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:integer">
																		<xsd:enumeration value="1">
																			<xsd:annotation>
																				<xsd:documentation>Monto de Lineas de Detalle
																					Corresponde a Valores Brutos (IVA + Impuestos
																					Adicionales)
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="TpoTranCompra" type="TipoTransCOMPRA" minOccurs="0">
														<xsd:annotation>
															<xsd:documentation>Tipo de Transacción para el comprador</xsd:documentation>
															<xsd:documentation>Indica el Uso de Montos Brutos en Detalle</xsd:documentation>
														</xsd:annotation>
													</xsd:element>
													<xsd:element name="TpoTranVenta" type="TipoTransVENTA" minOccurs="0">
														<xsd:annotation>
															<xsd:documentation>Tipo de Transacción para el vendedor</xsd:documentation>
															<xsd:documentation>Indica el Uso de Montos Brutos en Detalle</xsd:documentation>
														</xsd:annotation>
													</xsd:element>
															<xsd:element name="FmaPago" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Forma de Pago del DTE
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:enumeration value="1">
																			<xsd:annotation>
																				<xsd:documentation>Pago Contado</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="2">
																			<xsd:annotation>
																				<xsd:documentation>Pago Credito</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="3">
																			<xsd:annotation>
																				<xsd:documentation>Sin Costo</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="FmaPagExp" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Forma de Pago Exportación Tabla
																		Formas
																		de Pago de Aduanas
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:totalDigits value="2" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="FchCancel" type="FechaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Fecha de Cancelacion del DTE
																		(AAAA-MM-DD)
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MntCancel" type="MontoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto Cancelado al emitirse el
																		documento
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="SaldoInsol" type="MontoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Saldo Insoluto al emitirse el
																		documento
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MntPagos" minOccurs="0"
																maxOccurs="30">
																<xsd:annotation>
																	<xsd:documentation>Tabla de Montos de Pago
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:complexType>
																	<xsd:sequence>
																		<xsd:element name="FchPago" type="FechaType">
																			<xsd:annotation>
																				<xsd:documentation>Fecha de Pago (AAAA-MM-DD)
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="MntPago" type="MontoType">
																			<xsd:annotation>
																				<xsd:documentation>Monto de Pago</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="GlosaPagos" minOccurs="0">
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="40" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																	</xsd:sequence>
																</xsd:complexType>
															</xsd:element>
															<xsd:element name="PeriodoDesde" type="FechaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Periodo de Facturacion - Desde
																		(AAAA-MM-DD)
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="PeriodoHasta" type="FechaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Periodo Facturacion - Hasta
																		(AAAA-MM-DD)
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MedioPago" type="MedioPagoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Medio de Pago</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="TpoCtaPago" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Tipo Cuenta de Pago
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="10" />
																		<xsd:minLength value="5" />
																		<xsd:enumeration value="AHORRO" />
																		<xsd:enumeration value="CORRIENTE" />
																		<xsd:enumeration value="VISTA" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="NumCtaPago" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Número de la cuenta del pago
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="20" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="BcoPago" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Banco donde se realiza el pago
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="40" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="TermPagoCdg" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Codigo del Termino de Pago Acordado
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="4" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="TermPagoGlosa" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Términos del Pago - glosa
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="100" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="TermPagoDias" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Dias de Acuerdo al Codigo de Termino
																		de
																		Pago
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:totalDigits value="3" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="FchVenc" type="FechaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Fecha de Vencimiento del Pago
																		(AAAA-MM-DD)
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="Emisor">
													<xsd:annotation>
														<xsd:documentation>Datos del Emisor</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="RUTEmisor" type="RUTType">
																<xsd:annotation>
																	<xsd:documentation>RUT del Emisor del DTE
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="RznSoc">
																<xsd:annotation>
																	<xsd:documentation>Nombre o Razon Social del Emisor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="RznSocLargaType" />
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="GiroEmis">
																<xsd:annotation>
																	<xsd:documentation>Giro Comercial del Emisor Relevante
																		para el DTE
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="80" />
																		<xsd:minLength value="1" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="Telefono" minOccurs="0"
																maxOccurs="2">
																<xsd:annotation>
																	<xsd:documentation>Telefono Emisor</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="FonoType">
																		<xsd:maxLength value="20" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CorreoEmisor" type="MailType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Correo Elect. de contacto en empresa
																		del receptor
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="Acteco" maxOccurs="4">
																<xsd:annotation>
																	<xsd:documentation>Codigo de Actividad Economica del
																		Emisor Relevante para el DTE
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:totalDigits value="6" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="GuiaExport" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Emisor de una Guía de despacho para
																		Exportación
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:complexType>
																	<xsd:sequence>
																		<xsd:element name="CdgTraslado" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código Emisor Traslado
																					Excepcional
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="1" />
																					<xsd:enumeration value="1" />
																					<xsd:enumeration value="2" />
																					<xsd:enumeration value="3" />
																					<xsd:enumeration value="4" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="FolioAut" type="NroResolType"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Folio Autorización ( N° de
																					Resolución del SI)
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="FchAut" type="FechaType"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Fecha de emisión de la Resolución
																					de
																					autorización (AAAA-MM-DD)
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																	</xsd:sequence>
																</xsd:complexType>
															</xsd:element>
															<xsd:element name="Sucursal" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Sucursal que Emite el DTE
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="20" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CdgSIISucur" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Codigo de Sucursal Entregado por el
																		SII
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:totalDigits value="9" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="DirOrigen" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Direccion de Origen
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="70" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CmnaOrigen" type="ComunaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Comuna de Origen</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="CiudadOrigen" type="CiudadType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Ciudad de Origen</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="CdgVendedor" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Codigo del Vendedor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="60" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="IdAdicEmisor" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Identificador Adicional del Emisor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="20" />
																		<xsd:minLength value="1" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="RUTMandante" type="RUTType"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>RUT a Cuenta de Quien se Emite el DTE
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="Receptor">
													<xsd:annotation>
														<xsd:documentation>Datos del Receptor</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="RUTRecep" type="RUTType">
																<xsd:annotation>
																	<xsd:documentation>RUT del Receptor del DTE
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="CdgIntRecep" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Codigo Interno del Receptor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="20" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="RznSocRecep" type="RznSocLargaType">
																<xsd:annotation>
																	<xsd:documentation>Nombre o Razon Social del Receptor
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="Extranjero" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Receptor Extranjero
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:complexType>
																	<xsd:sequence>
																		<xsd:element name="NumId" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Num. Identif. Receptor Extranjero
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="20" />
																					<xsd:minLength value="1" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="Nacionalidad"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Nacionalidad Receptor Extranjero
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="3" />
																					<xsd:minLength value="1" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																	</xsd:sequence>
																</xsd:complexType>
															</xsd:element>
															<xsd:element name="GiroRecep" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Giro Comercial del Receptor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="40" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="Contacto" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Telefono o E-mail de Contacto del
																		Receptor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="80" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CorreoRecep" type="MailType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Correo Elect. de contacto en empresa
																		del receptor
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="DirRecep" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Direccion en la Cual se Envian los
																		Productos o se Prestan los Servicios
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="70" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CmnaRecep" type="ComunaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Comuna de Recepcion
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="CiudadRecep" type="CiudadType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Ciudad de Recepcion
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="DirPostal" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Direccion Postal</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="70" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CmnaPostal" type="ComunaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Comuna Postal</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="CiudadPostal" type="CiudadType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Ciudad Postal</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="RUTSolicita" type="RUTType"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>RUT que solicita el DTE en Venta a
															Publico
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="Transporte" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Informacion de Transporte de
															Mercaderias
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="Patente" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Patente del Vehiculo que Transporta
																		los
																		Bienes
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="8" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="RUTTrans" type="RUTType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>RUT del Transportista
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="Chofer" minOccurs="0">
																<xsd:complexType>
																	<xsd:sequence>
																		<xsd:element name="RUTChofer" type="RUTType">
																			<xsd:annotation>
																				<xsd:documentation>RUT del Chofer
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="NombreChofer">
																			<xsd:annotation>
																				<xsd:documentation>Nombre del Chofer
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="30" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																	</xsd:sequence>
																</xsd:complexType>
															</xsd:element>
															<xsd:element name="DirDest" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Direccion de Destino
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="70" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CmnaDest" type="ComunaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Comuna de Destino
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="CiudadDest" type="CiudadType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Ciudad de Destino
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="Aduana" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>documentos de Exportación y guías de
																		despacho
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:complexType>
																	<xsd:sequence>
																		<xsd:element name="CodModVenta" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código según tabla "Modalidad de
																					Venta" de aduana
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="2" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="CodClauVenta"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código según Tabla "Cláusula
																					compra-venta" de Aduana
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="2" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="TotClauVenta" type="Dec16_2Type"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Total Cláusula de venta
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="CodViaTransp"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Indicar el Código de la vía de
																					transporte utilizada para transportar la
																					mercadería,
																					según tabla Vías de Transporte de Aduana
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="2" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="NombreTransp"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Nombre o Identificación del Medio
																					de
																					Transporte
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="40" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="RUTCiaTransp" type="RUTType"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Rut Cía. Transportadora
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="NomCiaTransp"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Nombre Cía. Transportadora
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="40" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="IdAdicTransp"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Identificador Adicional Cía.
																					Transportadora
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="20" />
																					<xsd:minLength value="1" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="Booking" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Numero de reserva del Operador
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="20" />
																					<xsd:minLength value="1" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="Operador" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código del Operador
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="20" />
																					<xsd:minLength value="1" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="CodPtoEmbarque"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código del puerto de embarque
																					según
																					tabla de Aduana
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="4" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="IdAdicPtoEmb"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Identificador Adicional Puerto de
																					Embarque
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="20" />
																					<xsd:minLength value="1" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="CodPtoDesemb"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código del puerto de desembarque
																					según tabla de Aduana
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="4" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="IdAdicPtoDesemb"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Identificador Adicional Puerto de
																					Desembarque
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="20" />
																					<xsd:minLength value="1" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="Tara" minOccurs="0">
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="7" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="CodUnidMedTara"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código de la unidad de medida
																					según
																					tabla de Aduana
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="2" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="PesoBruto" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Sumatoria de los pesos brutos de
																					todos los ítems del documento
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:decimal">
																					<xsd:totalDigits value="10" />
																					<xsd:fractionDigits value="2" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="CodUnidPesoBruto"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código de la unidad de medida
																					según
																					tabla de Aduana
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="2" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="PesoNeto" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Sumatoria de los pesos netos de
																					todos los ítems del documento
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:decimal">
																					<xsd:totalDigits value="10" />
																					<xsd:fractionDigits value="2" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="CodUnidPesoNeto"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código de la unidad de medida
																					según
																					tabla de Aduana
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="2" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="TotItems" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Indique el total de items del
																					documento
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="18" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="TotBultos" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Cantidad total de bultos que
																					ampara
																					el documento.
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="18" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="TipoBultos" minOccurs="0"
																			maxOccurs="10">
																			<xsd:annotation>
																				<xsd:documentation>Tabla de descripción de los
																					distintos tipos de bultos
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:complexType>
																				<xsd:sequence>
																					<xsd:element name="CodTpoBultos"
																						minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Código según tabla "Tipos de
																								Bultos" de aduana
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:simpleType>
																							<xsd:restriction base="xsd:positiveInteger">
																								<xsd:totalDigits value="3" />
																							</xsd:restriction>
																						</xsd:simpleType>
																					</xsd:element>
																					<xsd:element name="CantBultos"
																						minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Cantidad de Bultos
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:simpleType>
																							<xsd:restriction base="xsd:positiveInteger">
																								<xsd:totalDigits value="10" />
																							</xsd:restriction>
																						</xsd:simpleType>
																					</xsd:element>
																					<xsd:element name="Marcas" minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Identificación de marcas,
																								cuando
																								es distinto de contenedor
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:simpleType>
																							<xsd:restriction base="xsd:string">
																								<xsd:maxLength value="255" />
																							</xsd:restriction>
																						</xsd:simpleType>
																					</xsd:element>
																					<xsd:element name="IdContainer"
																						minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Se utiliza cuando el tipo de
																								bulto es contenedor
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:simpleType>
																							<xsd:restriction base="xsd:string">
																								<xsd:maxLength value="25" />
																							</xsd:restriction>
																						</xsd:simpleType>
																					</xsd:element>
																					<xsd:element name="Sello" minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Sello contenedor. Con digito
																								verificador
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:simpleType>
																							<xsd:restriction base="xsd:string">
																								<xsd:maxLength value="20" />
																							</xsd:restriction>
																						</xsd:simpleType>
																					</xsd:element>
																					<xsd:element name="EmisorSello"
																						minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Nombre emisor sello
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:simpleType>
																							<xsd:restriction base="xsd:string">
																								<xsd:maxLength value="70" />
																							</xsd:restriction>
																						</xsd:simpleType>
																					</xsd:element>
																				</xsd:sequence>
																			</xsd:complexType>
																		</xsd:element>
																		<xsd:element name="MntFlete" type="Dec14_4Type"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Monto del flete según moneda de
																					venta
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="MntSeguro" type="Dec14_4Type"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Monto del seguro , según moneda
																					de
																					venta
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="CodPaisRecep"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código del país del receptor
																					extranjero de la mercadería,
																					según tabla Países aduana
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="3" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="CodPaisDestin"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código del país de destino
																					extranjero de la mercadería,
																					según tabla Países aduana
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="3" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																	</xsd:sequence>
																</xsd:complexType>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="Totales">
													<xsd:annotation>
														<xsd:documentation>Montos Totales del DTE
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="MntNeto" type="MontoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto Neto del DTE
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MntExe" type="MontoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto Exento del DTE
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MntBase" type="MontoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto Base Faenamiento Carne
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MntMargenCom" type="MontoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto Base de Márgenes de
																		Comercialización. Monto informado
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="TasaIVA" type="PctType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Tasa de IVA</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="IVA" type="MontoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto de IVA del DTE
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="IVAProp" type="MontoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto del IVA propio
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="IVATerc" type="MontoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto del IVA de Terceros
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="ImptoReten" minOccurs="0"
																maxOccurs="20">
																<xsd:annotation>
																	<xsd:documentation>Impuestos y Retenciones Adicionales
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:complexType>
																	<xsd:sequence>
																		<xsd:element name="TipoImp" type="ImpAdicDTEType">
																			<xsd:annotation>
																				<xsd:documentation>Tipo de Impuesto o Retencion
																					Adicional
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="TasaImp" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Tasa de Impuesto o Retencion
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="PctType">
																					<xsd:maxInclusive value="100.00" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="MontoImp" type="MntImpType">
																			<xsd:annotation>
																				<xsd:documentation>Monto del Impuesto o Retencion
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																	</xsd:sequence>
																</xsd:complexType>
															</xsd:element>
															<xsd:element name="IVANoRet" type="MntImpType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>IVA No Retenido</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="CredEC" type="MontoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Credito Especial Empresas
																		Constructoras
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="GrntDep" type="MontoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Garantia por Deposito de Envases o
																		Embalajes
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="Comisiones" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Comisiones y otros cargos es
																		obligatoria para Liquidaciones Factura
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:complexType>
																	<xsd:sequence>
																		<xsd:element name="ValComNeto" type="MontoType"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Valor Neto Comisiones y Otros
																					Cargos
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="ValComExe" type="MontoType"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Val. Comis. y Otros Cargos no
																					Afectos o Exentos
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="ValComIVA" type="MontoType"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Valor IVA Comisiones y Otros
																					Cargos
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																	</xsd:sequence>
																</xsd:complexType>
															</xsd:element>
															<xsd:element name="MntTotal" type="MontoType">
																<xsd:annotation>
																	<xsd:documentation>Monto Total del DTE
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MontoNF" type="ValorType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto No Facturable - Corresponde a
																		Bienes o Servicios Facturados Previamente
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MontoPeriodo" type="ValorType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Total de Ventas o Servicios del
																		Periodo
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="SaldoAnterior" type="ValorType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Saldo Anterior - Puede ser Negativo
																		o
																		Positivo
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="VlrPagar" type="ValorType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Valor a Pagar Total del documento
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="OtraMoneda" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Otra Moneda </xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="TpoMoneda" type="TipMonType">
																<xsd:annotation>
																	<xsd:documentation>Tipo Ottra moneda Tabla de Monedas
																		de
																		Aduanas
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="TpoCambio" type="Dec6_4Type"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Tipo de Cambio fijado por el Banco
																		Central de Chile
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MntNetoOtrMnda" type="Dec14_4Type"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto Neto del DTE en Otra Moneda
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MntExeOtrMnda" type="Dec14_4Type"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto Exento del DTE en Otra Moneda
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MntFaeCarneOtrMnda" type="Dec14_4Type"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto Base Faenamiento Carne en Otra
																		Moneda
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MntMargComOtrMnda" type="Dec14_4Type"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto Base de Márgenes de
																		Comercialización. Monto informado
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="IVAOtrMnda" type="Dec14_4Type"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto de IVA del DTE en Otra Moneda
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="ImpRetOtrMnda" minOccurs="0"
																maxOccurs="20">
																<xsd:annotation>
																	<xsd:documentation>Impuestos y Retenciones Adicionales
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:complexType>
																	<xsd:sequence>
																		<xsd:element name="TipoImpOtrMnda" type="ImpAdicDTEType">
																			<xsd:annotation>
																				<xsd:documentation>Tipo de Impuesto o Retencion
																					Adicional
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="TasaImpOtrMnda" type="PctType"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Tasa de Impuesto o Retencion
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="VlrImpOtrMnda" type="Dec14_4Type">
																			<xsd:annotation>
																				<xsd:documentation>Valor del impuesto o retención en
																					otra moneda
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																	</xsd:sequence>
																</xsd:complexType>
															</xsd:element>
															<xsd:element name="IVANoRetOtrMnda" type="Dec14_4Type"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>IVA no retenido Otra Moneda
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MntTotOtrMnda" type="Dec14_4Type">
																<xsd:annotation>
																	<xsd:documentation>Monto Total Otra Moneda
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
											</xsd:sequence>
										</xsd:complexType>
									</xsd:element>
									<xsd:element name="Detalle" maxOccurs="60">
										<xsd:annotation>
											<xsd:documentation>Detalle de Itemes del Documento
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="NroLinDet">
													<xsd:annotation>
														<xsd:documentation>Numero Secuencial de Linea
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:maxInclusive value="99" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="CdgItem" minOccurs="0"
													maxOccurs="5">
													<xsd:annotation>
														<xsd:documentation>Codificacion del Item
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="TpoCodigo">
																<xsd:annotation>
																	<xsd:documentation>Tipo de Codificacion
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="10" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="VlrCodigo">
																<xsd:annotation>
																	<xsd:documentation>Valor del Codigo de Item, para la
																		Codificacion Particular
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="35" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="IndExe" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Indicador de Exencion/Facturacion
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:enumeration value="1">
																<xsd:annotation>
																	<xsd:documentation>El Producto o Servicio NO ESTA
																		Afecto a
																		IVA
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="2">
																<xsd:annotation>
																	<xsd:documentation>El Producto o Servicio NO ES
																		Facturable
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="3">
																<xsd:annotation>
																	<xsd:documentation>Garantia por Deposito/Envase
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="4">
																<xsd:annotation>
																	<xsd:documentation>El producto No Constituye Venta
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="5">
																<xsd:annotation>
																	<xsd:documentation>Item a Rebajar</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="6">
																<xsd:annotation>
																	<xsd:documentation>No facturables negativos
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="Retenedor" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Sólo para transacciones realizadas por
															agentes retenedores
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="IndAgente">
																<xsd:annotation>
																	<xsd:documentation>Indicador Agente Retenedor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="1" />
																		<xsd:enumeration value="R" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="MntBaseFaena" type="MontoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto Base Faenamiento
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MntMargComer" type="MontoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Márgenes de Comercialización
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="PrcConsFinal" type="MontoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Precio Unitario Neto Consumidor
																		Final
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="NmbItem">
													<xsd:annotation>
														<xsd:documentation>Nombre del Item</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="80" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="DscItem" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Descripcion del Item
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="1000" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="QtyRef" type="Dec12_6Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Cantidad para la Unidad de Medida de
															Referencia
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="UnmdRef" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Unidad de Medida de Referencia
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="4" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="PrcRef" type="Dec12_6Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Precio Unitario de Referencia para
															Unidad
															de Referencia
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element
													name="QtyItem" type="Dec12_6Type" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Cantidad del Item</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="Subcantidad" minOccurs="0"
													maxOccurs="5">
													<xsd:annotation>
														<xsd:documentation>Distribucion de la Cantidad
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="SubQty" type="Dec12_6Type">
																<xsd:annotation>
																	<xsd:documentation>Cantidad Distribuida
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="SubCod">
																<xsd:annotation>
																	<xsd:documentation>Codigo Descriptivo de la Subcantidad
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="35" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="FchElabor" type="FechaType"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Fecha Elaboracion del Item
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="FchVencim" type="FechaType"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Fecha Vencimiento del Item
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="UnmdItem" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Unidad de Medida</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="4" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="PrcItem" type="Dec12_6Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Precio Unitario del Item en Pesos
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="OtrMnda" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Precio del Item en Otra Moneda
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="PrcOtrMon" type="Dec12_6Type">
																<xsd:annotation>
																	<xsd:documentation>Precio Unitario en Otra Moneda
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="Moneda">
																<xsd:annotation>
																	<xsd:documentation>Codigo de Otra Moneda (Usar Codigos
																		de
																		Moneda del Banco Central)
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="3" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="FctConv" type="Dec6_4Type"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Factor para Conversion a Pesos
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="DctoOtrMnda" type="Dec14_4Type"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Descuento en Otra Moneda
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="RecargoOtrMnda" type="Dec14_4Type"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Recargo en Otra Moneda
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MontoItemOtrMnda" type="Dec14_4Type"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Valor por línea de detalle en Otra
																		Moneda
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element
													name="DescuentoPct" type="PctType" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>
															Porcentaje
															de Descuento
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="DescuentoMonto" type="MntImpType"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Monto de Descuento</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="SubDscto" minOccurs="0"
													maxOccurs="5">
													<xsd:annotation>
														<xsd:documentation>Desglose del Descuento
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="TipoDscto"
																type="DineroPorcentajeType">
																<xsd:annotation>
																	<xsd:documentation>Tipo de SubDescuento
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="ValorDscto" type="Dec16_2Type">
																<xsd:annotation>
																	<xsd:documentation>Valor del SubDescuento
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="RecargoPct" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Porcentaje de Recargo
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="PctType">
															<xsd:maxInclusive value="999.99" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="RecargoMonto" type="MntImpType"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Monto de Recargo</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="SubRecargo" minOccurs="0"
													maxOccurs="5">
													<xsd:annotation>
														<xsd:documentation>Desglose del Recargo
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="TipoRecargo"
																type="DineroPorcentajeType">
																<xsd:annotation>
																	<xsd:documentation>Tipo de SubRecargo
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="ValorRecargo" type="Dec16_2Type">
																<xsd:annotation>
																	<xsd:documentation>Valor de SubRecargo
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="CodImpAdic" type="ImpAdicDTEType"
													minOccurs="0" maxOccurs="2">
													<xsd:annotation>
														<xsd:documentation>Codigo de Impuesto Adicional o
															Retencion
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="MontoItem" type="MontoType">
													<xsd:annotation>
														<xsd:documentation>Monto por Linea de Detalle. Corresponde
															al
															Monto Neto, a menos que MntBruto Indique lo Contrario
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
											</xsd:sequence>
										</xsd:complexType>
									</xsd:element>
									<xsd:element name="SubTotInfo" minOccurs="0"
										maxOccurs="20">
										<xsd:annotation>
											<xsd:documentation>Subtotales Informativos
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="NroSTI">
													<xsd:annotation>
														<xsd:documentation>Número de Subtotal </xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:maxInclusive value="99" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="GlosaSTI">
													<xsd:annotation>
														<xsd:documentation>Glosa</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="40" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="OrdenSTI" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Ubicación para Impresión
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:maxInclusive value="99" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="SubTotNetoSTI" type="Dec16_2Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Valor Neto del Subtotal
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="SubTotIVASTI" type="Dec16_2Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Valor del IVA del Subtotal
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="SubTotAdicSTI" type="Dec16_2Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Valor de los Impuestos adicionales o
															específicos del Subtotal
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="SubTotExeSTI" type="Dec16_2Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Valor no Afecto o Exento del Subtotal
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="ValSubtotSTI" type="Dec16_2Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Valor de la línea de subtotal
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="LineasDeta" minOccurs="0"
													maxOccurs="60">
													<xsd:annotation>
														<xsd:documentation>TABLA de Líneas de Detalle que se
															agrupan
															en el Subtotal
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger" />
													</xsd:simpleType>
												</xsd:element>
											</xsd:sequence>
										</xsd:complexType>
									</xsd:element>
									<xsd:element name="DscRcgGlobal" minOccurs="0"
										maxOccurs="20">
										<xsd:annotation>
											<xsd:documentation>Descuentos y/o Recargos que afectan al
												total
												del Documento
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="NroLinDR" type="xsd:positiveInteger">
													<xsd:annotation>
														<xsd:documentation>Numero Secuencial de Linea
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="TpoMov">
													<xsd:annotation>
														<xsd:documentation>Tipo de Movimiento</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:minLength value="1" />
															<xsd:maxLength value="1" />
															<xsd:enumeration value="D">
																<xsd:annotation>
																	<xsd:documentation>Descuento</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="R">
																<xsd:annotation>
																	<xsd:documentation>Recargo</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="GlosaDR" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Descripcion del Descuento o Recargo
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="45" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="TpoValor" type="DineroPorcentajeType">
													<xsd:annotation>
														<xsd:documentation>Unidad en que se Expresa el Valor
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element
													name="ValorDR" type="Dec16_2Type">
													<xsd:annotation>
														<xsd:documentation>
															Valor del
															Descuento o
															Recargo
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element
													name="ValorDROtrMnda" type="Dec14_4Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>
															Valor en
															otra moneda
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="IndExeDR" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Indica si el D/R es No Afecto o No
															Facturable
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:enumeration value="1">
																<xsd:annotation>
																	<xsd:documentation>Descuento/Recargo Global No Afecto
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="2">
																<xsd:annotation>
																	<xsd:documentation>Descuento/Recargo No Facturable
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
											</xsd:sequence>
										</xsd:complexType>
									</xsd:element>
									<xsd:element name="Referencia" minOccurs="0"
										maxOccurs="40">
										<xsd:annotation>
											<xsd:documentation>Identificacion de otros documentos
												Referenciados por Documento
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="NroLinRef">
													<xsd:annotation>
														<xsd:documentation>Numero Secuencial de Linea de
															Referencia
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:maxInclusive value="99" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="TpoDocRef">
													<xsd:annotation>
														<xsd:documentation>Tipo de Documento de Referencia
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="3" />
															<xsd:minLength value="1" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="IndGlobal" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Indica que se esta Referenciando un
															Conjunto de Documentos
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:nonNegativeInteger">
															<xsd:totalDigits value="1" />
															<xsd:enumeration value="1">
																<xsd:annotation>
																	<xsd:documentation>El Documento hace Referencia a un
																		Conjunto de Documentos Tributarios del Mismo Tipo
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="FolioRef" type="FolioRType">
													<xsd:annotation>
														<xsd:documentation>Folio del Documento de Referencia
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="RUTOtr" type="RUTType"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>RUT Otro Contribuyente
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="FchRef" type="FechaType">
													<xsd:annotation>
														<xsd:documentation>Fecha de la Referencia
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="CodRef" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Tipo de Uso de la Referencia
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:enumeration value="1">
																<xsd:annotation>
																	<xsd:documentation>Anula Documento de Referencia
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="2">
																<xsd:annotation>
																	<xsd:documentation>Corrige Texto del Documento de
																		Referencia
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="3">
																<xsd:annotation>
																	<xsd:documentation>Corrige Montos</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="RazonRef" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Razon Explicita por la que se
															Referencia
															el Documento
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="90" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
											</xsd:sequence>
										</xsd:complexType>
									</xsd:element>
									<xsd:element name="Comisiones" minOccurs="0"
										maxOccurs="20">
										<xsd:annotation>
											<xsd:documentation>Comisiones y otros cargos es obligatoria
												para
												Liquidaciones Factura
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="NroLinCom">
													<xsd:annotation>
														<xsd:documentation>Numero Secuencial de Linea
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:maxInclusive value="20" />
															<xsd:minInclusive value="1" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="TipoMovim">
													<xsd:annotation>
														<xsd:documentation>C (comisión) u O (otros cargos)
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:minLength value="1" />
															<xsd:enumeration value="C" />
															<xsd:enumeration value="O" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="Glosa">
													<xsd:annotation>
														<xsd:documentation>Especificación de la comisión u otro
															cargo
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="60" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="TasaComision" type="PctType"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Valor porcentual de la comisión u otro
															cargo
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="ValComNeto" type="MontoType">
													<xsd:annotation>
														<xsd:documentation>Valor Neto Comisiones y Otros Cargos
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="ValComExe" type="MontoType">
													<xsd:annotation>
														<xsd:documentation>Val. Comis. y Otros Cargos no Afectos o
															Exentos
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="ValComIVA" type="MontoType"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Valor IVA Comisiones y Otros Cargos
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
											</xsd:sequence>
										</xsd:complexType>
									</xsd:element>
									<xsd:element name="TED">
										<xsd:annotation>
											<xsd:documentation>Timbre Electronico de DTE
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="DD">
													<xsd:annotation>
														<xsd:documentation>Datos Basicos de Documento
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="RE" type="RUTType">
																<xsd:annotation>
																	<xsd:documentation>RUT Emisor</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="TD" type="DTEType">
																<xsd:annotation>
																	<xsd:documentation>Tipo DTE</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="F" type="FolioType">
																<xsd:annotation>
																	<xsd:documentation>Folio DTE</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="FE" type="FechaType">
																<xsd:annotation>
																	<xsd:documentation>Fecha Emision DTE en Formato
																		AAAA-MM-DD
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="RR" type="RUTType">
																<xsd:annotation>
																	<xsd:documentation>RUT Receptor</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="RSR">
																<xsd:annotation>
																	<xsd:documentation>Razon Social Receptor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:minLength value="1" />
																		<xsd:maxLength value="40" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="MNT" type="MontoType">
																<xsd:annotation>
																	<xsd:documentation>Monto Total DTE</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="IT1">
																<xsd:annotation>
																	<xsd:documentation>Descripcion Primer Item de Detalle
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:minLength value="1" />
																		<xsd:maxLength value="40" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CAF">
																<xsd:annotation>
																	<xsd:documentation>Codigo Autorizacion Folios
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:complexType>
																	<xsd:sequence>
																		<xsd:element name="DA">
																			<xsd:annotation>
																				<xsd:documentation>Datos de Autorizacion de Folios
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:complexType>
																				<xsd:sequence>
																					<xsd:element name="RE" type="RUTType">
																						<xsd:annotation>
																							<xsd:documentation>RUT Emisor</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="RS">
																						<xsd:annotation>
																							<xsd:documentation>Razon Social Emisor
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:simpleType>
																							<xsd:restriction base="xsd:string">
																								<xsd:minLength value="1" />
																								<xsd:maxLength value="40" />
																							</xsd:restriction>
																						</xsd:simpleType>
																					</xsd:element>
																					<xsd:element name="TD" type="DTEType">
																						<xsd:annotation>
																							<xsd:documentation>Tipo DTE</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="RNG">
																						<xsd:annotation>
																							<xsd:documentation>Rango Autorizado de Folios
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:complexType>
																							<xsd:sequence>
																								<xsd:element name="D" type="FolioType">
																									<xsd:annotation>
																										<xsd:documentation>Folio Inicial (Desde)
																										</xsd:documentation>
																									</xsd:annotation>
																								</xsd:element>
																								<xsd:element name="H" type="FolioType">
																									<xsd:annotation>
																										<xsd:documentation>Folio Final (Hasta)
																										</xsd:documentation>
																									</xsd:annotation>
																								</xsd:element>
																							</xsd:sequence>
																						</xsd:complexType>
																					</xsd:element>
																					<xsd:element name="FA" type="FechaType">
																						<xsd:annotation>
																							<xsd:documentation>Fecha Autorizacion en Formato
																								AAAA-MM-DD
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:choice>
																						<xsd:element name="RSAPK">
																							<xsd:annotation>
																								<xsd:documentation>Clave Publica RSA del
																									Solicitante
																								</xsd:documentation>
																							</xsd:annotation>
																							<xsd:complexType>
																								<xsd:sequence>
																									<xsd:element name="M"
																										type="xsd:string">
																										<xsd:annotation>
																											<xsd:documentation>Modulo RSA
																											</xsd:documentation>
																										</xsd:annotation>
																									</xsd:element>
																									<xsd:element name="E"
																										type="xsd:string">
																										<xsd:annotation>
																											<xsd:documentation>Exponente RSA
																											</xsd:documentation>
																										</xsd:annotation>
																									</xsd:element>
																								</xsd:sequence>
																							</xsd:complexType>
																						</xsd:element>
																						<xsd:element name="DSAPK">
																							<xsd:annotation>
																								<xsd:documentation>Clave Publica DSA del
																									Solicitante
																								</xsd:documentation>
																							</xsd:annotation>
																							<xsd:complexType>
																								<xsd:sequence>
																									<xsd:element name="P"
																										type="xsd:base64Binary">
																										<xsd:annotation>
																											<xsd:documentation>Modulo Primo
																											</xsd:documentation>
																										</xsd:annotation>
																									</xsd:element>
																									<xsd:element name="Q"
																										type="xsd:base64Binary">
																										<xsd:annotation>
																											<xsd:documentation>Entero Divisor de P - 1
																											</xsd:documentation>
																										</xsd:annotation>
																									</xsd:element>
																									<xsd:element name="G"
																										type="xsd:base64Binary">
																										<xsd:annotation>
																											<xsd:documentation>Entero f(P, Q)
																											</xsd:documentation>
																										</xsd:annotation>
																									</xsd:element>
																									<xsd:element name="Y"
																										type="xsd:base64Binary">
																										<xsd:annotation>
																											<xsd:documentation>G**X mod P
																											</xsd:documentation>
																										</xsd:annotation>
																									</xsd:element>
																								</xsd:sequence>
																							</xsd:complexType>
																						</xsd:element>
																					</xsd:choice>
																					<xsd:element name="IDK" type="xsd:long">
																						<xsd:annotation>
																							<xsd:documentation>Identificador de Llave
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																				</xsd:sequence>
																			</xsd:complexType>
																		</xsd:element>
																		<xsd:element name="FRMA">
																			<xsd:annotation>
																				<xsd:documentation>Firma Digital (RSA) del SII Sobre
																					DA
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:complexType>
																				<xsd:simpleContent>
																					<xsd:extension base="xsd:string">
																						<xsd:attribute name="algoritmo"
																							type="xsd:string" use="required" fixed="SHA1withRSA" />
																					</xsd:extension>
																				</xsd:simpleContent>
																			</xsd:complexType>
																		</xsd:element>
																	</xsd:sequence>
																	<xsd:attribute name="version" use="required"
																		fixed="1.0" />
																</xsd:complexType>
															</xsd:element>
															<xsd:element name="TSTED" type="FechaHoraType">
																<xsd:annotation>
																	<xsd:documentation>TimeStamp de Generacion del Timbre
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="FRMT">
													<xsd:annotation>
														<xsd:documentation>Valor de Firma Digital sobre DD
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:simpleContent>
															<xsd:extension base="xsd:base64Binary">
																<xsd:attribute name="algoritmo" use="required">
																	<xsd:simpleType>
																		<xsd:restriction base="xsd:string">
																			<xsd:enumeration value="SHA1withRSA" />
																			<xsd:enumeration value="SHA1withDSA" />
																		</xsd:restriction>
																	</xsd:simpleType>
																</xsd:attribute>
															</xsd:extension>
														</xsd:simpleContent>
													</xsd:complexType>
												</xsd:element>
											</xsd:sequence>
											<xsd:attribute name="version" use="required"
												fixed="1.0" />
										</xsd:complexType>
									</xsd:element>
									<xsd:element name="TmstFirma" type="FechaHoraType">
										<xsd:annotation>
											<xsd:documentation>Fecha y Hora en que se Firmo Digitalmente
												el
												Documento AAAA-MM-DDTHH:MI:SS
											</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
								</xsd:sequence>
								<xsd:attribute name="ID" type="xsd:ID" use="required" />
							</xsd:complexType>
						</xsd:element>
						<xsd:element name="Liquidacion">
							<xsd:annotation>
								<xsd:documentation>Informacion Tributaria de Liquidaciones
								</xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:sequence>
									<xsd:element name="Encabezado">
										<xsd:annotation>
											<xsd:documentation>Identificacion y Totales del Documento
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="IdDoc">
													<xsd:annotation>
														<xsd:documentation>Identificacion del DTE
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="TipoDTE" type="LIQType">
																<xsd:annotation>
																	<xsd:documentation>Tipo de DTE</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="Folio" type="FolioType">
																<xsd:annotation>
																	<xsd:documentation>Folio del Documento Electronico
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="FchEmis" type="FechaType">
																<xsd:annotation>
																	<xsd:documentation>Fecha Emision Contable del DTE
																		(AAAA-MM-DD)
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="IndServicio" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Indica si Transaccion Corresponde a
																		la
																		Prestacion de un Servicio
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:enumeration value="1">
																			<xsd:annotation>
																				<xsd:documentation>Facturacion de Servicios
																					Periodicos
																					Domiciliarios
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="2">
																			<xsd:annotation>
																				<xsd:documentation>Facturacion de Otros Servicios
																					Periodicos
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="3">
																			<xsd:annotation>
																				<xsd:documentation>Factura de Servicio
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="MntBruto" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Indica el Uso de Montos Brutos en
																		Detalle
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:integer">
																		<xsd:enumeration value="1">
																			<xsd:annotation>
																				<xsd:documentation>Monto de Lineas de Detalle
																					Corresponde a Valores Brutos (IVA + Impuestos
																					Adicionales)
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="TpoTranCompra" type="TipoTransCOMPRA" minOccurs="0">
														<xsd:annotation>
															<xsd:documentation>Tipo de Transacción para el comprador</xsd:documentation>
															<xsd:documentation>Indica el Uso de Montos Brutos en Detalle</xsd:documentation>
														</xsd:annotation>
													</xsd:element>
													<xsd:element name="TpoTranVenta" type="TipoTransVENTA" minOccurs="0">
														<xsd:annotation>
															<xsd:documentation>Tipo de Transacción para el vendedor</xsd:documentation>
															<xsd:documentation>Indica el Uso de Montos Brutos en Detalle</xsd:documentation>
														</xsd:annotation>
													</xsd:element>
															<xsd:element name="FmaPago" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Forma de Pago del DTE
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:enumeration value="1">
																			<xsd:annotation>
																				<xsd:documentation>Pago Contado</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="2">
																			<xsd:annotation>
																				<xsd:documentation>Pago Credito</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="3">
																			<xsd:annotation>
																				<xsd:documentation>Sin Costo</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="FchCancel" type="FechaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Fecha de Cancelacion del DTE
																		(AAAA-MM-DD)
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MntCancel" type="MontoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto Cancelado al emitirse el
																		documento
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="SaldoInsol" type="MontoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Saldo Insoluto al emitirse el
																		documento
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MntPagos" minOccurs="0"
																maxOccurs="30">
																<xsd:annotation>
																	<xsd:documentation>Tabla de Montos de Pago
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:complexType>
																	<xsd:sequence>
																		<xsd:element name="FchPago" type="FechaType">
																			<xsd:annotation>
																				<xsd:documentation>Fecha de Pago (AAAA-MM-DD)
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="MntPago" type="MontoType">
																			<xsd:annotation>
																				<xsd:documentation>Monto de Pago</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="GlosaPagos" minOccurs="0">
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="40" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																	</xsd:sequence>
																</xsd:complexType>
															</xsd:element>
															<xsd:element name="PeriodoDesde" type="FechaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Periodo de Facturacion - Desde
																		(AAAA-MM-DD)
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="PeriodoHasta" type="FechaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Periodo Facturacion - Hasta
																		(AAAA-MM-DD)
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MedioPago" type="MedioPagoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Medio de Pago</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="TpoCtaPago" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Tipo Cuenta de Pago
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="10" />
																		<xsd:minLength value="5" />
																		<xsd:enumeration value="AHORRO" />
																		<xsd:enumeration value="CORRIENTE" />
																		<xsd:enumeration value="VISTA" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="NumCtaPago" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Número de la cuenta del pago
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="20" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="BcoPago" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Banco donde se realiza el pago
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="40" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="TermPagoCdg" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Codigo del Termino de Pago Acordado
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="4" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="TermPagoGlosa" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Términos del Pago - glosa
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="100" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="TermPagoDias" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Dias de Acuerdo al Codigo de Termino
																		de
																		Pago
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:totalDigits value="3" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="FchVenc" type="FechaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Fecha de Vencimiento del Pago
																		(AAAA-MM-DD)
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="Emisor">
													<xsd:annotation>
														<xsd:documentation>Datos del Emisor</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="RUTEmisor" type="RUTType">
																<xsd:annotation>
																	<xsd:documentation>RUT del Emisor del DTE
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="RznSoc">
																<xsd:annotation>
																	<xsd:documentation>Nombre o Razon Social del Emisor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="100" />
																		<xsd:minLength value="1" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="GiroEmis">
																<xsd:annotation>
																	<xsd:documentation>Giro Comercial del Emisor Relevante
																		para el DTE
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="80" />
																		<xsd:minLength value="1" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="Telefono" minOccurs="0"
																maxOccurs="2">
																<xsd:annotation>
																	<xsd:documentation>Telefono Emisor </xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="FonoType">
																		<xsd:maxLength value="20" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CorreoEmisor" type="MailType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Correo Elect. de contacto en empresa
																		del receptor
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="Acteco" maxOccurs="4">
																<xsd:annotation>
																	<xsd:documentation>Codigo de Actividad Economica del
																		Emisor Relevante para el DTE
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:totalDigits value="6" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="Sucursal" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Sucursal que Emite el DTE
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="20" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CdgSIISucur" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Codigo de Sucursal Entregado por el
																		SII
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:totalDigits value="9" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="DirOrigen">
																<xsd:annotation>
																	<xsd:documentation>Direccion de Origen
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="70" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CmnaOrigen" type="ComunaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Comuna de Origen</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="CiudadOrigen" type="CiudadType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Ciudad de Origen</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="CdgVendedor" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Codigo del Vendedor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="60" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="Receptor">
													<xsd:annotation>
														<xsd:documentation>Datos del Receptor</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="RUTRecep" type="RUTType">
																<xsd:annotation>
																	<xsd:documentation>RUT del Receptor del DTE
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="CdgIntRecep" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Codigo Interno del Receptor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="20" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="RznSocRecep" type="RznSocLargaType">
																<xsd:annotation>
																	<xsd:documentation>Nombre o Razon Social del Receptor
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="GiroRecep">
																<xsd:annotation>
																	<xsd:documentation>Giro Comercial del Receptor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="40" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="Contacto" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Glosa con nombre o teléfono de
																		contacto
																		en empresa del receptor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="80" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CorreoRecep" type="MailType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Correo Elect. de contacto en empresa
																		del receptor
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="DirRecep">
																<xsd:annotation>
																	<xsd:documentation>Direccion en la Cual se Envian los
																		Productos o se Prestan los Servicios
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="70" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CmnaRecep" type="ComunaType">
																<xsd:annotation>
																	<xsd:documentation>Comuna de Recepcion
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="CiudadRecep" type="CiudadType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Ciudad de Recepcion
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="DirPostal" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Direccion Postal</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="70" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CmnaPostal" type="ComunaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Comuna Postal</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="CiudadPostal" type="CiudadType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Ciudad Postal</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="Totales">
													<xsd:annotation>
														<xsd:documentation>Montos Totales del DTE
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="MntNeto" type="ValorType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto Neto del DTE
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MntExe" type="ValorType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto Exento del DTE
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="TasaIVA" type="PctType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Tasa de IVA</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="IVA" type="ValorType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto de IVA del DTE
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="IVAProp" type="ValorType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto del IVA propio
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="IVATerc" type="ValorType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto del IVA de Terceros
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="ImptoReten" minOccurs="0"
																maxOccurs="20">
																<xsd:annotation>
																	<xsd:documentation>Impuestos y Retenciones Adicionales
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:complexType>
																	<xsd:sequence>
																		<xsd:element name="TipoImp" type="ImpAdicDTEType">
																			<xsd:annotation>
																				<xsd:documentation>Tipo de Impuesto o Retencion
																					Adicional
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="TasaImp" type="PctType"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Tasa de Impuesto o Retencion
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="MontoImp" type="MntImpType">
																			<xsd:annotation>
																				<xsd:documentation>Monto del Impuesto o Retencion
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																	</xsd:sequence>
																</xsd:complexType>
															</xsd:element>
															<xsd:element name="Comisiones" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Comisiones y otros cargos es
																		obligatoria para Liquidaciones Factura
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:complexType>
																	<xsd:sequence>
																		<xsd:element name="ValComNeto" type="ValorType"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Valor Neto Comisiones y Otros
																					Cargos
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="ValComExe" type="ValorType"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Val. Comis. y Otros Cargos no
																					Afectos o Exentos
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="ValComIVA" type="ValorType"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Valor IVA Comisiones y Otros
																					Cargos
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																	</xsd:sequence>
																</xsd:complexType>
															</xsd:element>
															<xsd:element name="MntTotal" type="ValorType">
																<xsd:annotation>
																	<xsd:documentation>Monto Total del DTE
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MontoPeriodo" type="ValorType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Total de Ventas o Servicios del
																		Periodo
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="SaldoAnterior" type="ValorType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Saldo Anterior - Puede ser Negativo
																		o
																		Positivo
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="VlrPagar" type="ValorType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Valor a Pagar Total del documento
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
											</xsd:sequence>
										</xsd:complexType>
									</xsd:element>
									<xsd:element name="Detalle" maxOccurs="60">
										<xsd:annotation>
											<xsd:documentation>Detalle de Itemes del Documento
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="NroLinDet">
													<xsd:annotation>
														<xsd:documentation>Numero Secuencial de Linea
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:maxInclusive value="99" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="CdgItem" minOccurs="0"
													maxOccurs="5">
													<xsd:annotation>
														<xsd:documentation>Codificacion del Item
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="TpoCodigo">
																<xsd:annotation>
																	<xsd:documentation>Tipo de Codificacion
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="10" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="VlrCodigo">
																<xsd:annotation>
																	<xsd:documentation>Valor del Codigo de Item, para la
																		Codificacion Particular
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="35" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="TpoDocLiq">
													<xsd:annotation>
														<xsd:documentation>Tipo de Documento que se Liquida
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:minLength value="1" />
															<xsd:maxLength value="3" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="IndExe" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Indicador de Exencion/Facturacion
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:enumeration value="1">
																<xsd:annotation>
																	<xsd:documentation>El Producto o Servicio NO ESTA
																		Afecto a
																		IVA
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="2">
																<xsd:annotation>
																	<xsd:documentation>El Producto o Servicio NO ES
																		Facturable
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="3">
																<xsd:annotation>
																	<xsd:documentation>Garantia por Deposito/Envase
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="4">
																<xsd:annotation>
																	<xsd:documentation>El producto No Constituye Venta
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="5">
																<xsd:annotation>
																	<xsd:documentation>Item a Rebajar</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="6">
																<xsd:annotation>
																	<xsd:documentation>No facturables negativos
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="NmbItem">
													<xsd:annotation>
														<xsd:documentation>Nombre del Item</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="80" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="DscItem" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Descripcion del Item
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="1000" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="QtyRef" type="Dec12_6Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Cantidad para la Unidad de Medida de
															Referencia
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="UnmdRef" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Unidad de Medida de Referencia
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="4" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="PrcRef" type="Dec12_6Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Precio Unitario de Referencia para
															Unidad
															de Referencia
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element
													name="QtyItem" type="Dec12_6Type" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>
															Cantidad del
															Item
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="Subcantidad" minOccurs="0"
													maxOccurs="5">
													<xsd:annotation>
														<xsd:documentation>Distribucion de la Cantidad
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="SubQty" type="Dec12_6Type">
																<xsd:annotation>
																	<xsd:documentation>Cantidad Distribuida
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="SubCod">
																<xsd:annotation>
																	<xsd:documentation>Codigo Descriptivo de la Subcantidad
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="35" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="FchElabor" type="FechaType"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Fecha Elaboracion del Item
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="FchVencim" type="FechaType"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Fecha Vencimiento del Item
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="UnmdItem" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Unidad de Medida</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="4" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="PrcItem" type="Dec12_6Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Precio Unitario del Item en Pesos
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="CodImpAdic" type="ImpAdicDTEType"
													minOccurs="0" maxOccurs="2">
													<xsd:annotation>
														<xsd:documentation>Codigo de Impuesto Adicional o
															Retencion
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="MontoItem" type="ValorType">
													<xsd:annotation>
														<xsd:documentation>Monto por Linea de Detalle. Corresponde
															al
															Monto Neto, a menos que MntBruto Indique lo Contrario
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
											</xsd:sequence>
										</xsd:complexType>
									</xsd:element>
									<xsd:element name="SubTotInfo" minOccurs="0"
										maxOccurs="20">
										<xsd:annotation>
											<xsd:documentation>Subtotales Informativos
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="NroSTI">
													<xsd:annotation>
														<xsd:documentation>Número de Subtotal </xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:maxInclusive value="99" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="GlosaSTI">
													<xsd:annotation>
														<xsd:documentation>Glosa</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="40" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="OrdenSTI" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Ubicación para Impresión
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:maxInclusive value="99" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="SubTotNetoSTI" type="Dec16_2Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Valor Neto del Subtotal
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="SubTotIVASTI" type="Dec16_2Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Valor del IVA del Subtotal
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="SubTotAdicSTI" type="Dec16_2Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Valor de los Impuestos adicionales o
															específicos del Subtotal
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="SubTotExeSTI" type="Dec16_2Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Valor no Afecto o Exento del Subtotal
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="ValSubtotSTI" type="Dec16_2Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Valor de la línea de subtotal
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="LineasDeta" minOccurs="0"
													maxOccurs="60">
													<xsd:annotation>
														<xsd:documentation>TABLA de Líneas de Detalle que se
															agrupan
															en el Subtotal
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger" />
													</xsd:simpleType>
												</xsd:element>
											</xsd:sequence>
										</xsd:complexType>
									</xsd:element>
									<xsd:element name="Referencia" minOccurs="0"
										maxOccurs="40">
										<xsd:annotation>
											<xsd:documentation>Identificacion de otros documentos
												Referenciados por Documento
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="NroLinRef">
													<xsd:annotation>
														<xsd:documentation>Numero Secuencial de Linea de
															Referencia
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:maxInclusive value="99" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="TpoDocRef">
													<xsd:annotation>
														<xsd:documentation>Tipo de Documento de Referencia
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="3" />
															<xsd:minLength value="1" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="IndGlobal" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Indica que se esta Referenciando un
															Conjunto de Documentos
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:nonNegativeInteger">
															<xsd:totalDigits value="1" />
															<xsd:enumeration value="1">
																<xsd:annotation>
																	<xsd:documentation>El Documento hace Referencia a un
																		Conjunto de Documentos Tributarios del Mismo Tipo
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="FolioRef" type="FolioRType">
													<xsd:annotation>
														<xsd:documentation>Folio del Documento de Referencia
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="FchRef" type="FechaType">
													<xsd:annotation>
														<xsd:documentation>Fecha de la Referencia
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="CodRef" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Tipo de Uso de la Referencia
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:enumeration value="1">
																<xsd:annotation>
																	<xsd:documentation>Anula Documento de Referencia
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="2">
																<xsd:annotation>
																	<xsd:documentation>Corrige Texto del Documento de
																		Referencia
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="3">
																<xsd:annotation>
																	<xsd:documentation>Corrige Montos</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="RazonRef" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Razon Explicita por la que se
															Referencia
															el Documento
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="90" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
											</xsd:sequence>
										</xsd:complexType>
									</xsd:element>
									<xsd:element name="Comisiones" minOccurs="0"
										maxOccurs="20">
										<xsd:annotation>
											<xsd:documentation>Comisiones y otros cargos es obligatoria
												para
												Liquidaciones Factura
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="NroLinCom">
													<xsd:annotation>
														<xsd:documentation>Numero Secuencial de Linea
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:maxInclusive value="20" />
															<xsd:totalDigits value="2" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="TipoMovim">
													<xsd:annotation>
														<xsd:documentation>C (comisión) u O (otros cargos)
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:minLength value="1" />
															<xsd:maxLength value="1" />
															<xsd:enumeration value="C" />
															<xsd:enumeration value="O" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="Glosa">
													<xsd:annotation>
														<xsd:documentation>Especificación de la comisión u otro
															cargo
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="60" />
															<xsd:minLength value="1" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="TasaComision" type="PctType"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Valor porcentual de la comisión u otro
															cargo
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="ValComNeto" type="ValorType">
													<xsd:annotation>
														<xsd:documentation>Valor Neto Comisiones y Otros Cargos
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="ValComExe" type="ValorType">
													<xsd:annotation>
														<xsd:documentation>Val. Comis. y Otros Cargos no Afectos o
															Exentos
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="ValComIVA" type="ValorType"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Valor IVA Comisiones y Otros Cargos
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
											</xsd:sequence>
										</xsd:complexType>
									</xsd:element>
									<xsd:element name="TED">
										<xsd:annotation>
											<xsd:documentation>Timbre Electronico de DTE
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="DD">
													<xsd:annotation>
														<xsd:documentation>Datos Basicos de Documento
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="RE" type="RUTType">
																<xsd:annotation>
																	<xsd:documentation>RUT Emisor</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="TD" type="LIQType">
																<xsd:annotation>
																	<xsd:documentation>Tipo DTE</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="F" type="FolioType">
																<xsd:annotation>
																	<xsd:documentation>Folio DTE</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="FE" type="FechaType">
																<xsd:annotation>
																	<xsd:documentation>Fecha Emision DTE en Formato
																		AAAA-MM-DD
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="RR" type="RUTType">
																<xsd:annotation>
																	<xsd:documentation>RUT Receptor</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="RSR">
																<xsd:annotation>
																	<xsd:documentation>Razon Social Receptor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:minLength value="1" />
																		<xsd:maxLength value="40" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element
																name="MNT" type="MontoType">
																<xsd:annotation>
																	<xsd:documentation>
																		Monto
																		Total
																		DTE
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="IT1">
																<xsd:annotation>
																	<xsd:documentation>Descripcion Primer Item de Detalle
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:minLength value="1" />
																		<xsd:maxLength value="40" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CAF">
																<xsd:annotation>
																	<xsd:documentation>Codigo Autorizacion Folios
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:complexType>
																	<xsd:sequence>
																		<xsd:element name="DA">
																			<xsd:annotation>
																				<xsd:documentation>Datos de Autorizacion de Folios
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:complexType>
																				<xsd:sequence>
																					<xsd:element name="RE" type="RUTType">
																						<xsd:annotation>
																							<xsd:documentation>RUT Emisor</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="RS"
																						type="RznSocCortaType">
																						<xsd:annotation>
																							<xsd:documentation>Razon Social Emisor
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="TD" type="LIQType">
																						<xsd:annotation>
																							<xsd:documentation>Tipo DTE</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="RNG">
																						<xsd:annotation>
																							<xsd:documentation>Rango Autorizado de Folios
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:complexType>
																							<xsd:sequence>
																								<xsd:element name="D" type="FolioType">
																									<xsd:annotation>
																										<xsd:documentation>Folio Inicial (Desde)
																										</xsd:documentation>
																									</xsd:annotation>
																								</xsd:element>
																								<xsd:element name="H" type="FolioType">
																									<xsd:annotation>
																										<xsd:documentation>Folio Final (Hasta)
																										</xsd:documentation>
																									</xsd:annotation>
																								</xsd:element>
																							</xsd:sequence>
																						</xsd:complexType>
																					</xsd:element>
																					<xsd:element name="FA" type="FechaType">
																						<xsd:annotation>
																							<xsd:documentation>Fecha Autorizacion en Formato
																								AAAA-MM-DD
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:choice>
																						<xsd:element name="RSAPK">
																							<xsd:annotation>
																								<xsd:documentation>Clave Publica RSA del
																									Solicitante
																								</xsd:documentation>
																							</xsd:annotation>
																							<xsd:complexType>
																								<xsd:sequence>
																									<xsd:element name="M"
																										type="xsd:string">
																										<xsd:annotation>
																											<xsd:documentation>Modulo RSA
																											</xsd:documentation>
																										</xsd:annotation>
																									</xsd:element>
																									<xsd:element name="E"
																										type="xsd:string">
																										<xsd:annotation>
																											<xsd:documentation>Exponente RSA
																											</xsd:documentation>
																										</xsd:annotation>
																									</xsd:element>
																								</xsd:sequence>
																							</xsd:complexType>
																						</xsd:element>
																						<xsd:element name="DSAPK">
																							<xsd:annotation>
																								<xsd:documentation>Clave Publica DSA del
																									Solicitante
																								</xsd:documentation>
																							</xsd:annotation>
																							<xsd:complexType>
																								<xsd:sequence>
																									<xsd:element name="P"
																										type="xsd:base64Binary">
																										<xsd:annotation>
																											<xsd:documentation>Modulo Primo
																											</xsd:documentation>
																										</xsd:annotation>
																									</xsd:element>
																									<xsd:element name="Q"
																										type="xsd:base64Binary">
																										<xsd:annotation>
																											<xsd:documentation>Entero Divisor de P - 1
																											</xsd:documentation>
																										</xsd:annotation>
																									</xsd:element>
																									<xsd:element name="G"
																										type="xsd:base64Binary">
																										<xsd:annotation>
																											<xsd:documentation>Entero f(P, Q)
																											</xsd:documentation>
																										</xsd:annotation>
																									</xsd:element>
																									<xsd:element name="Y"
																										type="xsd:base64Binary">
																										<xsd:annotation>
																											<xsd:documentation>G**X mod P
																											</xsd:documentation>
																										</xsd:annotation>
																									</xsd:element>
																								</xsd:sequence>
																							</xsd:complexType>
																						</xsd:element>
																					</xsd:choice>
																					<xsd:element name="IDK" type="xsd:long">
																						<xsd:annotation>
																							<xsd:documentation>Identificador de Llave
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																				</xsd:sequence>
																			</xsd:complexType>
																		</xsd:element>
																		<xsd:element name="FRMA">
																			<xsd:annotation>
																				<xsd:documentation>Firma Digital (RSA) del SII Sobre
																					DA
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:complexType>
																				<xsd:simpleContent>
																					<xsd:extension base="xsd:string">
																						<xsd:attribute name="algoritmo"
																							type="xsd:string" use="required" fixed="SHA1withRSA" />
																					</xsd:extension>
																				</xsd:simpleContent>
																			</xsd:complexType>
																		</xsd:element>
																	</xsd:sequence>
																	<xsd:attribute name="version" use="required"
																		fixed="1.0" />
																</xsd:complexType>
															</xsd:element>
															<xsd:element name="TSTED" type="FechaHoraType">
																<xsd:annotation>
																	<xsd:documentation>TimeStamp de Generacion del Timbre
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="FRMT">
													<xsd:annotation>
														<xsd:documentation>Valor de Firma Digital sobre DD
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:simpleContent>
															<xsd:extension base="xsd:base64Binary">
																<xsd:attribute name="algoritmo" use="required">
																	<xsd:simpleType>
																		<xsd:restriction base="xsd:string">
																			<xsd:enumeration value="SHA1withRSA" />
																			<xsd:enumeration value="SHA1withDSA" />
																		</xsd:restriction>
																	</xsd:simpleType>
																</xsd:attribute>
															</xsd:extension>
														</xsd:simpleContent>
													</xsd:complexType>
												</xsd:element>
											</xsd:sequence>
											<xsd:attribute name="version" use="required"
												fixed="1.0" />
										</xsd:complexType>
									</xsd:element>
									<xsd:element name="TmstFirma" type="FechaHoraType">
										<xsd:annotation>
											<xsd:documentation>Fecha y Hora en que se Firmo Digitalmente
												el
												Documento AAAA-MM-DDTHH:MI:SS
											</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
								</xsd:sequence>
								<xsd:attribute name="ID" type="xsd:ID" use="required" />
							</xsd:complexType>
						</xsd:element>
						<xsd:element name="Exportaciones">
							<xsd:annotation>
								<xsd:documentation>Informacion Tributaria de exportaciones
								</xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:sequence>
									<xsd:element name="Encabezado">
										<xsd:annotation>
											<xsd:documentation>Identificacion y Totales del Documento
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="IdDoc">
													<xsd:annotation>
														<xsd:documentation>Identificacion del DTE
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="TipoDTE" type="EXPType">
																<xsd:annotation>
																	<xsd:documentation>Tipo de DTE</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="Folio" type="FolioType">
																<xsd:annotation>
																	<xsd:documentation>Folio del Documento Electronico
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="FchEmis" type="FechaType">
																<xsd:annotation>
																	<xsd:documentation>Fecha Emision Contable del DTE
																		(AAAA-MM-DD)
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="TipoDespacho" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Indica Modo de Despacho de los
																		Bienes
																		que Acompanan al DTE
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:enumeration value="1">
																			<xsd:annotation>
																				<xsd:documentation>Despacho por Cuenta del Comprador
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="2">
																			<xsd:annotation>
																				<xsd:documentation>Despacho por Cuenta del Emisor a
																					Instalaciones del Comprador
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="3">
																			<xsd:annotation>
																				<xsd:documentation>Despacho por Cuenta del Emisor a
																					Otras Instalaciones
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="IndServicio" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Indica si Transaccion Corresponde a
																		la
																		Prestacion de un Servicio
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:totalDigits value="1" />
																		<xsd:enumeration value="3">
																			<xsd:annotation>
																				<xsd:documentation>Factura de Servicio
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="4" />
																		<xsd:enumeration value="5" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="FmaPago" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Forma de Pago del DTE
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:enumeration value="1">
																			<xsd:annotation>
																				<xsd:documentation>Pago Contado</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="2">
																			<xsd:annotation>
																				<xsd:documentation>Pago Credito</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="3">
																			<xsd:annotation>
																				<xsd:documentation>Sin Costo</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="FmaPagExp" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Forma de Pago Exportación Tabla
																		Formas
																		de Pago de Aduanas
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:totalDigits value="2" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="FchCancel" type="FechaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Fecha de Cancelacion del DTE
																		(AAAA-MM-DD)
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MntCancel" type="MontoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto Cancelado al emitirse el
																		documento
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="SaldoInsol" type="MontoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Saldo Insoluto al emitirse el
																		documento
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MntPagos" minOccurs="0"
																maxOccurs="30">
																<xsd:annotation>
																	<xsd:documentation>Tabla de Montos de Pago
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:complexType>
																	<xsd:sequence>
																		<xsd:element name="FchPago" type="FechaType">
																			<xsd:annotation>
																				<xsd:documentation>Fecha de Pago (AAAA-MM-DD)
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="MntPago" type="MontoType">
																			<xsd:annotation>
																				<xsd:documentation>Monto de Pago</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="GlosaPagos" minOccurs="0">
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="40" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																	</xsd:sequence>
																</xsd:complexType>
															</xsd:element>
															<xsd:element name="PeriodoDesde" type="FechaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Periodo de Facturacion - Desde
																		(AAAA-MM-DD)
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="PeriodoHasta" type="FechaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Periodo Facturacion - Hasta
																		(AAAA-MM-DD)
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MedioPago" type="MedioPagoType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Medio de Pago</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="TpoCtaPago" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Tipo Cuenta de Pago
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="10" />
																		<xsd:minLength value="5" />
																		<xsd:enumeration value="AHORRO" />
																		<xsd:enumeration value="CORRIENTE" />
																		<xsd:enumeration value="VISTA" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="NumCtaPago" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Número de la cuenta del pago
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="20" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="BcoPago" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Banco donde se realiza el pago
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="40" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="TermPagoCdg" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Codigo del Termino de Pago Acordado
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="4" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="TermPagoGlosa" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Términos del Pago - glosa
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="100" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="TermPagoDias" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Dias de Acuerdo al Codigo de Termino
																		de
																		Pago
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:totalDigits value="3" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="FchVenc" type="FechaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Fecha de Vencimiento del Pago
																		(AAAA-MM-DD)
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="Emisor">
													<xsd:annotation>
														<xsd:documentation>Datos del Emisor</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="RUTEmisor" type="RUTType">
																<xsd:annotation>
																	<xsd:documentation>RUT del Emisor del DTE
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="RznSoc">
																<xsd:annotation>
																	<xsd:documentation>Nombre o Razon Social del Emisor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="100" />
																		<xsd:minLength value="1" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="GiroEmis">
																<xsd:annotation>
																	<xsd:documentation>Giro Comercial del Emisor Relevante
																		para el DTE
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="80" />
																		<xsd:minLength value="1" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="Telefono" minOccurs="0"
																maxOccurs="2">
																<xsd:annotation>
																	<xsd:documentation>Telefono Emisor </xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="FonoType">
																		<xsd:maxLength value="20" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CorreoEmisor" type="MailType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Correo Elect. de contacto en empresa
																		del receptor
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="Acteco" maxOccurs="4">
																<xsd:annotation>
																	<xsd:documentation>Codigo de Actividad Economica del
																		Emisor Relevante para el DTE
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:totalDigits value="6" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="Sucursal" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Sucursal que Emite el DTE
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="20" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CdgSIISucur" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Codigo de Sucursal Entregado por el
																		SII
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:totalDigits value="9" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CodAdicSucur" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Sucursal que Emite el DTE
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="20" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="DirOrigen" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Direccion de Origen
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="70" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CmnaOrigen" type="ComunaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Comuna de Origen</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="CiudadOrigen" type="CiudadType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Ciudad de Origen</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="CdgVendedor" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Codigo del Vendedor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="60" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="IdAdicEmisor" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Identificador Adicional del Emisor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="20" />
																		<xsd:minLength value="1" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="Receptor">
													<xsd:annotation>
														<xsd:documentation>Datos del Receptor</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="RUTRecep" type="RUTType">
																<xsd:annotation>
																	<xsd:documentation>RUT del Receptor del DTE
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="CdgIntRecep" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Codigo Interno del Receptor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="20" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="RznSocRecep" type="RznSocLargaType">
																<xsd:annotation>
																	<xsd:documentation>Nombre o Razon Social del Receptor
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="Extranjero" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Receptor Extranjero
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:complexType>
																	<xsd:sequence>
																		<xsd:element name="NumId" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Num. Identif. Receptor Extranjero
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="20" />
																					<xsd:minLength value="1" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="Nacionalidad"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Nacionalidad Receptor Extranjero
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="3" />
																					<xsd:minLength value="1" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="IdAdicRecep" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Identificador Adicional del
																					Receptor
																					extranjero
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="20" />
																					<xsd:minLength value="1" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																	</xsd:sequence>
																</xsd:complexType>
															</xsd:element>
															<xsd:element name="GiroRecep" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Giro Comercial del Receptor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="40" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="Contacto" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Glosa con nombre o teléfono de
																		contacto
																		en empresa del receptor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="80" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CorreoRecep" type="MailType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Correo Elect. de contacto en empresa
																		del receptor
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="DirRecep" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Direccion en la Cual se Envian los
																		Productos o se Prestan los Servicios
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="70" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CmnaRecep" type="ComunaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Comuna de Recepcion
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="CiudadRecep" type="CiudadType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Ciudad de Recepcion
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="DirPostal" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Direccion Postal</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="70" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CmnaPostal" type="ComunaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Comuna Postal</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="CiudadPostal" type="CiudadType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Ciudad Postal</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="Transporte" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Informacion de Transporte de
															Mercaderias
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="Patente" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Patente del Vehiculo que Transporta
																		los
																		Bienes
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="8" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="RUTTrans" type="RUTType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>RUT del Transportista
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="Chofer" minOccurs="0">
																<xsd:complexType>
																	<xsd:sequence>
																		<xsd:element name="RUTChofer" type="RUTType">
																			<xsd:annotation>
																				<xsd:documentation>RUT del Chofer
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="NombreChofer">
																			<xsd:annotation>
																				<xsd:documentation>Nombre del Chofer
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="30" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																	</xsd:sequence>
																</xsd:complexType>
															</xsd:element>
															<xsd:element name="DirDest" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Direccion de Destino
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="70" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CmnaDest" type="ComunaType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Comuna de Destino
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="CiudadDest" type="CiudadType"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Ciudad de Destino
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="Aduana" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>documentos de Exportación y guías de
																		despacho
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:complexType>
																	<xsd:sequence>
																		<xsd:element name="CodModVenta" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código según tabla "Modalidad de
																					Venta" de aduana
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="2" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="CodClauVenta"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código según Tabla "Cláusula
																					compra-venta" de Aduana
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="2" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="TotClauVenta" type="Dec16_2Type"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Total Cláusula de venta
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="CodViaTransp"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Indicar el Código de la vía de
																					transporte utilizada para transportar la
																					mercadería,
																					según tabla Vías de Transporte de Aduana
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="2" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="NombreTransp"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Nombre o Identificación del Medio
																					de
																					Transporte
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="40" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="RUTCiaTransp" type="RUTType"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Rut Cía. Transportadora
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="NomCiaTransp"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Nombre Cía. Transportadora
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="40" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="IdAdicTransp"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Identificador Adicional Cía.
																					Transportadora
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="20" />
																					<xsd:minLength value="1" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="Booking" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Numero de reserva del Operador
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="20" />
																					<xsd:minLength value="1" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="Operador" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código del Operador
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="20" />
																					<xsd:minLength value="1" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="CodPtoEmbarque"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código del puerto de embarque
																					según
																					tabla de Aduana
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="4" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="IdAdicPtoEmb"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Identificador Adicional Puerto de
																					Embarque
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="20" />
																					<xsd:minLength value="1" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="CodPtoDesemb"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código del puerto de desembarque
																					según tabla de Aduana
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="4" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="IdAdicPtoDesemb"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Identificador Adicional Puerto de
																					Desembarque
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:string">
																					<xsd:maxLength value="20" />
																					<xsd:minLength value="1" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="Tara" minOccurs="0">
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="7" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="CodUnidMedTara"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código de la unidad de medida
																					según
																					tabla de Aduana
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="2" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="PesoBruto" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Sumatoria de los pesos brutos de
																					todos los ítems del documento
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:decimal">
																					<xsd:totalDigits value="10" />
																					<xsd:fractionDigits value="2" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="CodUnidPesoBruto"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código de la unidad de medida
																					según
																					tabla de Aduana
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="2" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="PesoNeto" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Sumatoria de los pesos netos de
																					todos los ítems del documento
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:decimal">
																					<xsd:totalDigits value="10" />
																					<xsd:fractionDigits value="2" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="CodUnidPesoNeto"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código de la unidad de medida
																					según
																					tabla de Aduana
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="2" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="TotItems" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Indique el total de items del
																					documento
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="18" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="TotBultos" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Cantidad total de bultos que
																					ampara
																					el documento.
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="18" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="TipoBultos" minOccurs="0"
																			maxOccurs="10">
																			<xsd:annotation>
																				<xsd:documentation>Tabla de descripción de los
																					distintos tipos de bultos
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:complexType>
																				<xsd:sequence>
																					<xsd:element name="CodTpoBultos"
																						minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Código según tabla "Tipos de
																								Bultos" de aduana
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:simpleType>
																							<xsd:restriction base="xsd:positiveInteger">
																								<xsd:totalDigits value="3" />
																							</xsd:restriction>
																						</xsd:simpleType>
																					</xsd:element>
																					<xsd:element name="CantBultos"
																						minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Cantidad de Bultos
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:simpleType>
																							<xsd:restriction base="xsd:positiveInteger">
																								<xsd:totalDigits value="10" />
																							</xsd:restriction>
																						</xsd:simpleType>
																					</xsd:element>
																					<xsd:element name="Marcas" minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Identificación de marcas,
																								cuando
																								es distinto de contenedor
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:simpleType>
																							<xsd:restriction base="xsd:string">
																								<xsd:maxLength value="255" />
																							</xsd:restriction>
																						</xsd:simpleType>
																					</xsd:element>
																					<xsd:element name="IdContainer"
																						minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Se utiliza cuando el tipo de
																								bulto es contenedor
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:simpleType>
																							<xsd:restriction base="xsd:string">
																								<xsd:maxLength value="25" />
																							</xsd:restriction>
																						</xsd:simpleType>
																					</xsd:element>
																					<xsd:element name="Sello" minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Sello contenedor. Con digito
																								verificador
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:simpleType>
																							<xsd:restriction base="xsd:string">
																								<xsd:maxLength value="20" />
																							</xsd:restriction>
																						</xsd:simpleType>
																					</xsd:element>
																					<xsd:element name="EmisorSello"
																						minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Nombre emisor sello
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:simpleType>
																							<xsd:restriction base="xsd:string">
																								<xsd:maxLength value="70" />
																							</xsd:restriction>
																						</xsd:simpleType>
																					</xsd:element>
																				</xsd:sequence>
																			</xsd:complexType>
																		</xsd:element>
																		<xsd:element name="MntFlete" type="Dec14_4Type"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Monto del flete según moneda de
																					venta
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="MntSeguro" type="Dec14_4Type"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Monto del seguro , según moneda
																					de
																					venta
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="CodPaisRecep"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código del país del receptor
																					extranjero de la mercadería,
																					según tabla Países aduana
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="3" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="CodPaisDestin"
																			minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Código del país de destino
																					extranjero de la mercadería,
																					según tabla Países aduana
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="3" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																	</xsd:sequence>
																</xsd:complexType>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="Totales">
													<xsd:annotation>
														<xsd:documentation>Montos Totales del DTE
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="TpoMoneda" type="TipMonType">
																<xsd:annotation>
																	<xsd:documentation>Tipo de Moneda en que se regisrtra
																		la
																		transacción. Tabla de Monedas de Aduanas
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MntExe">
																<xsd:annotation>
																	<xsd:documentation>Monto Exento del DTE
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:decimal">
																		<xsd:minInclusive value="0.0000" />
																		<xsd:maxInclusive value="99999999999999.9999" />
																		<xsd:totalDigits value="18" />
																		<xsd:fractionDigits value="4" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="MntTotal">
																<xsd:annotation>
																	<xsd:documentation>Monto Total del DTE
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:decimal">
																		<xsd:minInclusive value="0.0000" />
																		<xsd:maxInclusive value="99999999999999.9999" />
																		<xsd:totalDigits value="18" />
																		<xsd:fractionDigits value="4" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="OtraMoneda" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Otra Moneda </xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="TpoMoneda" type="TipMonType">
																<xsd:annotation>
																	<xsd:documentation>Tipo Otra moneda Tabla de Monedas de
																		Aduanas
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="TpoCambio" type="Dec6_4Type"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Tipo de Cambio fijado por el Banco
																		Central de Chile
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MntExeOtrMnda" type="Dec14_4Type"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Monto Exento del DTE en Otra Moneda
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="MntTotOtrMnda" type="Dec14_4Type">
																<xsd:annotation>
																	<xsd:documentation>Monto Total Otra Moneda
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
											</xsd:sequence>
										</xsd:complexType>
									</xsd:element>
									<xsd:element name="Detalle" maxOccurs="60">
										<xsd:annotation>
											<xsd:documentation>Detalle de Itemes del Documento
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="NroLinDet">
													<xsd:annotation>
														<xsd:documentation>Numero Secuencial de Linea
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:maxInclusive value="99" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="CdgItem" minOccurs="0"
													maxOccurs="5">
													<xsd:annotation>
														<xsd:documentation>Codificacion del Item
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="TpoCodigo">
																<xsd:annotation>
																	<xsd:documentation>Tipo de Codificacion
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="10" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="VlrCodigo">
																<xsd:annotation>
																	<xsd:documentation>Valor del Codigo de Item, para la
																		Codificacion Particular
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="35" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="IndExe" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Indicador de Exencion/Facturacion
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:enumeration value="1">
																<xsd:annotation>
																	<xsd:documentation>El Producto o Servicio NO ESTA
																		Afecto a
																		IVA
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="2">
																<xsd:annotation>
																	<xsd:documentation>El Producto o Servicio NO ES
																		Facturable
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="3">
																<xsd:annotation>
																	<xsd:documentation>Garantia por Deposito/Envase
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="4">
																<xsd:annotation>
																	<xsd:documentation>El producto No Constituye Venta
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="5">
																<xsd:annotation>
																	<xsd:documentation>Item a Rebajar</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="6">
																<xsd:annotation>
																	<xsd:documentation>No facturables negativos
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="NmbItem">
													<xsd:annotation>
														<xsd:documentation>Nombre del Item</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="80" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="DscItem" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Descripcion del Item
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="1000" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="QtyRef" type="Dec12_6Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Cantidad para la Unidad de Medida de
															Referencia
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="UnmdRef" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Unidad de Medida de Referencia
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="4" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="PrcRef" type="Dec12_6Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Precio Unitario de Referencia para
															Unidad
															de Referencia
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element
													name="QtyItem" type="Dec12_6Type" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>
															Cantidad del
															Item
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="Subcantidad" minOccurs="0"
													maxOccurs="5">
													<xsd:annotation>
														<xsd:documentation>Distribucion de la Cantidad
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="SubQty" type="Dec12_6Type">
																<xsd:annotation>
																	<xsd:documentation>Cantidad Distribuida
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="SubCod">
																<xsd:annotation>
																	<xsd:documentation>Codigo Descriptivo de la Subcantidad
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="35" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="TipCodSubQty" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Tipo de Código Subcantidad
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="10" />
																		<xsd:minLength value="1" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="FchElabor" type="FechaType"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Fecha Elaboracion del Item
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="FchVencim" type="FechaType"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Fecha Vencimiento del Item
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="UnmdItem" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Unidad de Medida</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="4" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="PrcItem" type="Dec12_6Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Precio Unitario del Item
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="OtrMnda" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Precio del Item en Otra Moneda
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="PrcOtrMon" type="Dec14_4Type">
																<xsd:annotation>
																	<xsd:documentation>Precio Unitario en Otra Moneda
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="Moneda">
																<xsd:annotation>
																	<xsd:documentation>Codigo de Otra Moneda (Usar Codigos
																		de
																		Moneda del Banco Central)
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="3" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="FctConv" type="Dec6_4Type"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Factor para Conversion a Pesos
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="DctoOtrMnda" type="Dec14_4Type"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Descuento en Otra Moneda
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="RecargoOtrMnda" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Recargo en Otra Moneda
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="Dec14_4Type">
																		<xsd:totalDigits value="18" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="MontoItemOtrMnda">
																<xsd:annotation>
																	<xsd:documentation>Valor por línea de detalle en Otra
																		Moneda
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="Dec14_4Type">
																		<xsd:totalDigits value="18" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="DescuentoPct" type="xsd:string"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Porcentaje de Descuento
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="DescuentoMonto" type="MntImpType"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Monto de Descuento</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="SubDscto" minOccurs="0"
													maxOccurs="5">
													<xsd:annotation>
														<xsd:documentation>Desglose del Descuento
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="TipoDscto">
																<xsd:annotation>
																	<xsd:documentation>Tipo de SubDescuento
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:enumeration value="$">
																			<xsd:annotation>
																				<xsd:documentation>Descuento en Monto
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="%">
																			<xsd:annotation>
																				<xsd:documentation>Descuento en Porcentaje
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="ValorDscto" type="Dec16_2Type">
																<xsd:annotation>
																	<xsd:documentation>Valor del SubDescuento
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="RecargoPct" type="PctType"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Porcentaje de Recargo
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="RecargoMonto" type="MntImpType"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Monto de Recargo</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="SubRecargo" minOccurs="0"
													maxOccurs="5">
													<xsd:annotation>
														<xsd:documentation>Desglose del Recargo
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="TipoRecargo">
																<xsd:annotation>
																	<xsd:documentation>Tipo de SubRecargo
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:enumeration value="$">
																			<xsd:annotation>
																				<xsd:documentation>Recargo en Monto
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="%">
																			<xsd:annotation>
																				<xsd:documentation>Recargo en Porcentaje
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="ValorRecargo" type="Dec16_2Type">
																<xsd:annotation>
																	<xsd:documentation>Valor de SubRecargo
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="MontoItem">
													<xsd:annotation>
														<xsd:documentation>Monto por Linea de Detalle. Corresponde
															al
															Monto Neto, a menos que MntBruto Indique lo Contrario
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:decimal">
															<xsd:minInclusive value="0.0000" />
															<xsd:maxInclusive value="99999999999999.9999" />
															<xsd:totalDigits value="18" />
															<xsd:fractionDigits value="4" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
											</xsd:sequence>
										</xsd:complexType>
									</xsd:element>
									<xsd:element name="SubTotInfo" minOccurs="0"
										maxOccurs="20">
										<xsd:annotation>
											<xsd:documentation>Subtotales Informativos
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="NroSTI">
													<xsd:annotation>
														<xsd:documentation>Número de Subtotal </xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:maxInclusive value="99" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="GlosaSTI">
													<xsd:annotation>
														<xsd:documentation>Glosa</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="40" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="OrdenSTI" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Ubicación para Impresión
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:maxInclusive value="99" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="SubTotNetoSTI" type="Dec16_2Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Valor Neto del Subtotal
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="SubTotIVASTI" type="Dec16_2Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Valor del IVA del Subtotal
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="SubTotAdicSTI" type="Dec16_2Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Valor de los Impuestos adicionales o
															específicos del Subtotal
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="SubTotExeSTI" type="Dec16_2Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Valor no Afecto o Exento del Subtotal
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="ValSubtotSTI" type="Dec16_2Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Valor de la línea de subtotal
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="LineasDeta" minOccurs="0"
													maxOccurs="60">
													<xsd:annotation>
														<xsd:documentation>TABLA de Líneas de Detalle que se
															agrupan
															en el Subtotal
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger" />
													</xsd:simpleType>
												</xsd:element>
											</xsd:sequence>
										</xsd:complexType>
									</xsd:element>
									<xsd:element name="DscRcgGlobal" minOccurs="0"
										maxOccurs="20">
										<xsd:annotation>
											<xsd:documentation>Descuentos y/o Recargos que afectan al
												total
												del Documento
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="NroLinDR" type="xsd:positiveInteger">
													<xsd:annotation>
														<xsd:documentation>Numero Secuencial de Linea
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="TpoMov">
													<xsd:annotation>
														<xsd:documentation>Tipo de Movimiento</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:enumeration value="D">
																<xsd:annotation>
																	<xsd:documentation>Descuento</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="R">
																<xsd:annotation>
																	<xsd:documentation>Recargo</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="GlosaDR" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Descripcion del Descuento o Recargo
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="45" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="TpoValor">
													<xsd:annotation>
														<xsd:documentation>Unidad en que se Expresa el Valor
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:enumeration value="%">
																<xsd:annotation>
																	<xsd:documentation>El valor se Expresa como Porcentaje
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="$">
																<xsd:annotation>
																	<xsd:documentation>El Valor se Expresa en Pesos
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element
													name="ValorDR" type="Dec16_2Type">
													<xsd:annotation>
														<xsd:documentation>
															Valor del
															Descuento o
															Recargo
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element
													name="ValorDROtrMnda" type="Dec14_4Type"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>
															Valor en
															otra moneda
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="IndExeDR" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Indica si el D/R es No Afecto o No
															Facturable
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:enumeration value="1">
																<xsd:annotation>
																	<xsd:documentation>Descuento/Recargo Global No Afecto
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="2">
																<xsd:annotation>
																	<xsd:documentation>Descuento/Recargo No Facturable
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
											</xsd:sequence>
										</xsd:complexType>
									</xsd:element>
									<xsd:element name="Referencia" minOccurs="0"
										maxOccurs="40">
										<xsd:annotation>
											<xsd:documentation>Identificacion de otros documentos
												Referenciados por Documento
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="NroLinRef">
													<xsd:annotation>
														<xsd:documentation>Numero Secuencial de Linea de
															Referencia
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:maxInclusive value="99" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="TpoDocRef">
													<xsd:annotation>
														<xsd:documentation>Tipo de Documento de Referencia
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="3" />
															<xsd:minLength value="1" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="IndGlobal" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Indica que se esta Referenciando un
															Conjunto de Documentos
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:nonNegativeInteger">
															<xsd:totalDigits value="1" />
															<xsd:enumeration value="1">
																<xsd:annotation>
																	<xsd:documentation>El Documento hace Referencia a un
																		Conjunto de Documentos Tributarios del Mismo Tipo
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="FolioRef" type="FolioRType">
													<xsd:annotation>
														<xsd:documentation>Folio del Documento de Referencia
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="RUTOtr" type="RUTType"
													minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>RUT Otro Contribuyente
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<xsd:element name="IdAdicOtr" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Identificador Adicional del otro
															contribuyente
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="20" />
															<xsd:minLength value="1" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="FchRef">
													<xsd:annotation>
														<xsd:documentation>Fecha de la Referencia
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:date">
															<xsd:minInclusive value="1950-01-01" />
															<xsd:maxInclusive value="2050-12-31" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="CodRef" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Tipo de Uso de la Referencia
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:positiveInteger">
															<xsd:enumeration value="1">
																<xsd:annotation>
																	<xsd:documentation>Anula Documento de Referencia
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="2">
																<xsd:annotation>
																	<xsd:documentation>Corrige Texto del Documento de
																		Referencia
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
															<xsd:enumeration value="3">
																<xsd:annotation>
																	<xsd:documentation>Corrige Montos</xsd:documentation>
																</xsd:annotation>
															</xsd:enumeration>
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
												<xsd:element name="RazonRef" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Razon Explicita por la que se
															Referencia
															el Documento
														</xsd:documentation>
													</xsd:annotation>
													<xsd:simpleType>
														<xsd:restriction base="xsd:string">
															<xsd:maxLength value="90" />
														</xsd:restriction>
													</xsd:simpleType>
												</xsd:element>
											</xsd:sequence>
										</xsd:complexType>
									</xsd:element>
									<xsd:element name="TED">
										<xsd:annotation>
											<xsd:documentation>Timbre Electronico de DTE
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="DD">
													<xsd:annotation>
														<xsd:documentation>Datos Basicos de Documento
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="RE" type="RUTType">
																<xsd:annotation>
																	<xsd:documentation>RUT Emisor</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="TD" type="EXPType">
																<xsd:annotation>
																	<xsd:documentation>Tipo DTE</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="F" type="FolioType">
																<xsd:annotation>
																	<xsd:documentation>Folio DTE</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="FE" type="FechaType">
																<xsd:annotation>
																	<xsd:documentation>Fecha Emision DTE en Formato
																		AAAA-MM-DD
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="RR" type="RUTType">
																<xsd:annotation>
																	<xsd:documentation>RUT Receptor</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="RSR">
																<xsd:annotation>
																	<xsd:documentation>Razon Social Receptor
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:minLength value="1" />
																		<xsd:maxLength value="40" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="MNT">
																<xsd:annotation>
																	<xsd:documentation>Monto Total DTE</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:decimal">
																		<xsd:minInclusive value="0.0000" />
																		<xsd:maxInclusive value="99999999999999.9999" />
																		<xsd:totalDigits value="18" />
																		<xsd:fractionDigits value="4" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="IT1">
																<xsd:annotation>
																	<xsd:documentation>Descripcion Primer Item de Detalle
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:minLength value="1" />
																		<xsd:maxLength value="40" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="CAF">
																<xsd:annotation>
																	<xsd:documentation>Codigo Autorizacion Folios
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:complexType>
																	<xsd:sequence>
																		<xsd:element name="DA">
																			<xsd:annotation>
																				<xsd:documentation>Datos de Autorizacion de Folios
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:complexType>
																				<xsd:sequence>
																					<xsd:element name="RE" type="RUTType">
																						<xsd:annotation>
																							<xsd:documentation>RUT Emisor</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="RS">
																						<xsd:annotation>
																							<xsd:documentation>Razon Social Emisor
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:simpleType>
																							<xsd:restriction base="xsd:string">
																								<xsd:minLength value="1" />
																								<xsd:maxLength value="40" />
																							</xsd:restriction>
																						</xsd:simpleType>
																					</xsd:element>
																					<xsd:element name="TD" type="EXPType">
																						<xsd:annotation>
																							<xsd:documentation>Tipo DTE</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="RNG">
																						<xsd:annotation>
																							<xsd:documentation>Rango Autorizado de Folios
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:complexType>
																							<xsd:sequence>
																								<xsd:element name="D" type="FolioType">
																									<xsd:annotation>
																										<xsd:documentation>Folio Inicial (Desde)
																										</xsd:documentation>
																									</xsd:annotation>
																								</xsd:element>
																								<xsd:element name="H" type="FolioType">
																									<xsd:annotation>
																										<xsd:documentation>Folio Final (Hasta)
																										</xsd:documentation>
																									</xsd:annotation>
																								</xsd:element>
																							</xsd:sequence>
																						</xsd:complexType>
																					</xsd:element>
																					<xsd:element name="FA" type="FechaType">
																						<xsd:annotation>
																							<xsd:documentation>Fecha Autorizacion en Formato
																								AAAA-MM-DD
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:choice>
																						<xsd:element name="RSAPK">
																							<xsd:annotation>
																								<xsd:documentation>Clave Publica RSA del
																									Solicitante
																								</xsd:documentation>
																							</xsd:annotation>
																							<xsd:complexType>
																								<xsd:sequence>
																									<xsd:element name="M"
																										type="xsd:string">
																										<xsd:annotation>
																											<xsd:documentation>Modulo RSA
																											</xsd:documentation>
																										</xsd:annotation>
																									</xsd:element>
																									<xsd:element name="E"
																										type="xsd:string">
																										<xsd:annotation>
																											<xsd:documentation>Exponente RSA
																											</xsd:documentation>
																										</xsd:annotation>
																									</xsd:element>
																								</xsd:sequence>
																							</xsd:complexType>
																						</xsd:element>
																						<xsd:element name="DSAPK">
																							<xsd:annotation>
																								<xsd:documentation>Clave Publica DSA del
																									Solicitante
																								</xsd:documentation>
																							</xsd:annotation>
																							<xsd:complexType>
																								<xsd:sequence>
																									<xsd:element name="P"
																										type="xsd:base64Binary">
																										<xsd:annotation>
																											<xsd:documentation>Modulo Primo
																											</xsd:documentation>
																										</xsd:annotation>
																									</xsd:element>
																									<xsd:element name="Q"
																										type="xsd:base64Binary">
																										<xsd:annotation>
																											<xsd:documentation>Entero Divisor de P - 1
																											</xsd:documentation>
																										</xsd:annotation>
																									</xsd:element>
																									<xsd:element name="G"
																										type="xsd:base64Binary">
																										<xsd:annotation>
																											<xsd:documentation>Entero f(P, Q)
																											</xsd:documentation>
																										</xsd:annotation>
																									</xsd:element>
																									<xsd:element name="Y"
																										type="xsd:base64Binary">
																										<xsd:annotation>
																											<xsd:documentation>G**X mod P
																											</xsd:documentation>
																										</xsd:annotation>
																									</xsd:element>
																								</xsd:sequence>
																							</xsd:complexType>
																						</xsd:element>
																					</xsd:choice>
																					<xsd:element name="IDK" type="xsd:long">
																						<xsd:annotation>
																							<xsd:documentation>Identificador de Llave
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																				</xsd:sequence>
																			</xsd:complexType>
																		</xsd:element>
																		<xsd:element name="FRMA">
																			<xsd:annotation>
																				<xsd:documentation>Firma Digital (RSA) del SII Sobre
																					DA
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:complexType>
																				<xsd:simpleContent>
																					<xsd:extension base="xsd:string">
																						<xsd:attribute name="algoritmo"
																							type="xsd:string" use="required" fixed="SHA1withRSA" />
																					</xsd:extension>
																				</xsd:simpleContent>
																			</xsd:complexType>
																		</xsd:element>
																	</xsd:sequence>
																	<xsd:attribute name="version" use="required"
																		fixed="1.0" />
																</xsd:complexType>
															</xsd:element>
															<xsd:element name="TSTED" type="FechaHoraType">
																<xsd:annotation>
																	<xsd:documentation>TimeStamp de Generacion del Timbre
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="FRMT">
													<xsd:annotation>
														<xsd:documentation>Valor de Firma Digital sobre DD
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:simpleContent>
															<xsd:extension base="xsd:base64Binary">
																<xsd:attribute name="algoritmo" use="required">
																	<xsd:simpleType>
																		<xsd:restriction base="xsd:string">
																			<xsd:enumeration value="SHA1withRSA" />
																			<xsd:enumeration value="SHA1withDSA" />
																		</xsd:restriction>
																	</xsd:simpleType>
																</xsd:attribute>
															</xsd:extension>
														</xsd:simpleContent>
													</xsd:complexType>
												</xsd:element>
											</xsd:sequence>
											<xsd:attribute name="version" use="required"
												fixed="1.0" />
										</xsd:complexType>
									</xsd:element>
									<xsd:element name="TmstFirma" type="FechaHoraType">
										<xsd:annotation>
											<xsd:documentation>Fecha y Hora en que se Firmo Digitalmente
												el
												Documento AAAA-MM-DDTHH:MI:SS
											</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
								</xsd:sequence>
								<xsd:attribute name="ID" type="xsd:ID" use="required" />
							</xsd:complexType>
						</xsd:element>
					</xsd:choice>
				</xsd:sequence>
				<xsd:attribute name="version" type="xsd:decimal" use="required"
					fixed="1.0" />
			</xsd:complexType>

			<!-- Default Schema-modified as per EnvioDTE_v10.xsd -->
	
			<xsd:element name="EnvioDTE" type="EnvioDTE" />
			<xsd:complexType name="EnvioDTE">
				<xsd:sequence>
					<xsd:element name="SetDTE" type="SetDTE">
					</xsd:element>

				</xsd:sequence>
				<xsd:attribute name="version" type="xsd:decimal" use="required"
					fixed="1.0" />
			</xsd:complexType>
			<xsd:complexType name="SetDTE">
				<xsd:sequence>					
					<xsd:element name="Caratula" type="Caratula">
					</xsd:element>
					<xsd:element name="DTE" type="DTEDefType" maxOccurs="unbounded">
						<xsd:annotation>
							<xsd:documentation>
								Documento Tributario Electronico
							</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
				</xsd:sequence>
				<xsd:attribute name="ID" type="xsd:ID" use="required" />
			</xsd:complexType>
			<xsd:complexType name="Caratula">
				<xsd:sequence>
					<xsd:element name="RutEmisor">
						<xsd:simpleType>
							<xsd:restriction base="RUTType" />
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="RutEnvia" type="RUTType">
						<xsd:annotation>
							<xsd:documentation>
								RUT que envia los DTE
							</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="RutReceptor"
						type="RUTType">
						<xsd:annotation>
							<xsd:documentation>
								RUT al que se le envian los DTE
							</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="FchResol" type="FechaType">
						<xsd:annotation>
							<xsd:documentation>
								Fecha de Resolucion que Autoriza el
								Envio de DTE (AAAA-MM-DD)
							</xsd:documentation>
							<xsd:documentation>
								Fecha de Resolucion que Autoriza el
								Envio de DTE (AAAA-MM-DD)
							</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="NroResol"
						type="NroResolType">
						<xsd:annotation>
							<xsd:documentation>
								Numero de Resolucion que Autoriza el
								Envio de DTE
							</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="TmstFirmaEnv"
						type="FechaHoraType">
						<xsd:annotation>
							<xsd:documentation>
								Fecha y Hora de la Firma del Archivo de
								Envio
							</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="SubTotDTE" maxOccurs="20"
						type="SubTotDTE">
					</xsd:element>
				</xsd:sequence>
				<xsd:attribute name="version" type="xsd:decimal" use="required"
					fixed="1.0" />
			</xsd:complexType>
			<xsd:complexType name="SubTotDTE">
				<xsd:sequence>
					<xsd:element name="TpoDTE" type="DOCType">
						<xsd:annotation>
							<xsd:documentation>
								Tipo de DTE
								Enviado
							</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="NroDTE" type="xsd:positiveInteger">
						<xsd:annotation>
							<xsd:documentation>
