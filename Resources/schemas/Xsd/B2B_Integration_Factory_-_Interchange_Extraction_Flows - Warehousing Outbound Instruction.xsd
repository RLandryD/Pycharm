   </xsd:complexType>
   <xsd:complexType name="EcomStringAttributeValuePairListType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">An attribute value pair that allows for a string and optionally an associated qualifier (e.g. Unit of Measure).</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="xsd:string">
            <xsd:attribute name="attributeName" use="required" type="String70Type">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: MyNewTax</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">The name of the temporary attribute being introduced as an attribute value pair.</xsd:documentation>
               </xsd:annotation>
            </xsd:attribute>
            <xsd:attribute name="qualifierCodeName" type="String70Type">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: EUR</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">The value of the attribute qualifier associated with the codeListName</xsd:documentation>
               </xsd:annotation>
            </xsd:attribute>
            <xsd:attribute name="qualifierCodeList" type="String70Type">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: CurrencyCode</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">The code list qualifying the temporary attribute</xsd:documentation>
               </xsd:annotation>
            </xsd:attribute>
            <xsd:attribute name="qualifierCodeListVersion" type="String70Type">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">The version of the code list qualifying the temporary attribute.</xsd:documentation>
               </xsd:annotation>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="Ecom_AttributeValuePairListType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">The placeholder for non-standard data.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="eComStringAttributeValuePairList" minOccurs="0" maxOccurs="unbounded"
            type="EcomStringAttributeValuePairListType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">E Com String Attribute Value Pair List</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
