	xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/" xmlns:xsd="http://www.w3.org/2001/XMLSchema"
	name="eDocPeruDocumentTransmission" targetNamespace="http://www.sap.com/eDocument/Peru/DocumentTransmission/v1.0"
	xmlns:dn="urn:oasis:names:specification:ubl:schema:xsd:DebitNote-2"
	xmlns:in="urn:oasis:names:specification:ubl:schema:xsd:Invoice-2"
