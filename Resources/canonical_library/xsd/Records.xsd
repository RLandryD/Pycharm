                    <xs:sequence>
                      <xs:element name="UniqueName" type="xs:string"  maxOccurs="1" minOccurs="0"/>
                    </xs:sequence>
                  </xs:complexType>
                </xs:element>
                <xs:element name="OrderID"  maxOccurs="1" minOccurs="0"/>
                <xs:element name="SplitAccountings" maxOccurs="unbounded" minOccurs="0">
                  <xs:complexType>
                    <xs:sequence>
                      <xs:element name="NumberInCollection" type="xs:unsignedByte"  maxOccurs="1" minOccurs="0"/>
                      <xs:element name="WBSElement"  maxOccurs="1" minOccurs="0"/>
                      <xs:element name="CostCenter" maxOccurs="1" minOccurs="0">
                        <xs:complexType>
                          <xs:sequence>
                            <xs:element name="ProcurementUnit" maxOccurs="1" minOccurs="0">
                              <xs:complexType>
                                <xs:sequence>
                                  <xs:element name="UniqueName" type="xs:string"  maxOccurs="1" minOccurs="0"/>
                                </xs:sequence>
                              </xs:complexType>
                            </xs:element>
                            <xs:element name="UniqueName" type="xs:unsignedByte"  maxOccurs="1" minOccurs="0"/>
                            <xs:element name="CompanyCode" maxOccurs="1" minOccurs="0">
                              <xs:complexType>
                                <xs:sequence>
                                  <xs:element name="UniqueName" type="xs:unsignedByte"  maxOccurs="1" minOccurs="0"/>
                                </xs:sequence>
                              </xs:complexType>
                            </xs:element>
                            <xs:element name="CostCenterDescription"  maxOccurs="1" minOccurs="0"/>
                          </xs:sequence>
                        </xs:complexType>
                      </xs:element>
                      <xs:element name="Percentage" type="xs:decimal"  maxOccurs="1" minOccurs="0"/>
                      <xs:element name="Amount" maxOccurs="1" minOccurs="0">
                        <xs:complexType>
                          <xs:sequence>
                            <xs:element name="AmountInReportingCurrency" type="xs:decimal"  maxOccurs="1" minOccurs="0"/>
                            <xs:element name="ApproxAmountInBaseCurrency" type="xs:decimal" maxOccurs="1" minOccurs="0"/>
                            <xs:element name="Amount" type="xs:decimal" maxOccurs="1" minOccurs="0"/>
                            <xs:element name="ConversionDate" type="xs:dateTime" maxOccurs="1" minOccurs="0"/>
                            <xs:element name="Currency" maxOccurs="1" minOccurs="0">
