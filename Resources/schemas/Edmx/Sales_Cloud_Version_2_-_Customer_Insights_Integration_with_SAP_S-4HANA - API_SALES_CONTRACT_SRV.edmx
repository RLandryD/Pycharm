       </Record>
      </PropertyValue>
     </Record>
    </Annotation>
   </Annotations>
   <Annotations Target="API_SALES_CONTRACT_SRV.API_SALES_CONTRACT_SRV_Entities/A_SalesContract" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Capabilities.InsertRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Creates a sales contract."/>
      <PropertyValue Property="LongDescription" String="Creates a header of a sales contract. The consumer can use deep insert requests. This means the consumer can include the following entities in the payload:header partner, header pricing element, sales contract item, item partner, and item pricing element."/>
     </Record>
    </Annotation>
   </Annotations>
