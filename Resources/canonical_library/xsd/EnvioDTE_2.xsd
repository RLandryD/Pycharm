					<xsd:enumeration value="34">
						<xsd:annotation>
							<xsd:documentation>Factura Electronica No Afecta o Exenta
							</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="46">
						<xsd:annotation>
							<xsd:documentation>Factura de Compra Electronica
							</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="52">
						<xsd:annotation>
							<xsd:documentation>Guia de Despacho Electronica
							</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="56" />
					<xsd:enumeration value="61" />
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="MailType">
				<xsd:annotation>
					<xsd:documentation>Dirección email</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:string">
					<xsd:maxLength value="80" />
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="DineroPorcentajeType">
				<xsd:annotation>
					<xsd:documentation>Unidad en que se expresa el Valor
					</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:string">
					<xsd:minLength value="1" />
					<xsd:maxLength value="1" />
					<xsd:enumeration value="%">
						<xsd:annotation>
							<xsd:documentation>El valor se Expresa como Porcentaje
							</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="$">
						<xsd:annotation>
							<xsd:documentation>El Valor se Expresa en Pesos
							</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="NroResolType">
				<xsd:annotation>
					<xsd:documentation>Número de Resolución</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:nonNegativeInteger">
					<xsd:totalDigits value="6" />
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="RznSocLargaType">
				<xsd:annotation>
					<xsd:documentation>Razón Social (max 100)</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:string">
					<xsd:maxLength value="100" />
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="RznSocCortaType">
				<xsd:annotation>
					<xsd:documentation>Razón Social (max 40)</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:string">
					<xsd:maxLength value="40" />
					<xsd:minLength value="1" />
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="DireccSoloDTEType">
				<xsd:annotation>
					<xsd:documentation>Dirección (maz 60)</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:string">
					<xsd:maxLength value="60" />
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="DireccType">
				<xsd:annotation>
					<xsd:documentation>Dirección (max 80)</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:string">
					<xsd:maxLength value="80" />
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="ComunaType">
				<xsd:annotation>
					<xsd:documentation>Comuna</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:string">
					<xsd:maxLength value="20" />
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="CiudadType">
				<xsd:annotation>
					<xsd:documentation>Ciudad</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:string">
					<xsd:maxLength value="20" />
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="FonoType">
				<xsd:annotation>
					<xsd:documentation>Fono</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:string">
					<xsd:maxLength value="40" />
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="NombreType">
				<xsd:annotation>
					<xsd:documentation>Nombre</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:string">
					<xsd:maxLength value="40" />
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="LIQType">
				<xsd:annotation>
					<xsd:documentation>Tipos de Liquidaciones </xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:positiveInteger">
					<xsd:enumeration value="43" />
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="EXPType">
				<xsd:annotation>
					<xsd:documentation>Tipos de Facturas de Exportacion
					</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:positiveInteger">
					<xsd:enumeration value="110" />
					<xsd:enumeration value="111" />
					<xsd:enumeration value="112" />
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="MedioPagoType">
				<xsd:annotation>
					<xsd:documentation>Medios de Pago</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:string">
					<xsd:enumeration value="CH">
						<xsd:annotation>
							<xsd:documentation>Cheque</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="LT">
						<xsd:annotation>
							<xsd:documentation>Letra</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="EF">
						<xsd:annotation>
							<xsd:documentation>Efectivo</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="PE">
						<xsd:annotation>
							<xsd:documentation>Pago a Cuenta Corriente</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="TC">
						<xsd:annotation>
							<xsd:documentation>Tarjeta de Credito</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="CF">
						<xsd:annotation>
							<xsd:documentation>Cheque a Fecha</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="OT">
						<xsd:annotation>
							<xsd:documentation>Otro</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:attribute name="version" type="xsd:decimal" fixed="1.0" />
			<xsd:simpleType name="TipMonType">
				<xsd:annotation>
					<xsd:documentation>Tipos de Moneda de Aduana</xsd:documentation>
				</xsd:annotation>
