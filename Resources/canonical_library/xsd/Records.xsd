                            </xs:element>
                          </xs:sequence>
                        </xs:complexType>
                      </xs:element>
                      <xs:element name="GeneralLedger" maxOccurs="1" minOccurs="0">
                        <xs:complexType>
                          <xs:sequence>
                            <xs:element name="GeneralLedgerDescription" type="xs:string" maxOccurs="1" minOccurs="0"/>
                            <xs:element name="GeneralLedgerDescription2" maxOccurs="1" minOccurs="0"/>
                            <xs:element name="UniqueName" type="xs:unsignedInt" maxOccurs="1" minOccurs="0"/>
