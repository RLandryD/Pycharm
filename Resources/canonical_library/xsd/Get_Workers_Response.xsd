<xsd:annotation>
<xsd:documentation>Worker who verified the ID.</xsd:documentation>
<xsd:appinfo>
<wd:Validation>
<wd:Validation_Message>Select a different worker in the Verified By field. The worker you entered was terminated before the Verification Date: [date].</wd:Validation_Message>
</wd:Validation>
</xsd:appinfo>
</xsd:annotation>
</xsd:element>
