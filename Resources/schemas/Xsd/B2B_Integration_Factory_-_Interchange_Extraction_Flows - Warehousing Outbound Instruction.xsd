         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="TransactionalGenericReferenceType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Reference to an associated information in support of related business processes. The type of references are defined in the TransactionalReferenceTypeCode list.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="transactionalReferenceTypeCode"
