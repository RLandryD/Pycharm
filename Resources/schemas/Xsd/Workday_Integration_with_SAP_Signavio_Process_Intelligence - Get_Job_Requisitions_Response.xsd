<xsd:annotation>
<xsd:documentation>Questionnaires to be used by Job Requisition for Internal and External Career Site Job Postings. For use by Recruiting customers only.</xsd:documentation>
<xsd:appinfo>
<wd:Validation>
<wd:Validation_Message>Select a primary questionnaire before selecting a secondary one.</wd:Validation_Message>
</wd:Validation>
</xsd:appinfo>
</xsd:annotation>
<xsd:sequence>
