         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="DeliverDateInformationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Provides the date information for the shipment.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="deliverDate" type="xsd:date">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Deliver Date</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The date on which the shipment is delivered.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="deliverDateType" type="DeliverDateTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Deliver Date Type</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A code identifying the type of date on which goods or services will or have been delivered. specifying a deliver date type. Allowed code values are specified in GS1 Code List DeliverDateTypeCode.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="DeliverDateTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a deliver date type. Allowed code values are specified in GS1 Code List DeliverDateTypeCode.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:DeliverDateTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: DELIVER_BY</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="DeliverDateTypeCode">
