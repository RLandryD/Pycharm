<?xml version="1.0" encoding="UTF-8"?>
<!--
  SCENARIO iFlow: Sync Selected Fulfillment Orders from SAP S4HANA to Amazon
  Display Name : OUT_S4HANA_Amazon_Cancel_Sync_Selected_Fulfil
  Package      : 1_S4HANA_Amazon_Cancel_Finance
  Strategy     : GREENFIELD: Clean cloud-native rebuild. No legacy mapping reuse.
  Complexity   : HIGH (score: 68)
  Effort       : 20.9 day(s)
  Sender       : S4HANA (SOAP)
  Receiver     : Amazon_Cancel (ProcessDirect)
  Batch        : No
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Sync_Selected_Fulfil"
             name="OUT_S4HANA_Amazon_Cancel_Sync_Selected_Fulfil">
  <process id="Sync_Selected_Fulfil_process" ifl:type="IntegrationFlow">

    <startEvent id="Start_SC" name="From Interface Separation">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Sync_Selected_Fulfil</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>



    <!-- PROCESSDIRECT: Forward to Outbound Delivery -->
    <serviceTask id="CallOutbound_1" name="→ Outbound Delivery" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/outbound/1_S4HANA_Amazon_Canc</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_SC"/>
    <sequenceFlow sourceRef="Start_SC" targetRef="CallOutbound_1"/>
    
    
    <sequenceFlow sourceRef="CallOutbound_1" targetRef="End_SC"/>
  </process>
</definitions>