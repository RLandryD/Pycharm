																		<xs:restriction
																			base="xs:string">
																			<xs:minLength
																				value="1" />
																			<xs:whiteSpace
																				value="collapse" />
																		</xs:restriction>
																	</xs:simpleType>
																</xs:attribute>
																<xs:attribute
																	name="EmpresaTransporte" use="required">
