      <xs:element type="xs:string" name="NameTranslated"/>
    </xs:sequence>
  </xs:complexType>
  <xs:complexType name="SelectedMarketType">
    <xs:sequence>
      <xs:element type="xs:string" name="CurrencyCode"/>
      <xs:element type="xs:string" name="CurrencyDescription"/>
