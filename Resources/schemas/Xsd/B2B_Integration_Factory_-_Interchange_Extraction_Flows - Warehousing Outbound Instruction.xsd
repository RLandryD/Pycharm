         <xsd:element name="shipper" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Shipper</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A party which engages in shipping this shipment of goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="receiver" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Receiver</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A party which engages in receiving this shipment of goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="buyer" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Buyer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifies the party to which products or services are sold.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="seller" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Seller</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifies the party which sells products or services to a buyer.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="shipFrom" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Ship From</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The physical location from where goods will be or have been shipped.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="shipTo" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Ship To</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The physical location to where goods will be or have been shipped.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="inventoryLocation" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inventory Location</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identification of the location (premises) where the goods will be stored.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="ultimateConsignee" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Ultimate Consignee</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifies the party that is the final destination for the shipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="logisticUnit" minOccurs="0" maxOccurs="unbounded"
            type="LogisticUnitType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Logistic Unit</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The logistic units contained in the shipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="administrativeUnit" minOccurs="0" maxOccurs="unbounded"
            type="AdministrativeUnitType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Administrative Unit</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">On or more administrative units related to the shipment.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="deliveryTerms" minOccurs="0" type="DeliveryTermsType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Delivery Terms</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The applicable legal, customs, financial and insurance terms that have been agreed for the shipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transactionalReference" minOccurs="0" maxOccurs="unbounded"
            type="TransactionalReferenceType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transactional Reference</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">One or more references to associated information in support of related business processes. E.g. a purchase order, a return authorization number.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transportCargoCharacteristics" minOccurs="0"
            type="TransportCargoCharacteristicsType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transport Cargo Characteristics</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Aggregate information on the goods that are contained in this shipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="packageTotal" minOccurs="0" maxOccurs="unbounded"
            type="PackageTotalType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Package Total</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Aggregate information per type of package contained in the shipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="handlingInstruction" minOccurs="0" maxOccurs="unbounded"
            type="HandlingInstructionType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Handling Instruction</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">One or more instructions on the way to treat the goods during transport and storage.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:simpleType name="Language">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">: ISO 639-2; 1998 representation of Language name. Refer to
        http://www.loc.gov/standards/iso639-2/iso639jac.html to get the latest version of the
        standard.</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string"/>
   </xsd:simpleType>
   <xsd:simpleType name="MimeTypeQualifier">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">:  The MIME type as defined by IANA. Please refer to
        http://www.iana.org/assignments/media-types/ for a list of types. </xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string"/>
   </xsd:simpleType>
   <xsd:simpleType name="TypeOfServiceTransaction">
      <xsd:restriction base="xsd:string">
         <xsd:enumeration value="RequestingServiceTransaction"/>
         <xsd:enumeration value="RespondingServiceTransaction"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="AllowanceOrChargeEnumerationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">N/A</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: CHARGE</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:enumeration value="ALLOWANCE"/>
         <xsd:enumeration value="CHARGE"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="DayOfTheWeekEnumerationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">N/A</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: MONDAY</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:enumeration value="FRIDAY"/>
         <xsd:enumeration value="MONDAY"/>
         <xsd:enumeration value="SATURDAY"/>
         <xsd:enumeration value="SUNDAY"/>
         <xsd:enumeration value="THURSDAY"/>
         <xsd:enumeration value="TUESDAY"/>
         <xsd:enumeration value="WEDNESDAY"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="DocumentActionEnumerationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the action to be taken in the system of the recipient using the information in the document.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: ADD</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:enumeration value="ADD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Definition">The creation of a new document.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CHANGE_BY_REFRESH">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Definition">A change on a previously sent document by sending the entire updated document.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DELETE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Definition">The deletion of a previously sent document.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="DocumentStatusEnumerationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Indicates if the document is a copy or an original.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: ORIGINAL</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:enumeration value="ADDITIONAL_TRANSMISSION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Definition">Message already transmitted via another communication channel. This transmission provides electronically processable data only. The French tax authorities ask to distinguish the different transmission modes for the invoices in case of control.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="COPY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Definition">A copy of the original document issued by the sender.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ORIGINAL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Definition">The original document issued by the sender.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="EnumerationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">N/A</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string"/>
   </xsd:simpleType>
   <xsd:simpleType name="GenderEnumerationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">N/A</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: FEMALE</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:enumeration value="FEMALE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Definition">Female</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MALE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Definition">Male</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="GIAIType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Global Individual Asset Identifier (GIAI), the GS1 key used for the identification of individual assets.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: More information about the Global Individual Asset Identifier can be found here: http://www.gs1.org/global-individual-asset-identifier-giai</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 3184208957635</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:pattern value="[-!&quot;%&amp;'()*+,./0-9:;&lt;=>?A-Z_a-z]{4,30}"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="GINCType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Global Identification Number for Consignment (GINC), the GS1 key used for the identification of consignments.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: More information about the Global Identification Number for Consignment can be found here: http://www.gs1.org/global-identification-number-consignment-ginc</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 7365566156191234567</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:pattern value="[-!&quot;%&amp;'()*+,./0-9:;&lt;=>?A-Z_a-z]{4,30}"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="GLNType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">The Global Location Number (GLN) is the GS1 Identification Key used to identify physical locations or parties. The key is comprised of a GS1 Company Prefix, Location Reference, and Check Digit.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: More information about the Global Location Number can be found here: http://www.gs1.org/gln</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 7365566156190</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:pattern value="\d{13}"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="GRAIType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">The GS1 Identification Key used to identify Returnable Assets. The key comprises a GS1 Company Prefix, Asset Type, Check Digit, and optional serial number.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: More information about the Global Returnable Asset Identifier can be found here: http://www.gs1.org/grai</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 66666666666661234567893698521</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:pattern value="\d{14}[-!&quot;%&amp;'()*+,./0-9:;&lt;=>?A-Z_a-z]{0,16}"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="GSINType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">The GS1 Identification Key used to identify a logical grouping of logistic or transport units that are assembled by the consignor (seller) for a transport Shipment from that consignor to one consignee (buyer) referencing a despatch advice and/or BOL. The key comprises a GS1 Company Prefix, Shipper Reference and Check Digit.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: More information about the Global Shipment Identification Numbers can be found here: http://www.gs1.org/global-shipment-identification-number-gsin</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 73655661561900123</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:pattern value="\d{17}"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="GSRNType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">The GS1 Identification Key used to identify the relationship between a service provider and service recipient. The key comprises a GS1 Company Prefix, Service Reference, and Check Digit.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: More information about the Global Service Relation Number can be found here: http://www.gs1.org/global-service-relation-number-gsrn</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 003265236523894895</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:pattern value="\d{18}"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="GTINType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">The GS1 Identification Key used to identify trade items. The key comprises a GS1 Company Prefix, an Item Reference and Check Digit.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: More information about the Global Trade Item Number can be found here: http://www.gs1.org/gtin</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 04098765000119</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:pattern value="\d{14}"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="NonBinaryLogicEnumerationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">N/A</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: UNSPECIFIED</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:enumeration value="FALSE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Definition">Negative value.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="NOT_APPLICABLE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Definition">A statement that an affirmative or negative response is not required for the attribute.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="TRUE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Definition">Affirmative value.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="UNSPECIFIED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Definition">Value not stated.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="ResponseStatusEnumerationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">N/A</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: ACCEPTED</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:enumeration value="ACCEPTED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Definition">Designates a positive response from the recipient.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MODIFIED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Definition">Designates a positive response from the recipient with modification.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="NO_ACTION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Definition">This line item is not affected by the actual message.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="REJECTED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Definition">Designates a negative response from the recipient.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="SSCCType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">The GS1 Identification Key used to identify logistics units. The key comprises an Extension digit, GS1 Company Prefix, Serial Reference, and Check Digit.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: More information about the Serial Shipping Container Code can be found here: http://www.gs1.org/serial-shipping-container-code-sscc</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 950110102081858960</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:pattern value="\d{18}"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="String1000Type">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">N/A</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="1000"/>
