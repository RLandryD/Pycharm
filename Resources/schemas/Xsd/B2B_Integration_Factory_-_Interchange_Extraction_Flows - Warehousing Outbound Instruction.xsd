   <xsd:simpleType name="NutrientTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:NutrientTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="ENERSF">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Calories From Saturated
                  Fat</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Calories From Saturated Fat
                  (Temporary GS1 Code)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="G_CMO">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Carbon Monoxide</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Carbon
                  Monoxide</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="G_HC">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Bicarbonate (or hydrogen
                  carbonate</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Bicarbonate (or hydrogen
                  carbonate) is an intermediate form in the deprotonation of carbonic acid. It is an
                  anion with the chemical formula HCO3. Bicarbonate serves a crucial biochemical
                  role in the physiological pH buffering system. Bicarbonate is a major element in
                  our body, and is present in all body fluids and organs. Secreted by the stomach,
                  it is necessary for digestion. When ingested, for example, with mineral water, it
                  helps buffer lactic acid generated during exercise and also reduces the acidity of
                  dietary components. Finally, it has a prevention effect on dental
                  cavities.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="G_NICT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Nicotine</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Nicotine</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="G_NMES">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Non-milk Extrinsic
                  Sugars</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Non-milk Extrinsic
                  Sugars</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="G_TAR">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Tar</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Tar</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="GINSENG">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Ginseng</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Ginseng may be included in
                  small doses in energy drinks or herbal teas, such as ginseng coffee. Ginseng is
                  known to contain phytoestrogens. The ginseng root has been used in Asia for more
                  than two millennia to enhance energy, support the immune system, and improve
                  concentration. Ginseng is a mild stimulant.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="HMB">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Beta-hydroxy-beta-methylbutyrate</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">(beta-hydroxy-beta-methylbutyrate) - increases muscle mass and decrease muscle
                  breakdown. (Temporary GS1 Code)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="IODIZED_SALT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Iodized Salt</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Table salt mixed with a
                  minute amount of various iodine-containing salts (Temporary GS1
                  Code)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="L_CARNITINE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Carnitine</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Carnitine is a substance that
                  helps the body turn fat into energy. Your body makes it in the liver and kidneys
                  and stores it in the skeletal muscles, heart, brain, and sperm. Carnitine is
                  available as a supplement in a variety of forms: a. L-carnitine: the most widely
                  available and least expensive b. Acetyl-L-carnitine: Often used in studies for
                  Alzheimer's disease and other brain disorders c. Propionyl-L-carnitine: Often used
                  in studies for heart disease and peripheral vascular disease (Temporary GS1 Code)
               </xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="NUCLEOTIDE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Nucleotide</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Nucleotides are organic
                  molecules composed of a nucleobase, a five-carbon sugar (ribose or deoxyribose)
                  and at least one phosphate group.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SALTEQ">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Salt
                  Equivalent:</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The calculated level of salt
                  equal to Na (natrium (sodium)) x 2,5. (Temporary GS1 Code)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="X_CASNWH">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Casein to Whey Protein
                  Ratio</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> A ratio determined by
                  dividing the total casein by total whey.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="X_FATRSA">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Combined saturated fat and trans
                  fat.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Combined saturated fat and
                  trans fat.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="X_FUNS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Total Unsaturated
                  Fat</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Total unsaturated fats
                  including both mono-unsaturated and polyunsaturated.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="X_PROSOL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Soluble Protein</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A protein that can be
                  dissolved in a liquid.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="X_SALATRIM">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Salatrim</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The abbreviation for "Short
                  and long chain acyl triglyceride molecule". Salatrim is mainly composed of
                  short-chain fatty acids (SCFAs) and stearic acid. SCFAs contain fewer calories per
                  gram than other fats, and the stearic acid in salatrim may be absorbed at a low
                  rate from the gastrointestinal tract. For these reasons, salatrim is proposed as a
                  reduced fat, reduced-calorie fat replacer. Salatrim contains no trans
                  fats.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="X_SUCRA">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sucralose </xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A non-nutritive
                  sweetener.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="ObservationTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:ObservationTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="AIR_COOLER_EXPEL_STATUS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Air cooler expel
                  status</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Operating state of the air
                  expel of the cooler equipment. Possible values are “On” and
                  “Off”.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="AIR_COOLER_STATUS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Air cooler
                  status</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Operating state of the air
                  cooler equipment. Possible values are “On” and “Off”</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="AXLE_WEIGHT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Axle weight</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The amount of weight carried
                  by a single axle and the amount of weight transmitted to the surface by one
                  axle.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DIRECTION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Direction</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The course along which a
                  ship, aircraft, etc., is traveling, expressed as the angle between true or
                  magnetic north and an imaginary line through the main fore-and-aft axis of the
                  means of transport. Minimum is 0, maximum is 359.99</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DOOR_STATUS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Door status</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The state of the door of the
                  transport means or equipment expressed as open or closed.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ELIPSOID_ELEVATION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Elipsoid
                  elevation</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Vertical distance from a
                  point down to sea level, based on the reference ellipsoid, rather than true sea
                  level.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ENGINE_STATUS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Engine status</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Operating state of the engine
                  of the transport means. Possible values are “On” and “Off”.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="FUEL_CONSUMPTION_AVERAGE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Fuel consumption
                  average</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The consumption of fuel
                  expressed as an intermediate scale value.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="GPS_STATUS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gps status</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Status of the GPS Signal
                  coverage. Values are “Under signal”, “No signal” or “Unknown”</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="LATITUDE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Latitude</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The angle, in degrees, of a
                  position on Earth above the equator. (Latitude is negative for a place below the
                  equator.)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="LOAD_WEIGHT_EXCLUDING_MEANS_AND_EQUIPMENT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Load weight excluding means and
                  equipment</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Weight of the cargo as loaded
                  on a means of transport, excluding the weight of the means and
                  equipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="LOAD_WEIGHT_INCLUDING_MEANS_AND_EQUIPMENT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Load weight including means and
                  equipment</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Weight of the cargo as loaded
                  on a means of transport, including the weight of the means and
                  equipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="LONGITUDE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Longitude</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The geographic coordinate
                  most commonly used in cartography and global navigation for east-west measurement.
                  Constant longitude is represented by lines running from north to
                  south.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ORTHOMETRIC_ELEVATION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Orthometric
                  elevation</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Vertical distance from the
                  Mean Sea Level (MSL).</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RELATIVE_HUMIDITY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Relative
                  humidity</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The ratio of the amount of
                  water in the air at a given temperature to the maximum amount it could hold at
                  that temperature; expressed as a percentage</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SPEED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Speed</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The rate of movement at which
                  a means of transport is operating.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="TEMPERATURE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Temperature</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The degree or intensity of
                  heat present in a substance or object.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="OrderEntryTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:OrderEntryTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="APPLICATION_CONSOLE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Application
                  console</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The order was placed via
                  application where business users perform order-related tasks and inventory
                  management</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CALL_CENTRE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Call centre</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The order was placed using a
                  call centre</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CATALOGUE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Catalogue</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The order was placed using a
                  catalogue</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MOBILE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Mobile</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The order was placed using a
                  mobile device, such as a cell phone or tablet</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ONLINE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Online</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The order was placed using an
                  online channel</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="POS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">POS</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The order was placed using a
                  store system</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="OrderInstructionCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:OrderInstructionCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="BACK_ORDERS_ACCEPTED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Back orders
                  accepted</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Back orders accepted when
                  partial delivery</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="BACK_ORDERS_NOT_ACCEPTED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Back orders not
                  accepted</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">No back orders accepted when
                  partial delivery</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CASE_SPLITTING_ALLOWED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Case Splitting
                  Allowed</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The standard case may be
                  split apart</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CASE_SPLITTING_NOT_ALLOWED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Case Splitting Not
                  Allowed</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The standard case must not be
                  split apart</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="FRESH_ITEM_REQUIRED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Fresh item
                  required</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The product must be more
                  fresh (newer) than the one used for fulfilling the previous
                  order</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="NO_PARTIAL_DELIVERY_ALLOWED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">No partial delivery
                  allowed</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The goods that are not
                  delivered have to be re-ordered by the buyer. Supplier only delivers the goods
                  they have in stock at that moment. One order leads to one
                  delivery.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="OVER_SHIP_ALLOWED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Over ship
                  Allowed</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The quantity of an item
                  contained in a case may be larger than the quantity ordered.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="OVER_SHIP_NOT_ALLOWED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Over ship Not
                  Allowed</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The quantity of an item
                  contained in a case must not be larger than the quantity ordered. Any overage
                  needs to be sent to the warehouse or back to the supplier.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PACK_SEPARATELY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Pack separately</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The items for this order must
                  be packed separately from other orders in one or more logistic unit(s) which may
                  all be part of the same shipment or consignment.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PARTIAL_DELIVERY_ALLOWED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Partial delivery
                  allowed</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The supplier keeps delivering
                  until the entire order is fulfilled. One order can lead to many deliveries. The
                  buyer doesn't need to place a new order; they just waits for the other goods to be
                  delivered.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="STANDARD_CASE_NOT_REQUIRED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Standard Case Not
                  Required</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The order may be delivered in
                  non-standard case</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="STANDARD_CASE_REQUIRED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Standard Case
                  Required</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The order must be delivered
                  in standard case</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="OrderRelationshipTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:OrderRelationshipTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="CHAINED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Chained</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A new order is created as a
                  result of processing a parent order</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DEPENDENT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dependent</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">One transfer order must be
                  completed before another transfer order can begin</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RELATED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Related</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An order created with
                  dependent relationships</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="OrderTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:OrderTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="220">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Order</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Document/message by means of
                  which a buyer initiates a transaction with a seller involving the supply of goods
                  or services as specified, according to conditions set out in an offer, or
                  otherwise known to the buyer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="221">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Blanket order</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Usage of document/message for
                  general order purposes with later split into quantities and delivery dates and
                  maybe delivery locations.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="223">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Lease Order</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> Document/message for goods
                  in leasing contracts.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="224">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Rush order</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Document/message for urgent
                  ordering.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="225">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Repair order</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Document/message to order
                  repair of goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="226">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Call off order</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Document/message to provide
                  split quantities and delivery dates referring to a previous blanket
                  order.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="227">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Consignment
                  order</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Order to deliver goods into
                  stock with agreement on payment when goods are sold out of this
                  stock.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="22E">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Manufacturer raised order (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Document/message providing
                  details of an order which has been raised by a manufacturer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="237">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Cross docking services
                  order</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A document or message to
                  order cross docking services.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="258">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Standing order</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An order to supply fixed
                  quantities of products at fixed regular intervals.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="400">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Exceptional
                  order</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An order which falls outside
                  the framework of an agreement</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="401">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transshipment
                  order</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An order requesting the
                  supply of products packed according to the final delivery point which will be
                  moved across a dock in a distribution centre without further
                  handling.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="402">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Cross docking
                  order</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An order requesting the
                  supply of products which will be moved across a dock, de-consolidated and
                  re-consolidated according to the final delivery location
                  requirements.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="OutOfStockMeasurementTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:OutOfStockMeasurementTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="MANUAL_AUDIT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Visual inspection of stocking
                  locations</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="OTHER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Other
                  method</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PERPETUAL_INVENTORY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Estimate of on-hand balance
                  based upon the previous inventory value, adjusted by subsequent sales and
                  receipts</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RFID_EPC">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Physical count of items at
                  stocking locations taken by radio frequency identification</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SALES_DATA_ANALYSIS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Estimate of on-hand balance
                  based upon the observed vs. expected rate of sale</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="OwnershipTransferConditionCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:OwnershipTransferConditionCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="FULL_PAYMENT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Full payment</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Fee reduction applies, due to
                  discount and bonus agreements</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="OUTSTANDING_PAYMENT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Outstanding
                  payment</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Fee reduction applies, due to
                  our current business terms.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="OUTSTANDING_PAYMENT_AND_RESALE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Outstanding payment and
                  resale</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Discount or bonus agreements
                  apply.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="PackageLevelCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:PackageLevelCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="1">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inner</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Level of packing, if it
                  exists, that is immediately subordinate to the intermediate packaging
                  level.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="1E">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Highest (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Level of packaging, if it
                  exists, which is highest in the packaging hierarchy.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="2">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Intermediate</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Level of packaging, if it
                  exists, that is immediately subordinate to the outer packaging
                  level.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="3">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Outer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">For packed merchandise,
                  outermost level of packaging for a shipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="4">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">No packaging
                  hierarchy</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">There is no specifiable level
                  of packaging: packaging is inner and outer level as well.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="5">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Shipment Level</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The packaging level described
                  is the shipment level.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
