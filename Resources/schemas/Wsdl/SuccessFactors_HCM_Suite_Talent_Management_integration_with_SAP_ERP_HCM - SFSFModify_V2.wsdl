				</sequence>
			</complexType>
			<!--//////////////////////////////////////// -->
			<!--Special type for Delete, as only fields ID and TYPE make sense -->
			<!--Less effort within back end implementation expected -->
			<!-- /////////////////////////////////////// -->
			<complexType name="DeleteObject">
				<sequence>
					<choice minOccurs="0" maxOccurs="1">
						<element name="id" type="xsd:string" minOccurs="0"
							maxOccurs="1" />
						<element name="businessKeys" type="xsd:anyType" minOccurs="0"
							maxOccurs="1" />
					</choice>
					<element name="type" type="xsd:string" />
				</sequence>
			</complexType>
			<element name="login">
