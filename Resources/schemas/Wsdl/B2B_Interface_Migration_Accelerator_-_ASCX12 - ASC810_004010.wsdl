></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="10"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_955"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c629d31ff311e1bc330026b9aa16ff</xsd:appinfo><xsd:documentation>TXI04| Tax Jurisdiction Code Qualifier. NOTES: P0405 - If either TXI04 or TXI05 is present, then the other is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_956"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c629d41ff311e1a8020026b9aa16ff</xsd:appinfo><xsd:documentation>TXI05| Tax Jurisdiction Code</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="10"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_441"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c629d51ff311e1cbd30026b9aa16ff</xsd:appinfo><xsd:documentation>TXI06| Tax Exempt Code</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="1"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_662"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c629d61ff311e1c7f70026b9aa16ff</xsd:appinfo><xsd:documentation>TXI07| Relationship Code. NOTES: TXI07 is a code indicating the relationship of the price or amount to the associated segment.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="1"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_828"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c629d71ff311e1c46e0026b9aa16ff</xsd:appinfo><xsd:documentation>TXI08| Dollar Basis For 