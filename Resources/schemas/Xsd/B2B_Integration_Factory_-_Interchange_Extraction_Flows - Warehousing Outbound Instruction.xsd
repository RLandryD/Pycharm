            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Event Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The moment in time at which the event occurred.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2013-06-15T11:00:00.000</xsd:documentation>
