   <xsd:complexType name="PassengerInformationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information on persons being transported.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="numberOfPassengers" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Number Of Passengers</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The number of persons being transported.</xsd:documentation>
