        <bpmn2:callActivity id="N_Process_165_4" name="process read data">
            <bpmn2:extensionElements>
                <ifl:property><key>bodyType</key><value>expression</value></ifl:property>
                <ifl:property><key>propertyTable</key><value>&lt;row&gt;&lt;cell id=&#x27;Action&#x27;&gt;Create&lt;/cell&gt;&lt;cell id=&#x27;Type&#x27;&gt;constant&lt;/cell&gt;&lt;cell id=&#x27;Value&#x27;&gt;{{TokenExpirationTimeInSeconds}}&lt;/cell&gt;&lt;cell id=&#x27;Default&#x27;&gt;&lt;/cell&gt;&lt;cell id=&#x27;Name&#x27;&gt;DeltaSecs&lt;/cell&gt;&lt;cell id=&#x27;Datatype&#x27;&gt;&lt;/cell&gt;&lt;/row&gt;&lt;row&gt;&lt;cell id=&#x27;Action&#x27;&gt;Create&lt;/cell&gt;&lt;cell id=&#x27;Type&#x27;&gt;xpath&lt;/cell&gt;&lt;cell id=&#x27;Value&#x27;&gt;//SavedAuth&lt;/cell&gt;&lt;cell id=&#x27;Default&#x27;&gt;&lt;/cell&gt;&lt;cell id=&#x27;Name&#x27;&gt;SavedAuth&lt;/cell&gt;&lt;cell id=&#x27;Datatype&#x27;&gt;java.lang.String&lt;/cell&gt;&lt;/row&gt;&lt;row&gt;&lt;cell id=&#x27;Action&#x27;&gt;Create&lt;/cell&gt;&lt;cell id=&#x27;Type&#x27;&gt;xpath&lt;/cell&gt;&lt;cell id=&#x27;Value&#x27;&gt;//DateSaved&lt;/cell&gt;&lt;cell id=&#x27;Default&#x27;&gt;&lt;/cell&gt;&lt;cell id=&#x27;Name&#x27;&gt;DateSaved&lt;/cell&gt;&lt;cell id=&#x27;Datatype&#x27;&gt;java.lang.String&lt;/cell&gt;&lt;/row&gt;&lt;row&gt;&lt;cell id=&#x27;Action&#x27;&gt;Create&lt;/cell&gt;&lt;cell id=&#x27;Type&#x27;&gt;expression&lt;/cell&gt;&lt;cell id=&#x27;Value&#x27;&gt;${date:now:yyyy-MM-dd HH:mm:ss}&lt;/cell&gt;&lt;cell id=&#x27;Default&#x27;&gt;&lt;/cell&gt;&lt;cell id=&#x27;Name&#x27;&gt;Now&lt;/cell&gt;&lt;cell id=&#x27;Datatype&#x27;&gt;java.lang.String&lt;/cell&gt;&lt;/row&gt;&lt;row&gt;&lt;cell id=&#x27;Action&#x27;&gt;Create&lt;/cell&gt;&lt;cell id=&#x27;Type&#x27;&gt;xpath&lt;/cell&gt;&lt;cell id=&#x27;Value&#x27;&gt;//SiiToken&lt;/cell&gt;&lt;cell id=&#x27;Default&#x27;&gt;&lt;/cell&gt;&lt;cell id=&#x27;Name&#x27;&gt;SiiToken&lt;/cell&gt;&lt;cell id=&#x27;Datatype&#x27;&gt;java.lang.String&lt;/cell&gt;&lt;/row&gt;&lt;row&gt;&lt;cell id=&#x27;Action&#x27;&gt;Create&lt;/cell&gt;&lt;cell id=&#x27;Type&#x27;&gt;xpath&lt;/cell&gt;&lt;cell id=&#x27;Value&#x27;&gt;//Seed&lt;/cell&gt;&lt;cell id=&#x27;Default&#x27;&gt;&lt;/cell&gt;&lt;cell id=&#x27;Name&#x27;&gt;Seed&lt;/cell&gt;&lt;cell id=&#x27;Datatype&#x27;&gt;java.lang.String&lt;/cell&gt;&lt;/row&gt;</value></ifl:property>
                <ifl:property><key>headerTable</key><value></value></ifl:property>
                <ifl:property><key>wrapContent</key><value></value></ifl:property>
                <ifl:property><key>componentVersion</key><value>1.5</value></ifl:property>
                <ifl:property><key>activityType</key><value>Enricher</value></ifl:property>
                <ifl:property><key>cmdVariantUri</key><value>ctype::FlowstepVariant/cname::Enricher/version::1.5.0</value></ifl:property>
            </bpmn2:extensionElements>
            <bpmn2:incoming>SF_Process_165_4</bpmn2:incoming>
            <bpmn2:outgoing>SF_Process_165_5</bpmn2:outgoing>
        </bpmn2:callActivity>
        <bpmn2:callActivity id="N_Process_165_5" name="add Token Cookie to the Header">
            <bpmn2:extensionElements>
