              <xsd:annotation>
               <xsd:documentation>Indicator for Infotype Segment Longer Than 1000 Bytes</xsd:documentation>
              </xsd:annotation>
              <xsd:simpleType>
               <xsd:restriction base="xsd:string">
                <xsd:maxLength value="1"/>
               </xsd:restriction>
              </xsd:simpleType>
             </xsd:element>
			 <xsd:element maxOccurs="999999" minOccurs="0" name="Z1P9007">
