               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="inventoryDispositionCode" type="InventoryDispositionCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inventory Disposition Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The inventory disposition code specifies the business condition of the inventory that is subject of the event.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
