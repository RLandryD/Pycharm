><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="10"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_1073"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40a01ff311e1c7fd0026b9aa16ff</xsd:appinfo><xsd:documentation>PAM15| Yes/No Condition or Response Code. NOTES: PAM15 indicates whether the monetary amount identified in PAM05 is a net or gross value. A "Y" indicates amount is a gross value; an "N" indicates amount is a net value.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="1"/></xsd:restriction></xsd:simpleType></xsd:element></xsd:sequence></xsd:complexType></xsd:element><xsd:element maxOccurs="5" minOccurs="0" name="S_CSH"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40ac1ff311e188ac0026b9aa16ff</xsd:appinfo><xsd:documentation>Sales Requirements. To specify general conditions or requirements of the sale</xsd:documentation></xsd:annotation><xsd:complexType><xsd:sequence><xsd:element minOccurs="0" name="D_563"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40a21ff311e1c2cf0026b9aa16ff</xsd:appinfo><xsd:documentation>CSH01| Sales Requirement Code</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_306"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40a31ff311e1b5b60026b9aa16ff</xsd:appinfo><xsd:documentation>CSH02| Action Code. NOTES: C0203 - If CSH02 is present, then CSH03 is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_610"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40a41ff311e1ab290026b9aa16ff</xsd:appinfo><xsd:documentation>CSH03| Amount. NOTES: CSH03 is the maximum monetary amount value which the order must not exceed.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="15"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_508"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40a51ff311e1c9aa0026b9aa16ff</xsd:appinfo><xsd:documentation>CSH04| Account Number. NOTES: CSH04 is the account number to which the purchase amount is charged.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="35"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_373"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40a61ff311e1876b0026b9aa16ff</xsd:appinfo><xsd:documentation>CSH05| Date. NOTES: CSH05 is the date specified by the sender to be shown on the invoice.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="8"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_559"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40a71ff311e18a6e0026b9aa16ff</xsd:appinfo><xsd:documentation>CSH06| Agency Qualifier Code. NOTES: P0607 - If either CSH06 or CSH07 is present, then the other is required. CSH06 identifies the source of the code value in CSH07.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_560"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40a81ff311e1b1920026b9aa16ff</xsd:appinfo><xsd:documentation>CSH07| Special Services Code</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="2"/><xsd:maxLength value="10"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_566"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40a91ff311e1aa3f0026b9aa16ff</xsd:appinfo><xsd:documentation>CSH08| Product/Service Substitution Code</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_954"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40aa1ff311e1a38f0026b9aa16ff</xsd:appinfo><xsd:documentation>CSH09| Percent. NOTES: P0910 - If either CSH09 or CSH10 is present, then the other is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="10"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_1004"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40ab1ff311e1cfb90026b9aa16ff</xsd:appinfo><xsd:documentation>CSH10| Percent Qualifier</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="2"/></xsd:restriction></xsd:simpleType></xsd:element></xsd:sequence></xsd:complexType></xsd:element><xsd:element maxOccurs="unbounded" minOccurs="0" name="S_TC2"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40af1ff311e1b6970026b9aa16ff</xsd:appinfo><xsd:documentation>Commodity. To identify a commodity or a group of commodities or a tariff page commodity</xsd:documentation></xsd:annotation><xsd:complexType><xsd:sequence><xsd:element name="D_23"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40ad1ff311e19bcb0026b9aa16ff</xsd:appinfo><xsd:documentation>TC201| Commodity Code Qualifier</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="1"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element name="D_22"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40ae1ff311e19c590026b9aa16ff</xsd:appinfo><xsd:documentation>TC202| Commodity Code</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="30"/></xsd:restriction></xsd:simpleType></xsd:element></xsd:sequence></xsd:complexType></xsd:element><xsd:element maxOccurs="25" minOccurs="0" name="L_SAC"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d01b5ec1ff311e1b63d0026b9aa16ff</xsd:appinfo></xsd:annotation><xsd:complexType><xsd:sequence><xsd:element minOccurs="0" name="S_SAC"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d01b5d51ff311e1c7ba0026b9aa16ff</xsd:appinfo><xsd:documentation>Service, Promotion, Allowance, or Charge Information. To request or identify a service, promotion, allowance, or charge; to specify the amount or percentage for the service, promotion, allowance, or charge</xsd:documentation></xsd:annotation><xsd:complexType><xsd:sequence><xsd:element name="D_248"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40b01ff311e1ba2b0026b9aa16ff</xsd:appinfo><xsd:documentation>SAC01| Allowance or Charge Indicator. NOTES: If SAC01 is "A" or "C", then at least one of SAC05, SAC07, or SAC08 is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="1"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_1300"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40b11ff311e1ab800026b9aa16ff</xsd:appinfo><xsd:documentation>SAC02| Service, Promotion, Allowance, or Charge Code. NOTES: R0203 - At least one of SAC02 or SAC03 is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="4"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_559"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40b21ff311e196450026b9aa16ff</xsd:appinfo><xsd:documentation>SAC03| Agency Qualifier Code. NOTES: P0304 - If either SAC03 or SAC04 is present, then the other is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_1301"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40b31ff311e1aaf20026b9aa16ff</xsd:appinfo><xsd:documentation>SAC04| Agency Service, Promotion, Allowance, or Charge Code. NOTES: SAC04 may be used to uniquely identify the service, promotion, allowance, or charge. In addition, it may be used in conjunction to further the code in SAC02.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="10"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_610"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40b41ff311e1af240026b9aa16ff</xsd:appinfo><xsd:documentation>SAC05| Amount. NOTES: SAC05 is the total amount for the service, promotion, allowance, or charge. If SAC05 is present with SAC07 or SAC08, then SAC05 takes precedence.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="15"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_378"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40b51ff311e1c9110026b9aa16ff</xsd:appinfo><xsd:documentation>SAC06| Allowance/Charge Percent Qualifier. NOTES: P0607 - If either SAC06 or SAC07 is present, then the other is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="1"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_332"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40b61ff311e1c4d40026b9aa16ff</xsd:appinfo><xsd:documentation>SAC07| Percent</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="6"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_118"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40b71ff311e18c9c0026b9aa16ff</xsd:appinfo><xsd:documentation>SAC08| Rate. NOTES: SAC08 is the allowance or charge rate per unit.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="9"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_355"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40b81ff311e1a76b0026b9aa16ff</xsd:appinfo><xsd:documentation>SAC09| Unit or Basis for Measurement Code. NOTES: P0910 - If either SAC09 or SAC10 is present, then the other is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_380"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40b91ff311e19e750026b9aa16ff</xsd:appinfo><xsd:documentation>SAC10| Quantity. NOTES: SAC10 and SAC11 is the quantity basis when the allowance or charge quantity is different from the purchase order or invoice quantity. SAC10 and SAC11 used together indicate a quantity range, which could be a dollar amount, ...</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="15"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_380_2"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8cff40ba1ff311e192000026b9aa16