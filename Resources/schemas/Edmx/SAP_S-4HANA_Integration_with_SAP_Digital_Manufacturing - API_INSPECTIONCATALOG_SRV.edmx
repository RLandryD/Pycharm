  <Schema Namespace="API_INSPECTIONCATALOG_SRV_01" xml:lang="en" sap:schema-version="1" xmlns="http://schemas.microsoft.com/ado/2008/09/edm">
   <EntityType Name="A_InspectionCatalogType" sap:label="InspectionCatalogType" sap:content-version="1">
    <Key>
