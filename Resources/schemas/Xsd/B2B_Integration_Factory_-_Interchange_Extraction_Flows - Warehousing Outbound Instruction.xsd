               <xsd:documentation xml:lang="en-US" source="Definition">A reference required in the Single Euro Payments Area - SEPA, such as Creditor Reference or Mandate Reference.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
