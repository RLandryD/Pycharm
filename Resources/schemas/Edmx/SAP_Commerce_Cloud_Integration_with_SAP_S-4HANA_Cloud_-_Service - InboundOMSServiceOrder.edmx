<edmx:Edmx xmlns:edmx="http://schemas.microsoft.com/ado/2007/06/edmx" Version="1.0">
    <edmx:DataServices xmlns:m="http://schemas.microsoft.com/ado/2007/08/dataservices/metadata" m:DataServiceVersion="2.0">
        <Schema xmlns="http://schemas.microsoft.com/ado/2008/09/edm" xmlns:s="http://schemas.sap.com/commerce" Namespace="HybrisCommerceOData" s:schema-version="1">
            <EntityType Name="SAPOrder">
                <Key>
                    <PropertyRef Name="integrationKey"/>
                </Key>
                <Property Name="serviceOrderId" Nullable="true" Type="Edm.String"/>
                <Property Name="code" Nullable="true" Type="Edm.String" s:IsUnique="true"/>
                <Property Name="integrationKey" Nullable="false" Type="Edm.String" s:Alias="SAPOrderStatus_code|SAPOrder_code"/>
                <NavigationProperty FromRole="SAPOrder" Name="sapOrderStatus" Nullable="true" Relationship="HybrisCommerceOData.FK_SAPOrder_sapOrderStatus" ToRole="SAPOrderStatus" s:IsUnique="true"/>
            </EntityType>
            <EntityType Name="SAPOrderStatus">
                <Key>
                    <PropertyRef Name="integrationKey"/>
                </Key>
                <Property Name="code" Nullable="false" Type="Edm.String" s:IsUnique="true"/>
                <Property Name="integrationKey" Nullable="false" Type="Edm.String" s:Alias="SAPOrderStatus_code"/>
            </EntityType>
            <Association Name="FK_SAPOrder_sapOrderStatus">
                <End Multiplicity="0..1" Role="SAPOrder" Type="HybrisCommerceOData.SAPOrder"/>
                <End Multiplicity="0..1" Role="SAPOrderStatus" Type="HybrisCommerceOData.SAPOrderStatus"/>
            </Association>
            <EntityContainer Name="Container" m:IsDefaultEntityContainer="true">
                <EntitySet EntityType="HybrisCommerceOData.SAPOrder" Name="SAPOrders"/>
                <EntitySet EntityType="HybrisCommerceOData.SAPOrderStatus" Name="SAPOrderStatuses"/>
                <AssociationSet Association="HybrisCommerceOData.FK_SAPOrder_sapOrderStatus" Name="SAPOrder_SAPOrderStatuses">
                    <End EntitySet="SAPOrders" Role="SAPOrder"/>
                    <End EntitySet="SAPOrderStatuses" Role="SAPOrderStatus"/>
                </AssociationSet>
            </EntityContainer>
        </Schema>
    </edmx:DataServices>
</edmx:Edmx>
