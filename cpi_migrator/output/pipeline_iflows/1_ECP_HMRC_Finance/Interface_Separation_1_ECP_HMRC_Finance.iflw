<?xml version="1.0" encoding="UTF-8"?>
<!--
  PIPELINE STEP 3: Interface Separation iFlow
  Package  : 1_ECP_HMRC_Finance
  Purpose  : Routes to the correct scenario-specific iFlow
             based on SAP_InterfaceName header set by Receiver Determination.
  Internal : ProcessDirect address /pd/InterfaceSeparation_1_ECP_HMRC_Finance
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Interface_Separation_1_ECP_HMRC_Finance"
             name="Interface_Separation_1_ECP_HMRC_Finance">
  <process id="IfaceSep_1_ECP_HMRC_Finance_process" ifl:type="IntegrationFlow">

    <startEvent id="Start_IS" name="From Receiver Determination">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/pd/InterfaceSeparation_1_ECP_HMRC_Finance</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>

    <!-- ROUTER: Branch to scenario-specific iFlow -->
    <exclusiveGateway id="Router_1" name="Route by Interface Name"/>

    <sequenceFlow id="route_0" sourceRef="Router_1"
      targetRef="Call_Full_Payment_Submiss_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Full Payment Submission - 2021-22' -->
    </sequenceFlow>
    <serviceTask id="Call_Full_Payment_Submiss_1"
      name="→ Full Payment Submission - 2021-22" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Full_Payment_Submiss</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_1" sourceRef="Router_1"
      targetRef="Call_Expense_And_Benefit__1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Expense And Benefit - 2020-21' -->
    </sequenceFlow>
    <serviceTask id="Call_Expense_And_Benefit__1"
      name="→ Expense And Benefit - 2020-21" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Expense_And_Benefit_</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_2" sourceRef="Router_1"
      targetRef="Call_Employer_Payment_Sum_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Employer Payment Summary - 2021-22' -->
    </sequenceFlow>
    <serviceTask id="Call_Employer_Payment_Sum_1"
      name="→ Employer Payment Summary - 2021-22" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Employer_Payment_Sum</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_IS"/>
    <sequenceFlow sourceRef="Start_IS" targetRef="Router_1"/>
  </process>
</definitions>