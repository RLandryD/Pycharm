<wd:Validation>
<wd:Validation_Message>The Custom Identifier Shared Reference should be used with the Change Other IDs web service.</wd:Validation_Message>
</wd:Validation>
<wd:Validation>
<wd:Validation_Message>Custom Identifier with reference [cir] is marked for deletion. Custom ID Data should not be included.</wd:Validation_Message>
</wd:Validation>
<wd:Validation>
<wd:Validation_Message>If the ID is not marked for deletion, ID data should be included.</wd:Validation_Message>
</wd:Validation>
<wd:Validation>
<wd:Validation_Message>The Custom ID referenced by [custom identifier reference] does not belong to [person].</wd:Validation_Message>
</wd:Validation>
<wd:Validation>
<wd:Validation_Message>Custom Identifier [identifier]  with workday id [workday id] is not  a valid custom identifier for the person.</wd:Validation_Message>
</wd:Validation>
</xsd:appinfo>
</xsd:annotation>
<xsd:sequence>
<xsd:element minOccurs="0" name="Custom_ID_Reference" type="wd:Unique_IdentifierObjectType">
