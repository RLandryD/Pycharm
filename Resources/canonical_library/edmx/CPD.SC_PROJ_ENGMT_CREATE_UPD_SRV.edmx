   <Annotations Target="CPD.SC_PROJ_ENGMT_CREATE_UPD_SRV.CPD_SC_PROJ_ENGMT_CREATE_UPD_SRV_Entities/WorkPackageSet" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Capabilities.ReadRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Returns information about work packages in customer and internal projects."/>
      <PropertyValue Property="LongDescription" String="Returns information such as the work package name, work package type, start and end dates, assigned work items, the resource plan, work package functions and their status, and when the work package was last changed. Since this operation is likely to return a large result set, it is recommended that you also use filters to retrieve only the required results. "/>
      <PropertyValue Property="ReadByKeyRestrictions">
       <Record>
        <PropertyValue Property="Description" String="Returns information about a specific work package in a customer or internal project."/>
        <PropertyValue Property="LongDescription" String="Returns detailed information about a work package and information from corresponding nested entities such as work items, resource demands, and work package functions."/>
       </Record>
      </PropertyValue>
     </Record>
    </Annotation>
    <Annotation Term="Capabilities.NavigationRestrictions">
     <Record>
      <PropertyValue Property="RestrictedProperties">
       <Collection>
        <Record>
         <PropertyValue Property="NavigationProperty" NavigationPropertyPath="DemandSet"/>
         <PropertyValue Property="ReadRestrictions">
          <Record>
           <PropertyValue Property="Description" String="Returns all the resources and expenses planned in a work package."/>
           <PropertyValue Property="LongDescription" String="Returns all the resources and expenses planned in the work package of a customer or internal project."/>
          </Record>
         </PropertyValue>
         <PropertyValue Property="InsertRestrictions">
          <Record>
           <PropertyValue Property="Description" String="Creates a resource plan for a work package."/>
           <PropertyValue Property="LongDescription" String="Creates a resource plan for a work package. You can create plan items for people and additional resources by providing details such as the resource type, resource, and planned effort or quantity. You can also plan expenses by providing the planned cost and revenue. You may use the billing control category property to indicate if a plan item is billable or not. "/>
          </Record>
         </PropertyValue>
        </Record>
        <Record>
         <PropertyValue Property="NavigationProperty" NavigationPropertyPath="WorkItemSet"/>
         <PropertyValue Property="ReadRestrictions">
          <Record>
           <PropertyValue Property="Description" String="Returns all the work items assigned to a work package."/>
           <PropertyValue Property="LongDescription" String="Returns all the work items assigned to the work package of a customer or internal project."/>
          </Record>
         </PropertyValue>
         <PropertyValue Property="InsertRestrictions">
          <Record>
           <PropertyValue Property="Description" String="Assigns work items to a work package."/>
           <PropertyValue Property="LongDescription" String="Assigns work items to a work package. You can use this operation to assign pre-defined work items that are already configured in your S/4HANA Cloud system or create new user-defined work items for the work package. To create and assign user-defined work items, provide only the work item name since the system generates a unique ID when the assignment is successful. Also note that user-defined work item IDs cannot be reused across work packages. "/>
          </Record>
         </PropertyValue>
        </Record>
        <Record>
         <PropertyValue Property="NavigationProperty" NavigationPropertyPath="WorkPackageFunctionSet"/>
         <PropertyValue Property="ReadRestrictions">
          <Record>
           <PropertyValue Property="Description" String="Returns the status of all work package functions in a work package."/>
           <PropertyValue Property="LongDescription" String="Returns the status of all work package functions in the work package of a customer or internal project."/>
          </Record>
         </PropertyValue>
         <PropertyValue Property="InsertRestrictions">
          <Record>
           <PropertyValue Property="Description" String="Sets the status of a work package function in a work package."/>
           <PropertyValue Property="LongDescription" String="Sets the status of a work package function. You can use this operation to block work package functions and thereby disallow the posting of certain costs to the work package. "/>
          </Record>
         </PropertyValue>
        </Record>
       </Collection>
      </PropertyValue>
     </Record>
    </Annotation>
    <Annotation Term="Capabilities.InsertRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Creates a work package for a customer or internal project."/>
      <PropertyValue Property="LongDescription" String="Creates a work package for a customer or internal project. Do not enter a work package ID since an automated number format is used. You must enter the basic details such as dates and work package type. You may also create optional information by providing the relevant inputs for nested entities such as work items, resource demands, and work package functions. Since this operation is likely to return a large result set, it is recommended that you also use filters to retrieve only the required results. "/>
     </Record>
    </Annotation>
    <Annotation Term="Capabilities.UpdateRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Updates basic information for a work package."/>
      <PropertyValue Property="LongDescription" String="Updates basic information such as the work package description and dates. For a service-based work package, you can also update the service quantity."/>
     </Record>
    </Annotation>
    <Annotation Term="Capabilities.DeleteRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Deletes a work package in a customer or internal project."/>
      <PropertyValue Property="LongDescription" String="Deletes a work package in a customer or internal project. Note that a work package can be deleted only if there are no actual postings."/>
     </Record>
    </Annotation>
   </Annotations>
   <Annotations Target="CPD.SC_PROJ_ENGMT_CREATE_UPD_SRV.CPD_SC_PROJ_ENGMT_CREATE_UPD_SRV_Entities/ProjectSet" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Capabilities.ReadRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Returns details about customer and internal projects."/>
      <PropertyValue Property="LongDescription" String="Returns details about all customer and internal projects in the system.  Besides retrieving basic information, it also retrieves information such as business partners assigned to project roles, the work packages and resources planned in a project, and staffing assignments.  Since this operation is likely to return a large result set, it is recommended that you also use filters to retrieve only the required results. "/>
      <PropertyValue Property="ReadByKeyRestrictions">
       <Record>
        <PropertyValue Property="Description" String="Returns details about a customer or internal project."/>
        <PropertyValue Property="LongDescription" String="Returns details about a customer or internal project. Using the project ID, you can retrieve information such as business partners assigned to project roles, the work packages and resources planned in a project, and staffing assignments."/>
       </Record>
      </PropertyValue>
     </Record>
    </Annotation>
    <Annotation Term="Capabilities.NavigationRestrictions">
     <Record>
      <PropertyValue Property="RestrictedProperties">
       <Collection>
        <Record>
         <PropertyValue Property="NavigationProperty" NavigationPropertyPath="WorkPackageSet"/>
         <PropertyValue Property="ReadRestrictions">
          <Record>
           <PropertyValue Property="Description" String="Returns work packages and their details, for a given customer or internal project."/>
           <PropertyValue Property="LongDescription" String="Returns the work packages and corresponding details, for a given customer or internal project. Besides retrieving details about a work package, it also retrieves information from related entities such as work package functions, work items, planned resources, and staffed resources. "/>
          </Record>
         </PropertyValue>
         <PropertyValue Property="InsertRestrictions">
          <Record>
           <PropertyValue Property="Description" String="Creates work packages for an internal or customer project."/>
           <PropertyValue Property="LongDescription" String="Creates work packages for an internal or customer project. You can either create a work packages by providing inputs to the WorkPackageSet. As an alternative, you may also create work packages by providing inputs to nested entities such as work items, resource demands, and work package functions. "/>
          </Record>
         </PropertyValue>
        </Record>
        <Record>
         <PropertyValue Property="NavigationProperty" NavigationPropertyPath="ProjectRoleSet"/>
         <PropertyValue Property="ReadRestrictions">
          <Record>
           <PropertyValue Property="Description" String="Returns, for a project, the project roles and the business partners assigned to those roles."/>
           <PropertyValue Property="LongDescription" String="Returns all the project roles and the business partner assigned to each role, for a given customer or internal project."/>
          </Record>
         </PropertyValue>
         <PropertyValue Property="InsertRestrictions">
          <Record>
           <PropertyValue Property="Description" String="Creates project roles for a customer or internal project."/>
           <PropertyValue Property="LongDescription" String="Creates project roles for a customer or internal project. You can also assign a business partner along with the creation of a project role. "/>
          </Record>
         </PropertyValue>
        </Record>
       </Collection>
      </PropertyValue>
     </Record>
    </Annotation>
    <Annotation Term="Capabilities.InsertRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Creates a customer or internal project."/>
      <PropertyValue Property="LongDescription" String="Creates a customer or internal project based on the level of information you provide. You can create a project by providing basic inputs to the ProjectSet. As an alternative, you may also create a project by providing inputs to nested entities such as project roles, work packages, work items, resource demands, and work package functions. "/>
     </Record>
    </Annotation>
    <Annotation Term="Capabilities.UpdateRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Updates the basic information for a customer or internal project."/>
      <PropertyValue Property="LongDescription" String="Updates the basic information for a customer or internal project. You can only update certain information such as project name, description, start and end dates, the project manager, project controller, project accountant, project partner, and settings such as confidentiality and time posting. Changes to information such as the project stage, profit center, and currency are possible with certain restrictions. "/>
     </Record>
    </Annotation>
   </Annotations>
   <Annotations Target="CPD.SC_PROJ_ENGMT_CREATE_UPD_SRV.CPD_SC_PROJ_ENGMT_CREATE_UPD_SRV_Entities/WorkItemSet" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Capabilities.ReadRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Returns the work items assigned to a work package and the status of the work item."/>
      <PropertyValue Property="LongDescription" String="Returns the work items assigned to a work package. It also retrieves information such as the work package ID, work item ID, description, and whether the work item is inactive. Since this operation is likely to return a large result set, it is recommended that you also use filters to retrieve only the required results. "/>
      <PropertyValue Property="ReadByKeyRestrictions">
       <Record>
        <PropertyValue Property="Description" String="Returns information about a work item in a work package."/>
        <PropertyValue Property="LongDescription" String="Returns information about a work item in a work package. You can retrieve information such as the name of the work item and whether it is inactive."/>
       </Record>
      </PropertyValue>
     </Record>
    </Annotation>
    <Annotation Term="Capabilities.InsertRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Assign a work item to a work package."/>
      <PropertyValue Property="LongDescription" String="Assigns a standard work item to a work package. You can also create user-defined work items. Note that user-defined work items are valid only for a specific work package."/>
     </Record>
    </Annotation>
    <Annotation Term="Capabilities.DeleteRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Deletes a work item from a work package."/>
      <PropertyValue Property="LongDescription" String="Deletes a work item from a work package. If a work item has been planned for a resource, it is not deleted but marked inactive. Moreover, you can only delete work items if there are no actual postings for it in the work package. "/>
     </Record>
    </Annotation>
   </Annotations>
   <Annotations Target="CPD.SC_PROJ_ENGMT_CREATE_UPD_SRV.CPD_SC_PROJ_ENGMT_CREATE_UPD_SRV_Entities/ProjectRoleSet" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Capabilities.ReadRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Returns the project roles and business partners assigned to them."/>
      <PropertyValue Property="LongDescription" String="Returns details about the roles assigned to a project and the business partner assigned to each role. Since this operation is likely to return a large result set, it is recommended that you also use filters to retrieve only the required results. "/>
      <PropertyValue Property="ReadByKeyRestrictions">
       <Record>
        <PropertyValue Property="Description" String="Returns the business partner assigned to a project role."/>
        <PropertyValue Property="LongDescription" String="Returns the business partner assigned to a project role in a customer or internal project. It retrieves information such as the ID and name of the business partner. "/>
       </Record>
      </PropertyValue>
     </Record>
    </Annotation>
    <Annotation Term="Capabilities.InsertRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Assigns a project role and a business partner to a project."/>
      <PropertyValue Property="LongDescription" String="Assigns a business partner to a standard or user-defined project role."/>
     </Record>
    </Annotation>
    <Annotation Term="Capabilities.UpdateRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Updates the business partner assigned to a project role."/>
      <PropertyValue Property="LongDescription" String="Updates the business partner assigned to a standard or user-defined project role."/>
     </Record>
    </Annotation>
    <Annotation Term="Capabilities.DeleteRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Deletes an assigned project role from a project."/>
      <PropertyValue Property="LongDescription" String="Deletes an assigned project role from a project. Note that deletion of the project manager role is not allowed."/>
     </Record>
    </Annotation>
   </Annotations>
   <Annotations Target="CPD.SC_PROJ_ENGMT_CREATE_UPD_SRV.CPD_SC_PROJ_ENGMT_CREATE_UPD_SRV_Entities/WorkPackageFunctionSet" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Capabilities.ReadRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Returns the work package functions in work packages of customer and internal projects."/>
      <PropertyValue Property="LongDescription" String="Returns information about work package functions and their status. It also retrieves information such as the work package ID, project ID, work package function, its description, and whether the work package function is blocked or allowed in the work package. Since this operation is likely to return a large result set, it is recommended that you also use filters to retrieve only the required results. "/>
      <PropertyValue Property="ReadByKeyRestrictions">
       <Record>
        <PropertyValue Property="Description" String="Returns information about a work package function in the work package of a customer or internal project."/>
        <PropertyValue Property="LongDescription" String="Returns information about a work package function in a work package. It retrieves information such as the work package function name and whether it is blocked or allowed. "/>
       </Record>
      </PropertyValue>
     </Record>
    </Annotation>
    <Annotation Term="Capabilities.InsertRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Sets the status of a work package function in a work package."/>
      <PropertyValue Property="LongDescription" String="Sets the status of a work package function to allow or block actual postings in a work package."/>
     </Record>
    </Annotation>
    <Annotation Term="Capabilities.UpdateRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Updates the status of a work package function in a work package."/>
      <PropertyValue Property="LongDescription" String="Updates the status of a work package function to allow or block actual postings in a work package."/>
     </Record>
    </Annotation>
   </Annotations>
   <Annotations Target="CPD.SC_PROJ_ENGMT_CREATE_UPD_SRV.CPD_SC_PROJ_ENGMT_CREATE_UPD_SRV_Entities/DemandSet" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Capabilities.ReadRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Returns items planned in work packages of customer and internal projects."/>
      <PropertyValue Property="LongDescription" String="Returns items planned in work packages of customer and internal projects. You can retrieve plan items such as demands for people and additional resources, and expenses. Since this operation is likely to return a large result set, it is recommended that you also use filters to retrieve only the required results. "/>
      <PropertyValue Property="ReadByKeyRestrictions">
       <Record>
        <PropertyValue Property="Description" String="Returns details about a specific item planned in a work package."/>
        <PropertyValue Property="LongDescription" String="Returns details about a specific item planned in a work package. You can retrieve information about a specific plan item such as a demand for people, additional resources, or expenses. If there are several records with identical values in key fields, the response is a set of aggregated records with planned efforts  or quantities grouped by a list of predefined criteria such as resource type, resource, work item, delivery organization,  and billing control category."/>
       </Record>
      </PropertyValue>
     </Record>
    </Annotation>
    <Annotation Term="Capabilities.InsertRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Creates a resource plan item in a work package."/>
      <PropertyValue Property="LongDescription" String="Creates a resource plan item in a work package. You can use this operation to plan items for which you need people, additional resources, or expenses, and plan if the item will be billed or not."/>
     </Record>
    </Annotation>
    <Annotation Term="Capabilities.UpdateRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Updates a plan item in a work package."/>
      <PropertyValue Property="LongDescription" String="Updates a plan item in a work package, with information about the billing control category and quantity. For expenses, you can update the planned cost and revenue.  If there are several records with identical values in key fields, the service updates the information in the first row that matches the key fields."/>
     </Record>
    </Annotation>
    <Annotation Term="Capabilities.DeleteRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Deletes a plan item from a work package."/>
