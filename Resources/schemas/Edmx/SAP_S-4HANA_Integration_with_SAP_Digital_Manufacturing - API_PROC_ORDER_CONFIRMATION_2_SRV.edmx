   <Annotations Target="API_PROC_ORDER_CONFIRMATION_2_SRV.API_PROC_ORDER_CONFIRMATION_2_SRV_Entities/ProcOrdConf2" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Capabilities.ReadRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Reads information on the header data of process order confirmations."/>
      <PropertyValue Property="LongDescription" String="Reads information available on the header data of existing process order confirmations. You can use the standard OData system query options to refine your request."/>
      <PropertyValue Property="ReadByKeyRestrictions">
       <Record>
        <PropertyValue Property="Description" String="Reads information on the header data of a single process order confirmation."/>
        <PropertyValue Property="LongDescription" String="Reads the information for a specific process order confirmation that you specify using the confirmation group and the confirmation count."/>
       </Record>
      </PropertyValue>
     </Record>
    </Annotation>
   </Annotations>
   <Annotations Target="API_PROC_ORDER_CONFIRMATION_2_SRV.API_PROC_ORDER_CONFIRMATION_2_SRV_Entities/ProcOrdConfMatlDocItm" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Capabilities.ReadRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Reads the material document for goods movements."/>
      <PropertyValue Property="LongDescription" String="Reads information available on the material document items of existing confirmations. You can use the standard OData system query options to refine your request."/>
      <PropertyValue Property="ReadByKeyRestrictions">
       <Record>
        <PropertyValue Property="Description" String="Reads information on a single material document for goods movements."/>
        <PropertyValue Property="LongDescription" String="Reads the information of a single material document item that you specify using the confirmation group number, the confirmation count, the number of the material document, the item in the material document, and the material document year."/>
       </Record>
      </PropertyValue>
     </Record>
    </Annotation>
   </Annotations>
   <Annotations Target="API_PROC_ORDER_CONFIRMATION_2_SRV.API_PROC_ORDER_CONFIRMATION_2_SRV_Entities/ProcOrderConfBatchCharc" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Capabilities.ReadRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Reads the batch characteristics in material documents for goods movements."/>
      <PropertyValue Property="LongDescription" String="Reads information available on the batch characteristics in material document items of existing confirmations. You can use the standard OData system query options to refine your request."/>
      <PropertyValue Property="ReadByKeyRestrictions">
       <Record>
        <PropertyValue Property="Description" String="Reads information on a single batch characteristic in a material document for goods movements."/>
        <PropertyValue Property="LongDescription" String="Reads the information on a single batch characteristic in a material document item that you specify using the confirmation group, the confirmation count,the material document number, the item in the material document, the material document year, the plant, the material, the batch, and the internal ID of the batch characteristic."/>
       </Record>
      </PropertyValue>
     </Record>
    </Annotation>
   </Annotations>
   <Annotations Target="API_PROC_ORDER_CONFIRMATION_2_SRV.API_PROC_ORDER_CONFIRMATION_2_SRV_Entities/ProcOrdConf2" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Capabilities.InsertRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Creates a new process order confirmation."/>
      <PropertyValue Property="LongDescription" String="Creates the header data for a new process order confirmation using the properties you provide. If desired, a material document for goods movement can be created together with the confirmation as well."/>
     </Record>
    </Annotation>
   </Annotations>
   <Annotations Target="API_PROC_ORDER_CONFIRMATION_2_SRV.API_PROC_ORDER_CONFIRMATION_2_SRV_Entities/ProcOrdConf2" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Capabilities.NavigationRestrictions">
     <Record>
      <PropertyValue Property="RestrictedProperties">
       <Collection>
        <Record>
         <PropertyValue Property="NavigationProperty" NavigationPropertyPath="to_ProcOrdConfMatlDocItm"/>
         <PropertyValue Property="ReadRestrictions">
          <Record>
           <PropertyValue Property="Description" String="Reads the header data of a process order confirmation together with the corresponding material documents for goods movements."/>
           <PropertyValue Property="LongDescription" String="Reads the header data of a single process order confirmation that you specify using the confirmation group and confirmation count. The response includes the material documents for goods movements belonging to the confirmation."/>
          </Record>
         </PropertyValue>
        </Record>
       </Collection>
      </PropertyValue>
     </Record>
    </Annotation>
   </Annotations>
   <Annotations Target="API_PROC_ORDER_CONFIRMATION_2_SRV.API_PROC_ORDER_CONFIRMATION_2_SRV_Entities/ProcOrdConfMatlDocItm" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Capabilities.NavigationRestrictions">
