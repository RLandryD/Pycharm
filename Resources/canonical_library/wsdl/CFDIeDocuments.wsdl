  <xsd:schema targetNamespace="http://www.sat.gob.mx/Pagos" xmlns="http://www.sat.gob.mx/Pagos" xmlns:xi0="http://www.sat.gob.mx/cfd/3" xmlns:xi1="http://cancelacfd.sat.gob.mx" xmlns:xi2="http://www.sat.gob.mx/ComercioExterior11" xmlns:xi3="http://www.sat.gob.mx/divisas" xmlns:xi4="http://www.sat.gob.mx/donat" xmlns:xi5="http://www.sat.gob.mx/implocal" xmlns:xi6="http://www.sat.gob.mx/Pagos" xmlns:xi7="http://www.w3.org/2000/09/xmldsig#" xmlns:xi8="http://www.sat.gob.mx/TimbreFiscalDigital" xmlns:xi9="http://www.sat.gob.mx/detallista" xmlns:xi10="http://www.sat.gob.mx/sitio_internet/cfd/catalogos/ComExt" xmlns:xi11="http://www.sat.gob.mx/sitio_internet/cfd/catalogos" xmlns:xi12="http://www.sat.gob.mx/sitio_internet/cfd/catalogos/Pagos" xmlns:xi13="http://www.sat.gob.mx/sitio_internet/cfd/tipoDatos/tdCFDI">
   <xsd:import namespace="http://www.sat.gob.mx/sitio_internet/cfd/catalogos/Pagos"/>
   <xsd:import namespace="http://www.sat.gob.mx/sitio_internet/cfd/tipoDatos/tdCFDI"/>
   <xsd:import namespace="http://www.sat.gob.mx/sitio_internet/cfd/catalogos"/>
   <xsd:element name="Pagos">
    <xsd:complexType>
     <xsd:sequence>
      <xsd:element name="Pago" form="qualified" maxOccurs="unbounded">
       <xsd:complexType>
        <xsd:sequence>
         <xsd:element name="DoctoRelacionado" minOccurs="0" form="qualified" maxOccurs="unbounded">
          <xsd:complexType>
           <xsd:attribute name="IdDocumento" use="required">
            <xsd:simpleType>
             <xsd:restriction base="xsd:string">
              <xsd:maxLength value="36"/>
              <xsd:minLength value="16"/>
              <xsd:pattern value="([a-f0-9A-F]{8}-[a-f0-9A-F]{4}-[a-f0-9A-F]{4}-[a-f0-9A-F]{4}-[a-f0-9A-F]{12})|([0-9]{3}-[0-9]{2}-[0-9]{9})"/>
              <xsd:whiteSpace value="collapse"/>
             </xsd:restriction>
            </xsd:simpleType>
           </xsd:attribute>
           <xsd:attribute name="Serie">
            <xsd:simpleType>
             <xsd:restriction base="xsd:string">
              <xsd:maxLength value="25"/>
              <xsd:minLength value="1"/>
              <xsd:pattern value="[^|]{1,25}"/>
              <xsd:whiteSpace value="collapse"/>
             </xsd:restriction>
            </xsd:simpleType>
           </xsd:attribute>
           <xsd:attribute name="Folio">
            <xsd:simpleType>
             <xsd:restriction base="xsd:string">
              <xsd:maxLength value="40"/>
              <xsd:minLength value="1"/>
              <xsd:pattern value="[^|]{1,40}"/>
              <xsd:whiteSpace value="collapse"/>
             </xsd:restriction>
            </xsd:simpleType>
           </xsd:attribute>
           <xsd:attribute name="MonedaDR" use="required" type="xi11:c_Moneda"/>
           <xsd:attribute name="TipoCambioDR">
            <xsd:simpleType>
             <xsd:restriction base="xsd:decimal">
              <xsd:fractionDigits value="6"/>
              <xsd:minInclusive value="0.000001"/>
              <xsd:whiteSpace value="collapse"/>
             </xsd:restriction>
            </xsd:simpleType>
           </xsd:attribute>
           <xsd:attribute name="MetodoDePagoDR" use="required" type="xi11:c_MetodoPago"/>
           <xsd:attribute name="NumParcialidad">
            <xsd:simpleType>
             <xsd:restriction base="xsd:integer">
              <xsd:pattern value="[1-9][0-9]{0,2}"/>
              <xsd:whiteSpace value="collapse"/>
             </xsd:restriction>
            </xsd:simpleType>
           </xsd:attribute>
           <xsd:attribute name="ImpSaldoAnt" type="xi13:t_Importe"/>
           <xsd:attribute name="ImpPagado" type="xi13:t_Importe"/>
           <xsd:attribute name="ImpSaldoInsoluto" type="xi13:t_Importe"/>
          </xsd:complexType>
         </xsd:element>
         <xsd:element name="Impuestos" minOccurs="0" form="qualified" maxOccurs="unbounded">
          <xsd:complexType>
           <xsd:sequence>
            <xsd:element name="Retenciones" minOccurs="0" form="qualified">
             <xsd:complexType>
              <xsd:sequence>
               <xsd:element name="Retencion" form="qualified" maxOccurs="unbounded">
                <xsd:complexType>
                 <xsd:attribute name="Impuesto" use="required" type="xi11:c_Impuesto"/>
                 <xsd:attribute name="Importe" use="required" type="xi13:t_Importe"/>
                </xsd:complexType>
               </xsd:element>
              </xsd:sequence>
             </xsd:complexType>
            </xsd:element>
            <xsd:element name="Traslados" minOccurs="0" form="qualified">
             <xsd:complexType>
              <xsd:sequence>
               <xsd:element name="Traslado" form="qualified" maxOccurs="unbounded">
                <xsd:complexType>
                 <xsd:attribute name="Impuesto" use="required" type="xi11:c_Impuesto"/>
                 <xsd:attribute name="TipoFactor" use="required" type="xi11:c_TipoFactor"/>
                 <xsd:attribute name="TasaOCuota" use="required">
                  <xsd:simpleType>
                   <xsd:restriction base="xsd:decimal">
                    <xsd:fractionDigits value="6"/>
                    <xsd:minInclusive value="0.000000"/>
                    <xsd:whiteSpace value="collapse"/>
                   </xsd:restriction>
                  </xsd:simpleType>
                 </xsd:attribute>
                 <xsd:attribute name="Importe" use="required" type="xi13:t_Importe"/>
                </xsd:complexType>
               </xsd:element>
              </xsd:sequence>
             </xsd:complexType>
            </xsd:element>
           </xsd:sequence>
           <xsd:attribute name="TotalImpuestosRetenidos" type="xi13:t_Importe"/>
           <xsd:attribute name="TotalImpuestosTrasladados" type="xi13:t_Importe"/>
          </xsd:complexType>
         </xsd:element>
        </xsd:sequence>
        <xsd:attribute name="FechaPago" use="required" type="xi13:t_FechaH"/>
        <xsd:attribute name="FormaDePagoP" use="required" type="xi11:c_FormaPago"/>
        <xsd:attribute name="MonedaP" use="required" type="xi11:c_Moneda"/>
        <xsd:attribute name="TipoCambioP">
         <xsd:simpleType>
          <xsd:restriction base="xsd:decimal">
           <xsd:fractionDigits value="6"/>
           <xsd:minInclusive value="0.000001"/>
           <xsd:whiteSpace value="collapse"/>
          </xsd:restriction>
         </xsd:simpleType>
        </xsd:attribute>
        <xsd:attribute name="Monto" use="required" type="xi13:t_Importe"/>
        <xsd:attribute name="NumOperacion">
         <xsd:simpleType>
          <xsd:restriction base="xsd:string">
           <xsd:maxLength value="100"/>
           <xsd:minLength value="1"/>
           <xsd:pattern value="[^|]{1,100}"/>
          </xsd:restriction>
         </xsd:simpleType>
        </xsd:attribute>
        <xsd:attribute name="RfcEmisorCtaOrd">
         <xsd:simpleType>
          <xsd:restriction base="xsd:string">
           <xsd:maxLength value="13"/>
           <xsd:minLength value="12"/>
           <xsd:pattern value="XEXX010101000|[A-Z&amp;Ñ]{3}[0-9]{2}(0[1-9]|1[012])(0[1-9]|[12][0-9]|3[01])[A-Z0-9]{2}[0-9A]"/>
           <xsd:whiteSpace value="collapse"/>
          </xsd:restriction>
         </xsd:simpleType>
        </xsd:attribute>
        <xsd:attribute name="NomBancoOrdExt">
         <xsd:simpleType>
          <xsd:restriction base="xsd:string">
           <xsd:maxLength value="300"/>
           <xsd:minLength value="1"/>
           <xsd:pattern value="[^|]{1,300}"/>
           <xsd:whiteSpace value="collapse"/>
          </xsd:restriction>
         </xsd:simpleType>
        </xsd:attribute>
        <xsd:attribute name="CtaOrdenante">
         <xsd:simpleType>
          <xsd:restriction base="xsd:string">
           <xsd:maxLength value="50"/>
           <xsd:minLength value="10"/>
           <xsd:pattern value="[A-Z0-9_]{10,50}"/>
           <xsd:whiteSpace value="collapse"/>
          </xsd:restriction>
         </xsd:simpleType>
        </xsd:attribute>
        <xsd:attribute name="RfcEmisorCtaBen" type="xi13:t_RFC_PM"/>
        <xsd:attribute name="CtaBeneficiario">
         <xsd:simpleType>
          <xsd:restriction base="xsd:string">
           <xsd:maxLength value="50"/>
           <xsd:minLength value="10"/>
           <xsd:pattern value="[A-Z0-9_]{10,50}"/>
           <xsd:whiteSpace value="collapse"/>
          </xsd:restriction>
         </xsd:simpleType>
        </xsd:attribute>
        <xsd:attribute name="TipoCadPago" type="xi12:c_TIpoCadenaPago"/>
        <xsd:attribute name="CertPago">
         <xsd:simpleType>
          <xsd:restriction base="xsd:base64Binary">
           <xsd:whiteSpace value="collapse"/>
          </xsd:restriction>
         </xsd:simpleType>
        </xsd:attribute>
        <xsd:attribute name="CadPago">
         <xsd:simpleType>
          <xsd:restriction base="xsd:string">
           <xsd:maxLength value="8192"/>
           <xsd:minLength value="1"/>
           <xsd:whiteSpace value="collapse"/>
          </xsd:restriction>
         </xsd:simpleType>
        </xsd:attribute>
        <xsd:attribute name="SelloPago">
         <xsd:simpleType>
          <xsd:restriction base="xsd:base64Binary">
           <xsd:whiteSpace value="collapse"/>
          </xsd:restriction>
         </xsd:simpleType>
        </xsd:attribute>
       </xsd:complexType>
      </xsd:element>
     </xsd:sequence>
     <xsd:attribute name="Version" use="required">
      <xsd:simpleType>
       <xsd:restriction base="xsd:string">
        <xsd:whiteSpace value="collapse"/>
       </xsd:restriction>
      </xsd:simpleType>
     </xsd:attribute>
    </xsd:complexType>
   </xsd:element>
  </xsd:schema>
