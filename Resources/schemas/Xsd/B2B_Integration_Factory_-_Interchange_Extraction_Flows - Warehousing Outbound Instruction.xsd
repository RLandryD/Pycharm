            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Trade Item Data Owner</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Specifies who owns the set of trade item transactional data.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="butterFatReference" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Butter Fat Reference</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A reference number assigned by custom authorities to butter based fat products.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 3871DUGN</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transactionalItemData" minOccurs="0" maxOccurs="unbounded"
