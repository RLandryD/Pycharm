</xsd:annotation>
</xsd:element>
<xsd:element maxOccurs="1" minOccurs="0" name="Leave_End_Date" type="xsd:date">
<xsd:annotation>
<xsd:documentation>Most recent leave event Actual End Date.</xsd:documentation>
</xsd:annotation>
</xsd:element>
<xsd:element maxOccurs="1" minOccurs="0" name="First_Day_of_Work" type="xsd:date">
