   <xsd:complexType name="TradeStatisticClassificationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Specifies details of the trade classification system used for statistical purposes.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="classificationSystemName" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Classification System Name</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Name of the trade classification system used.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: National business Classification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="classificationSystemVersion" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Classification System Version</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Version of the trade classification system used.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2014-1</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="classificationSystemCode">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Classification System Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Trade classification code.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: XYZ-17</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
