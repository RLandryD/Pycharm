			</element>
			<element name="upsertResponse">
				<complexType>
					<sequence>
						<element name="result" type="ens:ModifyResult" />
					</sequence>
				</complexType>
			</element>
			<!--//////////////////////////////////////// -->
			<!--Begin Typed delete Types -->
			<!-- /////////////////////////////////////// -->
			<element name="deleteRequest">
				<complexType>
					<sequence>
						<element name="sessionId" type="xsd:string" />
						<element name="delete" type="ens:ModifyRequest">
						</element>	
					</sequence>
				</complexType>
			</element>
			<element name="deleteResponse">
				<complexType>
					<sequence>
						<element name="result" type="ens:ModifyResult" />
					</sequence>
				</complexType>
			</element>
		</schema>
	</wsdl:types>
