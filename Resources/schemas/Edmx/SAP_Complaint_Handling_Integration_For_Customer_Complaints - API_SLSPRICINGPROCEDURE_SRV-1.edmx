Property="NavigationProperty"/><PropertyValue Property="ReadRestrictions"><Record><PropertyValue Property="Description" String="Reads the condition type for a specific condition type description."/><PropertyValue Property="LongDescription" String="Reads the data of condition types for pricing in Sales for a specific condition type description. Consumers must pass &#34;A&#34; as condition usage, &#34;V&#34; as condition application, condition type, and language code."/></Record></PropertyValue></Record></Collection></PropertyValue></Record></Annotation></Annotations><Annotations xmlns="http://docs.oasis-open.org/odata/ns/edm" Target="API_SLSPRICINGPROCEDURE_SRV.API_SLSPRICINGPROCEDURE_SRV_Entities/A_SlsPricingProcedure"><Annotation Term="Capabilities.ReadRestrictions"><Record><PropertyValue Property="Description" String="Reads all pricing procedures in Sales."/><PropertyValue Property="LongDescription" String="Reads all pricing procedures that are used in Sales."/><PropertyValue Property="ReadByKeyRestrictions"><Record><PropertyValue Property="Description" String="Reads a specific pricing procedure."/><PropertyValue Property="LongDescription" String="Reads a specific pricing procedure in Sales, which the consumer specifies by passing &#34;A&#34; as condition usage, &#34;V&#34; as condition application, and pricing procedure."/></Record></PropertyValue></Record></Annotation><Annotation Term="Capabilities.NavigationRestrictions"><Record><PropertyValue Property="RestrictedProperties"><Collection><Record><PropertyValue NavigationPropertyPath="to_Text" Property="NavigationProperty"/><PropertyValue Property="ReadRestrictions"><Record><PropertyValue Property="Description" String="Reads the description of a specific pricing procedure."/><PropertyValue Property="LongDescription" String="Reads pricing procedure description from a specific pricing procedure in Sales, which the consumer specifies by passing &#34;A&#34; as condition usage, &#34;V&#34; as condition application, and pricing procedure."/></Record></PropertyValue></Record><Record><PropertyValue NavigationPropertyPath="to_SalesPricingProcedureItem" Property="NavigationProperty"/><PropertyValue Property="ReadRestrictions"><Record><PropertyValue Property="Description" String="Reads the pricing procedure item of a specific pricing procedure."/><PropertyValue Property="LongDescription" String="Reads pricing procedure item data from a specific pricing procedure in Sales, which the consumer specifies by passing &#34;A&#34; as condition usage, &#34;V&#34; as condition application, and a pricing procedure. Pricing procedure item data contains a list of condition types and subtotal lines ordered by a combination of step and counter numbers."/></Record></PropertyValue></Record></Collection></PropertyValue></Record></Annotation></Annotations><Annotations xmlns="http://docs.oasis-open.org/odata/ns/edm" Target="API_SLSPRICINGPROCEDURE_SRV.API_SLSPRICINGPROCEDURE_SRV_Entities/A_SlsPricingProcedureText"><Annotation Term="Capabilities.ReadRestrictions"><Record><PropertyValue Property="Description" String="Reads all pricing procedure descriptions."/><PropertyValue Property="LongDescription" String="Reads descriptions of all pricing procedures in Sales."/><PropertyValue Property="ReadByKeyRestrictions"><Record><PropertyValue Property="Description" String="Reads a specific pricing procedure description."/><PropertyValue Property="LongDescription" String="Reads the description of a specific pricing procedure that is used in Sales, which the consumer specifies by passing &#34;A&#34; as condition usage, &#34;V&#34; as condition application, and pricing procedure."/></Record></PropertyValue></Record></Annotation><Annotation Term="Capabilities.NavigationRestrictions"><Record><PropertyValue Property="RestrictedProperties"><Collection><Record><PropertyValue NavigationPropertyPath="to_SalesPricingProcedure" Property="NavigationProperty"/><PropertyValue Property="ReadRestrictions"><Record><PropertyValue Property="Description" String="Reads the pricing procedure for a specific pricing procedure description."/><PropertyValue Property="LongDescription" String="Reads the pricing procedure for the description of a specific pricing procedure in Sales. Consumers must pass &#34;A&#34; as condition usage, &#34;V&#34; as condition application, and pricing procedure."/></Record></PropertyValue></Record></Collection></PropertyValue></Record></Annotation></Annotations><Annotations xmlns="http://docs.oasis-open.org/odata/ns/edm" Target="API_SLSPRICINGPROCEDURE_SRV.API_SLSPRICINGPROCEDURE_SRV_Entities/A_SlsPricingProcedureItem"><Annotation Term="Capabilities.ReadRestrictions"><Record><PropertyValue Property="Description" String="Reads all pricing procedure items in the system."/><PropertyValue Property="LongDescription" String="Reads item data of all pricing procedures that are used in Sales. Pricing procedure item data contains a list of condition types and subtotal lines ordered by a combination of step and counter numbers."/><PropertyValue Property="ReadByKeyRestrictions"><Record><PropertyValue Property="Description" String="Reads a specific pricing procedure item."/><PropertyValue Property="LongDescription" String="Reads data of a specific pricing procedure item in Sales, which the consumer specifies by passing &#34;A&#34; as condition usage, &#34;V&#34; as condition application, pricing procedure, pricing procedure step, and pricing procedure counter. A pricing procedure item can be a line for a condition type or a subtotal according to a combination of step and counter numbers."/></Record></PropertyValue></Record></Annotation><Annotation Term="Capabilities.NavigationRestrictions"><Record><PropertyValue Property="RestrictedProperties"><Collection><Record><PropertyValue NavigationPropertyPath="to_Text" Property="NavigationProperty"/><PropertyValue Property="ReadRestrictions"><Record><PropertyValue Property="Description" String="Reads the subtotal line description from a specific pricing procedure item."/><PropertyValue Property="LongDescription" String="Reads the subtotal line description from the data of a specific pricing procedure item in Sales. Consumers must pass &#34;A&#34; as condition usage, &#34;V&#34; as condition application, pricing procedure, pricing procedure step, and pricing procedure counter. Subtotal lines are the lines in a pricing procedure that are not specified with a condition type."/></Record></PropertyValue></Record><Record><PropertyValue NavigationPropertyPath="to_SalesPricingProcedure" Property="NavigationProperty"/><PropertyValue Property="ReadRestrictions"><Record><PropertyValue Property="Description" String="Reads the pricing procedure for a specific pricing procedure item."/><PropertyValue Property="LongDescription" String="Reads the pricing procedure from the data of a specific pricing procedure item in Sales, which the consumer specifies by passing &#34;A&#34; as condition usage, &#34;V&#34; as condition application, pricing procedure, pricing procedure step, and pricing procedure counter."/></Record></PropertyValue></Record><Record><PropertyValue NavigationPropertyPath="to_SlsPricingConditionType" Property="NavigationProperty"/><PropertyValue Property="ReadRestrictions"><Record><PropertyValue Property="Description" String="Reads the condition type from a specific pricing procedure item."/><PropertyValue Property="LongDescription" String="Reads the condition type from the data of a specific pricing procedure item in Sales, which the consumer specifies by passing &#34;A&#34; as condition usage, &#34;V&#34; as condition application, pricing procedure, pricing procedure step, and pricing procedure counter."/></Record></PropertyValue></Record></Collection></PropertyValue></Record></Annotation></Annotations><Annotations xmlns="http://docs.oasis-open.org/odata/ns/edm" Target="API_SLSPRICINGPROCEDURE_SRV.API_SLSPRICINGPROCEDURE_SRV_Entities/A_SlsPrcgProcedItemText"><Annotation Term="Capabilities.ReadRestrictions"><Record><PropertyValue Property="Description" String="Reads subtotal line descriptions in all pricing procedures."/><PropertyValue Property="LongDescription" String="Reads descriptions of subtotal lines of all pricing procedures used in Sales in different languages. Subtotal lines are the lines in a pricing procedure that are not specified with a condition type."/><PropertyValue Property="ReadByKeyRestrictions"><Record><PropertyValue Property="Description" String="Reads a specific subtotal line description in a specific pricing procedure."/><PropertyValue Property="LongDescription" String="Reads a specific subtotal line description in a specific pricing procedure in Sales, which the consumer specifies by passing &#34;A&#34; as condition usage, &#34;V&#34; as condition application, language, pricing procedure, pricing procedure step, and pricing procedure counter. Subtotal lines are the lines in a pricing procedure that are not specified with a condition type."/></Record></PropertyValue></Record></Annotation><Annotation Term="Capabilities.NavigationRestrictions"><Record><PropertyValue Property="RestrictedProperties"><Collection><Record><PropertyValue NavigationPropertyPath="to_SalesPricingProcedureItem" Property="NavigationProperty"/><PropertyValue Property="ReadRestrictions"><Record><PropertyValue Property="Description" String="Reads the pricing procedure item for a specific subtotal line description."/><PropertyValue Property="LongDescription" String="Reads data of the pricing procedure item in Sales for a specific subtotal line description. Consumers must pass &#34;A&#34; as condition usage, &#34;V&#34; as condition application, language, pricing procedure, pricing procedure step, and pricing procedure counter. A pricing procedure item can be a line for a condition type or a subtotal according to a combination of step and counter numbers."/></Record></PropertyValue></Record></Collection></PropertyValue></Record></Annotation></Annotations><Annotations xmlns="http://docs.oasis-open.org/odata/ns/edm" Target="API_SLSPRICINGPROCEDURE_SRV.API_SLSPRICINGPROCEDURE_SRV_Entities"/><atom:link xmlns:atom="http://www.w3.org/2005/Atom" href="https://host:port/sap/opu/odata/sap/API_SLSPRICINGPROCEDURE_SRV/$metadata" rel="self"/><atom:link xmlns:atom="http://www.w3.org/2005/Atom" href="https://host:port/sap/opu/odata/sap/API_SLSPRICINGPROCEDURE_SRV/$metadata" rel="latest-version"/></Schema></edmx:DataServices></edmx:Edmx>