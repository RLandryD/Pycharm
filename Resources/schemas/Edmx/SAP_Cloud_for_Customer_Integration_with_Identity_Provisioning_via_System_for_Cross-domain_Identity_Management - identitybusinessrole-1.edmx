<?xml version="1.0" encoding="utf-8"?>
<edmx:Edmx Version="1.0" xmlns:edmx="http://schemas.microsoft.com/ado/2007/06/edmx">
    <edmx:DataServices m:DataServiceVersion="1.0" xmlns:m="http://schemas.microsoft.com/ado/2007/08/dataservices/metadata">
        <Schema Namespace="http://sap.com/xi/AP/PC/IdentityManagement/Global" xmlns="http://schemas.microsoft.com/ado/2008/09/edm" xmlns:sap="http://www.sap.com/Protocols/SAPData" xmlns:c4c="http://www.sap.com/Protocols/C4CData">
            <EntityType Name="IdentityBusinessRoleAssignedBusinessUser">
                <Key>
                    <PropertyRef Name="BusinessRoleUUID"/>
                    <PropertyRef Name="BusinessRoleID"/>
                    <PropertyRef Name="UserID"/>
                </Key>
                <Property Name="BusinessRoleUUID" Type="Edm.String" Nullable="true" FixedLength="false" sap:creatable="true" sap:updatable="true" sap:filterable="true"/>
                <Property Name="BusinessRoleID" Type="Edm.String" Nullable="true" MaxLength="255" FixedLength="false" sap:creatable="true" sap:updatable="true" sap:filterable="true"/>
                <Property Name="UserUUID" Type="Edm.String" Nullable="true" FixedLength="false" sap:creatable="true" sap:updatable="true" sap:filterable="false"/>
                <Property Name="UserID" Type="Edm.String" Nullable="true" FixedLength="false" sap:creatable="true" sap:updatable="true" sap:filterable="true"/>
                <Property Name="UserName" Type="Edm.String" Nullable="false" FixedLength="false" sap:creatable="false" sap:updatable="false" sap:filterable="true"/>
            </EntityType>
            <EntityType Name="IdentityBusinessRole">
                <Key>
                    <PropertyRef Name="ObjectID"/>
                </Key>
                <Property Name="ObjectID" Type="Edm.String" Nullable="false" MaxLength="70" FixedLength="true" sap:creatable="false" sap:updatable="false" sap:filterable="true"/>
                <Property Name="ETag" Type="Edm.DateTimeOffset" Nullable="true" Precision="7" ConcurrencyMode="Fixed" sap:creatable="false" sap:updatable="false" sap:filterable="false"/>
                <Property Name="ID" Type="Edm.String" Nullable="true" MaxLength="40" FixedLength="true" sap:creatable="false" sap:updatable="false" sap:filterable="true"/>
                <Property Name="Description" Type="Edm.String" Nullable="true" MaxLength="255" FixedLength="true" sap:creatable="false" sap:updatable="false" sap:filterable="true"/>
                <Property Name="languageCode" Type="Edm.String" Nullable="true" MaxLength="2" FixedLength="true" sap:creatable="false" sap:updatable="false" sap:filterable="true" sap:text="languageCodeText" c4c:value-help="IdentityBusinessRolelanguageCodeCollection"/>
                <Property Name="languageCodeText" Type="Edm.String" Nullable="true" sap:creatable="false" sap:updatable="false" sap:filterable="true"/>
                <Property Name="Name" Type="Edm.String" Nullable="true" MaxLength="40" FixedLength="true" sap:creatable="false" sap:updatable="false" sap:filterable="true"/>
                <Property Name="languageCode1" Type="Edm.String" Nullable="true" MaxLength="2" FixedLength="true" sap:creatable="false" sap:updatable="false" sap:filterable="true" sap:text="languageCode1Text" c4c:value-help="IdentityBusinessRolelanguageCode1Collection"/>
                <Property Name="languageCode1Text" Type="Edm.String" Nullable="true" sap:creatable="false" sap:updatable="false" sap:filterable="true"/>
                <Property Name="EntityLastChangedOn" Type="Edm.DateTimeOffset" Nullable="true" Precision="7" sap:creatable="false" sap:updatable="false" sap:filterable="true"/>
            </EntityType>
            <EntityType Name="CodeList">
                <Key>
                    <PropertyRef Name="Code"/>
                </Key>
                <Property Name="Code" Type="Edm.String" Nullable="false" FixedLength="false" sap:creatable="false" sap:updatable="false" sap:filterable="true"/>
                <Property Name="Description" Type="Edm.String" Nullable="false" FixedLength="false" sap:creatable="false" sap:updatable="false" sap:filterable="true"/>
            </EntityType>
            <EntityContainer Name="identitybusinessrole" m:IsDefaultEntityContainer="true">
                <EntitySet Name="IdentityBusinessRoleAssignedBusinessUserCollection" EntityType="http://sap.com/xi/AP/PC/IdentityManagement/Global.IdentityBusinessRoleAssignedBusinessUser" sap:creatable="true" sap:updatable="true" sap:deletable="true"/>
                <EntitySet Name="IdentityBusinessRoleCollection" EntityType="http://sap.com/xi/AP/PC/IdentityManagement/Global.IdentityBusinessRole" sap:creatable="false" sap:updatable="false" sap:deletable="true"/>
                <EntitySet Name="IdentityBusinessRolelanguageCode1Collection" EntityType="http://sap.com/xi/AP/PC/IdentityManagement/Global.CodeList" sap:creatable="false" sap:updatable="false" sap:deletable="false" sap:semantics="fixed-values"/>
                <EntitySet Name="IdentityBusinessRolelanguageCodeCollection" EntityType="http://sap.com/xi/AP/PC/IdentityManagement/Global.CodeList" sap:creatable="false" sap:updatable="false" sap:deletable="false" sap:semantics="fixed-values"/>
            </EntityContainer>
        </Schema>
    </edmx:DataServices>
</edmx:Edmx>