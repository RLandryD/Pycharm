<?xml version="1.0" encoding="UTF-8"?>
<!--
  SCENARIO iFlow: Fetch Participant Data from GoToWebinar Platform
  Display Name : OUT_SAP_Marketing_Cloud_Fetch_GoToWebinar_At_Fetch_Participant_Da
  Package      : 1_SAP_Marketing_Cloud_Fetch_GoToWebinar_At_Finance
  Strategy     : GREENFIELD: Clean cloud-native rebuild. No legacy mapping reuse.
  Complexity   : HIGH (score: 140)
  Effort       : 42.5 day(s)
  Sender       : SAP_Marketing_Cloud (HTTPS)
  Receiver     : Fetch_GoToWebinar_Attendees_Custom_Fields (ProcessDirect)
  Batch        : No
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Fetch_Participant_Da"
             name="OUT_SAP_Marketing_Cloud_Fetch_GoToWebinar_At_Fetch_Participant_Da">
  <process id="Fetch_Participant_Da_process" ifl:type="IntegrationFlow">

    <startEvent id="Start_SC" name="From Interface Separation">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Fetch_Participant_Da</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>



    <!-- PROCESSDIRECT: Forward to Outbound Delivery -->
    <serviceTask id="CallOutbound_1" name="→ Outbound Delivery" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/outbound/1_SAP_Marketing_Clou</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_SC"/>
    <sequenceFlow sourceRef="Start_SC" targetRef="CallOutbound_1"/>
    
    
    <sequenceFlow sourceRef="CallOutbound_1" targetRef="End_SC"/>
  </process>
</definitions>