<?xml version="1.0" encoding="utf-8"?>
<xs:schema attributeFormDefault="unqualified" elementFormDefault="qualified" xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <xs:element name="response">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="entry">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="odata.context" type="xs:string" />
              <xs:element maxOccurs="unbounded" name="value">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="odata.etag" type="xs:string" />
                    <xs:element name="opportunityid" type="xs:string" />
                    <xs:element name="_createdby_value" type="xs:string" />
                    <xs:element name="_ownerid_value" type="xs:string" />
                    <xs:element name="_parentaccountid_value" type="xs:string" />
                    <xs:element name="createdon" type="xs:dateTime" />
                    <xs:element name="modifiedon" type="xs:dateTime" />
                    <xs:element name="actualclosedate" type="xs:string" />
                    <xs:element name="salesstage" type="xs:string" />
                    <xs:element name="name" type="xs:string" />
                    <xs:element name="totalamount" type="xs:unsignedShort" />
                    <xs:element name="_transactioncurrencyid_value" type="xs:string" />
                    <xs:element name="statecode" type="xs:unsignedByte" />
                    <xs:element name="prioritycode" type="xs:unsignedByte" />
                    <xs:element name="closeprobability" type="xs:string" />
                    <xs:element name="transactioncurrencyid">
                      <xs:complexType>
                        <xs:attribute name="currencyname" type="xs:string" />
                        <xs:attribute name="transactioncurrencyid" type="xs:string" />
                      </xs:complexType>
                    </xs:element>
                    <xs:element name="originatingleadid">
                      <xs:complexType>
                        <xs:attribute name="leadsourcecode" type="xs:string" />
                        <xs:attribute name="leadid" type="xs:string" />
                      </xs:complexType>
                    </xs:element>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
</xs:schema>