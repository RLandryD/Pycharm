xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ac871ff311e1bf570026b9aa16ff</xsd:appinfo><xsd:documentation>SR03 | Time. NOTES: SR03 defines the start time of the advertising promotion.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="4"/><xsd:maxLength value="8"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_337_2"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ac881ff311e184360026b9aa16ff</xsd:appinfo><xsd:documentation>SR04 | Time. NOTES: C0403 - If SR04 is present, then SR03 is required. SR04 defines the end time of the advertising promotion.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="4"/><xsd:maxLength value="8"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_3"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ac891ff311e1c8200026b9aa16ff</xsd:appinfo><xsd:documentation>SR05 | Free Form Message. NOTES: SR05 is used to describe the advertising schedule details in literal form.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="60"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_212"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ac8a1ff311e1a2390026b9aa16ff</xsd:appinfo><xsd:documentation>SR06 | Unit Price</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="17"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_380"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ac8b1ff311e1a8890026b9aa16ff</xsd:appinfo><xsd:documentation>SR07 | Quantity. NOTES: SR07 is used to provide the number of scheduled commercial spots to be run.</xsd:documentati