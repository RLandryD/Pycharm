			</xsd:simpleType>
			<xsd:simpleType name="ReferenceDocument_GFN">
				<xsd:annotation>
					<xsd:documentation xml:lang="EN">Document No. of a Reference Document</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:token">
					<xsd:minLength value="1"/>
					<xsd:maxLength value="10"/>
