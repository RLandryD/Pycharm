               <xsd:documentation xml:lang="en-US" source="Name">Document Effective Date</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The date that the document becomes effective from commercial or legal point of view.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="avpList" minOccurs="0" type="Ecom_AttributeValuePairListType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Avp List</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The transmission of non-standard data done in a simple, flexible, and easy to use method.</xsd:documentation>
            </xsd:annotation>
