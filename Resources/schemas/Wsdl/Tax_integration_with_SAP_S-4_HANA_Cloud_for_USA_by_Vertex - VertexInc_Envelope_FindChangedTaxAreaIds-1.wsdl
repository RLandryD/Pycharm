<?xml version="1.0" encoding="UTF-8"?>
<wsdl:definitions xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/" targetNamespace="urn:vertexinc:o-series:tps:7:0">
	<wsdl:types>
		<xsd:schema targetNamespace="urn:vertexinc:o-series:tps:7:0" elementFormDefault="qualified" version="7.0" xmlns="urn:vertexinc:o-series:tps:7:0" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
			<xsd:element name="VertexEnvelope">
				<xsd:annotation>
					<xsd:documentation>Vertex envelope containing transaction information.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element name="Login" type="LoginType"/>
						<xsd:choice>
							<xsd:element name="FindChangedTaxAreaIdsRequest" type="FindChangedTaxAreaIdsRequestType">
								<xsd:annotation>
									<xsd:documentation><![CDATA[The Tax Area Request message. This message initiates a single Tax Area lookup requested by an external system. Use the Tax Areas Request message to send a query to retrieve a single  tax jurisdiction lookup. For example, you could use this event to retrieve the Tax Area IDs for a single postal address.]]></xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="FindChangedTaxAreaIdsResponse" type="FindChangedTaxAreaIdsResponseType">
								<xsd:annotation>
									<xsd:documentation>The Tax Area Response message. This response returns the retrieved tax jurisdiction.</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
						</xsd:choice>
						<xsd:element name="ApplicationData" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>Logging information for this transaction.</xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:sequence>
									<xsd:element name="Sender" type="xsd:string" minOccurs="0">
										<xsd:annotation>
											<xsd:documentation><![CDATA[Identifies the application that created the request message. This can be the logical location of the application and/or database server, the application, or the task that was processing to create the request message.]]></xsd:documentation>
										</xsd:annotation>
									</xsd:element>
									<xsd:element name="MessageLogging" minOccurs="0">
										<xsd:annotation>
											<xsd:documentation>A group of logging parameters.</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="OverrideLoggingThreshold" minOccurs="0" maxOccurs="unbounded">
													<xsd:annotation>
														<xsd:documentation>When present, registers a logging threshold for the transaction. When request-handling is complete, this logging threshold is unregistered.</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:simpleContent>
															<xsd:extension base="LogLevelType">
																<xsd:attribute name="thresholdScope" type="xsd:string">
																	<xsd:annotation>
																		<xsd:documentation>Names a package scope for the threshold override. If absent, override threshold is global.</xsd:documentation>
																	</xsd:annotation>
																</xsd:attribute>
															</xsd:extension>
														</xsd:simpleContent>
													</xsd:complexType>
												</xsd:element>
											</xsd:sequence>
											<xsd:attribute name="returnLogEntries" type="xsd:boolean">
												<xsd:annotation>
													<xsd:documentation>Indicates whether to return the LogEntry elements in the response.</xsd:documentation>
												</xsd:annotation>
											</xsd:attribute>
										</xsd:complexType>
									</xsd:element>
									<xsd:element name="LogEntry" type="LogEntryType" minOccurs="0" maxOccurs="unbounded">
										<xsd:annotation>
											<xsd:documentation>A group of log entry data.</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
									<xsd:element name="ResponseTimeMS" type="xsd:decimal" minOccurs="0">
										<xsd:annotation>
											<xsd:documentation>The processing time in milliseconds. Use this information for 
troubleshooting performance issues.</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
								</xsd:sequence>
							</xsd:complexType>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="ExtendedPrice" type="AmountType">
				<xsd:annotation>
					<xsd:documentation>This field specifies the actual price of the line item.  However, if quantity and unit price are supplied, this is not required.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PhysicalOrigin" type="LocationType">
				<xsd:annotation>
					<xsd:documentation><![CDATA[A Vertex-defined term that is equivalent to the following terms: ship-from or first removed. Required (1) for VAT triangulation at either Transaction level or the Line Item level. If Physical Origin information is provided at both levels, the Line Item level information supersedes the Transaction level information.]]></xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="LandedCost" type="AmountType">
				<xsd:annotation>
					<xsd:documentation><![CDATA[Landed Costs are costs associated with transporting goods.  They are additional costs beyond the merchandise cost of inventory incurred in purchasing and receiving items, for instance, freight, import duties, and customs charges. Landed Costs are added to the Extended Amount on a line item but are not subject to any discounts or adjustments]]></xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DateTimePeriod" type="DateTimePeriodType"/>
			<xsd:element name="AdministrativeOrigin" type="LocationType">
				<xsd:annotation>
					<xsd:documentation>A Vertex-defined term that is equivalent to the following terms: order taken, order acceptance, place of principle negotiation, or place of business.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Weight" type="MeasureType">
				<xsd:annotation>
					<xsd:documentation>The weight of the product.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="StatisticalValue" type="CurrencyAmountType">
				<xsd:annotation>
					<xsd:documentation><![CDATA[Used for trades in the European Union (EU). The statisticalValue is the invoice value for imports or purchases (Arrivals) or exports or sales (Dispatches), calculated at the national borders of the EU Member States. The statisticalValue applies only if you meet the threshold amounts defined by each Member State. This field  is used in Intrastat reports.]]></xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DatePeriod" type="DatePeriodType"/>
			<xsd:element name="TotalTax" type="AmountType">
				<xsd:annotation>
					<xsd:documentation>Amount of tax based on variables of transaction.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Discount">
				<xsd:annotation>
					<xsd:documentation>Details on the discount. To pass Discount information, pass either DiscountPercent or DiscountAmount, but not both.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:choice>
						<xsd:element name="DiscountPercent" type="PercentType">
							<xsd:annotation>
								<xsd:documentation>The discount to be applied expressed as a percentage. Required (1) if no Discount Amount information is supplied.</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<xsd:element name="DiscountAmount" type="AmountType">
							<xsd:annotation>
								<xsd:documentation>The discount to be applied expressed as an amount. Required (1) if no Discount Percent information is supplied.</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
					</xsd:choice>
					<xsd:attribute name="userDefinedDiscountCode" type="xsd:string">
						<xsd:annotation>
							<xsd:documentation><![CDATA[A user-defined code that maps to a Vertex-supplied discount category. You can use the Vertex Central user interface to map your discount codes to discount categories.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="InputTotalTax" type="AmountType">
				<xsd:annotation>
					<xsd:documentation>The amount of tax to be distributed.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Currency" type="CurrencyType">
				<xsd:annotation>
					<xsd:documentation>Default unit of currency for the entire transaction.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DeductionOverride">
				<xsd:annotation>
					<xsd:documentation>Details on the deduction override.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element name="ExemptOverride" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation><![CDATA[The amount used to override taxability to partial or full exempt status. If this data element is used to pass an override amount from the host system, the calculation engine ignores any applicable exceptions or overrides set up using the Vertex Central user interface. Vertex recommends that you use the Vertex Central user interface to create and maintain exceptions and overrides rather than using this data element.]]></xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:simpleContent>
									<xsd:extension base="AmountType">
										<xsd:attribute name="overrideExemptReasonCode">
											<xsd:annotation>
												<xsd:documentation><![CDATA[A code that indicates the reason for the override. If your host system provides this functionality, this data element can be used. You can use the Vertex Central user interface to set up reason codes. Valid reason codes are expected from the host system and are pre-defined by Vertex for use in the Returns Export module in Vertex Central. Note: To pass a standard (i.e., not user-defined) single-digit reason code, pad the code to four digits. Refer to the Supporting Information section of the XML Integration Guide for information on exemption and deduction reason codes.]]></xsd:documentation>
											</xsd:annotation>
											<xsd:simpleType>
												<xsd:restriction base="xsd:string">
													<xsd:minLength value="1"/>
													<xsd:maxLength value="4"/>
												</xsd:restriction>
											</xsd:simpleType>
										</xsd:attribute>
									</xsd:extension>
								</xsd:simpleContent>
							</xsd:complexType>
						</xsd:element>
						<xsd:element name="NonTaxableOverride" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation><![CDATA[The amount used to override taxability to partial or full non-taxable status. If this data element is used to pass an override amount from the host system, the calculation engine ignores any applicable exceptions or overrides set up using the Vertex Central user interface. Vertex recommends that you use the Vertex Central user interface to create and maintain exceptions and overrides rather than using this data element.]]></xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:simpleContent>
									<xsd:extension base="AmountType">
										<xsd:attribute name="overrideNonTaxableReasonCode" type="ReasonCodeType">
											<xsd:annotation>
												<xsd:documentation><![CDATA[A code that indicates the reason for the override. If your host system provides this functionality, this data element can be used. You can use the Vertex Central user interface to set up reason codes. Valid reason codes are expected from the host system and are pre-defined by Vertex for use in the Returns Export module in Vertex Central. Note: To pass a standard (i.e., not user-defined) single-digit reason code, pad the code to four digits. Refer to the Supporting Information section of the XML Integration Guide for information on exemption and deduction reason codes.]]></xsd:documentation>
											</xsd:annotation>
										</xsd:attribute>
									</xsd:extension>
								</xsd:simpleContent>
							</xsd:complexType>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="Recipient">
				<xsd:annotation>
					<xsd:documentation>Recipient information. The recipient is described by the child elements and attributes.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element ref="RecipientCode"/>
						<xsd:element ref="TaxRegistration" minOccurs="0" maxOccurs="unbounded"/>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="AssistedParameters" type="AssistedParametersType"/>
			<xsd:element name="RateOverride">
				<xsd:annotation>
					<xsd:documentation><![CDATA[The rate override percentage for the specified jurisdiction. Vertex recommends that you use the Vertex Central user interface to create and maintain exceptions and overrides rather than using this data element.]]></xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="xsd:decimal"/>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="PreviousTaxPaid" type="AmountType">
				<xsd:annotation>
					<xsd:documentation><![CDATA[This value represents the amount of taxes paid previously on the asset. This information is needed to determine reciprocity rules between jurisdictions.]]></xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Amount" type="AmountType"/>
			<xsd:element name="AdditionalTaxesDue" type="AmountType"/>
			<xsd:element name="Product">
				<xsd:annotation>
					<xsd:documentation><![CDATA[A code from the host system that identifies the product, material, service, or SKU number. You can use the Vertex Central user interface to map your products to Product Categories. If the supplied Product and Product Class information is not recognized by the calculation engine, a general category indicating TPP is assigned. Required (1) if no Product Class information is supplied. If both are supplied, Product information supersedes Product Class information.]]></xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="EntityCodeType">
							<xsd:attribute name="productClass" type="EntityCodeType">
								<xsd:annotation>
									<xsd:documentation><![CDATA[A code used to represent groups or categories of products or services with similar taxability. You can use the Vertex Central user interface to map your products classes to Product Class Categories. If the supplied Product and Product Class information is not recognized by the calculation engine, a general category indicating TPP is assigned. Required (1) if no Product information is supplied. If both are supplied, Product information supersedes Product Class information.]]></xsd:documentation>
								</xsd:annotation>
							</xsd:attribute>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="Freight" type="AmountType">
				<xsd:annotation>
					<xsd:documentation><![CDATA[This field sets the freight charge associated with the line item.  Note that the preferred method for dealing with freight is to create a separate line item with an item type mapped to one of the Vertex-provided Item Categories.  However, using this method will calculate tax for the default Freight Item Category and roll it into this line item.]]></xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TaxRegistration" type="TaxRegistrationType">
				<xsd:annotation>
					<xsd:documentation><![CDATA[Registration information for Value Added Tax. Note: This transaction is considered to involve a  group if the buyer and seller have the same registration number, the POS jurisdiction is an EU country, and a value of 2 (Intra-EU Notice) is returned for InvoiceTextCode.]]></xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="VendorCode">
				<xsd:annotation>
					<xsd:documentation><![CDATA[A user-defined code that represents the vendor (external seller or vendor) for the transaction or line item. Use the Vertex Central user interface to set up any taxability rules that apply at this level. This should be a parameter that is configurable to data from the host system.]]></xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:restriction base="CompanyCodeType">
							<xsd:minLength value="0"/>
							<xsd:maxLength value="40"/>
						</xsd:restriction>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="TaxOverride">
				<xsd:annotation>
					<xsd:documentation>Details on the tax override.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:attribute name="overrideType" type="TaxOverrideCodeType" use="required">
						<xsd:annotation>
							<xsd:documentation>Classifies the override as taxable or nontaxable.</xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
					<xsd:attribute name="overrideReasonCode" type="ReasonCodeType">
						<xsd:annotation>
							<xsd:documentation><![CDATA[A code that indicates the reason for the override. If your host system provides this functionality, this data element can be used. You can use the Vertex Central user interface to set up reason codes. Valid reason codes are expected from the host system and are pre-defined by Vertex for use in the Returns Export module in Vertex Central. Note: To pass a standard (i.e., not user-defined) single-digit reason code, pad the code to four digits. Refer to the Supporting Information section of the XML Integration Guide for information on exemption and deduction reason codes.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="TimePeriod" type="TimePeriodType"/>
			<xsd:element name="InvoiceTextCode" type="xsd:integer">
				<xsd:annotation>
					<xsd:documentation><![CDATA[Indicator that alerts the host system of the need to add invoice text of a specific type to a line item. For a list of the codes and their meanings, see the Supporting Information section in the XML Integration Guide. Note: This transaction is considered to involve a VAT group if a value of 2 (Intra-EU Notice) is returned, the POS jurisdiction is an EU country, and the buyer and seller have the same registration number.]]></xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="UnitPrice" type="AmountType">
				<xsd:annotation>
					<xsd:documentation>The Unit Price is used in conjunction with the quantity to calculate an extended price, if one is not provided.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SitusOverride">
				<xsd:annotation>
					<xsd:documentation>Details on the situs determination overrides.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:attribute name="taxingLocation" type="TaxingLocationCodeType" use="required">
						<xsd:annotation>
							<xsd:documentation>The address type to be used as the situs. Required if performing a situs override.</xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="InputTax">
				<xsd:annotation>
					<xsd:documentation>Information necessary for the calculation of recoverability of an input tax.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element name="TaxingJurisdictionLocation">
							<xsd:annotation>
								<xsd:documentation>Identifies the jurisdiction where the tax is reported.</xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:complexContent>
									<xsd:extension base="TaxingJurisdictionLocationType"/>
								</xsd:complexContent>
							</xsd:complexType>
						</xsd:element>
						<xsd:element ref="InputAmount"/>
						<xsd:element name="InvoiceTaxRate" type="xsd:decimal" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>The tax rate  as shown on the vendor invoice.</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<xsd:element name="BlockingOverridePercent" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>The recoverable override percentage of the blocking override on the Input Tax level.</xsd:documentation>
							</xsd:annotation>
							<xsd:simpleType>
								<xsd:restriction base="PercentType"/>
							</xsd:simpleType>
						</xsd:element>
						<xsd:element name="PartialExemptRecoverableOverridePercent" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>The recoverable percentage
 of a partial exemption. This field is populated only for transactions
with a tax type of Value Added Tax.</xsd:documentation>
							</xsd:annotation>
							<xsd:simpleType>
								<xsd:restriction base="PercentType"/>
							</xsd:simpleType>
						</xsd:element>
					</xsd:sequence>
					<xsd:attribute name="isImport" type="xsd:boolean" default="false">
						<xsd:annotation>
							<xsd:documentation>Indicates that the input tax is Import VAT. Defaults to false.</xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="JurisdictionLevel" type="JurisdictionLevelCodeType">
				<xsd:annotation>
					<xsd:documentation>Jurisdiction level structure.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Cost" type="AmountType">
				<xsd:annotation>
					<xsd:documentation><![CDATA[The actual basis cost to the purchaser for the materials of the asset. For manufacturers, this is the cost of the actual materials purchased for resale from outside suppliers. For wholesalers and retailers, this is the material cost of the property itself.]]></xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SubTotal" type="AmountType">
				<xsd:annotation>
					<xsd:documentation>Sum of all extended amounts for line items in the transaction.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Purchase">
				<xsd:annotation>
					<xsd:documentation>A code from the host application that identifies the product, material, service or SKU code.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="EntityCodeType">
							<xsd:attribute name="purchaseClass" type="EntityCodeType">
								<xsd:annotation>
									<xsd:documentation>A code from the host application that identifies a general classification of product, material, service or SKU code.</xsd:documentation>
								</xsd:annotation>
							</xsd:attribute>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="FlexibleFields">
				<xsd:annotation>
					<xsd:documentation>Container for user-defined fields. Fields are provided for string values, numeric (double) values, and date values.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element name="FlexibleCodeField" minOccurs="0" maxOccurs="25">
							<xsd:annotation>
								<xsd:documentation>User-defined field for string values.</xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:simpleContent>
									<xsd:extension base="FlexibleFieldCodeType">
										<xsd:attribute name="fieldId" use="required">
											<xsd:annotation>
												<xsd:documentation>An identifier for a Flexible Code Field.</xsd:documentation>
											</xsd:annotation>
											<xsd:simpleType>
												<xsd:restriction base="xsd:integer">
													<xsd:minInclusive value="1"/>
													<xsd:maxInclusive value="25"/>
												</xsd:restriction>
											</xsd:simpleType>
										</xsd:attribute>
									</xsd:extension>
								</xsd:simpleContent>
							</xsd:complexType>
						</xsd:element>
						<xsd:element name="FlexibleNumericField" minOccurs="0" maxOccurs="10">
							<xsd:annotation>
								<xsd:documentation>User-defined field for double values.</xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:simpleContent>
									<xsd:extension base="xsd:decimal">
										<xsd:attribute name="fieldId" use="required">
											<xsd:annotation>
												<xsd:documentation>An identifier for a Flexible Numeric Field.</xsd:documentation>
											</xsd:annotation>
											<xsd:simpleType>
												<xsd:restriction base="xsd:integer">
													<xsd:minInclusive value="1"/>
													<xsd:maxInclusive value="10"/>
												</xsd:restriction>
											</xsd:simpleType>
										</xsd:attribute>
									</xsd:extension>
								</xsd:simpleContent>
							</xsd:complexType>
						</xsd:element>
						<xsd:element name="FlexibleDateField" minOccurs="0" maxOccurs="5">
							<xsd:annotation>
								<xsd:documentation>User-defined field for date values.</xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:simpleContent>
									<xsd:extension base="xsd:date">
										<xsd:attribute name="fieldId" use="required">
											<xsd:annotation>
												<xsd:documentation>An identifier for a Flexible Date Field.</xsd:documentation>
											</xsd:annotation>
											<xsd:simpleType>
												<xsd:restriction base="xsd:integer">
													<xsd:minInclusive value="1"/>
													<xsd:maxInclusive value="5"/>
												</xsd:restriction>
											</xsd:simpleType>
										</xsd:attribute>
									</xsd:extension>
								</xsd:simpleContent>
							</xsd:complexType>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="FairMarketValue" type="AmountType">
				<xsd:annotation>
					<xsd:documentation>The basis price at which the asset could be sold to the public. This is also known as the selling price or the value of the product for sale.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ExemptionCertificate">
				<xsd:annotation>
					<xsd:documentation>Details on the exemption certificate.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="xsd:string">
							<xsd:attribute name="exemptionCertificateNumber">
								<xsd:annotation>
									<xsd:documentation><![CDATA[The identifier of the exemption certificate, which is recorded in the Tax Journal. Vertex recommends that you use the Vertex Central user interface to set up and maintain Exemption Certificates. Note: If you pass an exemption certificate number in the XML message, the isTaxExempt attribute of the participant is set to true and the transaction is treated as exempt from tax.]]></xsd:documentation>
								</xsd:annotation>
								<xsd:simpleType>
									<xsd:restriction base="xsd:string">
										<xsd:minLength value="1"/>
										<xsd:maxLength value="30"/>
									</xsd:restriction>
								</xsd:simpleType>
							</xsd:attribute>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="CustomerCode" type="CustomerCodeType">
				<xsd:annotation>
					<xsd:documentation>A user-defined code that represents the customer for the transaction or line item.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ChargedTax" type="AmountType">
				<xsd:annotation>
					<xsd:documentation><![CDATA[This value is used when the buyer has paid a portion of the tax due on the invoice but an undercharge scenario occurs that required a partial accrual of tax or additional use tax may be due depending on the jurisdiction and usage of the Purchase. The amount paid from the invoice verification process should be passed so that partial accrual can be applied. Additional consumer use tax will be automatically accrued.]]></xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="InputAmount" type="AmountType">
				<xsd:annotation>
					<xsd:documentation>The amount of Input Tax to be distributed. Negative numbers are permitted so that corrections may be processed</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Taxes" type="TaxesType"/>
			<xsd:element name="CommodityCode">
				<xsd:annotation>
					<xsd:documentation>A standardized, unique code for the product or service.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="EntityCodeType">
							<xsd:attribute name="commodityCodeType" use="required">
								<xsd:annotation>
									<xsd:documentation>The type of commodity code mapping.</xsd:documentation>
								</xsd:annotation>
								<xsd:simpleType>
									<xsd:restriction base="xsd:string">
										<xsd:minLength value="1"/>
										<xsd:maxLength value="60"/>
									</xsd:restriction>
								</xsd:simpleType>
							</xsd:attribute>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="SupplementaryUnit" type="SupplementaryUnitType">
				<xsd:annotation>
					<xsd:documentation><![CDATA[A quantity used with commodity codes that require a unit of 
measurement other than kilograms. For example, a supplementary unit could be the number of pieces, liters, or cubic meters. This is a numeric field used for intrastat purposes on the line item level.]]></xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="JurisdictionOverride">
				<xsd:annotation>
					<xsd:documentation>Details on the jurisdiction overrides.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element ref="DeductionOverride" minOccurs="0"/>
						<xsd:element ref="RateOverride" minOccurs="0"/>
					</xsd:sequence>
					<xsd:attribute name="jurisdictionLevel" type="JurisdictionLevelCodeType" use="required">
						<xsd:annotation>
							<xsd:documentation><![CDATA[The jurisdiction level of the overrides. Vertex recommends that you use the Vertex Central user interface to create and maintain jurisdiction overrides.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
					<xsd:attribute name="impositionType">
						<xsd:annotation>
							<xsd:documentation><![CDATA[The type of imposition. impositionType can be Vertex-defined
or user-defined in Vertex Central. impositionType enables you to
set registration-level details during transaction processing.

Regstration can have multiple imposition types at both the Main 
Division and Country level. This is an optional attribute under the 
TaxRegistration element.]]></xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:minLength value="0"/>
								<xsd:maxLength value="60"/>
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:attribute>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="RecipientCode" type="CustomerCodeType">
				<xsd:annotation>
					<xsd:documentation>A user-defined code that represents the recipient for the transaction or line item.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Dispatcher">
				<xsd:annotation>
					<xsd:documentation>Dispatcher information. The dispatcher is described by the child elements and attributes.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element ref="DispatcherCode"/>
						<xsd:element ref="TaxRegistration" minOccurs="0" maxOccurs="unbounded"/>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="Quantity" type="MeasureType">
				<xsd:annotation>
					<xsd:documentation><![CDATA[The number of units included in the line item based on quantity and not a currency amount. This value is applied on a line item basis to the quantity level of the product. This application of tax differs from normal tax calculation because the tax amount/rate is applied at the quantity level of the item sold in the transaction and not to the purchase price. Required (1) if no Extended Price information is supplied.]]></xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="AdministrativeDestination" type="LocationType">
				<xsd:annotation>
					<xsd:documentation><![CDATA[A Vertex-defined term that is equivalent to the benefit received location in some service transactions. Required (1) for some service transactions at either the Transaction level or the Line Item level. If information is provided at both levels, the Line Item level information supersedes the Transaction level information.]]></xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Volume" type="MeasureType">
				<xsd:annotation>
					<xsd:documentation>The volume of the product.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PostalAddress" type="PostalAddressType"/>
			<xsd:element name="CurrencyConversion">
				<xsd:annotation>
					<xsd:documentation><![CDATA[The rate (multiplier) used for converting the transaction currency amount to the filing currency amount. Pass in this value and the currency code (isoCurrencyCodeAlpha or isoCurrencyCodeNum) to have filing currency calculated if your configuration parameters are set up to do so.]]></xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="xsd:decimal">
							<xsd:attributeGroup ref="isoCurrencyCode"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="OriginalCurrency" type="CurrencyType">
				<xsd:annotation>
					<xsd:documentation>This represents the currency in which the original business transaction took place.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DeliveryTerm" type="DeliveryTermCodeType">
				<xsd:annotation>
					<xsd:documentation>Delivery term structure.</xsd:documentation>
					<xsd:appinfo>Delivery term structure.</xsd:appinfo>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TaxingLocation" type="TaxingLocationCodeType">
				<xsd:annotation>
					<xsd:documentation>Taxing location structure.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DispatcherCode">
				<xsd:annotation>
					<xsd:documentation>A user-defined code that represents the dispatcher for the transaction or line item.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:restriction base="CompanyCodeType">
							<xsd:minLength value="0"/>
							<xsd:maxLength value="40"/>
						</xsd:restriction>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="ReturnsFields">
				<xsd:annotation>
					<xsd:documentation><![CDATA[Support the returns associated with your tax type. These fields allow you to pass in country-specific data to Vertex O Series for returns processing. This data is passed from Vertex O Series to your returns processing system. The value of the name attribute for country-specific fields is prefixed by the two-character ISO country code.]]></xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element name="ReturnsCodeField" minOccurs="0" maxOccurs="unbounded">
							<xsd:annotation>
								<xsd:documentation><![CDATA[A text value for your returns. If you require a 
country-specific setting, preface this text with the ISO 3166-1 alpha-2
country code and an underscore.]]></xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:simpleContent>
									<xsd:extension base="xsd:string">
										<xsd:attribute name="name" type="xsd:string" use="required">
											<xsd:annotation>
												<xsd:documentation>The name of the Returns Code field.</xsd:documentation>
											</xsd:annotation>
										</xsd:attribute>
									</xsd:extension>
								</xsd:simpleContent>
							</xsd:complexType>
						</xsd:element>
						<xsd:element name="ReturnsNumericField" minOccurs="0" maxOccurs="unbounded">
							<xsd:annotation>
								<xsd:documentation><![CDATA[A numeric value for your returns.  If you require a 
country-specific setting, preface this number with the ISO 3166-1 alpha-2 country code and an underscore.]]></xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:simpleContent>
									<xsd:extension base="xsd:decimal">
										<xsd:attribute name="name" type="xsd:string" use="required">
											<xsd:annotation>
												<xsd:documentation>The name of the Returns Numeric field.</xsd:documentation>
											</xsd:annotation>
										</xsd:attribute>
									</xsd:extension>
								</xsd:simpleContent>
							</xsd:complexType>
						</xsd:element>
						<xsd:element name="ReturnsDateField" minOccurs="0" maxOccurs="unbounded">
							<xsd:annotation>
								<xsd:documentation><![CDATA[A date value for your returns. If you require a 
country-specific setting, preface this date with the ISO 3166-1 alpha-2
country code and an underscore.]]></xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:simpleContent>
									<xsd:extension base="xsd:date">
										<xsd:attribute name="name" type="xsd:string" use="required">
											<xsd:annotation>
												<xsd:documentation>The name of the Returns Date field.</xsd:documentation>
											</xsd:annotation>
										</xsd:attribute>
									</xsd:extension>
								</xsd:simpleContent>
							</xsd:complexType>
						</xsd:element>
						<xsd:element name="ReturnsIndicatorField" minOccurs="0" maxOccurs="unbounded">
							<xsd:annotation>
								<xsd:documentation><![CDATA[A Boolean value for your returns. If you require a 
country-specific setting, preface this value with the ISO 3166-1 alpha-2 country code and an underscore.]]></xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:simpleContent>
									<xsd:extension base="xsd:boolean">
										<xsd:attribute name="name" type="xsd:string" use="required">
											<xsd:annotation>
												<xsd:documentation>The name of the Returns Indicator field.</xsd:documentation>
											</xsd:annotation>
										</xsd:attribute>
									</xsd:extension>
								</xsd:simpleContent>
							</xsd:complexType>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="AmountBilledToDate" type="AmountType">
				<xsd:annotation>
					<xsd:documentation><![CDATA[Certain states define a maximum tax amount that can be billed to a Lessee over the life of a lease. This field contains the amount the Lessee has been billed to date. The Amount Billed to Date enables you to determine the tax amount paid to date. When the tax amount paid to date reaches the maximum tax amount, the remaining billable amount for the Lease is non-taxable.]]></xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ImpositionToProcess">
				<xsd:annotation>
					<xsd:documentation>Limits the taxes calculated for the transaction to a specific jurisdiction level and imposition type.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="JurisdictionLevelCodeType">
							<xsd:attribute name="impositionType">
								<xsd:annotation>
									<xsd:documentation><![CDATA[The type of imposition. impositionType can be Vertex-defined
or user-defined in Vertex Central. impositionType enables you to  
set registration-level details during transaction processing.

Regstration can have multiple imposition types at both the Main 
Division and Country level. This is an optional attribute under the 
TaxRegistration element.]]></xsd:documentation>
								</xsd:annotation>
								<xsd:simpleType>
									<xsd:restriction base="xsd:string">
										<xsd:minLength value="0"/>
										<xsd:maxLength value="60"/>
									</xsd:restriction>
								</xsd:simpleType>
							</xsd:attribute>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="Destination" type="LocationType">
				<xsd:annotation>
					<xsd:documentation><![CDATA[A Vertex-defined term that is equivalent to the following terms: ship-to, benefit received, first used, where used, primary place of use, principle use location, location of property, or place of use. Required (1) at either the Transaction level or the Line Item level. If Destination information is provided at both levels, the Line Item level information supersedes the Transaction level information.]]></xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Total" type="AmountType">
				<xsd:annotation>
					<xsd:documentation>Total tax amount of each line item.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:attributeGroup name="isoCurrencyCode">
				<xsd:annotation>
					<xsd:documentation>ISO 4217 currency code structure</xsd:documentation>
				</xsd:annotation>
				<xsd:attribute name="isoCurrencyName" type="xsd:string">
					<xsd:annotation>
						<xsd:documentation>The ISO 4217 name for the currency unit. Not used for this version of O Series.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="isoCurrencyCodeAlpha" type="Code3Type">
					<xsd:annotation>
						<xsd:documentation>The three-character ISO 4217 alphabetic code for the currency unit.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="isoCurrencyCodeNum" type="CodeType">
					<xsd:annotation>
						<xsd:documentation>The three-digit ISO 4217 numeric code for the currency unit.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
			</xsd:attributeGroup>
			<xsd:attributeGroup name="nexusExemptionGroup">
				<xsd:annotation>
					<xsd:documentation><![CDATA[A type of deduction that applies to sales that would normally be taxable but, because of special circumstances, are not. For example, the sale of machinery is normally subject to sales tax. However, when the machinery is used in manufacturing, some taxing jurisdictions consider the sale exempt. A certificate is usually required for an exemption to apply.]]></xsd:documentation>
					<xsd:documentation>Copyright Vertex Inc. 2007-2012 All Rights Reserved</xsd:documentation>
				</xsd:annotation>
				<xsd:attribute name="nexusIndicator" type="xsd:boolean">
					<xsd:annotation>
						<xsd:documentation><![CDATA[Indicates whether the Seller is not required to collect taxes. In this case, all associated child line items are exempt from taxes. You can use the Vertex Central user interface to create and maintain nexus requirements.]]></xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="nexusReasonCode" type="ReasonCodeType">
					<xsd:annotation>
						<xsd:documentation><![CDATA[A code that indicates the reason that the Seller is exempt from tax. If your host system provides this functionality, this data element can be used. You can use the Vertex Central user interface to set up reason codes. Valid reason codes are expected from the host system and are pre-defined by Vertex for use in the Returns Export module in Vertex Central. Required (1) if the nexusIndicator is true. Note: To pass a standard (i.e., not user-defined) single-digit reason code, pad the code to four digits. Refer to the Supporting Information section of the XML Integration Guide for information on exemption and deduction reason codes.]]></xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
			</xsd:attributeGroup>
			<xsd:attributeGroup name="BuyerGroup">
				<xsd:attribute name="isTaxExempt" type="xsd:boolean" default="false">
					<xsd:annotation>
						<xsd:documentation><![CDATA[Indicates that the buyer is not required to collect taxes, and all line items associated with the purchase order are exempt from taxes. It is recommended that the buyer and vendor nexus requirements be created and maintained in the Vertex Central user interface. Note: This attribute is set to true if you pass an exemption certificate number in the XML message.]]></xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="exemptionReasonCode" type="ReasonCodeType">
					<xsd:annotation>
						<xsd:documentation><![CDATA[A code that indicates the reason that the Buyer is exempt from tax. If your host system provides this functionality, this data element can be used. You can use the Vertex Central user interface to set up reason codes. Valid reason codes are expected from the host system and are pre-defined by Vertex for use in the Returns Export module in Vertex Central. Note: To pass a standard (i.e., not user-defined) single-digit reason code, pad the code to four digits. Refer to the Supporting Information section of the XML Integration Guide for information on exemption and deduction reason codes.]]></xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
			</xsd:attributeGroup>
			<xsd:simpleType name="JurisdictionLevelCodeType">
				<xsd:annotation>
					<xsd:documentation>Identifies the common classification of a jurisdiction, based on its geopolitical or taxing context.</xsd:documentation>
					<xsd:documentation>Copyright Vertex Inc. 2007-2012 All Rights Reserved</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:NMTOKEN">
					<xsd:minLength value="1"/>
					<xsd:maxLength value="60"/>
					<xsd:enumeration value="APO">
						<xsd:annotation>
							<xsd:documentation>Army and Air Force Post Office box. This value may also be used for Diplomatic Post Office (DPO) box.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="BOROUGH">
						<xsd:annotation>
							<xsd:documentation>An entity that acts as a self-governing body on the local level.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="CITY">
						<xsd:annotation>
							<xsd:documentation>An incorporated municipality in which definite boundaries and legal powers are set forth in a charter granted by the state.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="COUNTRY">
						<xsd:annotation>
							<xsd:documentation>An entity that acts as a self-governing body, based on a special common geographic area of interest</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="COUNTY">
						<xsd:annotation>
							<xsd:documentation>An entity within a state or country, used for administrative purposes, created by territorial division for the purpose of local government.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="DISTRICT">
						<xsd:annotation>
							<xsd:documentation><![CDATA[A local jurisdiction, which may or may not follow city or county boundaries, in which taxes or fees are imposed to benefit a specific purpose.  Examples include Special Purpose Districts, Municipal Transportation Authorities, Transit Districts, Community Improvement Districts, Transportation Development Districts, Hospital Districts, Local Improvement Districts, Public Improvement Districts, School Districts, and Police Jurisdictions.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="FPO">
						<xsd:annotation>
							<xsd:documentation>(Military) Field Post Office.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="LOCAL_IMPROVEMENT_DISTRICT">
						<xsd:annotation>
							<xsd:documentation>A municipality that provides local government functions.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="PARISH">
						<xsd:annotation>
							<xsd:documentation><![CDATA[An entity within a state or country, used for administrative purposes, created by territorial division for the purpose of local government (most often seen in Louisiana).]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="PROVINCE">
						<xsd:annotation>
							<xsd:documentation><![CDATA[A territorial unit that acts in an administrative function or organized political system within a country. Provinces in Canada are similar to states in the United States.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="SPECIAL_PURPOSE_DISTRICT">
						<xsd:annotation>
							<xsd:documentation><![CDATA[A local jurisdiction that does not follow city or county boundaries.
Examples include municipal transportation authorities (MTAs), hospitals,
and school districts.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="STATE">
						<xsd:annotation>
							<xsd:documentation><![CDATA[A territorial unit that acts in an administrative function or organized political system within a country. States in the United States are similar to provinces in Canada.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="TERRITORY">
						<xsd:annotation>
							<xsd:documentation>A non-sovereign geographic region within a country.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="TOWNSHIP">
						<xsd:annotation>
							<xsd:documentation>An incorporated municipality in which definite boundaries and legal powers are set forth in a charter granted by the state, similar to a city.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="TRADE_BLOCK">
						<xsd:annotation>
							<xsd:documentation>A type of intergovernmental agreement where regional barriers to trade are reduced or eliminated among member countries.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="TRANSIT_DISTRICT">
						<xsd:annotation>
							<xsd:documentation><![CDATA[A special-purpose district organized as either a corporation authorized
 by statute, or a government agency that provides public transportation
 within a specific region.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="PercentType">
				<xsd:restriction base="xsd:decimal">
					<xsd:minInclusive value="0"/>
					<xsd:maxInclusive value="1"/>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="LookupResultType">
				<xsd:annotation>
					<xsd:documentation>The status of a Tax Area lookup.</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:NMTOKEN">
					<xsd:enumeration value="NORMAL">
						<xsd:annotation>
							<xsd:documentation>The lookup returned at least one tax area.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="BAD_REGION_FIELDS">
						<xsd:annotation>
							<xsd:documentation>The location information used during the lookup was incomplete or inconsistent.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="BAD_STREET_INFORMATION">
						<xsd:annotation>
							<xsd:documentation>The street address used during the lookup was incomplete or inconsistent.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="IGNORED_REGION_FIELDS">
						<xsd:annotation>
							<xsd:documentation>Some of the location information was missing during the lookup.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="MAX_TAXAREAS_EXCEEDED">
						<xsd:annotation>
							<xsd:documentation><![CDATA[The maximum number of tax areas was exceeded. The maximum number of
 tax areas that can be returned during a lookup is specified in the
 taxgis.jurisdictionfinder.MaximumTaxAreas parameter.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="MAX_FULL_ADDRESSES_EXCEEDED">
						<xsd:annotation>
							<xsd:documentation><![CDATA[The maximum number of full addresses was exceeded. 
 The maximum number of full addresses that can be returned during a 
 lookup is specified in the taxgis.jurisdictionfinder.MaximumFullAddresses
 parameter.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="MIN_AGGREGATE_CONFIDENCE_EXCEEDED">
						<xsd:annotation>
							<xsd:documentation><![CDATA[The minimum aggregate confidence level has been exceeded. The minimum 
 aggregate confidence indicator for returning tax areas is specified
 in the taxgis.jurisdictionfinder.MinimumAggregateConfidence parameter.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="CONFIDENCE_INDICATOR_SUPPRESSED">
						<xsd:annotation>
							<xsd:documentation><![CDATA[The confidence indicator value indicates the strength of the Tax Area lookup result.
 
The confidence indicator was supressed because one of the following was true: (1) the ZIP Code was missing in a lookup for a United States address, or (2) the lookup was for an address in Canada.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="PRECEDES_CONFIDENCE_INDICATOR_FUNCTIONALITY">
						<xsd:annotation>
							<xsd:documentation><![CDATA[The confidence indicator feature has been disabled because the transaction
date specified in the search criteria for this Tax Area lookup precedes the
implementation date of the TaxGIS Confidence Indicator.  The default date value is 20060501.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="FlexibleFieldCodeType">
				<xsd:restriction base="xsd:string">
					<xsd:minLength value="1"/>
					<xsd:maxLength value="40"/>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="InputOutputCodeType">
				<xsd:annotation>
					<xsd:documentation><![CDATA[Identifies whether tax is Input VAT, Output VAT, both Input and Output VAT, or Import VAT, according to the perspective of the transaction to allow for Reverse Charges.]]></xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:NMTOKEN">
					<xsd:enumeration value="INPUT">
						<xsd:annotation>
							<xsd:documentation>Input VAT is the VAT you incur as part of the purchase price of your goods or services. This is the VAT paid to the Vendor on purchases.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="IMPORT">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Import VAT is charged when goods are imported into one jurisdiction (country) from another jurisdiction (country). This is the VAT paid by the Importer of Record on goods brought in from another jurisdiction (country). The tax is paid at the time the goods clear customs unless they go into a suspended state. The tax would then be due when the goods enter into free circulation.

For VAT purposes, the jurisdictions (countries) in the EU are affiliated together as a trade block. The EU acts as a single jurisdiction (country) for VAT purposes. Specific territories that trade with the EU are excluded from VAT.  These territories are the Island of Heligoland and the territory of Büsingen  (Germany); Ceuta, Melilla, and Canary Island (Spain); Livigno, Campione d'Italia, and Tthe Italian waters of Lake Lugano (Italy); the French Overseas Departments of Guadeloupe, French Guiana, Martinque and  and Reunion, and Monaco (France); Mount Athos, also known asa Agion Poros (Greece);  Åland Islands, (Finland), the  Isle of Man (United Kingdom); and Akrotiri and Dhekelia (Cyprus).]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="OUTPUT">
						<xsd:annotation>
							<xsd:documentation>Output VAT is the VAT you add to the sale price of your goods or services. This is the VAT charged by the Taxpayer on sales.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="INPUT_OUTPUT">
						<xsd:annotation>
							<xsd:documentation>Input_Output is the code used to specify the application of a reverse charge. In this case, the buyer has accounted for the VAT due.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="TaxCollectedFromPartyType">
				<xsd:annotation>
					<xsd:documentation>The tax received from a taxable entity.</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:NMTOKEN">
					<xsd:enumeration value="SELLER">
						<xsd:annotation>
							<xsd:documentation>In Supplies transactions, the Seller is equivalent to the Taxpayer
responsible for collecting and remitting tax.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="BUYER">
						<xsd:annotation>
							<xsd:documentation>In Sales tax or Value Added Tax Supplies transactions, the Buyer is
equivalent to the Customer receiving goods or services.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="Code2Type">
				<xsd:annotation>
					<xsd:documentation>Simple type for alpha-3 code values comprised of two capital Roman letters, such as the ISO 3166-1 alpha-2 standard.</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:token">
					<xsd:pattern value="[A-Z]{2}"/>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="LocationCodeType">
				<xsd:restriction base="xsd:string">
					<xsd:minLength value="0"/>
					<xsd:maxLength value="20"/>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="ChainTransactionPhaseCodeType">
				<xsd:annotation>
					<xsd:documentation><![CDATA[Chain Transaction Phase identifies a phase within a series of transactions in which multiple invoices are created with only a single movement of goods. 
The phase identifies the position of the transaction in a supply chain. Use Tax Assist rules to evaluate this indicator along with other transaction facts to set the title transfer value and determine an appropriate taxability conclusion.]]></xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:NMTOKEN">
					<xsd:enumeration value="MANUFACTURER">
						<xsd:annotation>
							<xsd:documentation>An entity that creates some good or tangible property.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="INTERMEDIARY">
						<xsd:annotation>
							<xsd:documentation><![CDATA[A third-party entity between the manufacturer that creates the good or tangible property and the final consumer of the good or property. This is a Domestic VAT scenario.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="FINAL">
						<xsd:annotation>
							<xsd:documentation>An entity that is the final consumer of the good or tangible property. This is an Intra-EU, Zero Rate VAT scenario.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="TaxStructureCodeType">
				<xsd:annotation>
					<xsd:documentation>A type that contains the criteria  for how O Series applies tax. The tax rules determine the tax structure O Series applies  in a tax calculation.</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:NMTOKEN">
					<xsd:enumeration value="BRACKET">
						<xsd:annotation>
							<xsd:documentation>Tax is based on a the bracket tax schedule logic of a jurisdiction. Bracket tax schedules are provided through Vertex data updates.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="FLAT_TAX">
						<xsd:annotation>
							<xsd:documentation>Tax is a flat fee amount that is applied uniformly to every transaction.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="QUANTITY">
						<xsd:annotation>
							<xsd:documentation>Tax is based on either the number of units or the type of units in a transaction.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="SINGLE_RATE">
						<xsd:annotation>
							<xsd:documentation>Tax is based on a single percentage rate.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="TIERED">
						<xsd:annotation>
							<xsd:documentation>Tax varies, based on the levels of taxable amounts defined by the 
jurisdiction.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="AmountType">
				<xsd:restriction base="xsd:decimal"/>
			</xsd:simpleType>
			<xsd:simpleType name="DeliveryTermCodeType">
				<xsd:annotation>
					<xsd:documentation><![CDATA[An identifier that determines the vendor or customer jurisdiction in which the title transfer of a supply takes place. A Delivery Term Code identifies the importer of record on cross-border transactions. Also known as Shipping Terms or Incoterm.
 
Delivery Term information is critical in Value Added Tax transactions to determine the place of supply, for example, in distance selling. 

For detailed explanations of these terms, refer to the Terms of Sales definition in the glossary of the U.S. Department of Transportation Maritime Administration Web site at .]]><a target="_blank" href="http://www.marad.dot.gov/publications/glossary/T.html">http://www.marad.dot.gov/publications/glossary/T.html</a>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:NMTOKEN">
					<xsd:enumeration value="EXW">
						<xsd:annotation>
							<xsd:documentation>Ex Works (EXW)</xsd:documentation>
							<xsd:appinfo>Ex Works (EXW)</xsd:appinfo>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="FCA">
						<xsd:annotation>
							<xsd:documentation>Free Carrier (FCA)</xsd:documentation>
							<xsd:appinfo>Free Carrier (FCA)</xsd:appinfo>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="FAS">
						<xsd:annotation>
							<xsd:documentation>Free Along Side Ship (FAS)</xsd:documentation>
							<xsd:appinfo>Free Along Side Ship (FAS)</xsd:appinfo>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="FOB">
						<xsd:annotation>
							<xsd:documentation>Free Onboard Vessel (FOB)</xsd:documentation>
							<xsd:appinfo>Free Onboard Vessel (FOB)</xsd:appinfo>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="CFR">
						<xsd:annotation>
							<xsd:documentation>Cost and Freight (CFR)</xsd:documentation>
							<xsd:appinfo>Cost and Freight (CFR)</xsd:appinfo>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="CIF">
						<xsd:annotation>
							<xsd:documentation>Cost Insurance and Freight (CIF)</xsd:documentation>
							<xsd:appinfo>Cost Insurance and Freight (CIF)</xsd:appinfo>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="CPT">
						<xsd:annotation>
							<xsd:documentation>Carriage Paid To (CPT)</xsd:documentation>
							<xsd:appinfo>Carriage Paid To (CPT)</xsd:appinfo>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="CIP">
						<xsd:annotation>
							<xsd:documentation>Carriage Insurance Paid To (CIP)</xsd:documentation>
							<xsd:appinfo>Carriage Insurance Paid To (CIP)</xsd:appinfo>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="DAF">
						<xsd:annotation>
							<xsd:documentation>Delivered at Frontier (DAF)</xsd:documentation>
							<xsd:appinfo>Delivered at Frontier (DAF)</xsd:appinfo>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="DES">
						<xsd:annotation>
							<xsd:documentation>Delivered Ex Ship (DES)</xsd:documentation>
							<xsd:appinfo>Delivered Ex Ship (DES)</xsd:appinfo>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="DEQ">
						<xsd:annotation>
							<xsd:documentation>Delivered Ex Quay Duty Unpaid (DEQ)</xsd:documentation>
							<xsd:appinfo>Delivered Ex Quay Duty Unpaid (DEQ)</xsd:appinfo>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="DDU">
						<xsd:annotation>
							<xsd:documentation>Delivery Duty Unpaid (DDU)</xsd:documentation>
							<xsd:appinfo>Delivery Duty Unpaid (DDU)</xsd:appinfo>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="DDP">
						<xsd:annotation>
							<xsd:documentation>Delivery Duty Paid (DDP)</xsd:documentation>
							<xsd:appinfo>Delivery Duty Paid (DDP)</xsd:appinfo>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="DAP">
						<xsd:annotation>
							<xsd:documentation>Delivered at Place (DAP)</xsd:documentation>
							<xsd:appinfo>Delivered at Place (DAP)</xsd:appinfo>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="DAT">
						<xsd:annotation>
							<xsd:documentation>Delivered at Terminal (DAT)</xsd:documentation>
							<xsd:appinfo>Delivered at Terminal (DAT)</xsd:appinfo>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="SUP">
						<xsd:annotation>
							<xsd:documentation>Supplier Ships (SUP)</xsd:documentation>
							<xsd:appinfo>Supplier Ships (SUP)</xsd:appinfo>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="CUS">
						<xsd:annotation>
							<xsd:documentation>Customer Ships (CUS)</xsd:documentation>
							<xsd:appinfo>Customer Ships (CUS)</xsd:appinfo>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="SyncronizationCodeType">
				<xsd:annotation>
					<xsd:documentation>Indicates how O Series updates line items in a synchronized transaction.</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:NMTOKEN">
					<xsd:enumeration value="ADD">
						<xsd:annotation>
							<xsd:documentation>O Series synchronization adds a line item.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="MODIFY">
						<xsd:annotation>
							<xsd:documentation>O Series synchronization modifies a line item. The line item to be modified must have existed on a previous transaction.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="DELETE">
						<xsd:annotation>
							<xsd:documentation>O Series synchronization deletes a line item. The line item to be deleted must have existed on a previous transaction.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="CodeType">
				<xsd:annotation>
					<xsd:documentation>Simple type for 3-digit code values, such as the numeric code values used by the ISO 3166 standard</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:positiveInteger">
					<xsd:minInclusive value="1"/>
					<xsd:maxInclusive value="999"/>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="RegistrationIdType">
				<xsd:restriction base="xsd:string">
					<xsd:minLength value="0"/>
					<xsd:maxLength value="40"/>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="SimplificationCodeType">
				<xsd:annotation>
					<xsd:documentation>Identifies a special action on the transaction being processed.</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:NMTOKEN">
					<xsd:enumeration value="CONSIGNMENT">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Indicates transfer of goods from one country to another to create a stock that is held in the second country under the owners control. The stock is available for sale to multiple customers. This condition applies to Asset Movement transactions only. Depending on the countries involved in the transaction, it may allow for the deferment of Value Added Tax.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="CALL_OFF">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Indicates transfer of goods from one country to another to create a stock that is held in the second country for the use of a single customer. The stock is not intended for sale to any party other than the single customer. This condition applies to Asset Movement transactions only. Depending on the countries involved in the transaction, it may allow for the deferment of Value Added Tax.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="TRIANGULATION">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Involves two sales of the same goods within the EU. Three taxpayers are involved and located in different Member States. Party A sells goods to Party B, who in turn sells the goods to Party C but has Party A ship the goods directly to Party C. Party A issues a zero-rated invoice to Party B. Party B issues a zero-rated invoice to Party C. Party C self-assesses the VAT due. The goods do not follow the invoice trail because they never go to Party B.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="REGISTRATION_GROUP">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Identifies the transaction as involving a VAT group. A VAT group consists of two or more corporate entities that have registered to be treated as a single taxable person for VAT purposes.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="ExternalJurisdictionCodeType">
				<xsd:restriction base="xsd:string">
					<xsd:minLength value="0"/>
					<xsd:maxLength value="20"/>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="TaxOverrideCodeType">
				<xsd:annotation>
					<xsd:documentation>A type that enables you to override the taxability that is set up in O Series for a line item.</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:NMTOKEN">
					<xsd:enumeration value="TAXABLE">
						<xsd:annotation>
							<xsd:documentation>Indicates  the line item is subject to tax.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="NONTAXABLE">
						<xsd:annotation>
							<xsd:documentation>Indicates  the line item is not subject to tax. You can indicate the reason in the  overrideReasonCode attribute.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="LogLevelType">
				<xsd:annotation>
					<xsd:documentation>Log levels indicate the severity of an error. The following log levels are listed from most severe to least severe.</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:NMTOKEN">
					<xsd:enumeration value="FATAL">
						<xsd:annotation>
							<xsd:documentation>Logs any system condition or event that jeopardizes system
integrity, such as allocation failures, disk space errors, or major
database problems.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="ERROR">
						<xsd:annotation>
							<xsd:documentation>Logs all abnormal events that are neither warnings nor fatal. 
Use this setting in a production environment.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="WARNING">
						<xsd:annotation>
							<xsd:documentation>Logs any system condition or event that is abnormal but poses
no risk to stability, performance, or answer quality.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="OPS">
						<xsd:annotation>
							<xsd:documentation>Logs major system events, such as starting up or shutting
down of major system components or services.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="TRACE">
						<xsd:annotation>
							<xsd:documentation>Logs entry and exit points of substantial classes and services.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="DEBUG">
						<xsd:annotation>
							<xsd:documentation>Logs a detailed description of software execution. Use this setting only if you are working in a development environment.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="SUPPORT">
						<xsd:annotation>
							<xsd:documentation>Logs pertinent details to enhance Vertex Product Support troubleshooting.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="CountryAlphaCodeType">
				<xsd:restriction base="xsd:token">
					<xsd:pattern value="[A-Z]{2,3}"/>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="SaleTransactionType">
				<xsd:annotation>
					<xsd:documentation>Identifies the transaction type for a Sales transaction.</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:NMTOKEN">
					<xsd:enumeration value="SALE">
						<xsd:annotation>
							<xsd:documentation>A transaction that results in the passage of title, possession, or 
service benefit from a seller to a buyer in exchange for consideration.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="RENTAL">
						<xsd:annotation>
							<xsd:documentation><![CDATA[A transaction that results in the transfer of possession, not title, 
 of tangible personal property (for consideration) to a customer for 
 use. Rental time periods are typically shorter in duration as 
 compared to leases.  For some jurisdictions, rental and lease are
 synonymous.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="LEASE">
						<xsd:annotation>
							<xsd:documentation><![CDATA[A transaction that results in the transfer of possession, but not title,
of tangible personal property (for consideration) to a customer 
for the customer use for a specified time period.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="PointOfTitleTransferCodeType">
				<xsd:annotation>
					<xsd:documentation><![CDATA[Title Transfer (or Point of Title Transfer) is the location where the title to goods actually changes hands from seller to buyer. This location is a contractual term and is included on the contract between buyer and seller. Title Transfer applies only to goods.]]></xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:NMTOKEN">
					<xsd:enumeration value="ORIGIN">
						<xsd:annotation>
							<xsd:documentation><![CDATA[The Title Transfer for the transaction occurred at the point of origin. The buyer takes title at the origin and pays import tax when the goods clear customs.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="IN_TRANSIT">
						<xsd:annotation>
							<xsd:documentation>The Title Transfer is executed in transit (for example, on the high seas). In this scenario, no VAT is charged.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="DESTINATION">
						<xsd:annotation>
							<xsd:documentation><![CDATA[The Title Transfer is executed at the destination. In this scenario, the supplier is the importer of record and would be charged import VAT. Then, a domestic supply takes place between the supplier and the buyer.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="ProcurementTransactionType">
				<xsd:annotation>
					<xsd:documentation>Indicates the transaction type for a Procurement transaction.</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:NMTOKEN">
					<xsd:enumeration value="RENTAL">
						<xsd:annotation>
							<xsd:documentation><![CDATA[A transaction that results in the transfer of possession, not title, 
of tangible personal property (for consideration) to a customer for 
use. Rental time periods are typically shorter in duration as compared
 to leases. For some jurisdictions, rental and lease are synonymous.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="LEASE">
						<xsd:annotation>
							<xsd:documentation><![CDATA[A transaction that results in the transfer of possession, but not title,
of tangible personal property (for consideration) to a customer for 
the customer’s use for a specified time period.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="PURCHASE">
						<xsd:annotation>
							<xsd:documentation>A transaction that results in the passage of title, possession, or 
service benefit to a buyer from a seller in exchange for consideration.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="MovementMethodCodeType">
				<xsd:annotation>
					<xsd:documentation>Indicates how assets are moved. If you do not specify this value, the Calculation Engine defaults to REGULAR.</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:NMTOKEN">
					<xsd:enumeration value="CONSIGNMENT">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Indicates transfer of goods from one country to another to create a stock that is held in the second country under the owner's control. The stock is available for sale to multiple customers. This condition applies to Asset Movement transactions only. Depending on the countries involved in the transaction, it may allow for the deferment of Value Added Tax.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="CALL_OFF">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Indicates transfer of goods from one country to another to create a stock that is held in the second country for the use of a single customer. The stock is not intended for sale to any party other than the single customer. This condition applies to Asset Movement transactions only. Depending on the countries involved in the transaction, it may allow for the deferment of Value Added Tax.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="REGULAR">
						<xsd:annotation>
							<xsd:documentation>Indicates that there is no special consignment stock or call off stock condition to be considered for tax calculation.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="InpuRegistrationIdType">
				<xsd:restriction base="xsd:string">
					<xsd:minLength value="0"/>
					<xsd:maxLength value="40"/>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="EntityCodeType">
				<xsd:restriction base="xsd:string">
					<xsd:minLength value="0"/>
					<xsd:maxLength value="40"/>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="ReasonCodeType">
				<xsd:annotation>
					<xsd:documentation><![CDATA[The 'Reason Code' can be passed through the ERP application if functionality is provided, however most Lessee's will set up reason codes associated with Lessee's in Vertex Central by the tax department.  The valid reason codes are expected from the calling application and are pre-defined by Vertex for use in the Tax Returns application.]]></xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:string">
					<xsd:minLength value="1"/>
					<xsd:maxLength value="4"/>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="TaxAreaIdType">
				<xsd:annotation>
					<xsd:documentation><![CDATA[Identifies a specific instance of tax area. A Tax Area is determined by the geographic areas that correspond to a unique combination of taxing jurisdictions where the tax area's boundaries are derived from the overlay of the geographic areas that form the domain of those jurisdictions.]]></xsd:documentation>
					<xsd:documentation>Copyright Vertex Inc. 2007-2012 All Rights Reserved</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:integer">
					<xsd:minInclusive value="0"/>
					<xsd:maxInclusive value="999999999"/>
					<xsd:totalDigits value="9"/>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="TaxingLocationCodeType">
				<xsd:annotation>
					<xsd:documentation>Indicates the valid values for taxing locations that Vertex O Series uses when calculating tax.</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:NMTOKEN">
					<xsd:minLength value="1"/>
					<xsd:maxLength value="60"/>
					<xsd:enumeration value="ADMINISTRATIVE_DESTINATION">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Administrative Destination is equivalent to the Bill To: location. 
A common synonym is benefit received. 

For service transactions in the U.S. and Canada, the administrative
destination is the benefit received location and the destination is the
service performed location. 

For tangible personal property transactions, the administrative 
destination is examined when checking for the triangulation condition
of an intra-European Union (EU) transaction from the buyer's perspective.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="ADMINISTRATIVE_ORIGIN">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Administrative Origin is equivalent to the Bill-From: location. 
Common synonyms include order taken, order acceptance, place of 
principal negotiation, and place of business.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="DESTINATION">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Destination is equivalent to the Ship-To: location. Common synonyms
include benefit received, first used, where used, primary place of use,
principal use location, location of property, and place of use.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="PHYSICAL_ORIGIN">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Physical Origin is equivalent to the Ship-From: location. 
A common synonym is first removed. A physical origin is required to 
perform triangulation in the case of value added tax transactions.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="TaxResultCodeType">
				<xsd:annotation>
					<xsd:documentation>Indicates the result of a tax calculation, based on situs and item type.</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:NMTOKEN">
					<xsd:enumeration value="TAXABLE">
						<xsd:annotation>
							<xsd:documentation>This result has a tax imposition.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="NONTAXABLE">
						<xsd:annotation>
							<xsd:documentation>This result does not have a tax imposition.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="EXEMPT">
						<xsd:annotation>
							<xsd:documentation>This result is exempt from tax.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="DPPAPPLIED">
						<xsd:annotation>
							<xsd:documentation><![CDATA[This result, due to its situs (Place of Supply) determination, applies a Direct Pay Permit tax imposition. A Direct Pay Permit is a document granted by a jurisdiction that allows a buyer to determine which of their purchases are taxable and which are exempt, and remit any tax that is due directly to the jurisdiction. When a buyer submits a valid Direct Payment Permit certificate to a seller, the seller is relieved of all responsibility for collecting tax from the permit holder. Tax is not calculated]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="NO_TAX">
						<xsd:annotation>
							<xsd:documentation>This result has no tax.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="DEFERRED">
						<xsd:annotation>
							<xsd:documentation>This result, due to its situs determination, has a tax, but the imposition of the tax is deferred.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="TaxingType">
				<xsd:annotation>
					<xsd:documentation>These values are tax type enumerations.</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:NMTOKEN">
					<xsd:enumeration value="SALES">
						<xsd:annotation>
							<xsd:documentation>A tax imposed on the privilege of making sales. Sales taxes are typically imposed on intrastate transactions.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="SELLER_USE">
						<xsd:annotation>
							<xsd:documentation><![CDATA[A tax imposed on the amount charged for the transfer of title or possession of tangible personal property and/or services. The tax is collected when the seller and the purchaser are located in different taxing authorities.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="CONSUMERS_USE">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Tax liability that is imposed on the storage, use, consumption, and, sometimes, distribution of property or services. Consumer use taxes typically arise when the seller that provides the goods or services is not registered to bill and collect the tax in a taxing jurisdiction.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="VAT">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Value Added Tax (VAT) is imposed on all possible entity types of taxpayer (such as individuals and enterprises) on the sale price of goods or certain services. VAT typically applies to the sale and importation of goods and also applies to processing, repair, or replacement services carried out in the taxing country.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="IMPORT_VAT">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Import VAT is charged when goods are imported into one jurisdiction (country) from another jurisdiction (country). This is the VAT paid by the Importer of Record on goods brought in from another jurisdiction (country). The tax is paid at the time the goods clear customs unless they go into a suspended state. The tax would then be due when the goods enter into free circulation. 

For VAT purposes, the jurisdictions (countries) in the EU are affiliated together as a trade block. The EU acts as a single jurisdiction (country) for VAT purposes. Specific territories that trade with the EU are excluded from VAT.  These territories are the Island of Heligoland and the territory of Büsingen  (Germany); Ceuta, Melilla, and Canary Island (Spain); Livigno, Campione d'Italia, and the Italian waters of Lake Lugano (Italy); the French Overseas Departments of Guadeloupe, French Guiana, Martinque and  and Reunion, and Monaco (France); Mount Athos, also known asa Agion Poros (Greece).]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="NONE">
						<xsd:annotation>
							<xsd:documentation>No tax is imposed.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="LocationCustomsStatusCodeType">
				<xsd:annotation>
					<xsd:documentation>Identifies the customs status at a given location.</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:NMTOKEN">
					<xsd:minLength value="0"/>
					<xsd:enumeration value="FREE_CIRCULATION">
						<xsd:annotation>
							<xsd:documentation>The status of goods which have been imported, where all the applicable documentation has been completed and the duties paid.</xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="BONDED_WAREHOUSE">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Indicates that goods reside in a Bonded or Customs Warehouse. A Bonded warehouse is a warehouse where goods on which duties have not yet been paid can be stored. The goods are stored under bond and in joint custody of the importer (or the importer’s agent) and the customs officers.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="FREE_TRADE_ZONE">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Indicates that goods are located in a Free Trade Zone (FTZ). An FTZ is one or more areas of a country where tariffs and quotas are eliminated, and bureaucratic requirements are lowered in hopes of attracting new business and foreign investment.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="TEMPORARY_IMPORT">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Indicates that goods have entered the location on a temporary basis. Temporary imports are a procedure where goods may enter a custom territory, under specific conditions, free of duty for a limited time. Instead of duty, the importer posts bond for twice the amount of duty, taxes, and other related importation charges that would otherwise be owed. The importer agrees to export or destroy the merchandise within a specified time or pay liquidated damages, which are twice the normal duty.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="INWARD_PROCESSING_RELIEF">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Indicates that goods are subject to Inward Processing Relief (IPR). IPR is a method of obtaining relief from customs duties and VAT charges. This relief applies to goods imported from outside a country, processed, and exported to other countries.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
					<xsd:enumeration value="OUTWARD_PROCESSING_RELIEF">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Indicates that goods are subject to Outward Processing Relief (OPR). OPR is a method of obtaining relief from Customs duty. The relief applies to goods, imported from non-EU countries, which have been produced from goods which were previously exported from the EU.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:enumeration>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="Code3Type">
				<xsd:annotation>
					<xsd:documentation>Simple type for alpha-3 code values comprised of three capital Roman letters, such as the ISO 3166-1 alpha-3 standard.</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:token">
					<xsd:pattern value="[A-Z]{3}"/>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:complexType name="VendorType">
				<xsd:complexContent>
					<xsd:extension base="PartyType">
						<xsd:sequence>
							<xsd:element ref="VendorCode" minOccurs="0"/>
							<xsd:element ref="PhysicalOrigin" minOccurs="0"/>
							<xsd:element ref="AdministrativeOrigin" minOccurs="0"/>
							<xsd:element ref="TaxRegistration" minOccurs="0" maxOccurs="unbounded"/>
						</xsd:sequence>
					</xsd:extension>
				</xsd:complexContent>
			</xsd:complexType>
			<xsd:complexType name="TaxTransactionResponseType">
				<xsd:annotation>
					<xsd:documentation>Parent type for all Tax Transaction response messges</xsd:documentation>
				</xsd:annotation>
			</xsd:complexType>
			<xsd:complexType name="PostalAddressType">
				<xsd:annotation>
					<xsd:documentation>Postal Address declaration.</xsd:documentation>
					<xsd:documentation>Copyright Vertex Inc. 2007-2012 All Rights Reserved</xsd:documentation>
				</xsd:annotation>
				<xsd:sequence>
					<xsd:element name="StreetAddress1" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>The first line of the street address.</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:minLength value="1"/>
								<xsd:maxLength value="100"/>
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="StreetAddress2" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>The second line of the street address.</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:minLength value="1"/>
								<xsd:maxLength value="100"/>
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="City" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation><![CDATA[The proper name of the city used to determine the Tax Area ID (if none is supplied). Optional (0..1) but recommended for greatest accuracy if no Tax Area ID is supplied.]]></xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:minLength value="1"/>
								<xsd:maxLength value="60"/>
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="MainDivision" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation><![CDATA[The proper name or the postal abbreviation of the state, province, or territory used to determine the Tax Area ID if none is supplied. Optional (0..1) but is recommended for greatest accuracy if no Tax Area ID is supplied.]]></xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:minLength value="1"/>
								<xsd:maxLength value="60"/>
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="SubDivision" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation><![CDATA[The name of the county used to determine the Tax Area ID if none is supplied. Optional (0..1) but is recommended for greatest accuracy if no Tax Area ID is supplied.]]></xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:minLength value="1"/>
								<xsd:maxLength value="60"/>
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="PostalCode" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation><![CDATA[The postal code used to determine the Tax Area ID (if none is supplied). For valid formats, see the Supporting Information section in the XML Integration Guide. Optional (0..1) but recommended for greatest accuracy if no Tax Area ID is supplied.]]></xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:minLength value="1"/>
								<xsd:maxLength value="20"/>
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="Country" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation><![CDATA[The country used to determine the Tax Area ID (if none is supplied). You can use a Data Extract report to see the valid country values. (Refer to the Vertex Central online help for information on running Data Extract reports.) Defaults to the value of the taxgis.jurisdictionfinder.DefaultCountryCodeForAddress parameter. The default value for this parameter is USA. (For details on this configuration parameter, refer to the Configuration File Parameters Reference Guide.)]]></xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:minLength value="1"/>
								<xsd:maxLength value="60"/>
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
				</xsd:sequence>
			</xsd:complexType>
			<xsd:complexType name="TaxgisResponseType">
				<xsd:annotation>
					<xsd:documentation>Parent type for all Taxgis response messages</xsd:documentation>
				</xsd:annotation>
			</xsd:complexType>
			<xsd:complexType name="CurrencyAmountType">
				<xsd:annotation>
					<xsd:documentation>A number of monetary units specified in a currency where the unit of currency is explicit or implied.</xsd:documentation>
					<xsd:documentation>Copyright Vertex Inc. 2007-2012 All Rights Reserved</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleContent>
					<xsd:extension base="xsd:decimal">
						<xsd:attributeGroup ref="isoCurrencyCode"/>
					</xsd:extension>
				</xsd:simpleContent>
			</xsd:complexType>
			<xsd:complexType name="LogEntryType">
				<xsd:annotation>
					<xsd:documentation>Log  entry type indicates the type of log entry.</xsd:documentation>
				</xsd:annotation>
				<xsd:sequence>
					<xsd:element name="Message" type="xsd:string">
						<xsd:annotation>
							<xsd:documentation>The exception message text.</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="Exception" type="xsd:string" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>The exception name.</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
				</xsd:sequence>
				<xsd:attribute name="logLevel" type="LogLevelType" use="required">
					<xsd:annotation>
						<xsd:documentation>The specific log level for this entry.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="instanceId" type="xsd:string">
					<xsd:annotation>
						<xsd:documentation>The service instance that processed the request.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="threadId" type="xsd:string">
					<xsd:annotation>
						<xsd:documentation>The thread that processed the request.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="className" type="xsd:string">
					<xsd:annotation>
						<xsd:documentation>The class that generated the log entry.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
			</xsd:complexType>
			<xsd:complexType name="InvoiceVerificationBuyerType">
				<xsd:complexContent>
					<xsd:extension base="TaxpayerType">
						<xsd:sequence>
							<xsd:element ref="Destination" minOccurs="0"/>
							<xsd:element ref="AdministrativeDestination" minOccurs="0"/>
							<xsd:element ref="ExemptionCertificate" minOccurs="0"/>
							<xsd:element ref="TaxRegistration" minOccurs="0" maxOccurs="unbounded"/>
						</xsd:sequence>
						<xsd:attributeGroup ref="BuyerGroup"/>
					</xsd:extension>
				</xsd:complexContent>
			</xsd:complexType>
			<xsd:complexType name="TaxAreaResponseType">
				<xsd:annotation>
					<xsd:documentation>Tax Area Response type structure</xsd:documentation>
				</xsd:annotation>
				<xsd:complexContent>
					<xsd:extension base="TaxgisResponseType">
						<xsd:sequence>
							<xsd:element name="TaxAreaResult" type="TaxAreaResultType" minOccurs="0" maxOccurs="unbounded">
								<xsd:annotation>
									<xsd:documentation><![CDATA[A set of one or more geographic areas that correspond to a unique combination of tax jurisdictions where the tax area's boundaries are derived from the overlay of the geographic areas that form the domain of those jurisdictions.]]></xsd:documentation>
								</xsd:annotation>
							</xsd:element>
						</xsd:sequence>
					</xsd:extension>
				</xsd:complexContent>
			</xsd:complexType>
			<xsd:complexType name="MeasureType">
				<xsd:simpleContent>
					<xsd:extension base="xsd:decimal">
						<xsd:attribute name="unitOfMeasure">
							<xsd:annotation>
								<xsd:documentation><![CDATA[The unit of measure for the line item to be used in surcharges based on quantity and not price. For a list of the possible values, see the Supporting Information section of the XML Integration Guide. If you pass a value that does not match the unit of measure for the quantity-based tax rule, that rule is not used. May be Required (1) to determine tax liability in some jurisdictions.]]></xsd:documentation>
							</xsd:annotation>
							<xsd:simpleType>
								<xsd:restriction base="xsd:string">
									<xsd:minLength value="1"/>
									<xsd:maxLength value="3"/>
								</xsd:restriction>
							</xsd:simpleType>
						</xsd:attribute>
					</xsd:extension>
				</xsd:simpleContent>
			</xsd:complexType>
			<xsd:complexType name="LoginType">
				<xsd:annotation>
					<xsd:documentation>System Login. Declaration of structure and data types.</xsd:documentation>
					<xsd:documentation>Copyright Vertex Inc. 2007-2012 All Rights Reserved</xsd:documentation>
				</xsd:annotation>
				<xsd:sequence>
					<xsd:element name="UserName" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>The User ID of the individual initiating the login.</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:minLength value="1"/>
								<xsd:maxLength value="64"/>
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="Password" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>The password associated with the User ID of the individual initiating the login.</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:minLength value="1"/>
								<xsd:maxLength value="64"/>
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="TrustedId" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>An identifier supplied by an ERP.</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:minLength value="6"/>
								<xsd:maxLength value="16"/>
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
				</xsd:sequence>
			</xsd:complexType>
			<xsd:complexType name="TaxSynchronizationResponseType">
				<xsd:annotation>
					<xsd:documentation>Parent type for all Tax Synchronziation response message</xsd:documentation>
				</xsd:annotation>
			</xsd:complexType>
			<xsd:complexType name="LocationType">
				<xsd:complexContent>
					<xsd:extension base="PostalAddressType">
						<xsd:sequence>
							<xsd:element ref="CurrencyConversion" minOccurs="0"/>
						</xsd:sequence>
						<xsd:attribute name="taxAreaId" type="TaxAreaIdType">
							<xsd:annotation>
								<xsd:documentation><![CDATA[A Vertex-specific number that identifies a tax area. If the Tax Area ID exists in your host system, use that data to populate this data element in a request message.]]></xsd:documentation>
							</xsd:annotation>
						</xsd:attribute>
						<xsd:attribute name="locationCustomsStatus" type="LocationCustomsStatusCodeType">
							<xsd:annotation>
								<xsd:documentation>The customs status at this location.</xsd:documentation>
							</xsd:annotation>
						</xsd:attribute>
						<xsd:attribute name="locationCode" type="LocationCodeType">
							<xsd:annotation>
								<xsd:documentation>A value that can be used for tax return filing in jurisdictions that require taxes to be filed for individual retail locations.</xsd:documentation>
							</xsd:annotation>
						</xsd:attribute>
						<xsd:attribute name="externalJurisdictionCode" type="ExternalJurisdictionCodeType">
							<xsd:annotation>
								<xsd:documentation>The jurisdiction code assigned by the relevant governmental authority.</xsd:documentation>
							</xsd:annotation>
						</xsd:attribute>
					</xsd:extension>
				</xsd:complexContent>
			</xsd:complexType>
			<xsd:complexType name="SellerType">
				<xsd:complexContent>
					<xsd:extension base="TaxpayerType">
						<xsd:sequence>
							<xsd:element ref="Dispatcher" minOccurs="0"/>
							<xsd:element ref="PhysicalOrigin" minOccurs="0"/>
							<xsd:element ref="AdministrativeOrigin" minOccurs="0"/>
							<xsd:element ref="TaxRegistration" minOccurs="0" maxOccurs="unbounded"/>
						</xsd:sequence>
						<xsd:attributeGroup ref="nexusExemptionGroup"/>
					</xsd:extension>
				</xsd:complexContent>
			</xsd:complexType>
			<xsd:complexType name="TimePeriodType">
				<xsd:sequence>
					<xsd:element name="BeginTime" type="xsd:time"/>
					<xsd:element name="EndTime" type="xsd:time" minOccurs="0"/>
				</xsd:sequence>
			</xsd:complexType>
			<xsd:complexType name="DateTimePeriodType">
				<xsd:sequence>
					<xsd:element name="BeginDateTime" type="xsd:dateTime"/>
					<xsd:element name="EndDateTime" type="xsd:dateTime" minOccurs="0"/>
				</xsd:sequence>
			</xsd:complexType>
			<xsd:complexType name="TaxgisRequestType">
				<xsd:annotation>
					<xsd:documentation>Parent type for all Taxgis request messages</xsd:documentation>
				</xsd:annotation>
			</xsd:complexType>
			<xsd:complexType name="OwnerType">
				<xsd:complexContent>
					<xsd:extension base="TaxpayerType">
						<xsd:sequence>
							<xsd:element ref="PhysicalOrigin" minOccurs="0"/>
							<xsd:element ref="Destination" minOccurs="0"/>
							<xsd:element ref="TaxRegistration" minOccurs="0" maxOccurs="unbounded"/>
						</xsd:sequence>
					</xsd:extension>
				</xsd:complexContent>
			</xsd:complexType>
			<xsd:complexType name="TaxpayerType">
				<xsd:complexContent>
					<xsd:extension base="PartyType">
						<xsd:sequence>
							<xsd:element name="Company" type="EntityCodeType" minOccurs="0">
								<xsd:annotation>
									<xsd:documentation><![CDATA[Identifies the top-level legal entity for which tax exceptions may exist. The Vertex Central user interface is used to set up any taxability rules that apply at this level. This should be a parameter that is configurable to data from the host system based on an individual company's legal and tax requirements.]]></xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="Division" type="EntityCodeType" minOccurs="0">
								<xsd:annotation>
									<xsd:documentation><![CDATA[Identifies the mid-level legal entity for which tax exceptions may exist. The Vertex Central user interface is used to set up any taxability rules that apply at this level. This should be a parameter that is configurable to data from the host system based on an individual company's legal and tax requirements.]]></xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:element name="Department" type="EntityCodeType" minOccurs="0">
								<xsd:annotation>
									<xsd:documentation><![CDATA[Identifies the low-level legal entity for which specific tax requirements and exceptions may exist. Use the Vertex Central user interface to set up any taxability rules that apply at this level. Based on your legal/tax liabilities at this level, map the appropriate host system parameter to this data element. If all of your tax exceptions are at the top- or mid-level entity, you may choose not to populate this data element. Note that this data element is also used to sort reports.]]></xsd:documentation>
								</xsd:annotation>
							</xsd:element>
						</xsd:sequence>
					</xsd:extension>
				</xsd:complexContent>
			</xsd:complexType>
			<xsd:complexType name="TaxRegistrationType">
				<xsd:sequence>
					<xsd:element name="TaxRegistrationNumber" type="RegistrationIdType" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>The tax registration ID number.</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="NexusOverride" minOccurs="0" maxOccurs="4">
						<xsd:annotation>
							<xsd:documentation>Information for the nexus override.</xsd:documentation>
						</xsd:annotation>
						<xsd:complexType>
							<xsd:attribute name="locationRole" type="TaxingLocationCodeType" use="required">
								<xsd:annotation>
									<xsd:documentation>The location for the nexus override.</xsd:documentation>
								</xsd:annotation>
							</xsd:attribute>
							<xsd:attribute name="country" type="xsd:boolean">
								<xsd:annotation>
									<xsd:documentation>Indicates whether or not the override applies at this jurisdiction level.</xsd:documentation>
								</xsd:annotation>
							</xsd:attribute>
							<xsd:attribute name="mainDivision" type="xsd:boolean">
								<xsd:annotation>
									<xsd:documentation>Indicates whether or not the override applies at this jurisdiction level.</xsd:documentation>
								</xsd:annotation>
							</xsd:attribute>
							<xsd:attribute name="subDivision" type="xsd:boolean">
								<xsd:annotation>
									<xsd:documentation>Indicates whether or not the override applies at this jurisdiction level.</xsd:documentation>
								</xsd:annotation>
							</xsd:attribute>
							<xsd:attribute name="city" type="xsd:boolean">
								<xsd:annotation>
									<xsd:documentation>Indicates whether or not the override applies at this jurisdiction level.</xsd:documentation>
								</xsd:annotation>
							</xsd:attribute>
							<xsd:attribute name="district" type="xsd:boolean">
								<xsd:annotation>
									<xsd:documentation>Indicates whether or not the override applies at this jurisdiction level.</xsd:documentation>
								</xsd:annotation>
							</xsd:attribute>
						</xsd:complexType>
					</xsd:element>
					<xsd:element name="PhysicalLocation" minOccurs="0" maxOccurs="unbounded">
						<xsd:annotation>
							<xsd:documentation>The physical location associated with the tax registration. Use the taxAreaId or address information to identify the physical location.</xsd:documentation>
						</xsd:annotation>
						<xsd:complexType>
							<xsd:complexContent>
								<xsd:extension base="PostalAddressType">
									<xsd:attribute name="taxAreaId" type="TaxAreaIdType">
										<xsd:annotation>
											<xsd:documentation>The Vertex-defined Tax Area ID for the location.</xsd:documentation>
										</xsd:annotation>
									</xsd:attribute>
								</xsd:extension>
							</xsd:complexContent>
						</xsd:complexType>
					</xsd:element>
				</xsd:sequence>
				<xsd:attribute name="isoCountryCode" type="CountryAlphaCodeType" use="required">
					<xsd:annotation>
						<xsd:documentation>The 2-character or 3-character alphabetic ISO 3166 code indicating the country represented by the registration.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="mainDivision">
					<xsd:annotation>
						<xsd:documentation>The proper name or postal abbreviation of the state, province, or territory of the tax registration.</xsd:documentation>
					</xsd:annotation>
					<xsd:simpleType>
						<xsd:restriction base="xsd:string">
							<xsd:minLength value="1"/>
							<xsd:maxLength value="60"/>
						</xsd:restriction>
					</xsd:simpleType>
				</xsd:attribute>
				<xsd:attribute name="hasPhysicalPresenceIndicator" type="xsd:boolean">
					<xsd:annotation>
						<xsd:documentation>Indicates whether or not the entity has a physical presence in the country represented by the registration.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="impositionType">
					<xsd:annotation>
						<xsd:documentation><![CDATA[The type of imposition. impositionType can be Vertex-defined
or user-defined in Vertex Central. impositionType enables you to  
set registration-level details during transaction processing.

Regstration can have multiple imposition types at both the Main 
Division and Country level. This is an optional attribute under the 
TaxRegistration element.]]></xsd:documentation>
					</xsd:annotation>
					<xsd:simpleType>
						<xsd:restriction base="xsd:string">
							<xsd:minLength value="0"/>
							<xsd:maxLength value="60"/>
						</xsd:restriction>
					</xsd:simpleType>
				</xsd:attribute>
			</xsd:complexType>
			<xsd:complexType name="TaxesType">
				<xsd:annotation>
					<xsd:documentation>Taxes calculated by the transaction processing system.</xsd:documentation>
				</xsd:annotation>
				<xsd:sequence>
					<xsd:element name="Jurisdiction" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>The name of jurisdiction to which a tax is applied.</xsd:documentation>
						</xsd:annotation>
						<xsd:complexType>
							<xsd:complexContent>
								<xsd:extension base="JurisdictionType"/>
							</xsd:complexContent>
						</xsd:complexType>
					</xsd:element>
					<xsd:element name="CalculatedTax" type="AmountType" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Amount of tax calculated by the calculation engine.</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="EffectiveRate" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation><![CDATA[For Buyer Input tax and Seller Import tax, this rate is calculated based on the Extended Price and Tax Amount (Import or Input) passed in the Request message. If you total the Extended Price and Tax Amounts before passing them in, this rate is an average.

For all other message types, this is the effective rate the system used to calculate tax.]]></xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:decimal">
								<xsd:minInclusive value="0"/>
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="Exempt" type="AmountType" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Amount of the line item not subject to tax due to exempt status.</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="NonTaxable" type="AmountType" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Amount of the line item not subject to tax due to nontaxable status.</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="Taxable" type="AmountType" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Amount of the line item subject to tax.</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="Imposition" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation><![CDATA[The name of the imposition to which the relevant tax rule belongs. This is assigned either by Vertex or by the user when setting up a user-defined imposition in the Vertex Central user interface.]]></xsd:documentation>
						</xsd:annotation>
						<xsd:complexType>
							<xsd:simpleContent>
								<xsd:extension base="xsd:string">
									<xsd:attribute name="userDefined" type="xsd:boolean">
										<xsd:annotation>
											<xsd:documentation>Identifier for user-defined rules. This identifier is useful for troubleshooting. The default value is False, Vertex-defined rule.</xsd:documentation>
										</xsd:annotation>
									</xsd:attribute>
									<xsd:attribute name="impositionId" type="xsd:positiveInteger">
										<xsd:annotation>
											<xsd:documentation>The Vertex internal identifier for the imposition.</xsd:documentation>
										</xsd:annotation>
									</xsd:attribute>
								</xsd:extension>
							</xsd:simpleContent>
						</xsd:complexType>
					</xsd:element>
					<xsd:element name="ImpositionType" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation><![CDATA[The type description assigned to the imposition. When multiple impositions are imposed within a jurisdiction, each must have a different type. This is assigned either by Vertex or by the user when setting up a user-defined imposition in the Vertex Central user interface.]]></xsd:documentation>
						</xsd:annotation>
						<xsd:complexType>
							<xsd:simpleContent>
								<xsd:extension base="xsd:string">
									<xsd:attribute name="userDefined" type="xsd:boolean">
										<xsd:annotation>
											<xsd:documentation>Identifier for user-defined rules. This identifier is useful for troubleshooting. The default value is False, Vertex-defined rule.</xsd:documentation>
										</xsd:annotation>
									</xsd:attribute>
									<xsd:attribute name="impositionTypeId" type="xsd:positiveInteger">
										<xsd:annotation>
											<xsd:documentation>The Vertex internal identifier for the impositionType.</xsd:documentation>
										</xsd:annotation>
									</xsd:attribute>
								</xsd:extension>
							</xsd:simpleContent>
						</xsd:complexType>
					</xsd:element>
					<xsd:element name="TaxRuleId" type="RuleType" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>An identifier for the tax rule that was used in tax calculation. This can be used as a troubleshooting aid.</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="BasisRuleId" type="RuleType" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>An identifier for the basis rule that was used in tax calculation. This can be used as a troubleshooting aid.</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="MaxTaxRuleId" type="RuleType" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>An identifier for the Max Tax rule that was used in tax calculation. This can be used as a troubleshooting aid.</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="RecoverableRuleId" type="RuleType" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation><![CDATA[The identifier of the applicable VAT Recoverability Rule for the line item. This Recoverability Rule determines
the percentage of input VAT that is deemed to be unrecoverable. This is an optional child element of the Taxes element.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="CertificateNumber" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>The certificate number associated with the line item tax.</xsd:documentation>
						</xsd:annotation>
						<xsd:complexType>
							<xsd:simpleContent>
								<xsd:extension base="xsd:string">
									<xsd:attribute name="certificateType" type="xsd:string">
										<xsd:annotation>
											<xsd:documentation>The certificate type associated with the line item tax.</xsd:documentation>
										</xsd:annotation>
									</xsd:attribute>
								</xsd:extension>
							</xsd:simpleContent>
						</xsd:complexType>
					</xsd:element>
					<xsd:element name="RecoverableAmount" type="AmountType" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation><![CDATA[The amount of input or import tax that the buyer is able to recover on a transaction.  This is the amount that the Buyer puts on their returns in order to recover these funds.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="RecoverablePercent" type="PercentType" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation><![CDATA[The percent of the tax that is recoverable, as calculated based on passed in recoverable amount and tax. Expressed as a decimal: 1.0 for 100%, .8 for 80%, .5 for 50%, and so on.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="BlockingRecoverablePercent" type="PercentType" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>The recoverable override percentage
 of the blocking override on the Input Tax level.</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="PartialExemptRecoverablePercent" type="PercentType" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>The recoverable percentage  of a partial exemption. This field is populated only for transactions with a tax type of Value Added Tax.</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="UnrecoverableAmount" type="AmountType" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>The amount of input or import tax that the taxpayer is not able to recover.  It is lost, which is a true cost to the taxpayer.</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="FilingCurrencyAmounts" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>A grouping of filing currency converted taxability amounts.</xsd:documentation>
						</xsd:annotation>
						<xsd:complexType>
							<xsd:sequence>
								<xsd:element ref="CurrencyConversion"/>
								<xsd:element name="FilingCalculatedTax" type="AmountType" minOccurs="0">
									<xsd:annotation>
										<xsd:documentation>The calculated tax amount for the line item, reported in the filing currency.</xsd:documentation>
									</xsd:annotation>
								</xsd:element>
								<xsd:element name="FilingExempt" type="AmountType" minOccurs="0">
									<xsd:annotation>
										<xsd:documentation>The exempt amount for the line item, reported in the filing currency.</xsd:documentation>
									</xsd:annotation>
								</xsd:element>
								<xsd:element name="FilingNonTaxable" type="AmountType" minOccurs="0">
									<xsd:annotation>
										<xsd:documentation>The non-taxable amount for the line item, reported in the filing currency</xsd:documentation>
									</xsd:annotation>
								</xsd:element>
								<xsd:element name="FilingTaxable" type="AmountType" minOccurs="0">
									<xsd:annotation>
										<xsd:documentation>The taxable amount for the line item, reported in the filing currency.</xsd:documentation>
									</xsd:annotation>
								</xsd:element>
								<xsd:element name="FilingRecoverableAmount" type="AmountType" minOccurs="0">
									<xsd:annotation>
										<xsd:documentation>The recoverable amount for the VAT line item, reported in the filing currency.</xsd:documentation>
									</xsd:annotation>
								</xsd:element>
								<xsd:element name="FilingUnrecoverableAmount" type="AmountType" minOccurs="0">
									<xsd:annotation>
										<xsd:documentation>The unrecoverable amount for the VAT line item, reported in the filing currency.</xsd:documentation>
									</xsd:annotation>
								</xsd:element>
							</xsd:sequence>
						</xsd:complexType>
					</xsd:element>
					<xsd:element name="SellerRegistrationId" type="RegistrationIdType" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>The Registration ID for the Seller associated with this line item tax.</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="BuyerRegistrationId" type="RegistrationIdType" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>The Registration ID for the Buyer associated with this line item tax.</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="OwnerRegistrationId" type="RegistrationIdType" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>The Registration ID for the Owner associated with this line item tax.</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="DispatcherRegistrationId" type="RegistrationIdType" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>The Registration ID for the Dispatcher associated with this line item tax.</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="RecipientRegistrationId" type="RegistrationIdType" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>The Registration ID for the Recipient associated with this line item tax.</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element ref="InvoiceTextCode" minOccurs="0" maxOccurs="unbounded"/>
					<xsd:element name="SummaryInvoiceText" type="xsd:string" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Additional information about a tax, to be returned to your host system after tax calculation. To supply a value for this field, you need to set up a post-calculation Tax Assist rule. Note: The text you add to this field is not stored in the Tax Journal.]]></xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element ref="AssistedParameters" minOccurs="0"/>
				</xsd:sequence>
				<xsd:attribute name="taxResult" type="TaxResultCodeType">
					<xsd:annotation>
						<xsd:documentation><![CDATA[System determination of taxable status based on situs and item type. Note: Tax amounts with a value of Deferred are payable at a later time and should NOT be written to the invoice.]]></xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="taxType" type="TaxingType">
					<xsd:annotation>
						<xsd:documentation>System determined tax type, based on situs, transaction type, and party role type (perspective).</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="maxTaxIndicator" type="xsd:boolean">
					<xsd:annotation>
						<xsd:documentation>Indicates that max tax was applied to this line item of the invoice.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="situs" type="TaxingLocationCodeType">
					<xsd:annotation>
						<xsd:documentation>The situs determined by the calculation engine for the line item.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="notRegisteredIndicator" type="xsd:boolean">
					<xsd:annotation>
						<xsd:documentation>Indicates that the taxpayer company is not registered in the taxing jurisdiction.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="inputOutputType" type="InputOutputCodeType">
					<xsd:annotation>
						<xsd:documentation>Identifies whether tax is Input VAT, Output VAT, or both according to the perspective of the transaction to allow for Reverse Charges.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="taxCode" type="xsd:string">
					<xsd:annotation>
						<xsd:documentation><![CDATA[A user-defined code for the tax, to be returned to your host system after tax calculation. To return a value for this field, set up a post-calculation Tax Assist rule.]]></xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="vertexTaxCode" type="xsd:string">
					<xsd:annotation>
						<xsd:documentation><![CDATA[A code that can be used to classify the transaction at the tax level for reporting or tax return filing purposes. The code is generated by the Calculation Engine for each line item after tax calculation. It can be used as a filter for reports or as an input for post-calculation Tax Assist rules. For detailed information about the contents of the code, see the Supporting Information section of the XML Integration Guide.]]></xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="reasonCode" type="ReasonCodeType">
					<xsd:annotation>
						<xsd:documentation><![CDATA[A code that indicates the reason for the exception that was applied to this tax. Note: For a tax with multiple tiers, O Series returns the reason code associated with the largest basis amount. Note: To pass a standard (i.e., not user-defined) single-digit reason code, pad the code to four digits. Refer to the Supporting Information section of the XML Integration Guide for information on exemption and deduction reason codes.]]></xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="filingCategoryCode">
					<xsd:annotation>
						<xsd:documentation><![CDATA[Provides additional classification of the transaction for tax returns and reporting. Codes are jurisdiction-specific. Note: For a tax with multiple tiers, O Series returns the filing category code associated with the largest basis amount.]]></xsd:documentation>
					</xsd:annotation>
					<xsd:simpleType>
						<xsd:restriction base="xsd:positiveInteger">
							<xsd:minInclusive value="1"/>
							<xsd:maxInclusive value="99999"/>
						</xsd:restriction>
					</xsd:simpleType>
				</xsd:attribute>
				<xsd:attribute name="isService" type="xsd:boolean">
					<xsd:annotation>
						<xsd:documentation>Indicates whether or not the product is a service.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="rateClassification" type="xsd:string">
					<xsd:annotation>
						<xsd:documentation><![CDATA[A Vertex-defined classification of the applicable tax rule for returns filing purposes. Possible values are: Luxury Rate, Standard Rate, Reduced Rate 1, Reduced Rate 2, Reduced Rate 3, Reduced Rate 4, Reduced Rate 5, User Defined, Zero Rate, Outside the Scope.]]></xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="taxCollectedFromParty" type="TaxCollectedFromPartyType">
					<xsd:annotation>
						<xsd:documentation><![CDATA[The party who is responsible for the sales tax. Note: Tax amounts with a value of Seller cannot be charged to your customer and should NOT be written to the invoice.]]></xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="taxStructure" type="TaxStructureCodeType">
					<xsd:annotation>
						<xsd:documentation><![CDATA[Specifies the applicable tax structure when the transaction includes a flat 
fee or quantity-based fee. Valid values are 
BRACKET, FLAT_TAX, QUANTITY, SINGLE_RATE, and TIERED.]]></xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
			</xsd:complexType>
			<xsd:complexType name="TaxingJurisdictionLocationType">
				<xsd:complexContent>
					<xsd:extension base="LocationType">
						<xsd:attribute name="jurisdictionLevel" type="JurisdictionLevelCodeType" use="required">
							<xsd:annotation>
								<xsd:documentation>Identifies the jurisdiction level to which the tax applies.</xsd:documentation>
							</xsd:annotation>
						</xsd:attribute>
						<xsd:attribute name="impositionType">
							<xsd:annotation>
								<xsd:documentation><![CDATA[The type of imposition. impositionType can be Vertex-defined
or user-defined in Vertex Central. impositionType enables you to  
set registration-level details during transaction processing.

Regstration can have multiple imposition types at both the Main 
Division and Country level. This is an optional attribute under the 
TaxRegistration element.]]></xsd:documentation>
							</xsd:annotation>
							<xsd:simpleType>
								<xsd:restriction base="xsd:string">
									<xsd:minLength value="0"/>
									<xsd:maxLength value="60"/>
								</xsd:restriction>
							</xsd:simpleType>
						</xsd:attribute>
					</xsd:extension>
				</xsd:complexContent>
			</xsd:complexType>
			<xsd:complexType name="TaxSynchronizationRequestType">
				<xsd:annotation>
					<xsd:documentation>Parent type for all Tax Synchronization request messages</xsd:documentation>
				</xsd:annotation>
			</xsd:complexType>
			<xsd:complexType name="PartyType">
				<xsd:annotation>
					<xsd:documentation>Specialized participant to mark taxpayer in DOM.</xsd:documentation>
				</xsd:annotation>
			</xsd:complexType>
			<xsd:complexType name="CustomerType">
				<xsd:complexContent>
					<xsd:extension base="PartyType">
						<xsd:sequence>
							<xsd:element ref="CustomerCode" minOccurs="0"/>
							<xsd:element ref="Destination" minOccurs="0"/>
							<xsd:element ref="AdministrativeDestination" minOccurs="0"/>
							<xsd:element ref="ExemptionCertificate" minOccurs="0"/>
							<xsd:element ref="TaxRegistration" minOccurs="0" maxOccurs="unbounded"/>
						</xsd:sequence>
						<xsd:attribute name="isTaxExempt" type="xsd:boolean" default="false">
							<xsd:annotation>
								<xsd:documentation><![CDATA[Indicates that the buyer is not required to collect taxes, and all line items associated with the purchase order are exempt from taxes. It is recommended that the buyer and vendor nexus requirements be created and maintained in the Vertex Central user interface. Note: this attribute is set to true if you pass an exemption certificate number in the XML message.]]></xsd:documentation>
							</xsd:annotation>
						</xsd:attribute>
						<xsd:attribute name="exemptionReasonCode" type="ReasonCodeType">
							<xsd:annotation>
								<xsd:documentation><![CDATA[The 'Reason Code' can be passed through the ERP application if functionality is provided, however most Lessee's will set up reason codes associated with Lessee's in the Vertex Central user interface by the tax department.  The valid reason codes are expected from the calling application and are pre-defined by Vertex for use in the Tax Returns application. Note: To pass a standard (i.e., not user-defined) single-digit reason code, pad the code to four digits. Refer to the Supporting Information section of the XML Integration Guide for information on exemption and deduction reason codes.]]></xsd:documentation>
							</xsd:annotation>
						</xsd:attribute>
					</xsd:extension>
				</xsd:complexContent>
			</xsd:complexType>
			<xsd:complexType name="TaxTransactionRequestType">
				<xsd:annotation>
					<xsd:documentation>Parent type for all Tax Transaction request messages</xsd:documentation>
				</xsd:annotation>
			</xsd:complexType>
			<xsd:complexType name="RuleType">
				<xsd:simpleContent>
					<xsd:extension base="xsd:positiveInteger">
						<xsd:attribute name="userDefined" type="xsd:boolean">
							<xsd:annotation>
								<xsd:documentation>Identifier for user-defined rules. This identifier is useful for troubleshooting. The default value is False, Vertex-defined rule.</xsd:documentation>
							</xsd:annotation>
						</xsd:attribute>
						<xsd:attribute name="salesTaxHolidayIndicator" type="xsd:boolean">
							<xsd:annotation>
								<xsd:documentation>Indicates whether this rule applies as a Sales Tax Holiday.</xsd:documentation>
							</xsd:annotation>
						</xsd:attribute>
					</xsd:extension>
				</xsd:simpleContent>
			</xsd:complexType>
			<xsd:complexType name="CompanyCodeType">
				<xsd:simpleContent>
					<xsd:extension base="EntityCodeType">
						<xsd:attribute name="classCode">
							<xsd:annotation>
								<xsd:documentation><![CDATA[A code used to represent groups of customers, vendors, dispatchers, or recipients who have similar taxability. Note: If you pass a classCode, you should not pass a TaxRegistrationNumber because the registration number does not apply to the entire class.]]></xsd:documentation>
							</xsd:annotation>
							<xsd:simpleType>
								<xsd:restriction base="xsd:string">
									<xsd:minLength value="1"/>
									<xsd:maxLength value="40"/>
								</xsd:restriction>
							</xsd:simpleType>
						</xsd:attribute>
					</xsd:extension>
				</xsd:simpleContent>
			</xsd:complexType>
			<xsd:complexType name="BuyerType">
				<xsd:annotation>
					<xsd:documentation>The buyer for the transaction or line item. The buyer is described by the child elements and attributes.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexContent>
					<xsd:extension base="TaxpayerType">
						<xsd:sequence>
							<xsd:element ref="Recipient" minOccurs="0"/>
							<xsd:element ref="Destination" minOccurs="0"/>
							<xsd:element ref="AdministrativeDestination" minOccurs="0"/>
							<xsd:element ref="ExemptionCertificate" minOccurs="0"/>
							<xsd:element ref="TaxRegistration" minOccurs="0" maxOccurs="unbounded"/>
						</xsd:sequence>
						<xsd:attributeGroup ref="BuyerGroup"/>
					</xsd:extension>
				</xsd:complexContent>
			</xsd:complexType>
			<xsd:complexType name="JurisdictionType">
				<xsd:annotation>
					<xsd:documentation>The name that this jurisdiction is commonly known. For example, Pennsylvania.</xsd:documentation>
					<xsd:documentation>Copyright Vertex Inc. 2007-2012 All Rights Reserved</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleContent>
					<xsd:extension base="xsd:string">
						<xsd:attribute name="jurisdictionLevel" type="JurisdictionLevelCodeType" use="required">
							<xsd:annotation>
								<xsd:documentation>The level of the jurisdiction for which the tax on the line item is applied.</xsd:documentation>
							</xsd:annotation>
						</xsd:attribute>
						<xsd:attribute name="jurisdictionId" use="required">
							<xsd:annotation>
								<xsd:documentation>The Vertex-specific number that identifies a jurisdiction.</xsd:documentation>
							</xsd:annotation>
							<xsd:simpleType>
								<xsd:restriction base="xsd:integer">
									<xsd:minInclusive value="0"/>
									<xsd:maxInclusive value="999999999"/>
								</xsd:restriction>
							</xsd:simpleType>
						</xsd:attribute>
						<xsd:attribute name="effectiveDate" type="xsd:date">
							<xsd:annotation>
								<xsd:documentation/>
								<xsd:documentation>The date when the tax for the jurisdiction became effective.</xsd:documentation>
							</xsd:annotation>
						</xsd:attribute>
						<xsd:attribute name="expirationDate" type="xsd:date">
							<xsd:annotation>
								<xsd:documentation>The date after which the tax for the jurisdiction is no longer effective.</xsd:documentation>
							</xsd:annotation>
						</xsd:attribute>
						<xsd:attribute name="externalJurisdictionCode" type="ExternalJurisdictionCodeType">
							<xsd:annotation>
								<xsd:documentation>Jurisdiction code assigned by the relevant governmental authority.</xsd:documentation>
							</xsd:annotation>
						</xsd:attribute>
					</xsd:extension>
				</xsd:simpleContent>
			</xsd:complexType>
			<xsd:complexType name="SupplementaryUnitType">
				<xsd:annotation>
					<xsd:documentation><![CDATA[A supplementary unit type used with commodity codes that require
an alternative to Net Mass by Kilograms. For example, a transaction mayhave no weight unit type. However,there may be pieces, pairs, or liters. This field is used for intrastat purposes.This element is associated with the Supplementary Unit element.]]></xsd:documentation>
				</xsd:annotation>
				<xsd:simpleContent>
					<xsd:extension base="xsd:decimal">
						<xsd:attribute name="unitType">
							<xsd:annotation>
								<xsd:documentation><![CDATA[A unit type used with commodity codes that require an alternative to Net Mass by Kilograms. For example, a transaction may
have no weight unit type but there may be pieces, pairs, or liters. This element is used for intrastat purposes and is associated with the Supplementary Unit element.]]></xsd:documentation>
							</xsd:annotation>
							<xsd:simpleType>
								<xsd:restriction base="xsd:string">
									<xsd:maxLength value="20"/>
								</xsd:restriction>
							</xsd:simpleType>
						</xsd:attribute>
					</xsd:extension>
				</xsd:simpleContent>
			</xsd:complexType>
			<xsd:complexType name="CurrencyType">
				<xsd:annotation>
					<xsd:documentation>The monetary unit to be used in calculations as defined by ISO 4217 standard.</xsd:documentation>
					<xsd:documentation>Copyright Vertex Inc. 2007-2012 All Rights Reserved</xsd:documentation>
				</xsd:annotation>
				<xsd:attributeGroup ref="isoCurrencyCode"/>
			</xsd:complexType>
			<xsd:complexType name="AssistedParametersType">
				<xsd:annotation>
					<xsd:documentation>List of all parameters on the tax or line item that were assisted by one or more assisting services.</xsd:documentation>
				</xsd:annotation>
				<xsd:sequence>
					<xsd:element name="AssistedParameter" maxOccurs="unbounded">
						<xsd:annotation>
							<xsd:documentation><![CDATA[Element body is value for assisted parameter.  Body may be date
            (yyyy-mm-dd), numeric (default format for long or double), boolean
            (true or false), or simple string.]]></xsd:documentation>
						</xsd:annotation>
						<xsd:complexType>
							<xsd:simpleContent>
								<xsd:extension base="xsd:string">
									<xsd:attribute name="paramName" type="xsd:string" use="required">
										<xsd:annotation>
											<xsd:documentation>Unique name by which the modified parameter can be identified.</xsd:documentation>
										</xsd:annotation>
									</xsd:attribute>
									<xsd:attribute name="phase" use="required">
										<xsd:annotation>
											<xsd:documentation>Indicates whether the parameter was assisted pre-calculation or post-calculation.</xsd:documentation>
										</xsd:annotation>
										<xsd:simpleType>
											<xsd:restriction base="xsd:string">
												<xsd:enumeration value="PRE"/>
												<xsd:enumeration value="POST"/>
											</xsd:restriction>
										</xsd:simpleType>
									</xsd:attribute>
									<xsd:attribute name="ruleName" type="xsd:string">
										<xsd:annotation>
											<xsd:documentation><![CDATA[The name of the Tax Assist Rule that the Calculation Engine applied during transction processing. To return the Tax Assist Rule name, the returnAssistedParametersIndicator must be enabled. The ruleName is an attribute of the XML Response message AssistedParameter element.]]></xsd:documentation>
										</xsd:annotation>
									</xsd:attribute>
									<xsd:attribute name="originalValue" type="xsd:string">
										<xsd:annotation>
											<xsd:documentation><![CDATA[The original value of the assisted parameter before the Calculation Engine applied a Tax Assist Rule. This is an attribute of the XML Response 
message AssistedParameter element.]]></xsd:documentation>
										</xsd:annotation>
									</xsd:attribute>
								</xsd:extension>
							</xsd:simpleContent>
						</xsd:complexType>
					</xsd:element>
				</xsd:sequence>
			</xsd:complexType>
			<xsd:complexType name="CustomerCodeType">
				<xsd:simpleContent>
					<xsd:extension base="CompanyCodeType">
						<xsd:attribute name="isBusinessIndicator" type="xsd:boolean">
							<xsd:annotation>
								<xsd:documentation>Indicates whether or not the participant is a business.</xsd:documentation>
							</xsd:annotation>
						</xsd:attribute>
					</xsd:extension>
				</xsd:simpleContent>
			</xsd:complexType>
			<xsd:complexType name="TaxAreaResultType">
				<xsd:sequence>
					<xsd:element name="Jurisdiction" type="JurisdictionType" minOccurs="0" maxOccurs="unbounded"/>
					<xsd:element ref="PostalAddress" minOccurs="0" maxOccurs="unbounded"/>
					<xsd:element name="Status" minOccurs="0" maxOccurs="unbounded">
						<xsd:annotation>
							<xsd:documentation>Represents the result of the lookup process.</xsd:documentation>
						</xsd:annotation>
						<xsd:complexType>
							<xsd:simpleContent>
								<xsd:extension base="xsd:string">
									<xsd:attribute name="lookupResult" type="LookupResultType" use="required">
										<xsd:annotation>
											<xsd:documentation>The status of the Tax Area lookup.</xsd:documentation>
										</xsd:annotation>
									</xsd:attribute>
								</xsd:extension>
							</xsd:simpleContent>
						</xsd:complexType>
					</xsd:element>
					<xsd:element name="AddressCleansingResultMessage" minOccurs="0" maxOccurs="unbounded">
						<xsd:annotation>
							<xsd:documentation>The reason for the Address Cleansing failure.</xsd:documentation>
						</xsd:annotation>
						<xsd:complexType>
							<xsd:simpleContent>
								<xsd:extension base="xsd:string">
									<xsd:attribute name="code" type="xsd:string">
										<xsd:annotation>
											<xsd:documentation>The specific fault code for the Address Cleansing failure.</xsd:documentation>
										</xsd:annotation>
									</xsd:attribute>
									<xsd:attribute name="type" type="xsd:string">
										<xsd:annotation>
											<xsd:documentation>The type of the Address Cleansing result.</xsd:documentation>
										</xsd:annotation>
									</xsd:attribute>
								</xsd:extension>
							</xsd:simpleContent>
						</xsd:complexType>
					</xsd:element>
				</xsd:sequence>
				<xsd:attribute name="taxAreaId" type="TaxAreaIdType">
					<xsd:annotation>
						<xsd:documentation>A Vertex-specific number that identifies a tax area.</xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="asOfDate" type="xsd:date">
					<xsd:annotation>
						<xsd:documentation><![CDATA[A date that provides time perspective for a Tax Area lookup. Tax Area IDs returned for the lookup are based on the jurisdiction boundaries in effect as of this date. Defaults to the current date.]]></xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="confidenceIndicator">
					<xsd:annotation>
						<xsd:documentation>Indicates the relative likelihood that a result of a tax area lookup is correct based on the lookup criteria.</xsd:documentation>
					</xsd:annotation>
					<xsd:simpleType>
						<xsd:restriction base="xsd:integer">
							<xsd:minInclusive value="0"/>
							<xsd:maxInclusive value="100"/>
						</xsd:restriction>
					</xsd:simpleType>
				</xsd:attribute>
			</xsd:complexType>
			<xsd:complexType name="DatePeriodType">
				<xsd:sequence>
					<xsd:element name="BeginDate" type="xsd:date"/>
					<xsd:element name="EndDate" type="xsd:date" minOccurs="0"/>
				</xsd:sequence>
			</xsd:complexType>
			<xsd:complexType name="TaxAreaRequestType">
				<xsd:annotation>
					<xsd:documentation>Tax Area request type declaration.</xsd:documentation>
				</xsd:annotation>
				<xsd:complexContent>
					<xsd:extension base="TaxgisRequestType">
						<xsd:sequence>
							<xsd:element name="TaxAreaLookup" type="TaxAreaLookupType" minOccurs="0">
								<xsd:annotation>
									<xsd:documentation>The criteria to use in looking up the tax area. Use one of the following: TaxAreaId, PostalAddress, or ExternalJurisdiction.</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
						</xsd:sequence>
					</xsd:extension>
				</xsd:complexContent>
			</xsd:complexType>
			<xsd:complexType name="TaxAreaLookupType">
				<xsd:choice minOccurs="0">
					<xsd:element name="TaxAreaId" type="TaxAreaIdType">
						<xsd:annotation>
							<xsd:documentation>The Vertex-defined Tax Area ID for the jurisdiction.</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element ref="PostalAddress"/>
					<xsd:element name="ExternalJurisdiction">
						<xsd:annotation>
							<xsd:documentation>The relevant governmental authority associated with the Tax Area ID.</xsd:documentation>
						</xsd:annotation>
						<xsd:complexType>
							<xsd:sequence>
								<xsd:element name="ExternalJurisdictionCode" type="ExternalJurisdictionCodeType">
									<xsd:annotation>
										<xsd:documentation>The jurisdiction code assigned by the relevant governmental authority.</xsd:documentation>
									</xsd:annotation>
								</xsd:element>
								<xsd:element name="Country">
									<xsd:annotation>
										<xsd:documentation><![CDATA[The country associated with the external jurisdiction code. You can use a Data Extract report to see the valid country values. (Refer to the Vertex Central online help for information on running Data Extract reports.)]]></xsd:documentation>
									</xsd:annotation>
									<xsd:simpleType>
										<xsd:restriction base="xsd:string">
											<xsd:minLength value="1"/>
											<xsd:maxLength value="60"/>
										</xsd:restriction>
									</xsd:simpleType>
								</xsd:element>
							</xsd:sequence>
						</xsd:complexType>
					</xsd:element>
				</xsd:choice>
				<xsd:attribute name="asOfDate" type="xsd:date">
					<xsd:annotation>
						<xsd:documentation><![CDATA[A date that provides time perspective for a Tax Area lookup. Tax Area IDs returned for the lookup are based on the jurisdiction boundaries in effect as of this date. Defaults to the current date.]]></xsd:documentation>
					</xsd:annotation>
				</xsd:attribute>
				<xsd:attribute name="lookupId">
					<xsd:annotation>
						<xsd:documentation>Internal identifier or sequence number for this lookup.</xsd:documentation>
					</xsd:annotation>
					<xsd:simpleType>
						<xsd:restriction base="xsd:string">
							<xsd:minLength value="1"/>
							<xsd:maxLength value="40"/>
						</xsd:restriction>
					</xsd:simpleType>
				</xsd:attribute>
			</xsd:complexType>
			<xsd:complexType name="FindChangedTaxAreaIdsRequestType">
		<xsd:complexContent>
			<xsd:extension base="TaxgisRequestType">
				<xsd:sequence>
					<xsd:element name="DatePeriod">
						<xsd:annotation>
							<xsd:documentation>The date range to be searched.</xsd:documentation>
						</xsd:annotation>
						<xsd:complexType>
							<xsd:complexContent>
								<xsd:restriction base="DatePeriodType">
									<xsd:sequence>
										<xsd:element name="BeginDate" type="xsd:date">
											<xsd:annotation>
												<xsd:documentation>The start date of the range to be searched.</xsd:documentation>
											</xsd:annotation>
										</xsd:element>
										<xsd:element name="EndDate" type="xsd:date" default="9999-12-31" minOccurs="0">
											<xsd:annotation>
												<xsd:documentation>The end date of the range to be searched. Defaults to 9999-12-31.</xsd:documentation>
											</xsd:annotation>
										</xsd:element>
									</xsd:sequence>
								</xsd:restriction>
							</xsd:complexContent>
						</xsd:complexType>
					</xsd:element>
				</xsd:sequence>
			</xsd:extension>
		</xsd:complexContent>
	</xsd:complexType>

<xsd:complexType name="FindChangedTaxAreaIdsResponseType">
		<xsd:annotation>
			<xsd:documentation>List of tax areas changed during an identified period of time.</xsd:documentation>
		</xsd:annotation>
		<xsd:complexContent>
			<xsd:extension base="TaxgisResponseType">
				<xsd:sequence>
					<xsd:element name="TaxAreaId" type="TaxAreaIdType" minOccurs="0" maxOccurs="unbounded">
						<xsd:annotation>
							<xsd:documentation>A Vertex-specific number that identifies a tax area.</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
				</xsd:sequence>
			</xsd:extension>
		</xsd:complexContent>
	</xsd:complexType>
		</xsd:schema>
	</wsdl:types>
	<wsdl:message name="VertexEnvelope">
		<wsdl:part name="VertexEnvelope" element="p27:VertexEnvelope" xmlns:p27="urn:vertexinc:o-series:tps:7:0"/>
	</wsdl:message>
</wsdl:definitions>
