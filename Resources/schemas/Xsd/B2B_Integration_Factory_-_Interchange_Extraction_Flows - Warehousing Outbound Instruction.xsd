               <xsd:documentation xml:lang="en-US" source="Definition">Measurement of the distance between the front and the back.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 700</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="height" type="MeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Height</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The vertical dimension from the lowest extremity to the highest extremity.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 700</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="width" type="MeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Width</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The measurement of the extent of something from side to side. Width is the measurement from left to right.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 700</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="DocumentReferenceType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information identifying a document and potentially a line within the document for referencing purposes.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">Information identifying a piece of information, such as an object or document.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="entityIdentification">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Entity Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The unique identifier of the piece of information, such as the object id or the document id.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: ABCDE00001</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="contentOwner" minOccurs="0" type="PartyIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Content Owner</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Uniquely identifies the creator of the entity identification.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="creationDateTime" minOccurs="0" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Creation Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date and time of creation of the referenced document.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15T11:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="revisionNumber" minOccurs="0" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Revision Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number to be used for identification and referencing of subsequent updates to a business document.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="lineItemNumber" minOccurs="0" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Line Item Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number specifying a line in the referenced document.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="DocumentType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Used to specify basic information about the content of the message including version number, creation date and time.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="creationDateTime" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Creation Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date and time when the document was created.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15T11:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="documentStatusCode" type="DocumentStatusEnumerationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Document Status Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="documentActionCode" minOccurs="0" type="DocumentActionEnumerationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Document Action Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="documentStructureVersion" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Document Structure Version</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Specification of the version of the standard on which the structure of the document is based.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 3.3</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="lastUpdateDateTime" minOccurs="0" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Last Update Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date and time when the document was last updated.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-05T11:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="revisionNumber" minOccurs="0" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Revision Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number to be used for identification and referencing of subsequent updates to a business document.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 3</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="extension" minOccurs="0" type="ExtensionType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Extension</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="documentEffectiveDate" minOccurs="0" type="DateOptionalTimeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Document Effective Date</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The date that the document becomes effective from commercial or legal point of view.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="EntityIdentificationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information identifying a piece of information, such as an object or document.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="entityIdentification">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Entity Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The unique identifier of the piece of information, such as the object id or the document id.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: ABCDE00001</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="contentOwner" minOccurs="0" type="PartyIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Content Owner</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Uniquely identifies the creator of the entity identification.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="EntityTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:EntityTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 35</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="EntityTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="ExtensionType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Extension point for inclusion of additional information through an extension to the document.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="extensionElement" type="xsd:string" minOccurs="0" maxOccurs="unbounded">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Definition">The placeholder element that allows adding extensions</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="FinancialAccountNumberTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a financial account number type. Allowed code values are specified in GS1 Code List FinancialAccountNumberTypeCode.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:FinancialAccountNumberTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: BUSINESS_ACCOUNT</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="FinancialAccountNumberTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="FinancialAccountType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information identifying a client’s financial account with a financial institution.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="financialAccountNumber">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Financial Account Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Text specifying the number of the financial account.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 8725934582149</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="financialAccountNumberTypeCode"
            type="FinancialAccountNumberTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Financial Account Number Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifies the type of financial account number.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="financialAccountName" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Financial Account Name</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Text specifying the name of the financial account.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Sales Account</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="FinancialRoutingNumberType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Number assigned to a transaction in financial routing between parties.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="financialRoutingNumber">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Financial Routing Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number assigned to a transaction in financial routing between parties. The number is determined by and used in conjunction with the type of routing, e.g. SWIFT,ABA,CHIPS.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: BE16054659360612876</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="financialRoutingNumberTypeCode"
            type="FinancialRoutingNumberTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Financial Routing Number Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the type of financial routing, e.g. SWIFT.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: SWIFT_IDENTIFICATION</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="FinancialRoutingNumberTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:FinancialRoutingNumberTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: CHIPS</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="FinancialRoutingNumberTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="GeographicalCoordinatesType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">The longitude and latitude of a geographical location.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="latitude">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Latitude</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Angular distance North or South from the earth's equator measured through 90 degrees.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 50d 49' 23.2032"</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="longitude">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Longitude</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The arc or portion of the earth's equator intersected between the meridian of a given place and the prime meridian and expressed either in degrees or in time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 4d 22' 7.266"</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="GPCAttributeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information on the type and value of a Global Product Classification (GPC) attribute.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="gpcAttributeTypeCode">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gpc Attribute Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the type of the Global Product Classification (GPC) attribute, for example 20000081 - Grape Variety.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="gpcAttributeValueCode">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gpc Attribute Value Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The GS1 provided code which identifies the Global Product Classification Attribute Value.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="gpcAttributeTypeName" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gpc Attribute Type Name</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The GS1 provided text equivalent of the Global Product Classification Attribute Code.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="gpcAttributeValueName" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gpc Attribute Value Name</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The GS1 provided text equivalent of the Global Product Classification Attribute Value Code.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="GS1CodeType">
