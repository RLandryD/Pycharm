<xsd:appinfo>
<wd:Validation>
<wd:Validation_Message>Remove Internal Project Experience is true without an Internal Project Experience or valid Internal Project Experience ID.  An Internal Project Experience or valid Internal Project Experience ID must be specified in order to remove the Internal Project Experience.</wd:Validation_Message>
</wd:Validation>
</xsd:appinfo>
</xsd:annotation>
</xsd:element>
