<?xml version="1.0" encoding="UTF-8"?>
<!--
  PIPELINE STEP 3: Interface Separation iFlow
  Package  : 1_ERP_YaaS_Finance
  Purpose  : Routes to the correct scenario-specific iFlow
             based on SAP_InterfaceName header set by Receiver Determination.
  Internal : ProcessDirect address /pd/InterfaceSeparation_1_ERP_YaaS_Finance
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Interface_Separation_1_ERP_YaaS_Finance"
             name="Interface_Separation_1_ERP_YaaS_Finance">
  <process id="IfaceSep_1_ERP_YaaS_Finance_process" ifl:type="IntegrationFlow">

    <startEvent id="Start_IS" name="From Receiver Determination">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/pd/InterfaceSeparation_1_ERP_YaaS_Finance</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>

    <!-- ROUTER: Branch to scenario-specific iFlow -->
    <exclusiveGateway id="Router_1" name="Route by Interface Name"/>

    <sequenceFlow id="route_0" sourceRef="Router_1"
      targetRef="Call_Replicate_Customer_f_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Replicate Customer from SAP ERP' -->
    </sequenceFlow>
    <serviceTask id="Call_Replicate_Customer_f_1"
      name="→ Replicate Customer from SAP ERP" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Replicate_Customer_f</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_1" sourceRef="Router_1"
      targetRef="Call_Replicate_Customer_A_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Replicate Customer Address from SAP ERP' -->
    </sequenceFlow>
    <serviceTask id="Call_Replicate_Customer_A_1"
      name="→ Replicate Customer Address from SAP ERP" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Replicate_Customer_A</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_IS"/>
    <sequenceFlow sourceRef="Start_IS" targetRef="Router_1"/>
  </process>
</definitions>