							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="132" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="STD_RECIP" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Flag: Recipient is standard recipient for this
