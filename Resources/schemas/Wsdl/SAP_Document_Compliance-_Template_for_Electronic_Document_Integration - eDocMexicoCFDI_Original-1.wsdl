            <xs:import schemaLocation="cfdv33.xsd" namespace="http://www.sat.gob.mx/cfd/3"></xs:import>
            <xs:element name="CFDSubmitRequest" type="tns1:CFDSubmitRequestType">
			</xs:element>

			<xs:element name="CFDCancelRequest">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="Emisor">
							<xs:annotation>
								<xs:documentation>
