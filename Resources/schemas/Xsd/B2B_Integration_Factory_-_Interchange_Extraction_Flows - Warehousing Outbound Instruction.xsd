      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="200"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="String2500Type">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">N/A</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="2500"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="String35Type">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">N/A</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="35"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="String5000Type">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">N/A</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="5000"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="String500Type">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">N/A</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="500"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="String70Type">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">N/A</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="70"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="String80Type">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">N/A</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="WeekendDayEnumerationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">N/A</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: SATURDAY</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:enumeration value="SATURDAY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Definition">Not Available</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SUNDAY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Definition">Not Available</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="DebitCreditEnumerationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">N/A</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: CREDIT</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:enumeration value="CREDIT"/>
         <xsd:enumeration value="DEBIT"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="GDTIType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 0857674002331</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:pattern value="[-!&quot;%&amp;'()*+,./0-9:;&lt;=>?A-Z_a-z]{13,30}"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="TransportPlanningDateTypeEnumerationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: DELIVERY_DATE</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">N/A</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:string">
         <xsd:enumeration value="DELIVERY_DATE"/>
         <xsd:enumeration value="PICKUP_DATE"/>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="Action">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:Action</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="add">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Not
                  Available</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="delete">
