<?xml version="1.0" encoding="UTF-8"?>
<!--
  SCENARIO iFlow: Update Figaf Transport from Azure
  Display Name : OUT_Azure_Webhook_Figaf_2_Update_Figaf_Transpo
  Package      : 1_Azure_Webhook_Figaf_2_Finance
  Strategy     : BROWNFIELD: Lift-and-shift. Mapping '' ported directly.
  Complexity   : MEDIUM (score: 22)
  Effort       : 3 day(s)
  Sender       : Azure_Webhook (HTTPS)
  Receiver     : Figaf_2 (HTTP)
  Batch        : No
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Update_Figaf_Transpo"
             name="OUT_Azure_Webhook_Figaf_2_Update_Figaf_Transpo">
  <process id="Update_Figaf_Transpo_process" ifl:type="IntegrationFlow">

    <startEvent id="Start_SC" name="From Interface Separation">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Update_Figaf_Transpo</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>



    <!-- PROCESSDIRECT: Forward to Outbound Delivery -->
    <serviceTask id="CallOutbound_1" name="→ Outbound Delivery" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/outbound/1_Azure_Webhook_Figa</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_SC"/>
    <sequenceFlow sourceRef="Start_SC" targetRef="CallOutbound_1"/>
    
    
    <sequenceFlow sourceRef="CallOutbound_1" targetRef="End_SC"/>
  </process>
</definitions>