	<xs:element name="insertResponse">
		<xs:complexType>
			<xs:sequence>
				<xs:element name="result">
					<xs:complexType>
						<xs:sequence>
							<xs:element name="jobStatus" type="xs:string" />
							<xs:element name="message" />
							<xs:element name="objectEditResult">
								<xs:complexType>
									<xs:sequence>
										<xs:element name="id" type="xs:string" />
										<xs:element name="errorStatus" type="xs:string" />
										<xs:element name="editStatus" type="xs:string" />
										<xs:element name="index" type="xs:int" />
										<xs:element name="message" type="xs:string" />
									</xs:sequence>
								</xs:complexType>
							</xs:element>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
</xs:schema>