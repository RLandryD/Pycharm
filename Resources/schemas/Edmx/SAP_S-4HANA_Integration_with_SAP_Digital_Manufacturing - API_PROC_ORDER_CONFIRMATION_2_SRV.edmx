 <edmx:DataServices m:DataServiceVersion="2.0">
  <Schema Namespace="API_PROC_ORDER_CONFIRMATION_2_SRV" xml:lang="en" sap:schema-version="1" xmlns="http://schemas.microsoft.com/ado/2008/09/edm">
   <EntityType Name="ProcOrdConf2Type" sap:label="Process Order Confirmation" sap:content-version="1">
    <Key>
     <PropertyRef Name="ConfirmationGroup"/>
     <PropertyRef Name="ConfirmationCount"/>
    </Key>
    <Property Name="ConfirmationGroup" Type="Edm.String" Nullable="false" MaxLength="10" sap:display-format="NonNegative" sap:label="Confirmation Group" sap:quickinfo="Collective ID of Order Confirmations"/>
    <Property Name="ConfirmationCount" Type="Edm.String" Nullable="false" MaxLength="8" sap:display-format="NonNegative" sap:label="Order Confirmation" sap:quickinfo="Identifier of Single Order Confirmation"/>
    <Property Name="OrderID" Type="Edm.String" MaxLength="12" sap:display-format="UpperCase" sap:label="Manufacturing Order" sap:quickinfo="Manufacturing Order ID"/>
    <Property Name="Sfc" Type="Edm.String" MaxLength="128" sap:display-format="UpperCase" sap:label="SFC"/>
    <Property Name="ApprovedByUser" Type="Edm.String" MaxLength="128" sap:display-format="UpperCase" sap:label="ApprovedByUser"/>
    <Property Name="OrderOperation" Type="Edm.String" MaxLength="4" sap:display-format="UpperCase" sap:label="Operation" sap:quickinfo="Manufacturing Order Operation"/>
    <Property Name="OrderSuboperation" Type="Edm.String" MaxLength="4" sap:display-format="UpperCase" sap:label="Suboperation" sap:quickinfo="Manufacturing Order Suboperation"/>
    <Property Name="OrderType" Type="Edm.String" MaxLength="4" sap:display-format="UpperCase" sap:label="Order Type" sap:quickinfo="Manufacturing Order Type"/>
    <Property Name="OrderOperationInternalID" Type="Edm.String" MaxLength="8" sap:display-format="NonNegative" sap:label="Operation Internal ID" sap:quickinfo="Internal Identifier of an Operation or Activity"/>
    <Property Name="ConfirmationText" Type="Edm.String" MaxLength="40" sap:label="Confirmation Text"/>
    <Property Name="Language" Type="Edm.String" MaxLength="2" sap:label="Language Key" sap:heading="Language">
     <Documentation>
      <Summary>The language key indicates</Summary>
      <LongDescription>- the language in which texts are displayed,- the language in which you enter texts,- the language in which the system prints texts.</LongDescription>
     </Documentation>
    </Property>
    <Property Name="Material" Type="Edm.String" MaxLength="40" sap:display-format="UpperCase" sap:label="Material" sap:quickinfo="Material Number for Order">
     <Documentation>
      <Summary>Number of the material that is to be produced with this order.</Summary>
      <LongDescription/>
     </Documentation>
    </Property>
    <Property Name="OrderPlannedTotalQty" Type="Edm.Decimal" Precision="13" Scale="3" sap:unit="ProductionUnit" sap:label="Total Quantity" sap:quickinfo="Manufacturing Order Planned Total Quantity"/>
    <Property Name="ProductionUnit" Type="Edm.String" MaxLength="3" sap:label="Production Unit" sap:heading="UoM" sap:quickinfo="Production Unit of Measure" sap:semantics="unit-of-measure"/>
    <Property Name="FinalConfirmationType" Type="Edm.String" MaxLength="1" sap:display-format="UpperCase" sap:label="Final Confirmation Type"/>
    <Property Name="IsFinalConfirmation" Type="Edm.Boolean" sap:display-format="UpperCase" sap:label="Final Confirmation" sap:heading="FCf" sap:quickinfo="Activation of Final Confirmation">
     <Documentation>
      <Summary>Specifies that no further confirmations are required.</Summary>
      <LongDescription>The system assigns the 'finally confirmed' system status.</LongDescription>
     </Documentation>
    </Property>
    <Property Name="OpenReservationsIsCleared" Type="Edm.Boolean" sap:display-format="UpperCase" sap:label="Clear Open Reservs." sap:heading="COR" sap:quickinfo="Clear Open Reservations">
     <Documentation>
      <Summary>Indicator specifying that with a final confirmation, the indicator "delivery completed" is set for all open reservations that are assigned to the confirmed operation.</Summary>
      <LongDescription>The indicator is only set for the open reservations of the components that are not to be backflushed and for batch summary records for the components to be backflushed.The operation is given the system status "finally delivered" as well as the system status "finally confirmed".</LongDescription>
     </Documentation>
    </Property>
    <Property Name="IsReversed" Type="Edm.Boolean" sap:display-format="UpperCase" sap:label="Reversed" sap:heading="Rev" sap:quickinfo="Indicator: Document was reversed"/>
    <Property Name="IsReversal" Type="Edm.Boolean" sap:display-format="UpperCase" sap:label="Is a Cancellation" sap:quickinfo="Confirmation record is a Cancellation"/>
    <Property Name="APIConfHasNoGoodsMovements" Type="Edm.Boolean" sap:display-format="UpperCase" sap:label="No Goods Movement" sap:heading="NoGoodsMovement" sap:quickinfo="Confirmation: No Goods Movement via API"/>
    <Property Name="OrderConfirmationRecordType" Type="Edm.String" MaxLength="3" sap:display-format="UpperCase" sap:label="Record Type" sap:heading="Typ" sap:quickinfo="Record Type for Confirmation">
     <Documentation>
      <Summary>Specifies which PP confirmation is to be executed.</Summary>
      <LongDescription>There are confirmations for an operation time event (such as, record type B10 start of processing) or for an operation time ticket (such as, record type L40 finish).</LongDescription>
     </Documentation>
    </Property>
    <Property Name="ConfirmationEntryDate" Type="Edm.DateTime" Precision="0" sap:display-format="Date" sap:label="Entry Date" sap:quickinfo="Entry Date of Confirmation"/>
    <Property Name="ConfirmationEntryTime" Type="Edm.Time" Precision="0" sap:label="Entry Time" sap:heading="Time" sap:quickinfo="Confirmation Entry Time"/>
    <Property Name="EnteredByUser" Type="Edm.String" MaxLength="12" sap:display-format="UpperCase" sap:label="Entered by User" sap:heading="Entered by" sap:quickinfo="User who Entered the Confirmation"/>
    <Property Name="LastChangeDate" Type="Edm.DateTime" Precision="0" sap:display-format="Date" sap:label="Last Change" sap:heading="Last Chg" sap:quickinfo="Date of Last Change">
     <Documentation>
      <Summary>Date on which this rate was last changed.</Summary>
      <LongDescription/>
     </Documentation>
    </Property>
    <Property Name="LastChangedByUser" Type="Edm.String" MaxLength="12" sap:display-format="UpperCase" sap:label="Changed By" sap:quickinfo="Name of Person who Changed Object"/>
    <Property Name="ConfirmationExternalEntryDate" Type="Edm.DateTime" Precision="0" sap:display-format="Date" sap:label="Created on" sap:heading="Created" sap:quickinfo="External date of entry for confirmation">
     <Documentation>
      <Summary>Creation date of the record.</Summary>
      <LongDescription/>
     </Documentation>
    </Property>
    <Property Name="ConfirmationExternalEntryTime" Type="Edm.Time" Precision="0" sap:label="Time" sap:quickinfo="External time of entry for confirmation">
     <Documentation>
      <Summary>Time at which the document was posted and saved in the system.</Summary>
      <LongDescription/>
     </Documentation>
    </Property>
    <Property Name="EnteredByExternalUser" Type="Edm.String" MaxLength="12" sap:display-format="UpperCase" sap:label="Created by" sap:quickinfo="External creator of confirmation">
     <Documentation>
      <Summary>Name of the person, who originally entered the confirmation, if it was created in a non-SAP system or using SAP fast entry for confirmations.</Summary>
      <LongDescription/>
     </Documentation>
    </Property>
    <Property Name="ExternalSystemConfirmation" Type="Edm.Guid" sap:label="External Key" sap:heading="External key" sap:quickinfo="External Key for Confirmation (for example, from PDC System)"/>
    <Property Name="Plant" Type="Edm.String" MaxLength="4" sap:display-format="UpperCase" sap:label="Plant" sap:heading="Plnt">
     <Documentation>
      <Summary>Key uniquely identifying a plant.</Summary>
      <LongDescription/>
     </Documentation>
    </Property>
    <Property Name="WorkCenterTypeCode" Type="Edm.String" MaxLength="2" sap:display-format="UpperCase" sap:label="Resource Object Type" sap:heading="Typ" sap:quickinfo="Object Type of the Resource"/>
    <Property Name="WorkCenter" Type="Edm.String" MaxLength="8" sap:display-format="UpperCase" sap:label="Work Center"/>
    <Property Name="Personnel" Type="Edm.String" MaxLength="8" sap:display-format="NonNegative" sap:label="Personnel" sap:quickinfo="Personnel Number"/>
    <Property Name="TimeRecording" Type="Edm.String" MaxLength="8" sap:display-format="NonNegative" sap:label="Time Recording" sap:quickinfo="Time Recording ID"/>
    <Property Name="EmployeeWageType" Type="Edm.String" MaxLength="4" sap:display-format="UpperCase" sap:label="Employee Wage Type"/>
    <Property Name="EmployeeWageGroup" Type="Edm.String" MaxLength="3" sap:display-format="UpperCase" sap:label="Employee Wage Group"/>
    <Property Name="BreakDurationUnit" Type="Edm.String" MaxLength="3" sap:label="Break Time Unit" sap:heading="Unit" sap:quickinfo="Unit for a Break Time" sap:semantics="unit-of-measure"/>
    <Property Name="BreakDurationUnitISOCode" Type="Edm.String" MaxLength="3" sap:display-format="UpperCase" sap:label="ISO code" sap:heading="ISO" sap:quickinfo="ISO code for unit of measurement">
     <Documentation>
      <Summary>ISO code for measurement units. An ISO code can be assigned to several internal measurement units of a dimension.</Summary>
      <LongDescription>The ISO code is important for EDI. It is used to convert the internal SAP measurement units into standard measurement units. Data exchange via EDI requires internal measurement units to be converted into standard measurement units.A list of the current internationally agreed ISO codes can be ordered from the UN commission responsible (WP.4 Trade Facilitation Recommendations, Recommendation 20):UN Economic Commission for EuropeInformation OfficePalais des Nations1211 GenevaSwitzerlande-mail: info.ece@unece.orgor viewed directly on the Internet:http://www.unece.org/cefact/codesfortrade/codes_index.htmFor more information, see SAP Note 69063.</LongDescription>
     </Documentation>
    </Property>
    <Property Name="BreakDurationUnitSAPCode" Type="Edm.String" MaxLength="3" sap:label="Internal SAP Code" sap:quickinfo="Unit of Measurement, Internal SAP Code (No Conversion)"/>
    <Property Name="ConfirmedBreakDuration" Type="Edm.Decimal" Precision="9" Scale="3" sap:label="Confirmed Break Time" sap:heading="Break Time">
     <Documentation>
      <Summary>Specified the confirmed break time for the operation.</Summary>
      <LongDescription/>
     </Documentation>
    </Property>
    <Property Name="EmployeeSuitability" Type="Edm.String" MaxLength="2" sap:display-format="UpperCase" sap:label="Employee Suitability"/>
    <Property Name="NumberOfEmployees" Type="Edm.Decimal" Precision="5" Scale="2" sap:label="Number of Employees"/>
    <Property Name="PostingDate" Type="Edm.DateTime" Precision="0" sap:display-format="Date" sap:label="Posting Date"/>
    <Property Name="ConfirmedExecutionStartDate" Type="Edm.DateTime" Precision="0" sap:display-format="Date" sap:label="Confirmed Execution Start Date" sap:quickinfo="Confirmed Start Date of Execution"/>
    <Property Name="ConfirmedExecutionStartTime" Type="Edm.Time" Precision="0" sap:label="Confirmed Execution Start Time" sap:quickinfo="Confirmed Start Time of Execution"/>
    <Property Name="ConfirmedSetupEndDate" Type="Edm.DateTime" Precision="0" sap:display-format="Date" sap:label="Confirmed Setup End Date" sap:quickinfo="Confirmed End Date of Setup"/>
    <Property Name="ConfirmedSetupEndTime" Type="Edm.Time" Precision="0" sap:label="Confirmed Setup End Time" sap:quickinfo="Confirmed End Time of Setup"/>
    <Property Name="ConfirmedProcessingStartDate" Type="Edm.DateTime" Precision="0" sap:display-format="Date" sap:label="Confirmed Processing Start Date" sap:quickinfo="Confirmed Start Date of Processing"/>
    <Property Name="ConfirmedProcessingStartTime" Type="Edm.Time" Precision="0" sap:label="Confirmed Processing Start Time" sap:quickinfo="Confirmed Start Time of Processing"/>
    <Property Name="ConfirmedProcessingEndDate" Type="Edm.DateTime" Precision="0" sap:display-format="Date" sap:label="Confirmed Processing End Date" sap:quickinfo="Confirmed End Date of Processing"/>
    <Property Name="ConfirmedProcessingEndTime" Type="Edm.Time" Precision="0" sap:label="Confirmed Processing End Time" sap:quickinfo="Confirmed End Time of Processing"/>
    <Property Name="ConfirmedTeardownStartDate" Type="Edm.DateTime" Precision="0" sap:display-format="Date" sap:label="Confirmed Teardown Start Date" sap:quickinfo="Confirmed Start Date of Teardown"/>
    <Property Name="ConfirmedTeardownStartTime" Type="Edm.Time" Precision="0" sap:label="Confirmed Teardown Start Time" sap:quickinfo="Confirmed Start Time of Teardown"/>
    <Property Name="ConfirmedExecutionEndDate" Type="Edm.DateTime" Precision="0" sap:display-format="Date" sap:label="Confirmed Execution End Date" sap:quickinfo="Confirmed End Date of Execution"/>
    <Property Name="ConfirmedExecutionEndTime" Type="Edm.Time" Precision="0" sap:label="Confirmed Execution End Time" sap:quickinfo="Confirmed End Time of Execution"/>
    <Property Name="ConfirmationUnit" Type="Edm.String" MaxLength="3" sap:label="Confirmation Unit" sap:heading="Un" sap:quickinfo="Confirmation Unit of Measure" sap:semantics="unit-of-measure">
     <Documentation>
      <Summary>Unit in which the yield/scrap is confirmed.</Summary>
      <LongDescription/>
     </Documentation>
    </Property>
