ilities.ReadRestrictions"><Record><PropertyValue Property="Description" String="Retrieves all technical resource data."/><PropertyValue Property="LongDescription" String="Retrieves details of technical resource for all subscription related items in the system. The details include technical resource type code, ID, and so on."/><PropertyValue Property="ReadByKeyRestrictions"><Record><PropertyValue Property="Description" String="Retrieves a specific technical resource."/><PropertyValue Property="LongDescription" String="Retrieves data of a specific technical resource, which the consumer specifies by passing the solution quotation ID, the subscription related item number, and technical resource type code."/></Record></PropertyValue></Record></Annotation></Annotations><Annotations Target="API_BUS_SOLUTION_QUOTATION_SRV.API_BUS_SOLUTION_QUOTATION_SRV_Entities/A_BuSoQtanSrvcContrItmRefObj" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Capabilities.ReadRestrictions"><Record><PropertyValue Property="Description" String="Retrieves all object list data."/><PropertyValue Property="LongDescription" String="Retrieves the object list details of all service contract items in the system. The details include product ID and equipment ID."/><PropertyValue Property="ReadByKeyRestrictions"><Record><PropertyValue Property="Description" String="Retrieves a specific object list."/><PropertyValue Property="LongDescription" String="Retrieves a specific object list of a specific service contract item, which the consumer specifies by passing the solution quotation ID, service contract item number, product ID, and equipment ID."/></Record></PropertyValue></Record></Annotation></Annotations><Annotations Target="API_BUS_SOLUTION_QUOTATION_SRV.API_BUS_SOLUTION_QUOTATION_SRV_Entities/A_BusSolnQtanItmPriceElement" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Capabilities.ReadRestrictions"><Record><PropertyValue Property="Description" String="Retrieves all item