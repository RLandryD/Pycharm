            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="NOT_APPLICABLE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Not Applicable</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A statement that an
                  affirmative or negative response is not required for the
                  attribute.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="TRUE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">True</xsd:documentation>
