<?xml version="1.0" encoding="UTF-8"?>
<!--
  PIPELINE STEP 3: Interface Separation iFlow
  Package  : 1_Figaf_JiraAPI_Transition_Integration
  Purpose  : Routes to the correct scenario-specific iFlow
             based on SAP_InterfaceName header set by Receiver Determination.
  Internal : ProcessDirect address /pd/InterfaceSeparation_1_Figaf_JiraAPI_Tran
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Interface_Separation_1_Figaf_JiraAPI_Tran"
             name="Interface_Separation_1_Figaf_JiraAPI_Tran">
  <process id="IfaceSep_1_Figaf_JiraAPI_Tran_process" ifl:type="IntegrationFlow">

    <startEvent id="Start_IS" name="From Receiver Determination">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/pd/InterfaceSeparation_1_Figaf_JiraAPI_Tran</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>

    <!-- ROUTER: Branch to scenario-specific iFlow -->
    <exclusiveGateway id="Router_1" name="Route by Interface Name"/>

    <sequenceFlow id="route_0" sourceRef="Router_1"
      targetRef="Call_Update_Azure_Issues_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Update Azure Issues' -->
    </sequenceFlow>
    <serviceTask id="Call_Update_Azure_Issues_1"
      name="→ Update Azure Issues" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Update_Azure_Issues</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_1" sourceRef="Router_1"
      targetRef="Call_Update_Jira_Issues_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Update Jira Issues' -->
    </sequenceFlow>
    <serviceTask id="Call_Update_Jira_Issues_1"
      name="→ Update Jira Issues" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Update_Jira_Issues</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_IS"/>
    <sequenceFlow sourceRef="Start_IS" targetRef="Router_1"/>
  </process>
</definitions>