 Details (Equipment). To specify transportation details relating to the equipment used by the carrier</xsd:documentation></xsd:annotation><xsd:complexType><xsd:sequence><xsd:element minOccurs="0" name="D_40"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d14bb961ff311e183170026b9aa16ff</xsd:appinfo><xsd:documentation>TD301| Equipment Description Code. NOTES: E0110 - Only one of TD301 or TD310 may be present.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_206"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d14bb971ff311e1c10c0026b9aa16ff</xsd:appinfo><xsd:documentation>TD302| Equipment Initial. NOTES: C0203 - If TD302 is present, then TD303 is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="4"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_207"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d14bb981ff311e1964f0026b9aa16ff</xsd:appinfo><xsd:documentation>TD303| Equipment Number</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="10"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_187"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d14bb991ff311e1aef50026b9aa16ff</xsd:appinfo><xsd:documentation>TD304| Weight Qualifier. NOTES: C0405 - If TD304 is present, then TD305 is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_81"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d14bb9a1ff311e1bfb40026b9aa16ff</xsd:appinfo><xsd:documentation>TD305| Weight. NOTES: P0506 - If either TD305 or TD306 is present, then the other is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="10"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_355"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d14bb9b1ff311e1aefc0026b9aa16ff</xsd:appinfo><xsd:documentation>TD306| Unit or Basis for Measurement Code</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_102"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d14bb9c1ff311e1a5150026b9aa16ff</xsd:appinfo><xsd:documentation>TD307| Ownership Code</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="1"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_407"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d14bb9d1ff311e199710026b9aa16ff</xsd:appinfo><xsd:documentation>TD308| Seal Status Code</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_225"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d14bb9e1ff311e1c7770026b9aa16ff</xsd:appinfo><xsd:documentation>TD309| Seal Number</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="2"/><xsd:maxLength value="15"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_24"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d14bb9f1ff311e1902a0026b9aa16ff</xsd:appinfo><xsd:documentation>TD310| Equipment Type</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="4"/></xsd:restriction></xsd:simpleType></xsd:element></xsd:sequence></xsd:complexType></xsd:element><xsd:element maxOccurs="5" minOccurs="0" name="S_TD4"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d14bba61ff311e1998c0026b9aa16ff</xsd:appinfo><xsd:documentation>Carrier Details (Special Handling, or Hazardous Materials, or Both). To specify transportation special handling requirements, or hazardous materials information, or both</xsd:documentation></xsd:annotation><xsd:complexType><xsd:sequence><xsd:element minOccurs="0" name="D_152"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d14bba11ff311e1bb870026b9aa16ff</xsd:appinfo><xsd:documentation>TD401| Special Handling Code. NOTES: R010204 - At least one of TD401, TD402 or TD404 is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="2"/><xsd:maxLength value="3"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_208"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d14bba21ff311e1c0eb0026b9aa16ff</xsd:appinfo><xsd:documentation>TD402| Hazardous Material Code Qualifier. NOTES: C0203 - If TD402 is present, then TD403 is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="1"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_209"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d14bba31ff311e1cd3b0026b9aa16ff</xsd:appinfo><xsd:documentation>TD403| Hazardous Material Class Code</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="4"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_352"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d14bba41ff311e1cae50026b9aa16ff</xsd:appinfo><xsd:documentation>TD404| Description</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="80"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_1073"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d14bba51ff311e1be140026b9aa16ff</xsd:appinfo><xsd:documentation>TD405| Yes/No Condition or Response Code. NOTES: TD405 identifies if a Material Safety Data Sheet (MSDS) exists for this product. A "Y" indicates an MSDS exists for this product; an "N" indicates an MSDS does not exist for this product.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="1"/></xsd:restriction></xsd:simpleType></xsd:element></xsd:sequence></xsd:complexType></xsd:element><xsd:element maxOccurs="200" minOccurs="0" name="S_PKG"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d172f8f1ff311e1a0fa0026b9aa16ff</xsd:appinfo><xsd:documentation>Marking, Packaging, Loading. To describe marking, packaging, loading, and unloading requirements</xsd:documentation></xsd:annotation><xsd:complexType><xsd:sequence><xsd:element minOccurs="0" name="D_349"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d14bba71ff311e1ab870026b9aa16ff</xsd:appinfo><xsd:documentation>PKG01| Item Description Type. NOTES: If PKG01 equals "F", then PKG05 is used. If PKG01 equals "S", then PKG04 is used. If PKG01 equals "X", then both PKG04 and PKG05 are used.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="1"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_753"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d14bba81ff311e1b0800026b9aa16ff</xsd:appinfo><xsd:documentation>PKG02| Packaging Characteristic Code</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="5"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_559"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d14bba91ff311e1b91b0026b9aa16ff</xsd:appinfo><xsd:documentation>PKG03| Agency Qualifier Code. NOTES: Use PKG03 to indicate the organization that publishes the code list being referred to.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_754"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d14bbaa1ff311e1a9b90026b9aa16ff</xsd:appinfo><xsd:documentation>PKG04| Packaging Description Code. NOTES: R040506 - At least one of PKG04, PKG05 or PKG06 is required. C0403 - If PKG04 is present, then PKG03 is required. PKG04 should be used for industry-specific packaging description codes.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="7"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_352"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d172f8d1ff311e1b1370026b9aa16ff</xsd:appinfo><xsd:documentation>PKG05| Description. NOTES: C0501 - If PKG05 is present, then PKG01 is required. Special marking or tagging data can be given in PKG05 (description).</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="80"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_400"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d172f8e1ff311e198b60026b9aa16ff</xsd:appinfo><xsd:documentation>PKG06| Unit Load Option Code</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element></xsd:sequence></xsd:complexType></xsd:element><xsd:element maxOccurs="unbounded" minOccurs="0" name="L_LDT_2"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d172fbf1ff311e1b2e70026b9aa16ff</xsd:appinfo></xsd:annotation><xsd:complexType><xsd:sequence><xsd:element minOccurs="0" name="S_LDT"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d172f941ff311e18eb20026b9aa16ff</xsd:appinfo><xsd:documentation>Lead Time. To specify lead time for availability of products and services</xsd:documentation></xsd:annotation><xsd:complexType><xsd:sequence><xsd:element name="D_345"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d172f901ff311e1a6d20026b9aa16ff</xsd:appinfo><xsd:documentation>LDT01| Lead Time Code</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element name="D_380"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d172f911ff311e1c7fa0026b9aa16ff</xsd:appinfo><xsd:documentation>LDT02| Quantity. NOTES: LDT02 is the quantity of unit of time periods.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="15"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element name="D_344"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d172f921ff311e18e110026b9aa16ff</xsd:appinfo><xsd:documentation>LDT03| Unit of Time Period or Interval</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_373"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d172f931ff311e1bcdf0026b9aa16ff</xsd:appinfo><xsd:documentation>LDT04| Date. NOTES: LDT04 is the effective date of lead time information.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="8"/></xsd:restriction></xsd:simpleType></xsd:element></xsd:sequence></xsd:complexType></xsd:element><xsd:element maxOccurs="10" minOccurs="0" name="S_MAN"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d172f9b1ff311e1b97e0026b9aa16ff</xsd:appinfo><xsd:documentation>Marks and Numbers. To indicate identifying marks and numbers for shipping containers</xsd:documentation></xsd:annotation><xsd:complexType><xsd:sequence><xsd:element name="D_88"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d172f951ff311e1ad460026b9aa16ff</xsd:appinfo><xsd:documentation>MAN01| Marks and Numbers Qualifier. NOTES: MAN01/MAN02 and MAN04/MAN05 may be used to identify two different marks and numbers assigned to the same physical container. When MAN01 contains code "UC" (U.P.C. Shipping Container Code) and MAN05/MAN06 ...</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element name="D_87"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d172f961ff311e180260026b9aa16ff</xsd:appinfo><xsd:documentation>MAN02| Marks and Numbers. NOTES: When both MAN02 and MAN03 are used, MAN02 is the starting number of a sequential range and MAN03 is the ending number of that range.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="48"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_87_2"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d172f971ff311e193e10026b9aa16ff</xsd:appinfo><xsd:documentation>MAN03| Marks and Numbers. NOTES: MAN03 and/or MAN06 are only used when sending a range(s) of ID numbers. When both MAN02/MAN03 and MAN05/MAN06 are used to send ranges of ID numbers, the integrity of the two ID numbers must be maintained.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="48"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_88_2"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d172f981ff311e186b90026b9aa16ff</xsd:appinfo><xsd:documentation>MAN04| Marks and Numbers Qualifier. NOTES: P0405 - If either MAN04 or MAN05 is present, then the other is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_87_3"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d172f991ff311e1aea30026b9aa16ff</xsd:appinfo><xsd:documentation>MAN05| Marks and Numbers. NOTES: When both MAN05 and MAN06 are used, MAN05 is the starting number of a sequential range, and MAN06 is the ending number of that range.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="48"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_87_4"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d172f9a1ff311e186450026b9aa16ff</xsd:appinfo><xsd:documentation>MAN06| Marks and Numbers. NOTES: C0605 - If MAN06 is present, then MAN05 is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="48"/></xsd:restriction></xsd:simpleType></xsd:element></xsd:sequence></xsd:complexType></xsd:element><xsd:element maxOccurs="5" minOccurs="0" name="S_QTY"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d172faf1ff311e180870026b9aa16ff</xsd:appinfo><xsd:documentation>Quantity. To specify quantity information</xsd:documentation></xsd:annotation><xsd:complexType><xsd:sequence><xsd:element name="D_673"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d172f9