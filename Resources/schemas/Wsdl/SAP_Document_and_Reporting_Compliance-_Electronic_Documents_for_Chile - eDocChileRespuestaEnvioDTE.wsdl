							<xs:documentation>Pago a Cuenta Corriente</xs:documentation>
						</xs:annotation>
					</xs:enumeration>
					<xs:enumeration value="TC">
						<xs:annotation>
							<xs:documentation>Tarjeta de Credito</xs:documentation>
