			<wsdl:input>
				<soap:body use="literal" />
			</wsdl:input>
			<wsdl:output>
				<soap:body use="literal" />
			</wsdl:output>
		</wsdl:operation>
	</wsdl:binding>
	<wsdl:service name="eDocChileSendMail_v1">
		<wsdl:port binding="tns:eDocChileSendMail_v1SOAP" name="eDocChileSendMail_v1SOAP">
