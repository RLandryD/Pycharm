<xsd:documentation>The name of the project.  Required unless the project is being removed.</xsd:documentation>
<xsd:appinfo>
<wd:Validation>
<wd:Validation_Message>Internal Project must be specified unless the Internal Project Experience is being removed.</wd:Validation_Message>
</wd:Validation>
</xsd:appinfo>
</xsd:annotation>
</xsd:element>
