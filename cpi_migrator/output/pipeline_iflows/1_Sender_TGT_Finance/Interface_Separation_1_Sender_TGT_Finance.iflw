        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Chile_Sign_Sales_and</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_3" sourceRef="Router_1"
      targetRef="Call_Chile_Sign_DTE_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Chile Sign DTE' -->
    </sequenceFlow>
