    <Property Name="CatalogType" Type="Edm.String" Nullable="false" MaxLength="1" sap:label="Catalog Type"/>
    <Property Name="Language" Type="Edm.String" Nullable="false" MaxLength="2" sap:label="Language Key"/>
    <Property Name="InspectionCatalogCodeTxt" Type="Edm.String" MaxLength="40" sap:label="Short Text for Code"/>
