   <xsd:complexType name="PaymentMethodType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Provides information on the means of payment.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
