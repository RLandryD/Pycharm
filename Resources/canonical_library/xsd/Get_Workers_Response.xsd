</xsd:annotation>
</xsd:element>
<xsd:element maxOccurs="1" minOccurs="0" name="Leave_Start_Date" type="xsd:date">
<xsd:annotation>
<xsd:documentation>Current leave event Start Date.</xsd:documentation>
</xsd:annotation>
</xsd:element>
<xsd:element maxOccurs="1" minOccurs="0" name="Estimated_Leave_End_Date" type="xsd:date">
