   <xsd:complexType name="TradeItemInventoryEventType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information specifying an inventory activity of one or more trade items (of the same type) at a specific sub-location at a specific point in time.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">A trade item is any item (product or service) upon which there is a need to retrieve pre-defined information and that may be priced, or ordered, or invoiced at any point in any supply chain.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">Provides the GTIN as the unique identifier for the item and optionally additional formats of non GTIN identifiers for the item.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="gtin" minOccurs="0" type="GTINType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gtin</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="additionalTradeItemIdentification" minOccurs="0" maxOccurs="unbounded"
            type="AdditionalTradeItemIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Additional Trade Item Identification</xsd:documentation>
