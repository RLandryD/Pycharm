      <xs:element type="xs:string" name="Email"/>
      <xs:element type="xs:string" name="FirstName"/>
      <xs:element type="xs:string" name="LastName"/>
      <xs:element type="xs:string" name="OwnerName"/>
      <xs:element type="xs:string" name="PrimaryIndustry"/>
      <xs:element type="xs:string" name="Province"/>
      <xs:element type="xs:byte" name="QuoteId"/>
      <xs:element type="xs:string" name="StateAbbreviation"/>
      <xs:element type="xs:string" name="TerritoryName"/>
      <xs:element type="xs:string" name="Title"/>
      <xs:element type="xs:short" name="UserId"/>
