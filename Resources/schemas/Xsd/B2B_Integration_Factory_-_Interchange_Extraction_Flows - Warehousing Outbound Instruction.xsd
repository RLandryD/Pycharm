   <xsd:complexType name="LeviedDutyFeeTaxType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">A duty, fee or tax charged in a particular trade transaction.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="dutyFeeTaxAccountingCurrency" minOccurs="0" type="CurrencyCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Duty Fee Tax Accounting Currency</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The monetary unit used in the calculation of the duty, tax or fee.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dutyFeeTaxAgencyName" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Duty Fee Tax Agency Name</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Agency responsible for the collection of this duty, fee or tax.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Department of Tax</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dutyFeeTaxAmount" minOccurs="0" type="AmountType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Duty Fee Tax Amount</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 25200</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The monetary amount being charged for this duty, fee or tax.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dutyFeeTaxAmountInAccountingCurrency" minOccurs="0" type="AmountType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Duty Fee Tax Amount In Accounting Currency</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 200</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The monetary amount being charged for this duty, fee or tax, expressed in the accounting currency.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dutyFeeTaxBasisAmount" minOccurs="0" type="AmountType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Duty Fee Tax Basis Amount</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 120000</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The monetary amount on which the calculation of the charged amount is based.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dutyFeeTaxBasisAmountInAccountingCurrency" minOccurs="0"
            type="AmountType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Duty Fee Tax Basis Amount In Accounting Currency</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 120000</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The monetary amount on which the calculation of the charged amount is based, expressed in the accounting currency.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dutyFeeTaxCategoryCode" minOccurs="0" type="TaxCategoryCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Duty Fee Tax Category Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the applicable charge category for this duty, fee or tax. For example low, high, exempt.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dutyFeeTaxDescription" minOccurs="0" type="Description80Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Duty Fee Tax Description</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Additional tax info</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Textual description of this duty, fee or tax. For example, "Taxes sur les supports audio" or WEEE for "Waste Electrical and Electronic Equipment".</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dutyFeeTaxExemptionDescription" minOccurs="0" type="Description80Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Duty Fee Tax Exemption Description</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Additional tax Exemption info</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Textual description of the reason for being exempt for this duty, fee or tax.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dutyFeeTaxExemptionReason" minOccurs="0"
            type="DutyFeeTaxExemptionReasonCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Duty Fee Tax Exemption Reason</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dutyFeeTaxPercentage" minOccurs="0" type="xsd:float">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Duty Fee Tax Percentage</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Percentage allowing calculation of the amount being charged.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 21</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dutyFeeTaxPointDate" minOccurs="0" type="xsd:date">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Duty Fee Tax Point Date</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date at which a tax becomes applicable.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2011-12-15T11:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dutyFeeTaxTypeCode" minOccurs="0" type="DutyFeeTaxTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Duty Fee Tax Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the type of duty, fee or tax.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="extension" minOccurs="0" type="ExtensionType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Extension</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Extension point for inclusion of additional information.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="LineItemActionCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:LineItemActionCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: NOT_AMENDED</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a line item action. Allowed code values are specified in GS1 Code List LineItemActionCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="LineItemActionCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="LocationInformationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Provides the contact, name and address, and GLN of the location.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="partyIdentification" minOccurs="0" type="Ecom_PartyIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Party Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Provides the location's Global Location Number and additional identifications.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="address" type="AddressType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Address</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Provides the location's address.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="contactInformation" minOccurs="0" maxOccurs="unbounded"
            type="ContactType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Contact Information</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Provides the contact information for a location.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="LocationScopeParameterTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:LocationScopeParameterTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: RECEIVING_LOCATION</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a location scope parameter type. Allowed code values are specified in GS1 Code List LocationParameterScopeTypeCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="LocationScopeParameterTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="LocationScopeTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:LocationScopeTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: CITY</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a location scope type. Allowed code values are specified in GS1 Code List LocationScopeTypeCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="LocationScopeTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="LogisticEventType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">A planned or actual occurrence of a physical goods movement at a specific time and location.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="logisticEventTypeCode" minOccurs="0" type="LogisticEventTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Logistic Event Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the type of logistic event. Example: Customs clearance.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="logisticEventDuration" minOccurs="0" type="TimeMeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Logistic Event Duration</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 3</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Measurement value specifying the duration of the logistic event.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="logisticLocation" minOccurs="0" type="LogisticLocationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Logistic Location</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The location where the logistic event occurs.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="logisticEventPeriod" minOccurs="0" type="DateTimeRangeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Logistic Event Period</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The timeframe during which the logistic event occurs.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="logisticEventDateTime" minOccurs="0" type="DateOptionalTimeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Logistic Event Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The date and time on which the logistic event occurs.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="LogisticEventTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:LogisticEventTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: TERMINAL_ARRIVAL</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a logistic event type. Allowed code values are specified in GS1 Code List LogisticEventTypeCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="LogisticEventTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="LogisticLocationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Place where a physical goods movement is or will be carried out.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="unLocationCode" minOccurs="0" type="UNLocationCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Un Location Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">UN/LOCODE is a geographic coding scheme maintained by UN/ECE for locations used in trade and transport with functions such as seaports, rail and road terminals, airports, post offices and border crossing points.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found at the  UN/ECE website: http://www.unece.org/tradewelcome/un-centre-for-trade-facilitation-and-e-business-uncefact/outputs/cefactrecommendationsrec-index/list-of-trade-facilitation-recommendations-n-16-to-20.html</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="gln" minOccurs="0" type="GLNType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gln</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The GS1 global location number (GLN) of this logistic location.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="additionalLocationIdentification" minOccurs="0" maxOccurs="unbounded"
            type="IdentifierType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Additional Location Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: ABCDG084572</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identification of a location by use of a code other than the Global Location Number.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sublocationIdentification" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sublocation Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Text further specifying the exact logistic location. For example: dock door, department, building.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: ABCDG084572-CDE12</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="locationName" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Location Name</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The name of this logistic location.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Warehouse C2</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="locationSpecificInstructions" minOccurs="0" type="Description200Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Location Specific Instructions</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Please be on time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Instructions related to the pick-up or drop-off of goods at this location.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="utcOffset" minOccurs="0" type="xsd:float">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Utc Offset</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Numeric value specifying the time zone of the location as offset from the Coordinated Universal Time (UTC).</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: -2</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="address" minOccurs="0" type="AddressType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Address</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Address details of this logistic location.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="contact" minOccurs="0" maxOccurs="unbounded" type="ContactType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Contact</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Person or department that can be contacted at this logistic location.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="regularOperatingHours" minOccurs="0" maxOccurs="unbounded"
            type="OperatingHoursType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Regular Operating Hours</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="specialOperatingHours" minOccurs="0" maxOccurs="unbounded"
            type="SpecialOperatingHoursType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Special Operating Hours</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The period during which the location is operational on special days, such as holidays.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="LogisticServiceReferenceType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">References to GS1 messages related to logistic services</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">Information identifying a piece of information, such as an object or document.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="entityIdentification">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Entity Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The unique identifier of the piece of information, such as the object id or the document id.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: ABCDE00001</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="contentOwner" minOccurs="0" type="Ecom_PartyIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Content Owner</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="creationDateTime" minOccurs="0" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Creation Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date and time of creation of the referenced document.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15T11:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="revisionNumber" minOccurs="0" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Revision Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number to be used for identification and referencing of subsequent updates to a business document.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="lineItemNumber" minOccurs="0" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Line Item Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number specifying a line in the referenced document.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="referencedDocumentUrl" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Referenced Document Url</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An URI pointing to the on-line location where the referenced document is stored.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: http://www.company/documentABC</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="logisticServiceReferenceTypeCode"
            type="LogisticServiceReferenceTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Logistic Service Reference Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: TRANSPORT_INSTRUCTION</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:LogisticServiceReferenceTypeCode</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="LogisticServiceReferenceTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: TRANSPORT_INSTRUCTION</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:LogisticServiceReferenceTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">List of GS1 messages related to logistic services. Allowed code values are specified in GS1 Code List LogisticServiceReferenceTypeCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="LogisticServiceReferenceTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="LogisticServiceRequirementCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:LogisticServiceRequirementCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a logistic service requirement. Allowed code values are specified in GS1 Code List LogisticServiceRequirementCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="LogisticServiceRequirementCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="LogisticServiceType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Service requested from a logistic services provider.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="logisticServiceRequirementCode"
            type="LogisticServiceRequirementCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Logistic Service Requirement Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the type of service required.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="cashOnDeliveryAmount" minOccurs="0" type="AmountType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Cash On Delivery Amount</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 12000</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Monetary amount applicable in case the logistic services provider is requested collect the payment for the delivered goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="insuranceValue" minOccurs="0" type="AmountType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Insurance Value</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 12000</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Monetary amount applicable in case the logistic service provider is requested to arrange the insurance of the delivered goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="logisticServiceChargeAmount" minOccurs="0" type="AmountType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Logistic Service Charge Amount</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 500</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Monetary amount to be paid to the logistic service provider as compensation for the provided service.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="cashOnDeliveryPayer" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Cash On Delivery Payer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifies the party who will carry out the payment of the cash-on-delivery invoice.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="cashOnDeliveryBillTo" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Cash On Delivery Bill To</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifies the party who receives the cash-on-delivery invoice. Synonym: Invoicee.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="LogisticUnitMeasurementType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information specifying the physical measurement and the physical dimensions of a specific logistic unit.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="dimension" minOccurs="0" type="DimensionType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dimension</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information specifying the physical measurement and the physical dimensions of a specific logistic unit.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="unitMeasurement" minOccurs="0" maxOccurs="unbounded"
            type="UnitMeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Unit Measurement</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information specifying the weight or volume of the logistic unit.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="LogisticUnitsType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information specifying the physical appearance, the physical dimensions as well as the contents of a specific logistic unit.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="levelIdentification" minOccurs="0" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Level Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Hierarchical structure level identifier (Sequential numbering recommended).</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="parentLevelIdentification" minOccurs="0" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Parent Level Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Hierarchical structure parent identifier.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="packageTypeCode" minOccurs="0" type="PackageTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Package Type Code</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="quantityOfLogisticUnits" minOccurs="0" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Quantity Of Logistic Units</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number of packages at the current level.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 5</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="childPackageTypeCode" minOccurs="0" type="PackageTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Child Package Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the type of the included (lower level) package.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="quantityOfChildren" minOccurs="0" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Quantity Of Children</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number of packages at the next lower level.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 6</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="logisticUnitIdentification" minOccurs="0"
            type="Ecom_LogisticUnitIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Logistic Unit Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The globally unique identification attached to the logistic unit, used for logistical and traceability purposes.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="logisticUnitMeasurement" minOccurs="0"
            type="LogisticUnitMeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Logistic Unit Measurement</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The physical dimensions of the logistic unit.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="returnablePackaging" minOccurs="0" maxOccurs="unbounded"
            type="ReturnablePackagingType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Returnable Packaging</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Details on the returnable packaging included in the logistic units.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="individualAssetIdentification" minOccurs="0" maxOccurs="unbounded"
            type="Ecom_IndividualAssetIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Individual Asset Identification</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="carrierTrackAndTraceInformation" minOccurs="0"
            type="CarrierTrackAndTraceInformationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Carrier Track And Trace Information</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="avpList" minOccurs="0" type="Ecom_AttributeValuePairListType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Avp List</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="LogisticUnitType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition"> A logistic unit is a unit of any composition made up for transport and or storage which has to be managed throughout the supply chain.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">The globally unique identification attached to a shipping container or shipping package and used for logistical and traceability purposes.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="sscc" type="SSCCType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sscc</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Serial Shipping Container Code (SSCC),the GS1 key used for the identification of logistic units.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="additionalLogisticUnitIdentification" minOccurs="0"
            maxOccurs="unbounded" type="AdditionalLogisticUnitIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Additional Logistic Unit Identification</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="parentLogisticUnitId" minOccurs="0"
            type="Ecom_LogisticUnitIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Parent Logistic Unit Id</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Reference to the logistic unit that contains this logistic unit.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="grossWeight" minOccurs="0" type="MeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gross Weight</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1500</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The weight of the logistic unit including packaging.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="packageLevelCode" minOccurs="0" type="PackageLevelCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Package Level Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the hierarchical level of this logistical unit within a consignment or shipment.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="packageTypeCode" minOccurs="0" type="PackageTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Package Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the type of logistic unit based on its primary packaging.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="tradeItemQuantity" minOccurs="0" type="QuantityType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Trade Item Quantity</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 520</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The number of trade items contained in the logistic unit.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="packagingMarking" minOccurs="0" maxOccurs="unbounded"
            type="PackagingMarkingType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Packaging Marking</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Details on the markings present on the packaging of the logistic unit.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="referencedTransportEquipment" minOccurs="0"
            type="TransportEquipmentType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Referenced Transport Equipment</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Reference to the transport equipment that contains this logistic unit.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="returnablePackaging" minOccurs="0" maxOccurs="unbounded"
            type="ReturnablePackagingType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Returnable Packaging</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Details on the returnable packaging included in the logistic unit.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dimension" minOccurs="0" type="DimensionType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dimension</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The depth, height and width of the logistic unit.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="unitMeasurement" minOccurs="0" maxOccurs="unbounded"
            type="UnitMeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Unit Measurement</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information specifying the weight or volume of the logistic unit.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="LowerLevelTradeItemType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Identification and quantity of trade items contained in the current trade item</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">Provides the GTIN as the unique identifier for the item and optionally additional formats of non GTIN identifiers for the item.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="gtin" minOccurs="0" type="GTINType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gtin</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="additionalTradeItemIdentification" minOccurs="0" maxOccurs="unbounded"
            type="AdditionalTradeItemIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Additional Trade Item Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Alternative means to the Global Trade Item Number to identify a trade item.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="quantityOfLowerLevelTradeItem" type="xsd:nonNegativeInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Quantity Of Lower Level Trade Item</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number of trade items contained in the current trade item</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 6</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="MarginSchemeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:MarginSchemeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: WORKS_OF_ART</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a margin scheme. Allowed code values are specified in GS1 Code List MarginSchemeCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="MarginSchemeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="MaterialTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:MaterialTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: ALUMINIUM</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a type of material. Allowed code values are specified in GS1 Code List MaterialTypeCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="MaterialTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="MeasurementTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:MeasurementTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: NET_VOLUME</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a type of measurement. Allowed code values are specified in GS1 Code List MeasurementTypeCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="MeasurementTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="ObservationTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:ObservationTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: TEMPERATURE</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying an observation type. Allowed code values are specified in GS1 Code List ObservationTypeCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="ObservationTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="OperatingHoursType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">The period during which a business or facility is operational on a weekday.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="dayOfTheWeekCode" type="DayOfTheWeekEnumerationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Day Of The Week Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the day of the week to which the operating hours apply.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="isOperational" type="xsd:boolean">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Is Operational</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Indicator specifying whether or not the business or facility is operational on the specified day.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: true</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="closingTime" minOccurs="0" type="xsd:time">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Closing Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Time on which the business or facility closes on the specified day.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 22:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="openingTime" minOccurs="0" type="xsd:time">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Opening Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Time on which the business or facility opens on the specified day.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 06:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="OrderEntryTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the entry channel of customer orders. Allowed code values are specified in GS1 Code List OrderEntryTypeCode. Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:OrderEntryTypeCode. POS</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">Generic code data type not linked to a specific code list. Besides the code value the GS1 code data type allows to specify the code list version.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence/>
   </xsd:complexType>
   <xsd:complexType name="OrderInstructionCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:OrderInstructionCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: NO_PARTIAL_DELIVERY_ALLOWED</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying an order instruction. Allowed code values are specified in GS1 Code List OrderInstructionCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="OrderInstructionCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="OrderLogisticalDateInformationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Contains the choices to select various types of dates or date ranges associated to the order.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="requestedDeliveryDateRange" minOccurs="0" type="DateTimeRangeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Requested Delivery Date Range</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Provides the earliest and latest date ranges and the optional times on which the goods are requested to be delivered.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="requestedShipDateRange" minOccurs="0" type="DateTimeRangeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Requested Ship Date Range</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Provides the earliest and latest date ranges and the optional times on which the goods are requested to be shipped or despatched.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="requestedDeliveryDateRangeAtUltimateConsignee" minOccurs="0"
            type="DateTimeRangeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Requested Delivery Date Range At Ultimate Consignee</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Provides the earliest and latest date ranges and the optional times on which the goods are requested to be delivered to the Ultimate Consignee.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="requestedDeliveryDateTime" minOccurs="0" type="DateOptionalTimeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Requested Delivery Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Provides the date and optional time on which the goods are requested to be delivered.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="requestedShipDateTime" minOccurs="0" type="DateOptionalTimeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Requested Ship Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Provides the date and optional time on which the goods are requested to be shipped or despatched by the supplier.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="requestedPickUpDateTime" minOccurs="0" type="DateOptionalTimeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Requested Pick Up Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Provides the date and optional time on which the goods are requested to be available for pickup at the seller's location.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="requestedDeliveryDateTimeAtUltimateConsignee" minOccurs="0"
            type="DateOptionalTimeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Requested Delivery Date Time At Ultimate Consignee</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Provides the date and optional time on which the goods are requested to be delivered to the Ultimate Consignee.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="OrderLogisticalInformationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Provides identification of the locations of the parties dealing with the goods associated with the order, as well as the dates or date ranges associated with the order and the transportation of the shipment associated with the order.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="commodityTypeCode" minOccurs="0" type="CodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Commodity Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Specifies the type of commodity for transport purposes, according to the user-selected coding scheme.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="shipFrom" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Ship From</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifies the origin location from which goods will be shipped.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="shipTo" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Ship To</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifies the destination location to which goods will be shipped.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="inventoryLocation" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inventory Location</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifies the location of merchandise or stock on hand.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="ultimateConsignee" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Ultimate Consignee</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifies the final destination location to which goods will be shipped.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="orderLogisticalDateInformation" minOccurs="0"
            type="OrderLogisticalDateInformationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Order Logistical Date Information</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="shipmentTransportationInformation" minOccurs="0"
            type="ShipmentTransportationInformationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Shipment Transportation Information</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Provides information on the means of transportation or carrier associated with the order.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="OrderRelationshipTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying relationship between related Purchase Order messages.  Allowed code values are specified in GS1 Code List OrderRelationshipTypeCode.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:OrderRelationshipTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: RELATED</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="OrderRelationshipTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="OrderTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:OrderTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 220</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying an order type. Allowed code values are specified in GS1 Code List OrderTypeCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="OrderTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="OrganisationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">An entity pursuing collective goals, such as a business, government body, department, charity, or financial institution.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="organisationName">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Organisation Name</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The official name of the organisation.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Chocolate Masters</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="issuedCapital" minOccurs="0" type="AmountType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Issued Capital</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 150000000</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The amount of the issued capital.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="legalStructure" minOccurs="0" type="Description80Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Legal Structure</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Describe legal structure</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Description of the type of legal structure of the organisation.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="officialAddress" minOccurs="0" type="AddressType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Official Address</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The address where the organisation is officially based.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="legalRegistration" minOccurs="0" maxOccurs="unbounded"
            type="LegalRegistrationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Legal Registration</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="OutOfStockMeasurementTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:OutOfStockMeasurementTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: OTHER</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying an out of stock measurement type. Allowed code values are specified in GS1 Code List OutOfStockMeasurementTypeCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="OutOfStockMeasurementTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="OwnershipTransferConditionCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:OwnershipTransferConditionCode Specifies who owns the goods before the invoice is paid and when the transfer of ownership can take place.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">Generic code data type not linked to a specific code list. Besides the code value the GS1 code data type allows to specify the code list version.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence/>
   </xsd:complexType>
   <xsd:complexType name="PackageLevelCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:PackageLevelCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a package level. Allowed code values are specified in GS1 Code List PackageLevelCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="PackageLevelCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="PackageTotalType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Aggregated information for a specific package type.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="packageTypeCode" type="PackageTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Package Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The code specifying the type of logistics package.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="totalPackageQuantity" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Total Package Quantity</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The total number of units of this package type.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 70</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="totalGrossVolume" minOccurs="0" type="MeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Total Gross Volume</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 343000000</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A measure of the gross volume normally calculated by multiplying the maximum length, width, and height of this package type.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="totalGrossWeight" minOccurs="0" type="MeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Total Gross Weight</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1500</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A measure of the gross weight (mass) of this package which includes the weight of packaging but which excludes the weight of any transport equipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="returnablePackaging" minOccurs="0" maxOccurs="unbounded"
            type="ReturnablePackagingType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Returnable Packaging</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="PackageTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: PX</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a package type. Allowed code values are specified in UN/ECE Recommendation 21, extended by GS1</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:PackageTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="PackageTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="PackagingConditionCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:PackagingConditionCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: GOOD_CONDITION</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a packaging quality condition. Allowed code values are specified in GS1 Code List PackagingConditionCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="PackagingConditionCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="PackagingMarkingType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Textual or barcoded information that is physically present on the packaging. This information can be about either the contents of the package e.g. best before date or the packaging e.g. Recycling characteristics.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="markingTypeCode" type="PackagingMarkingTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Marking Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The code specifying the type of marking on the package for example batch number.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="markingContentDateTime" minOccurs="0" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Marking Content Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The value as printed on the packaging, specified as date time value.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15T11:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="markingContentText" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Marking Content Text</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The value as printed on the packaging, specified as text.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Serial Shipping Container Code</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="PackagingMarkingTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:PackagingMarkingTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 33E</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying an packaging marking type. Allowed code values are specified in GS1 Code List PackagingMarkingTypeCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="PackagingMarkingTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="PackagingTermsCodeType">
      <xsd:simpleContent>
         <xsd:extension base="String80Type">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="PartyReferenceType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Name and identification details of a party.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">Information used to identify a party or location.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
