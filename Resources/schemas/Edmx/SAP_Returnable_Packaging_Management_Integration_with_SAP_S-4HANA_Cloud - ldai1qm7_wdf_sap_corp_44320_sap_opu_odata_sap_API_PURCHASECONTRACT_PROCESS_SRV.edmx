alse" sap:updatable="false" sap:deletable="false" sap:content-version="1"><End EntitySet="A_PurchaseContract" Role="FromRole_assoc_8FC638EF78A39409A8B6DBC77A8FDE4C"/><End EntitySet="A_PurCtrPartners" Role="ToRole_assoc_8FC638EF78A39409A8B6DBC77A8FDE4C"/></AssociationSet></EntityContainer><Annotations Target="API_PURCHASECONTRACT_PROCESS_SRV.A_PurchaseContractItemType/PurchaseContract" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Common.ValueList"><Record><PropertyValue Property="Label" String="Purchase Contract"/><PropertyValue Property="CollectionPath" String="A_PurchaseContract"/><PropertyValue Property="SearchSupported" Bool="false"/><PropertyValue Property="Parameters"><Collection><Record Type="Common.ValueListParameterInOut"><PropertyValue Property="LocalDataProperty" PropertyPath="PurchaseContract"/><PropertyValue Property="ValueListProperty" String="PurchaseContract"/></Record></Collection></PropertyValue></Record></Annotation></Annotations><Annotations Target="API_PURCHASECONTRACT_PROCESS_SRV.API_PURCHASECONTRACT_PROCESS_SRV_Entities" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Common.ApplyMultiUnitBehaviorForSortingAndFiltering" Bool="true"/><Annotation Term="Aggregation.ApplySupported"><Record><PropertyValue Property="Transformations"><Collection><String>aggregate</String><String>groupby</String><String>filter</String></Collection></PropertyValue><PropertyValue Property="Rollup" EnumMember="None"/></Record></Annotation></Annotations><Annotations Target="API_PURCHASECONTRACT_PROCESS_SRV.API_PURCHASECONTRACT_PROCESS_SRV_Entities/A_ValAddedSrvcMM" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Capabilities.FilterRestrictions"><Record><PropertyValue Property="NonFilterableProperties"><Collection><PropertyPath>ValueAddedServiceLongText</PropertyPath></Collection></PropertyValue></Record></Annotation><Annotation Term="Capabilities.SortRestrictions"><Record><PropertyValue Property="NonSortableProperties"><Collection><PropertyPath>ValueAddedServiceLongText</PropertyPath></Collection></PropertyValue></Record></Annotation></Annotations><Annotations Target="API_PURCHASECONTRACT_PROCESS_SRV.A_PurContrItemConditionType" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Common.SemanticKey"><Collection><PropertyPath>ConditionSequentialNumber</PropertyPath><PropertyPath>ConditionRecord</PropertyPath><PropertyPath>ConditionType</PropertyPath><PropertyPath>ConditionValidityEndDate</PropertyPath><PropertyPath>PurchaseContractItem</PropertyPath><PropertyPath>PurchaseContract</PropertyPath></Collection></Annotation></Annotations><Annotations Target="API_PURCHASECONTRACT_PROCESS_SRV.API_PURCHASECONTRACT_PROCESS_SRV_Entities/A_PurchaseContract" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Capabilities.ReadRestrictions"><Record><PropertyValue Property="Description" String="Gets the header details of all the purchase contracts in the system"/><PropertyValue Property="LongDescription" String="Gets the header details of all the purchase contracts in the system. This operation filters and sorts the returned data. Note that if there are many purchase contracts in the system, this operation might take a while. "/><PropertyValue Property="ReadByKeyRestrictions"><Record><PropertyValue Property="Description" String="Gets the header details of a purchase contract"/><PropertyValue Property="LongDescription" String="Gets the header details such as supplier, company code, currency, and so on of a purchase contract, using the purchase contract number provided."/></Record></PropertyValue></Record></Annotation></Annotations><Annotations Target="API_PURCHASECONTRACT_PROCESS_SRV.API_PURCHASECONTRACT_PROCESS_SRV_Entities/A_PurchaseContractItem" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Capabilities.ReadRestrictions"><Record><PropertyValue Property="Description" String="Gets the details of all the items, in all the purchase contracts in the system"/><PropertyValue Property="LongDescription" String="Gets the details of all the items, in all the purchase contracts in the system. Note that if there are many purchase contracts in the system, this operation might take a while. "/><PropertyValue Property="ReadByKeyRestrictions"><Record><PropertyValue Property="Description" String="Gets the item details of an item in a purchase contract"/><PropertyValue Property="LongDescription" String="Gets the item details such as material, plant, quantity, and so on of an item in a purchase contract, using the purchase contract and item number provided."/></Record></PropertyValue></Record></Annotation></Annotations><Annotations Target="API_PURCHASECONTRACT_PROCESS_SRV.API_PURCHASECONTRACT_PROCESS_SRV_Entities/A_PurCtrPartners" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Capabilities.ReadRestrictions"><Record><PropertyValue Property="Description" String="Gets the details of all the partners of all the purchase contracts in the system"/><PropertyValue Property="LongDescription" String="Gets the details of all the partners of all the purchase contracts in the system. Note that if there are many purchase contracts in the system, this operation might take a while."/><PropertyValue Property="ReadByKeyRestrictions"><Record><PropertyValue Property="Description" String="Gets the partner details of a purchase contract"/><PropertyValue Property="LongDescription" String="Gets the partner details such as partner function, purchasing organization, and so on in a purchase contract, using the purchase contract number, item number, purchasing organization, plant, partner function, partner counter, and supplier sub range provided. "/></Record></PropertyValue></Record></Annotation></Annotations><Annotations Target="API_PURCHASECONTRACT_PROCESS_SRV.API_PURCHASECONTRACT_PROCESS_SRV_Entities/A_PurContrItemCondition" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Capabilities.ReadRestrictions"><Record><PropertyValue Property="Description" String="Gets the conditions details of all the items lines of all the items, in all the purchase contracts in the system"/><PropertyValue Property="LongDescription" String="Gets the conditions details of all the items lines of all the items, in all the purchase contracts in the system. Note that if there are many purchase contracts in the system, this operation might take a while."/><PropertyValue Property="ReadByKeyRestrictions"><Record><PropertyValue Property="Description" String="Gets the conditions details of a specific item in a purchase contract"/><PropertyValue Property="LongDescription" String="Gets the conditions details of a specific item in a purchase contract, such as condition type, condition amount, and so on, using the purchase contract number, item number, condition type, condition validity date, condition record number, and condition sequential number of a condition provided."/></Record></PropertyValue></Record></Annotation></Annotations><Annotations Target="API_PURCHASECONTRACT_PROCESS_SRV.API_PURCHASECONTRACT_PROCESS_SRV_Entities/A_PurCtrAccount" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Capabilities.ReadRestrictions"><Record><PropertyValue Property="Description" String="Gets the details of all the accounting assignments of all the items, in all the purchase contracts in the system "/><PropertyValue Property="LongDescription" String="Gets the details of all the accounting assignments of all the items, in all the purchase contracts in the system. Note that if there are many purchase contracts in the system, this operation might take a while."/><PropertyValue Property="ReadByKeyRestrictions"><Record><PropertyValue Property="Description" String="Gets the account assignment details of a specific accounting line of an item in a purchase contract"/><PropertyValue Property="LongDescription" String="Gets the account assignment details of a specific accounting line of an item in a purchase contract, such as GL acocunt, cost center, and so on, using the purchase contract number, item number, and serial number of the accounting line provided."/></Record></PropertyValue></Record></Annotation></Annotations><Annotations Target="API_PURCHASECONTRACT_PROCESS_SRV.API_PURCHASECONTRACT_PROCESS_SRV_Entities/A_PurCtrAddress" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Capabilities.ReadRestrictions"><Record><PropertyValue Property="Description" String="Gets the details of all the delivery addresses of all the items, in all the purchase contracts in the system "/><PropertyValue Property="LongDescription" String="Gets the details of all the delivery addresses of all the items, in all the purchase contracts in the system. Note that if there are many purchase contracts in the system, this operation might take a while."/><PropertyValue Property="ReadByKeyRestrictions"><Record><PropertyValue Property="Description" String="Gets the details of all the delivery addresses of a specific item in a purchase contract"/><PropertyValue Property="LongDescription" String="Gets the delivery address details of a specific item in a purchase contract, such as name, city name, postal code, and so on, using the purchase contract number, item number, and address ID provided."/></Record></PropertyValue></Record></Annotation></Annotations><Annotations Target="API_PURCHASECONTRACT_PROCESS_SRV.API_PURCHASECONTRACT_PROCESS_SRV_Entities/A_ValAddedSrvcMM" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Capabilities.ReadRestrictions"><Record><PropertyValue Property="Description" String="Gets the details of all the value-added service data for purchase contract items in the system "/><PropertyValue Property="LongDescription" String="Gets the details of all the value-added service data for purchase contract items in the system. You can use this operation by activating ISR_RETAILSYSTEM business function. Note that if there are many purchase contract items in the system, this operation might take a while."/><PropertyValue Property="ReadByKeyRestrictions"><Record><PropertyValue Property="Description" String="Gets the details of all the value-added service data for a specific purchase contract item"/><PropertyValue Property="LongDescription" String="Gets the details of all the value-added service data for a specific item in a purchase contract, such as Service Types, Sub Service types, and so on, using the purchase contract number, item number, item group, service type and sub service type.You can use this operation by activating ISR_RETAILSYSTEM business function."/></Record></PropertyValue></Record></Annotation></Annotations><Annotations Target="API_PURCHASECONTRACT_PROCESS_SRV.API_PURCHASECONTRACT_PROCESS_SRV_Entities/A_PurchaseContract" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Capabilities.NavigationRestrictions"><Record><PropertyValue Property="RestrictedProperties"><Collection><Record><PropertyValue Property="NavigationProperty" NavigationPropertyPath="to_PurchaseContractItem"/><PropertyValue Property="ReadRestrictions"><Record><PropertyValue Property="Description" String="Gets the item details of all the items in a purchase contract"/><PropertyValue Property="LongDescription" String="Gets the item details such as material, plant, quantity, and so on of all the items in a purchase contract, using the purchase contract number provided."/></Record></PropertyValue></Record><Record><PropertyValue Property="NavigationProperty" NavigationPropertyPath="to_PurCtrPartners"/><PropertyValue Property="ReadRestrictions"><Record><PropertyValue Property="Description" String="Gets the partner details of a purchase contract"/><PropertyValue Property="LongDescription" String="Gets all the partner details of a purchase contract, using the purchase contract number provided."/></Record></PropertyValue></Record></Collection></PropertyValue></Record></Annotation></Annotations><Annotations Target="API_PURCHASECONTRACT_PROCESS_SRV.API_PURCHASECONTRACT_PROCESS_SRV_Entities/A_PurchaseContractItem" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Capabilities.NavigationRestrictions"><Record><PropertyValue Property="RestrictedProperties"><Collection><Record><PropertyValue Property="NavigationProperty" NavigationPropertyPath="to_PurContrItemCondition"/><PropertyValue Property="ReadRestrictions"><Record><PropertyValue Property="Description" String="Gets the conditions details of an item in a purchase contract"/><PropertyValue Property="LongDescription" String="Gets the conditions details of an item in a purchase contract, using purchase contract number, item number, condition type, condition validity date, condition record number, and condition sequential number of a condition provided."/></Record></PropertyValue></Record><Record><PropertyValue Property="NavigationProperty" NavigationPropertyPath="to_PurCtrAccount"/><PropertyValue Property="ReadRestrictions"><Record><PropertyValue Property="Description" String="Gets the account assignment details of all the accounting lines of an item in a purchase contract"/><PropertyValue Property="LongDescription" String="Gets the account assignment details of all the accounting lines of an item in a purchase contract, using the purchase contract number, item number, and serial number of the accounting line provided."/></Record></PropertyValue></Record><Record><PropertyValue Property="NavigationProperty" NavigationPropertyPath="to_PurCtrAddress"/><PropertyValue Property="ReadRestrictions"><Record><PropertyValue Property="Description" String="Gets the delivery address details of an item in a purchase contract"/><PropertyValue Property="LongDescription" String="Gets the delivery address details of an item in a purchase contract, using the purchase contract number, item number, and address ID provided."/></Record></PropertyValue></Record><Record><PropertyValue Property="NavigationProperty" NavigationPropertyPath="to_PurchaseContract"/><PropertyValue Property="ReadRestrictions"><Record><PropertyValue Property="Description" String="Gets the details of a purchase contract to which a specific item belongs"/><PropertyValue Property="LongDescription" String="Gets the details of a purchase contract to which a specific item belongs, using the purchase contract number and item number provided."/></Record></PropertyValue></Record><Record><PropertyValue Property="NavigationProperty" NavigationPropertyPath="to_ValueAddedService"/><PropertyValue Property="ReadRestrictions"><Record><PropertyValue Property="Description" String="Reads all value-added service data for a specific purchase contract item"/><PropertyValue Property="LongDescription" String="Reads all value-added service data for a specific purchase contract item using purchase contract number and item number. You can use this operation by activating the business function ISR_RETAILSYSTEM."/></Record></PropertyValue></Record><Record><PropertyValue Property="NavigationProperty" NavigationPropertyPath="to_ValueAddedService"/><PropertyValue Property="InsertRestrictions"><Record><PropertyValue Property="Description" String="Reads all value-added service data for a specific purchase contract item"/><PropertyValue Property="LongDescription" String="Reads all value-added service data for a specific purchase contract item using purchase contract number and item number. You can use this operation by activating the business function ISR_RETAILSYSTEM."/></Record></PropertyValue></Record></Collection></PropertyValue></Record></Annotation></Annotations><Annotations Target="API_PURCHASECONTRACT_PROCESS_SRV.API_PURCHASECONTRACT_PROCESS_SRV_Entities/A_PurchaseContract" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Capabilities.InsertRestrictions"><Record><PropertyValue Property="Description" String="Creates a new purchase contract"/><PropertyValue Property="LongDescription" String="Creates a new purchase contract with one or more items. It validates the correctness of the payload. In case the validation fails, it returns the errors in the response."/></Record></Annotation></Annotations><Annotations Target="API_PURCHASECONTRACT_PROCESS_SRV.API_PURCHASECONTRACT_PROCESS_SRV_Entities/A_ValAddedSrvcMM" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Capabilities.InsertRestrictions"><Record><PropertyValue Property="Description" String="Creates one or more value-added services for a specific purchase contract item"/><PropertyValue Property="LongDescription" String="Creates value-added service data for a specific purchase contract item that you must specify in the payload.You can use this operation by activating the business function ISR_RETAILSYSTEM."/></Record></Annotation></Annotations><Annotations Target="API_PURCHASECONTRACT_PROCESS_SRV.API_PURCHASECONTRACT_PROCESS_SRV_Entities/A_ValAddedSrvcMM" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Capabilities.UpdateRestrictions"><Record><PropertyValue Property="Description" String="Updates a specific value-added service"/><PropertyValue Property="LongDescription" String="Updates the data of a specific value-added service item using purchase contract number, item number, value-added service type, and value-added subservice type. You can use this operation by activating the business function ISR_RETAILSYSTEM."/></Record></Annotation></Annotations><Annotations Target="API_PURCHASECONTRACT_PROCESS_SRV.API_PURCHASECONTRACT_PROCESS_SRV_Entities/A_ValAddedSrvcMM" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Capabilities.DeleteRestrictions"><Record><PropertyValue Property="Description" String="Deletes a specific value-added service"/><PropertyValue Property="LongDescription" String="Deletes the data of a specific value-added service item using purchase contract number, item number, value-added service type, and value-added subservice type. You can use this operation by activating the business function ISR_RETAILSYSTEM."/></Record></Annotation></Annotations><Annotations Target="API_PURCHASECONTRACT_PROCESS_SRV.API_PURCHASECONTRACT_PROCESS_SRV_Entities" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Org.OData.Capabilities.V1.BatchSupport"><Record Type="Org.OData.Capabilities.V1.BatchSupportType"><PropertyValue Property="ReferencesAcrossChangeSetsSupported" Bool="true"/></Record></Annotation><Annotation Term="SAP__CodeList.CurrencyCodes"><Record><PropertyValue Property="Url" String="../../iwbep/common;v=0001;o=LOCAL/$metadata"/><PropertyValue Property="CollectionPath" String="Currencies"/></Record></Annotation><Annotation Term="SAP__CodeList.UnitsOfMeasure"><Record><PropertyValue Property="Url" String="../../iwbep/common;v=0001;o=LOCAL/$metadata"/><PropertyValue Property="CollectionPath" String="UnitsOfMeasure"/></Record></Annotation></Annotations><atom:link rel="self" href="https://ldai1qm7.wdf.sap.corp:44320/sap/opu/odata/sap/API_PURCHASECONTRACT_PROCESS_SRV/$metadata" xmlns:atom="http://www.w3.org/2005/Atom"/><atom:link rel="latest-version" href="https://ldai1qm7.wdf.sap.corp:44320/sap/opu/odata/sap/API_PURCHASECONTRACT_PROCESS_SRV/$metadata" xmlns:atom="http://www.w3.org/2005/Atom"/></Schema></edmx:DataServices></edmx:Edmx>