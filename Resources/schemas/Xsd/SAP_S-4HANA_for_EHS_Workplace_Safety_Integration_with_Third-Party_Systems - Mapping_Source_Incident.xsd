<?xml version="1.0" encoding="utf-8"?>
<xs:schema attributeFormDefault="unqualified" elementFormDefault="qualified" xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <xs:element name="Incident">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="IncidentCategory" type="xs:unsignedByte" />
		<xs:element name="IncidentTitle" type="xs:string" />
        <xs:element name="IncidentUTCDateTime" type="xs:dateTime" />
		<xs:element name="IncidentDescriptionOfEvents" type="xs:string" nillable="true" minOccurs="0" />
        <xs:element name="EHSLocationUUID" type="xs:string" nillable="true" minOccurs="0" />
		<xs:element name="IncidentLocationDescription" type="xs:string" nillable="true" minOccurs="0" />
		<xs:element name="IncidentLongitudeMeasure" type="xs:decimal" nillable="true" minOccurs="0" />
		<xs:element name="IncidentLatitudeMeasure" type="xs:decimal" nillable="true" minOccurs="0" />
      </xs:sequence>
    </xs:complexType>
  </xs:element>
</xs:schema>