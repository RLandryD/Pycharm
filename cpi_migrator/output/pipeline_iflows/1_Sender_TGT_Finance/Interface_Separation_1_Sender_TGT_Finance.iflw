    <sequenceFlow id="route_6" sourceRef="Router_1"
      targetRef="Call_Chile_Pull_SII_Email_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Chile Pull SII Emails' -->
    </sequenceFlow>
    <serviceTask id="Call_Chile_Pull_SII_Email_1"
