appinfo source="http://sap.com/xi/TextID">b6c3acea1ff311e1affa0026b9aa16ff</xsd:appinfo><xsd:documentation>REF04| Reference Identifier. NOTES: REF04 contains data relating to the value cited in REF02.</xsd:documentation></xsd:annotation><xsd:complexType><xsd:sequence><xsd:element name="D_128"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ace41ff311e1a8710026b9aa16ff</xsd:appinfo><xsd:documentation>C04001| Reference Identification Qualifier</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="2"/><xsd:maxLength value="3"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element name="D_127"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ace51ff311e19dac0026b9aa16ff</xsd:appinfo><xsd:documentation>C04002| Reference Identification</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="30"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_128_2"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ace61ff311e185e60026b9aa16ff</xsd:appinfo><xsd:documentation>C04003| Reference Identification Qualifier. NOTES: P0304 - If either C04003 or C04004 is present, then the other is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="2"/><xsd:maxLength value="3"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_127_2"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ace71ff311e185c60026b9aa16ff</xsd:appinfo><xsd:documentation>C04004| Reference Identification</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="30"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_128_3"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ace81ff311e1b6970026b9aa16ff</xsd:appinfo><xsd:documentation>C04005| Reference Identification Qualifier. NOTES: P0506 - If either C04005 or C04006 is present, then the other is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="2"/><xsd:maxLength value="3"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_127_3"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ace91ff311e1c2830026b9aa16ff</xsd:appinfo><xsd:documentation>C04006| Reference Identification</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="30"/></xsd:restriction></xsd:simpleType></xsd:element></xsd:sequence></xsd:complexType></xsd:element></xsd:sequence></xsd:complexType></xsd:element><xsd:element maxOccurs="1000" minOccurs="0" name="S_PID"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acf51ff311e1bdd40026b9aa16ff</xsd:appinfo><xsd:documentation>Product/Item Description. To describe a product or process in coded or free-form format</xsd:documentation></xsd:annotation><xsd:complexType><xsd:sequence><xsd:element name="D_349"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acec1ff311e1cb030026b9aa16ff</xsd:appinfo><xsd:documentation>PID01| Item Description Type. NOTES: If PID01 equals "F", then PID05 is used. If PID01 equals "S", then PID04 is used. If PID01 equals "X", then both PID04 and PID05 are used.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="1"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_750"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3aced1ff311e1c6f90026b9aa16ff</xsd:appinfo><xsd:documentation>PID02| Product/Process Characteristic Code</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="2"/><xsd:maxLength value="3"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_559"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acee1ff311e1cd1b0026b9aa16ff</xsd:appinfo><xsd:documentation>PID03| Agency Qualifier Code. NOTES: Use PID03 to indicate the organization that publishes the code list being referred to.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_751"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acef1ff311e1b6db0026b9aa16ff</xsd:appinfo><xsd:documentation>PID04| Product Description Code. NOTES: C0403 - If PID04 is present, then PID03 is required. R0405 - At least one of PID04 or PID05 is required. PID04 should be used for industry-specific product description codes.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="12"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_352"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acf01ff311e19d420026b9aa16ff</xsd:appinfo><xsd:documentation>PID05| Description</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="80"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_752"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acf11ff311e1bbd90026b9aa16ff</xsd:appinfo><xsd:documentation>PID06| Surface/Layer/Position Code. NOTES: Use PID06 when necessary to refer to the product surface or layer being described in the segment.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_822"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acf21ff311e1a3780026b9aa16ff</xsd:appinfo><xsd:documentation>PID07| Source Subqualifier. NOTES: C0703 - If PID07 is present, then PID03 is required. PID07 specifies the individual code list of the agency specified in PID03.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="15"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_1073"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acf31ff311e188d40026b9aa16ff</xsd:appinfo><xsd:documentation>PID08| Yes/No Condition or Response Code. NOTES: C0804 - If PID08 is present, then PID04 is required. PID08 describes the physical characteristics of the product identified in PID04. A "Y" indicates that the specified attribute applies to this ite...</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="1"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_819"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acf41ff311e1c8cd0026b9aa16ff</xsd:appinfo><xsd:documentation>PID09| Language Code. NOTES: C0905 - If PID09 is present, then PID05 is required. PID09 is used to identify the language being used in PID05.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="2"/><xsd:maxLength value="3"/></xsd:restriction></xsd:simpleType></xsd:element></xsd:sequence></xsd:complexType></xsd:element><xsd:element maxOccurs="25" minOccurs="0" name="S_SAC"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ad061ff311e1cc080026b9aa16ff</xsd:appinfo><xsd:documentation>Service, Promotion, Allowance, or Charge Information. To request or identify a service, promotion, allowance, or charge; to specify the amount or percentage for the service, promotion, allowance, or charge</xsd:documentation></xsd:annotation><xsd:complexType><xsd:sequence><xsd:element name="D_248"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acf61ff311e195900026b9aa16ff</xsd:appinfo><xsd:documentation>SAC01| Allowance or Charge Indicator. NOTES: If SAC01 is "A" or "C", then at least one of SAC05, SAC07, or SAC08 is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="1"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_1300"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acf71ff311e193430026b9aa16ff</xsd:appinfo><xsd:documentation>SAC02| Service, Promotion, Allowance, or Charge Code. NOTES: R0203 - At least one of SAC02 or SAC03 is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="4"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_559"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acf81ff311e19f360026b9aa16ff</xsd:appinfo><xsd:documentation>SAC03| Agency Qualifier Code. NOTES: P0304 - If either SAC03 or SAC04 is present, then the other is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_1301"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acf91ff311e1cf3b0026b9aa16ff</xsd:appinfo><xsd:documentation>SAC04| Agency Service, Promotion, Allowance, or Charge Code. NOTES: SAC04 may be used to uniquely identify the service, promotion, allowance, or charge. In addition, it may be used in conjunction to further the code in SAC02.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="10"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_610"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acfa1ff311e186360026b9aa16ff</xsd:appinfo><xsd:documentation>SAC05| Amount. NOTES: SAC05 is the total amount for the service, promotion, allowance, or charge. If SAC05 is present with SAC07 or SAC08, then SAC05 takes precedence.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="15"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_378"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acfb1ff311e1b6820026b9aa16ff</xsd:appinfo><xsd:documentation>SAC06| Allowance/Charge Percent Qualifier. NOTES: P0607 - If either SAC06 or SAC07 is present, then the other is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="1"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_332"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acfc1ff311e1a29e0026b9aa16ff</xsd:appinfo><xsd:documentation>SAC07| Percent</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="6"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_118"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acfd1ff311e19e820026b9aa16ff</xsd:appinfo><xsd:documentation>SAC08| Rate. NOTES: SAC08 is the allowance or charge rate per unit.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="9"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_355"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acfe1ff311e1afec0026b9aa16ff</xsd:appinfo><xsd:documentation>SAC09| Unit or Basis for Measurement Code. NOTES: P0910 - If either SAC09 or SAC10 is present, then the other is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_380"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3acff1ff311e181d20026b9aa16ff</xsd:appinfo><xsd:documentation>SAC10| Quantity. NOTES: SAC10 and SAC11 is the quantity basis when the allowance or charge quantity is different from the purchase order or invoice quantity. SAC10 and SAC11 used together indicate a quantity range, which could be a dollar amount, ...</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="15"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_380_2"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ad001ff311e1a2260026b9aa16ff</xsd:appinfo><xsd:documentation>SAC11| Quantity. NOTES: C1110 - If SAC11 is present, then SAC10 is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="15"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_331"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ad011ff311e19d240026b9aa16ff</xsd:appinfo><xsd:documentation>SAC12| Allowance or Charge Method of Handling Code</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_127"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ad021ff311e193730026b9aa16ff</xsd:appinfo><xsd:documentation>SAC13| Reference Identification. NOTES: L130204 - If SAC13 is present, then at least one of SAC02 or SAC04 is required. SAC13 is used in conjunction with SAC02 or SAC04 to provide a specific reference number as identified by the code used.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="30"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_770"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ad031ff311e18f1c0026b9aa16ff</xsd:appinfo><xsd:documentation>SAC14| Option Number. NOTES: C1413 - If SAC14 is present, then SAC13 is required. SAC14 is used in conjunction with SAC13 to identify an option when there is more than one option of the promotion.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="20"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_352"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ad041ff311e1c4620026b9aa16ff</xsd:appinfo><xsd:documentation>SAC15| Description</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="80"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_819"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ad051ff311e1af440026b9aa16ff</xsd:appinfo><xsd:documentation>SAC16| Language Code. NOTES: C1615 - If SAC16 is present, then SAC15 is required. SAC16 is used to identify the language being used in SAC15.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="2"/><xsd:maxLength value="3"/></xsd:restriction></xsd:simpleType></xsd:element></xsd:sequence></xsd:complexType></xsd:element><xsd:element maxOccurs="2" minOccurs="0" name="S_TC2"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c3ad091ff311e1b2db0026b9aa16ff</xsd:appinfo><xsd:documentation>Commodity. To identify a commodity or a group of commodities or a tariff page commodity</xsd:documentation></xsd:annotation><xsd:comp