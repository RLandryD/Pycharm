            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="61">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Under deck</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The
