						<ccts:DefinitionText xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> Indicates the collective agreement code that applies to the
					employee. </ccts:DefinitionText>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:normalizedString">
					<xsd:length value="5"/>
				</xsd:restriction>
			</xsd:simpleType>
