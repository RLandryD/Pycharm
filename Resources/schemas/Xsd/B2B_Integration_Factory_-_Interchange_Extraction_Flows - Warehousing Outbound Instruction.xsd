   <xsd:complexType name="ShipmentReferenceType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Reference to details of shipment.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="shipmentIdentification" type="Ecom_ShipmentIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Shipment Identification</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="shipper" minOccurs="0" type="Ecom_PartyIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Shipper</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A party who engages in shipping goods. In a commercial scenario this would be the supplier.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="receiver" minOccurs="0" type="Ecom_PartyIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Receiver</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A party who engages in receiving goods. In a commercial scenario this would be the customer.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="ShipmentTransportationInformationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Detailed information on the transportation of  shipments.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="handlingInstructionCode" minOccurs="0" maxOccurs="unbounded"
            type="HandlingInstructionCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Handling Instruction Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code identifying handling instructions for this shipment, such as where or how specified packages or containers are to be loaded on a means of transport. Handling instructions can include haulage/ pickup and or delivery instruction/ temperature/humidity instructions.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transportMeansType" minOccurs="0" type="TransportMeansTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transport Means Type</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code identifying the means of transport: the type of vehicle, aircraft, vessel or other device used for the transport of goods. The means of transport has a means of locomotion.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transportMeansID" minOccurs="0" type="IdentifierType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transport Means I D</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Vehicle license plate/Aircraft number identifying a means of transport</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1-FFN-599</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transportServiceCategoryType" minOccurs="0"
            type="TransportServiceCategoryCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transport Service Category Type</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A code specifying a type of category for this transport service.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transportServiceLevelCode" minOccurs="0"
            type="TransportServiceLevelCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transport Service Level Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the service level required for the transport of the shipment.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="routeID" minOccurs="0" type="IdentifierType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Route I D</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Unique identifier of the standard route that will be used for this transport movement</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="carrier" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Carrier</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Uniquely identifies the entity that transports the shipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="freightForwarder" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Freight Forwarder</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Party that arranges the carriage of goods including connected services and/or associated formalities on behalf of the shipper (consignor) or consignee.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="SourceReferenceType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Reference to an external system containing the source data for a certain piece of exchanged information.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="sourceName" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Source Name</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A text identifying an external source (such as a database).</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: CMS1</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="referenceIdentifier" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Reference Identifier</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number or string identifying the version of the referenced source.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: FIELD_A</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="referenceURI" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Reference U R I</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Simple text string that identifies the name of the reference or the location of the reference on the Internet.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: http://www.thesource.com</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="versionIdentifier" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Version Identifier</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number or string identifying the version of the referenced source.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: VERSION_A</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="versionDateTime" minOccurs="0" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Version Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date and time identifying the version of the referenced source.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-12-17T09:30:47Z</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="SpecialOperatingHoursType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">The period during which a business or facility is operational on special days, such as holidays.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="isOperational" type="xsd:boolean">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Is Operational</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Indicator specifying whether or not the business or facility is operational on the specified day.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: true</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="specialDate" type="xsd:date">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Special Date</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date specifying the day to which the special operating hours apply.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2011-12-24</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="closingTime" minOccurs="0" type="xsd:time">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Closing Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Time on which the business or facility will close on the specified day.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 14:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="openingTime" minOccurs="0" type="xsd:time">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Opening Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Time on which the business or facility will open on the specified day.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 06:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="specialDateName" minOccurs="0" type="Description80Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Special Date Name</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Christmas Eve</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Text describing the day to which the special operating hours apply. Example: Christmas.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
