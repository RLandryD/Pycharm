<?xml version="1.0" encoding="UTF-8"?>
<!--
  SCENARIO iFlow: Create or Change Equipment from SAP ERP to SAP S4HANA Cloud
  Display Name : OUT_SAP_ERP_Sender_S4HC_Get_Create_or_Change_Equ
  Package      : 1_SAP_ERP_Sender_S4HC_Get_Finance
  Strategy     : BROWNFIELD: Lift-and-shift. Mapping '' ported directly.
  Complexity   : MEDIUM (score: 20)
  Effort       : 3 day(s)
  Sender       : SAP_ERP_Sender (IDOC)
  Receiver     : S4HC_Get (HCIOData)
  Batch        : No
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Create_or_Change_Equ"
             name="OUT_SAP_ERP_Sender_S4HC_Get_Create_or_Change_Equ">
  <process id="Create_or_Change_Equ_process" ifl:type="IntegrationFlow">

    <startEvent id="Start_SC" name="From Interface Separation">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Create_or_Change_Equ</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>



    <!-- PROCESSDIRECT: Forward to Outbound Delivery -->
    <serviceTask id="CallOutbound_1" name="→ Outbound Delivery" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/outbound/1_SAP_ERP_Sender_S4H</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_SC"/>
    <sequenceFlow sourceRef="Start_SC" targetRef="CallOutbound_1"/>
    
    
    <sequenceFlow sourceRef="CallOutbound_1" targetRef="End_SC"/>
  </process>
</definitions>