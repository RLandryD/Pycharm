<edmx:Edmx xmlns:edmx="http://schemas.microsoft.com/ado/2007/06/edmx" Version="1.0">
    <edmx:DataServices xmlns:m="http://schemas.microsoft.com/ado/2007/08/dataservices/metadata" m:DataServiceVersion="2.0">
        <Schema xmlns="http://schemas.microsoft.com/ado/2008/09/edm" xmlns:s="http://schemas.sap.com/commerce" Namespace="HybrisCommerceOData" s:schema-version="1">
            <EntityType Name="SAPCpiOutboundConfig">
                <Key>
                    <PropertyRef Name="integrationKey"/>
                </Key>
                <Property Name="url" Nullable="true" Type="Edm.String"/>
                <Property Name="username" Nullable="true" Type="Edm.String" s:IsUnique="true"/>
                <Property Name="extBillingResponseStatusCode" Nullable="true" Type="Edm.String"/>
                <Property Name="extBillingResponseValue" Nullable="true" Type="Edm.String"/>
                <Property Name="integrationKey" Nullable="false" Type="Edm.String" s:Alias="SAPCpiOutboundConfig_username"/>
            </EntityType>
            <EntityContainer Name="Container" m:IsDefaultEntityContainer="true">
                <EntitySet EntityType="HybrisCommerceOData.SAPCpiOutboundConfig" Name="SAPCpiOutboundConfigs"/>
            </EntityContainer>
        </Schema>
    </edmx:DataServices>
</edmx:Edmx>