																Generacion
																del
																Timbre
															</xs:documentation>
														</xs:annotation>
													</xs:element>
												</xs:sequence>
											</xs:complexType>
										</xs:element>
										<xs:element name="FRMT">
											<xs:annotation>
												<xs:documentation>
