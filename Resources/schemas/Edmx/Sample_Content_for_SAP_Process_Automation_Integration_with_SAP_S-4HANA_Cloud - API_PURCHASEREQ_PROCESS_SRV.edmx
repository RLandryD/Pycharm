   <Annotations Target="API_PURCHASEREQ_PROCESS_SRV.API_PURCHASEREQ_PROCESS_SRV_Entities/A_PurReqnAcctAssgmt" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Capabilities.InsertRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Adds a new accounting line to an item in a purchase requisition"/>
      <PropertyValue Property="LongDescription" String="Adds a new accounting line to an item in a purchase requisition using the purchase requisition number, and item number provided. It is mandatory to provide the purchase requisition number, &quot;PurchaseRequisition&quot;, and item number,&quot;PurchaseRequisitionItem&quot;, in the request body. This operation is only supported as a batch request. Please note that while you add a new accounting line to an item, you must also correspondingly update the accounting details in the purchase requisition item, hence this operation is only supported as a batch request."/>
     </Record>
    </Annotation>
   </Annotations>
