            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="PaymentTermsTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:PaymentTermsTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="PaymentTermsTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="PaymentTimePeriodType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Provides the payment time period information.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="dateDue" minOccurs="0" type="xsd:date">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Date Due</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Calendar date specifying when the payment is due.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dayOfMonthDue" minOccurs="0" type="xsd:gDay">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Day Of Month Due</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The time at which a payment is due, expressed as a day of the month.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 05</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="timePeriodDue" minOccurs="0" type="TimeMeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Time Period Due</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Measurement specifying the duration of the period within which the payment in due, for example within 10 days.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="QuantityRangeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Provides the difference or interval between a minimum and maximum quantity.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="maximumQuantity" minOccurs="0" type="QuantityType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Maximum Quantity</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 700</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Specifies the upper limit of the quantity range.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="minimumQuantity" minOccurs="0" type="QuantityType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Minimum Quantity</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Specifies the lower limit of the quantity range.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 500</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="QuantityType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Provides quantity value and an associated unit of measure code.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="xsd:decimal">
            <xsd:attribute name="measurementUnitCode" type="MeasurementUnitCode">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Any standardized, reproducible unit that can be used to measure any physical property. Allowed code values are specified in UN/ECE Recommendation 20 - Fully Adopted by GS1.</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: KGM</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found at the  UN/ECE website: http://www.unece.org/tradewelcome/un-centre-for-trade-facilitation-and-e-business-uncefact/outputs/cefactrecommendationsrec-index/list-of-trade-facilitation-recommendations-n-16-to-20.html</xsd:documentation>
               </xsd:annotation>
            </xsd:attribute>
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Revision 6</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="RangeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Provides the difference or interval between the minimum and maximum value.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="maximum" minOccurs="0" type="xsd:float">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Maximum</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Specifies the upper limit of the quantity range.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="maximumType" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Maximum Type</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifies the type of measurement the range is expressed in.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="minimum" minOccurs="0" type="xsd:float">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Minimum</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Specifies the lower limit of the quantity range.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="minimumType" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Minimum Type</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A code that identifies the unit of measure of the range lower limit.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="ResponsibleAgencyCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a responsible agency. Allowed code values are specified in GS1 Code List ResponsibleAgencyCode.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:ResponsibleAgencyCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 327</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="String80Type">
            <xsd:attribute name="codeDescription">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">A description for the code value provided.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="80"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">The snapshot of the code list at a certain point in time.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
