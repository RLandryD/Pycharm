    <xsd:element name="Get_Interviews_Response" type="wd:Get_Interviews_ResponseType"/>
    <xsd:complexType name="Get_Interviews_ResponseType">
        <xsd:annotation>
            <xsd:documentation>Wrapper element containing Interview Response Data for requested references or criteria and for requested response group.</xsd:documentation>
        </xsd:annotation>
        <xsd:sequence>
            <xsd:element minOccurs="0" name="Request_References" type="wd:Interview_Request_ReferencesType"/>
            <xsd:element minOccurs="0" name="Request_Criteria" type="wd:Interview_Request_CriteriaType"/>
            <xsd:element minOccurs="0" name="Response_Filter" type="wd:Response_FilterType"/>
            <xsd:element minOccurs="0" name="Response_Group" type="wd:Interview_Response_GroupType"/>
            <xsd:element minOccurs="0" name="Response_Results" type="wd:Response_ResultsType"/>
            <xsd:element minOccurs="0" name="Response_Data" type="wd:Interview_Response_DataType">
                <xsd:annotation>
                    <xsd:documentation>Contains interview data.</xsd:documentation>
                </xsd:annotation>
            </xsd:element>
        </xsd:sequence>
        <xsd:attribute ref="wd:version"/>
    </xsd:complexType>
