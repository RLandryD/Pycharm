   <Annotations Target="API_PURCHASEREQ_PROCESS_SRV.API_PURCHASEREQ_PROCESS_SRV_Entities/A_PurchaseRequisitionHeader" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Capabilities.ReadRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Gets the header details of all the purchase requisitions in the system"/>
      <PropertyValue Property="LongDescription" String="Gets the header details of all the purchase requisitions in the system.Note that if there are many purchase requisitions in the system, this operation might take a while."/>
      <PropertyValue Property="ReadByKeyRestrictions">
       <Record>
        <PropertyValue Property="Description" String="Gets the header details of a purchase requisition"/>
        <PropertyValue Property="LongDescription" String="Gets the header details of a purchase requisition using the purchase requisition number provided."/>
       </Record>
      </PropertyValue>
     </Record>
    </Annotation>
   </Annotations>
   <Annotations Target="API_PURCHASEREQ_PROCESS_SRV.API_PURCHASEREQ_PROCESS_SRV_Entities/A_PurchaseRequisitionItem" xmlns="http://docs.oasis-open.org/odata/ns/edm">
