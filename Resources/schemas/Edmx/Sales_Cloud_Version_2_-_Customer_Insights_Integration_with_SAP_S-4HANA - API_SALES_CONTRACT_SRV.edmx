   <Annotations Target="API_SALES_CONTRACT_SRV.API_SALES_CONTRACT_SRV_Entities/A_SalesContract" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Capabilities.ReadRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Reads all sales contract headers."/>
      <PropertyValue Property="LongDescription" String="Reads the header data of all sales contracts in the system."/>
      <PropertyValue Property="ReadByKeyRestrictions">
       <Record>
        <PropertyValue Property="Description" String="Reads the header of a specific sales contract."/>
        <PropertyValue Property="LongDescription" String="Reads the header data of a specific sales contract, which the consumer specifies by passing the sales contract number."/>
       </Record>
      </PropertyValue>
     </Record>
    </Annotation>
   </Annotations>
   <Annotations Target="API_SALES_CONTRACT_SRV.API_SALES_CONTRACT_SRV_Entities/A_SalesContractItem" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Capabilities.ReadRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Reads all sales contract items."/>
      <PropertyValue Property="LongDescription" String="Reads all item data of all sales contracts in the system."/>
      <PropertyValue Property="ReadByKeyRestrictions">
       <Record>
        <PropertyValue Property="Description" String="Reads a specific sales contract item."/>
        <PropertyValue Property="LongDescription" String="Reads the data of a specific sales contract item, which the consumer specifies by passing the sales contract number and item number."/>
       </Record>
      </PropertyValue>
     </Record>
    </Annotation>
   </Annotations>
   <Annotations Target="API_SALES_CONTRACT_SRV.API_SALES_CONTRACT_SRV_Entities/A_SalesContractPartner" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Capabilities.ReadRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Reads all header-level partners."/>
      <PropertyValue Property="LongDescription" String="Reads partner data from the headers of all sales contracts in the system. This includes fields such as partner function, customer, contact person, and more."/>
      <PropertyValue Property="ReadByKeyRestrictions">
       <Record>
        <PropertyValue Property="Description" String="Reads a specific header-level partner."/>
        <PropertyValue Property="LongDescription" String="Reads a specific header-level partner, which the consumer specifies by passing the sales contract number and partner function."/>
       </Record>
      </PropertyValue>
     </Record>
    </Annotation>
   </Annotations>
   <Annotations Target="API_SALES_CONTRACT_SRV.API_SALES_CONTRACT_SRV_Entities/A_SalesContractPrcgElmnt" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Capabilities.ReadRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Reads all header-level pricing elements."/>
      <PropertyValue Property="LongDescription" String="Reads pricing element data from the headers of all sales contracts in the system. This includes fields such as pricing procedure counter, pricing procedure step, and more."/>
      <PropertyValue Property="ReadByKeyRestrictions">
       <Record>
        <PropertyValue Property="Description" String="Reads a specific header-level pricing element."/>
        <PropertyValue Property="LongDescription" String="Reads a specific header-level pricing element, which the consumer specifies by passing the sales contract number, pricing procedure step, and pricing procedure counter."/>
       </Record>
      </PropertyValue>
     </Record>
    </Annotation>
   </Annotations>
