               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: SRN</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transactionalReferenceValue">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transactional Reference Value</xsd:documentation>
