<?xml version='1.0' encoding='UTF-8'?>
<edmx:Edmx Version="1.0" xmlns:edmx="http://schemas.microsoft.com/ado/2007/06/edmx">
	<edmx:DataServices m:DataServiceVersion="1.0" xmlns:m="http://schemas.microsoft.com/ado/2007/08/dataservices/metadata">
		<Schema Namespace="HybrisCommerceOData" s:schema-version="1" xmlns="http://schemas.microsoft.com/ado/2008/09/edm" xmlns:s="http://schemas.sap.com/commerce">
			<EntityType Name="Quote">
				<Key>
					<PropertyRef Name="integrationKey"/>
				</Key>
				<Property Name="c4cQuoteExternalQuoteId" Nullable="true" Type="Edm.String"/>
				<Property Name="code" Nullable="true" Type="Edm.String" s:IsUnique="true"/>
				<Property Name="version" Nullable="true" Type="Edm.String"/>
				<Property Name="integrationKey" Nullable="false" Type="Edm.String" s:Alias="Quote_code"/>
			</EntityType>
			<EntityContainer Name="Container" m:IsDefaultEntityContainer="true">
				<EntitySet EntityType="HybrisCommerceOData.Quote" Name="Quotes"/>
			</EntityContainer>
		</Schema>
	</edmx:DataServices>
</edmx:Edmx>