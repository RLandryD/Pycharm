<xs:schema attributeFormDefault="unqualified" elementFormDefault="qualified" xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <xs:element name="root">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="supplierDetails">
          <xs:complexType>
            <xs:sequence>
              <xs:element type="xs:string" name="code"/>
              <xs:element type="xs:string" name="role"/>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element name="personDetails">
          <xs:complexType>
            <xs:sequence>
              <xs:element type="xs:string" name="code"/>
              <xs:element type="xs:string" name="role"/>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element name="qualityNotifications">
          <xs:complexType>
            <xs:sequence>
              <xs:element type="xs:string" name="ReporterInternalID"/>
              <xs:element type="xs:short" name="plant_ID"/>
              <xs:element type="xs:byte" name="purchaseOrderItem"/>
              <xs:element name="defect" maxOccurs="unbounded" minOccurs="0">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element type="xs:string" name="description"/>
                    <xs:element type="xs:string" name="defectGroup_code"/>
                    <xs:element type="xs:byte" name="defectCode_code"/>
                    <xs:element type="xs:byte" name="defectNumber"/>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
              <xs:element type="xs:string" name="referenceNumber"/>
              <xs:element type="xs:float" name="quantity"/>
              <xs:element type="xs:string" name="unit"/>
              <xs:element type="xs:long" name="purchaseOrderNumber"/>
              <xs:element type="xs:string" name="material_ID"/>
              <xs:element type="xs:string" name="qnType"/>
              <xs:element type="xs:byte" name="subjectCode_code"/>
              <xs:element type="xs:string" name="subjectCode_subjectCodeGroup_code"/>
              <xs:element type="xs:string" name="processDescription"/>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
</xs:schema>
