n quotations simultaneously, use a batch request."/></Record></Annotation></Annotations><Annotations Target="API_BUS_SOLUTION_QUOTATION_SRV.API_BUS_SOLUTION_QUOTATION_SRV_Entities/A_BuSoQtanItmFUPSubscrpnContr" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Capabilities.NavigationRestrictions"><Record><PropertyValue Property="RestrictedProperties"><Collection><Record><PropertyValue Property="NavigationProperty" NavigationPropertyPath="to_BusinessSolutionQuotation"/><PropertyValue Property="ReadRestrictions"><Record><PropertyValue Property="Description" String="Retrieves the solution quotation header for a specific follow-up subscription contract item."/><PropertyValue Property="LongDescription" String="Retrieves the details of the solution quotation header for a specific follow-up subscription contract item. The details include transaction type, description, organization data, and so on. Consumers must pass the following key fields: item relation UUID and item relation sequential number."/></Record></PropertyValue></Record></Collection></PropertyValue></Record></Annotation></Annotations><Annotations Target="API_BUS_SOLUTION_QUOTATION_SRV.API_BUS_SOLUTION_QUOTATION_SRV_Entities/A_BuSoQtanSrvcContrItmRefObj" xmlns="http://docs.oasis-open.org/odata/ns/edm"><Annotation Term="Capabilities.NavigationRestrictions"><Record><PropertyValue Property="RestrictedProperties"><Collection><Record><PropertyValue Property="NavigationProperty" NavigationPropertyPath="to_BusinessSolutionQuotation"/><PropertyValue Property="ReadRestrictions"><Record><PropertyValue Property="Description" String="Retrieves the solution quotation header for a specific object list of a specific service contract item."/><PropertyValue Property="LongDescription" String="Retrieves the details of the solution quotation header for a specific object list of a specific service contract item. The details include transaction type, description, organization data, and so on. Consumers must pass the 