    		<xsd:element name="error" type="tns:errorType1" maxOccurs="1"
    			minOccurs="0">
    		</xsd:element>
    		<xsd:element name="stepID" type="xsd:string" maxOccurs="1" minOccurs="0"></xsd:element>
    	</xsd:sequence>
