															<xs:simpleType>
																<xs:restriction
																	base="xs:string">
																	<xs:enumeration
																		value="SHA1withRSA" />
																	<xs:enumeration
																		value="SHA1withDSA" />
																</xs:restriction>
															</xs:simpleType>
														</xs:attribute>
													</xs:extension>
												</xs:simpleContent>
											</xs:complexType>
										</xs:element>
									</xs:sequence>
									<xs:attribute name="version"
										use="required" fixed="1.0" />
								</xs:complexType>
							</xs:element>
							<xs:element name="TmstFirma"
								type="FechaHoraType">
								<xs:annotation>
									<xs:documentation>
										Fecha y Hora en que se Firmo
