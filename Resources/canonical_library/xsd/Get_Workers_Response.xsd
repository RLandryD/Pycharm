<xsd:documentation>All worker roles will be returned for the person associated with each universal identifier.</xsd:documentation>
</xsd:annotation>
</xsd:element>
</xsd:sequence>
</xsd:complexType>
<xsd:complexType name="Qualified_Domestic_Relations_Order_Replacement_DataType">
