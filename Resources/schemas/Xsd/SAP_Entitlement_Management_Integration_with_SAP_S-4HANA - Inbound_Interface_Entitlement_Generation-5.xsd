              <xsd:element maxOccurs="1" minOccurs="0" name="DocumentType" type="xsd:string"/>
              <xsd:element maxOccurs="1" minOccurs="1" name="DocumentNumber" type="xsd:string"/>
              
              <xsd:element maxOccurs="unbounded" minOccurs="1" name="Item">
