					<xsd:enumeration value="LIBRA EST" />
					<xsd:enumeration value="LIRA" />
					<xsd:enumeration value="MARCO AL" />
					<xsd:enumeration value="MARCO FIN" />
					<xsd:enumeration value="NUEVO SOL" />
					<xsd:enumeration value="OTRAS MONEDAS" />
					<xsd:enumeration value="PESETA" />
					<xsd:enumeration value="PESO" />
					<xsd:enumeration value="PESO CL" />
					<xsd:enumeration value="PESO COL" />
					<xsd:enumeration value="PESO MEX" />
					<xsd:enumeration value="PESO URUG" />
					<xsd:enumeration value="RAND" />
					<xsd:enumeration value="RENMINBI" />
					<xsd:enumeration value="RUPIA" />
					<xsd:enumeration value="SUCRE" />
					<xsd:enumeration value="YEN" />
