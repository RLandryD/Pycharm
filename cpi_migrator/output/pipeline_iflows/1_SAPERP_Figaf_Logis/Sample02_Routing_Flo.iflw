<?xml version="1.0" encoding="UTF-8"?>
<!--
  SCENARIO iFlow: Sample02 Routing Flow
  Display Name : OUT_SAPERP_Figaf_Sample02_Routing_Flo
  Package      : 1_SAPERP_Figaf_Logistics
  Strategy     : GREENFIELD: Clean cloud-native rebuild. No legacy mapping reuse.
  Complexity   : HIGH (score: 43)
  Effort       : 13.4 day(s)
  Sender       : SAPERP (HTTPS)
  Receiver     : Figaf (HTTP)
  Batch        : No
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Sample02_Routing_Flo"
             name="OUT_SAPERP_Figaf_Sample02_Routing_Flo">
  <process id="Sample02_Routing_Flo_process" ifl:type="IntegrationFlow">

    <startEvent id="Start_SC" name="From Interface Separation">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Sample02_Routing_Flo</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>



    <!-- PROCESSDIRECT: Forward to Outbound Delivery -->
    <serviceTask id="CallOutbound_1" name="→ Outbound Delivery" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/outbound/1_SAPERP_Figaf_Logis</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_SC"/>
    <sequenceFlow sourceRef="Start_SC" targetRef="CallOutbound_1"/>
    
    
    <sequenceFlow sourceRef="CallOutbound_1" targetRef="End_SC"/>
  </process>
</definitions>