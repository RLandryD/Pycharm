   <xsd:complexType name="PaymentTermsDiscountType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information on a discount specified in a payment term. Information on discounts that may be applied to the payment depending on the way the payment is being made.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="discountType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Discount Type</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A string value that specifies the type of payment discount for example “2 percent in 10 days, net 30”.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2 percent in 10 days</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="discountAmount" minOccurs="0" type="AmountType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Discount Amount</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The deduction represented as an amount.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 200</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="discountPercent" minOccurs="0" type="xsd:float">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Discount Percent</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The deduction represented as a percentage.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="paymentTimePeriod" type="PaymentTimePeriodType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Payment Time Period</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information on a  payment time period  determining the applicability of the discount.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="discountDescription" minOccurs="0" type="MultiDescription70Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Discount Description</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A text field describing the discount.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
