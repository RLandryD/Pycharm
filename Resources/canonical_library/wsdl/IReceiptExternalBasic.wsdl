    <wsdl:operation name="GetReceiptListBasicV2">
      <wsdl:documentation>&lt;summary&gt;&#13;
            This operation enables the search for a list of receipts based on a given receipt type and a date and time span for when&#13;
            the receipt was changed.&#13;
            &lt;/summary&gt;&#13;
            &lt;param name="systemUserName"&gt;System user name is the relevant agency system name that is registered in Altinn.&lt;/param&gt;&#13;
