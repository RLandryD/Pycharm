                              </xs:complexType>
                            </xs:element>
                            <xs:element name="FieldStatusGroup" type="xs:string" maxOccurs="1" minOccurs="0"/>
                            <xs:element name="ExternalId" type="xs:unsignedInt" maxOccurs="1" minOccurs="0"/>
                          </xs:sequence>
                        </xs:complexType>
                      </xs:element>
                      <xs:element name="Quantity" type="xs:decimal" maxOccurs="1" minOccurs="0"/>
                      <xs:element name="InternalOrder" maxOccurs="1" minOccurs="0"/>
                      <xs:element name="CompanyCode" maxOccurs="1" minOccurs="0"/>
                    </xs:sequence>
                  </xs:complexType>
                </xs:element>
                <xs:element name="NumberInCollection" type="xs:unsignedByte" maxOccurs="1" minOccurs="0"/>
                <xs:element name="Description.Description" type="xs:string" maxOccurs="1" minOccurs="0"/>
                <xs:element name="CommodityCode" maxOccurs="1" minOccurs="0">
                  <xs:complexType>
                    <xs:sequence>
                      <xs:element name="UniqueName" type="xs:string" maxOccurs="1" minOccurs="0"/>
