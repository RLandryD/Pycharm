   <EntityType Name="WorkItem" sap:label="Work Items" sap:content-version="1">
    <Key>
     <PropertyRef Name="ProjectID"/>
     <PropertyRef Name="WorkPackageID"/>
     <PropertyRef Name="WorkPackageName"/>
     <PropertyRef Name="Workitem"/>
