					<xsd:documentation>
						<ccts:DictionaryEntryName xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> Payment Wagetype 2 </ccts:DictionaryEntryName>
						<ccts:DefinitionText xmlns:ccts="urn:un:unece:uncefact:documentation:1.1"> Payment Wagetype 2 </ccts:DefinitionText>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:normalizedString">
					<xsd:length value="4"/>
				</xsd:restriction>
			</xsd:simpleType>
