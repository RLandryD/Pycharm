<xsd:documentation>Transaction Log Entry Data</xsd:documentation>
</xsd:annotation>
</xsd:element>
<xsd:element maxOccurs="unbounded" minOccurs="0" name="Transaction_Log_Corrected_And_Rescinded_Data" type="wd:Event_Target_Transaction_Log_Rescind_And_Correct_DataType"/>
