<?xml version="1.0" encoding="UTF-8"?>
<!--
  PIPELINE STEP 3: Interface Separation iFlow
  Package  : 1_SAP_S4HANA_PostExit_Integration
  Purpose  : Routes to the correct scenario-specific iFlow
             based on SAP_InterfaceName header set by Receiver Determination.
  Internal : ProcessDirect address /pd/InterfaceSeparation_1_SAP_S4HANA_PostExi
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Interface_Separation_1_SAP_S4HANA_PostExi"
             name="Interface_Separation_1_SAP_S4HANA_PostExi">
  <process id="IfaceSep_1_SAP_S4HANA_PostExi_process" ifl:type="IntegrationFlow">

    <startEvent id="Start_IS" name="From Receiver Determination">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/pd/InterfaceSeparation_1_SAP_S4HANA_PostExi</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>

    <!-- ROUTER: Branch to scenario-specific iFlow -->
    <exclusiveGateway id="Router_1" name="Route by Interface Name"/>

    <sequenceFlow id="route_0" sourceRef="Router_1"
      targetRef="Call_Sync_Return_Updates__1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Sync Return Updates with Amazon from S4HANA' -->
    </sequenceFlow>
    <serviceTask id="Call_Sync_Return_Updates__1"
      name="→ Sync Return Updates with Amazon from S4HANA" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Sync_Return_Updates_</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_IS"/>
    <sequenceFlow sourceRef="Start_IS" targetRef="Router_1"/>
  </process>
</definitions>