positive (+) value cannot be assumed, use MEA05 as the nega...</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="20"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_741"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d08d4a91ff311e191ec0026b9aa16ff</xsd:appinfo><xsd:documentation>MEA06| Range Maximum. NOTES: C0604 - If MEA06 is present, then MEA04 is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="20"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_935"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d08d4aa1ff311e198080026b9aa16ff</xsd:appinfo><xsd:documentation>MEA07| Measurement Significance Code. NOTES: L07030506 - If MEA07 is present, then at least one of MEA03, MEA05 or MEA06 is required.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_936"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d08d4ab1ff311e1c0800026b9aa16ff</xsd:appinfo><xsd:documentation>MEA08| Measurement Attribute Code. NOTES: E0803 - Only one of MEA08 or MEA03 may be present.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_752"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">8d08d4ac1ff311e1cfc80026b9aa16ff</xsd:appinfo><xsd:documentation>MEA09| Surface/Layer/Position Code</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_1373"><xsd:annotation><xsd:appi