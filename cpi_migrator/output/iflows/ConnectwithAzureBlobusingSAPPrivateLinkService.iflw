                    <value>ctype::IFlowVariant/cname::IFlowConfiguration/version::1.2.3</value>
                </ifl:property>
        </bpmn2:extensionElements>
        <bpmn2:participant id="Participant_Process_1" ifl:type="IntegrationProcess" name="Integration Process" processRef="Process_1">
            <bpmn2:extensionElements/>
        </bpmn2:participant>
        <bpmn2:participant id="Participant_Recv_1" ifl:type="EndpointRecevier" name="XSUAA-Approuter">
            <bpmn2:extensionElements/>
        </bpmn2:participant>
        <bpmn2:participant id="Participant_Recv_2" ifl:type="EndpointRecevier" name="Azure_Blob">
            <bpmn2:extensionElements/>
        </bpmn2:participant>
        <bpmn2:messageFlow id="MessageFlow_R1" name="HTTP" sourceRef="CallActivity_1" targetRef="Participant_Recv_1">
            <bpmn2:extensionElements><ifl:property><key>Description</key><value></value></ifl:property><ifl:property><key>methodSourceExpression</key><value></value></ifl:property><ifl:property><key>ComponentNS</key><value>sap</value></ifl:property><ifl:property><key>privateKeyAlias</key><value></value></ifl:property><ifl:property><key>httpMethod</key><value>POST</value></ifl:property><ifl:property><key>allowedResponseHeaders</key><value>*</value></ifl:property><ifl:property><key>Name</key><value>HTTP</value></ifl:property><ifl:property><key>TransportProtocolVersion</key><value>1.11.0</value></ifl:property><ifl:property><key>ComponentSWCVName</key><value>external</value></ifl:property><ifl:property><key>proxyPort</key><value></value></ifl:property><ifl:property><key>httpAddressQuery</key><value>grant_type=client_credentials</value></ifl:property><ifl:property><key>httpRequestTimeout</key><value>{{xsuaa_timeout}}</value></ifl:property><ifl:property><key>MessageProtocol</key><value>None</value></ifl:property><ifl:property><key>ComponentSWCVId</key><value>1.11.0</value></ifl:property><ifl:property><key>allowedRequestHeaders</key><value>*</value></ifl:property><ifl:property><key>direction</key><value>Receiver</value></ifl:property><ifl:property><key>ComponentType</key><value>HTTP</value></ifl:property><ifl:property><key>httpShouldSendBody</key><value>false</value></ifl:property><ifl:property><key>throwExceptionOnFailure</key><value>true</value></ifl:property><ifl:property><key>proxyType</key><value>default</value></ifl:property><ifl:property><key>componentVersion</key><value>1.11</value></ifl:property><ifl:property><key>proxyHost</key><value></value></ifl:property><ifl:property><key>system</key><value>XSUAA-Approuter</value></ifl:property><ifl:property><key>authenticationMethod</key><value>Basic</value></ifl:property><ifl:property><key>locationID</key><value></value></ifl:property><ifl:property><key>TransportProtocol</key><value>HTTP</value></ifl:property><ifl:property><key>cmdVariantUri</key><value>ctype::AdapterVariant/cname::sap:HTTP/tp::HTTP/mp::None/direction::Receiver/version::1.11.0</value></ifl:property><ifl:property><key>credentialName</key><value>{{security_material_name}}</value></ifl:property><ifl:property><key>MessageProtocolVersion</key><value>1.11.0</value></ifl:property><ifl:property><key>httpAddressWithoutQuery</key><value>{{xsuaa_url}}</value></ifl:property></bpmn2:extensionElements>
        </bpmn2:messageFlow>
        <bpmn2:messageFlow id="MessageFlow_R2" name="HTTP" sourceRef="CallActivity_4" targetRef="Participant_Recv_2">
            <bpmn2:extensionElements><ifl:property><key>Description</key><value></value></ifl:property><ifl:property><key>methodSourceExpression</key><value></value></ifl:property><ifl:property><key>ComponentNS</key><value>sap</value></ifl:property><ifl:property><key>privateKeyAlias</key><value></value></ifl:property><ifl:property><key>httpMethod</key><value>GET</value></ifl:property><ifl:property><key>allowedResponseHeaders</key><value>*</value></ifl:property><ifl:property><key>Name</key><value>HTTP</value></ifl:property><ifl:property><key>TransportProtocolVersion</key><value>1.11.0</value></ifl:property><ifl:property><key>ComponentSWCVName</key><value>external</value></ifl:property><ifl:property><key>proxyPort</key><value></value></ifl:property><ifl:property><key>httpAddressQuery</key><value>sp=sp&amp;st=st&amp;se=se&amp;spr=https&amp;sv=sv&amp;sr=c&amp;sig=sig</value></ifl:property><ifl:property><key>httpRequestTimeout</key><value>{{approuter_timeout}}</value></ifl:property><ifl:property><key>MessageProtocol</key><value>None</value></ifl:property><ifl:property><key>ComponentSWCVId</key><value>1.11.0</value></ifl:property><ifl:property><key>allowedRequestHeaders</key><value>x-approuter-authorization</value></ifl:property><ifl:property><key>direction</key><value>Receiver</value></ifl:property><ifl:property><key>ComponentType</key><value>HTTP</value></ifl:property><ifl:property><key>httpShouldSendBody</key><value>false</value></ifl:property><ifl:property><key>throwExceptionOnFailure</key><value>true</value></ifl:property><ifl:property><key>proxyType</key><value>default</value></ifl:property><ifl:property><key>componentVersion</key><value>1.11</value></ifl:property><ifl:property><key>proxyHost</key><value></value></ifl:property><ifl:property><key>system</key><value>Azure_Blob</value></ifl:property><ifl:property><key>authenticationMethod</key><value>None</value></ifl:property><ifl:property><key>locationID</key><value></value></ifl:property><ifl:property><key>TransportProtocol</key><value>HTTP</value></ifl:property><ifl:property><key>cmdVariantUri</key><value>ctype::AdapterVariant/cname::sap:HTTP/tp::HTTP/mp::None/direction::Receiver/version::1.11.0</value></ifl:property><ifl:property><key>credentialName</key><value></value></ifl:property><ifl:property><key>MessageProtocolVersion</key><value>1.11.0</value></ifl:property><ifl:property><key>httpAddressWithoutQuery</key><value>{{approuter_url}}</value></ifl:property></bpmn2:extensionElements>
        </bpmn2:messageFlow>
