                            <xs:element nillable="true" minOccurs="0" maxOccurs="1" name="FSMChecklistChangedBy">
                                <xs:simpleType>
                                    <xs:restriction base="xs:string" xmlns="">
                                        <xs:maxLength value="12"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element type="xs:decimal" nillable="true" minOccurs="0" maxOccurs="1" name="FSMChklstLastChangedDateTime" xmlns=""/>
