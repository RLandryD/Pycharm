                 <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                   <xsd:maxLength value="12"/>
                  </xsd:restriction>
                 </xsd:simpleType>
                </xsd:element>
                <xsd:element minOccurs="0" name="HISTO">
                 <xsd:annotation>
                  <xsd:documentation>Historical Record Flag</xsd:documentation>
