            </xsd:simpleType>
           </xsd:attribute>
           <xsd:attribute name="ValorDolares" use="required">
            <xsd:simpleType>
             <xsd:restriction base="xsd:decimal">
              <xsd:pattern value="[0-9]{1,16}(.([0-9]{1,2}))?"/>
              <xsd:minInclusive value="0.00"/>
              <xsd:whiteSpace value="collapse"/>
             </xsd:restriction>
            </xsd:simpleType>
           </xsd:attribute>
          </xsd:complexType>
         </xsd:element>
        </xsd:sequence>
       </xsd:complexType>
      </xsd:element>
     </xsd:sequence>
     <xsd:attribute name="Version" use="required">
      <xsd:simpleType>
