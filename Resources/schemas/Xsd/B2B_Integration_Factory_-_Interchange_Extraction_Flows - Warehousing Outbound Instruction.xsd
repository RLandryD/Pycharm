   <xsd:simpleType name="PackagingConditionCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:PackagingConditionCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="DAMAGED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Damaged</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The packaging needs to be
                  repaired.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="GOOD_CONDITION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Good condition</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The packaging is ready to be
                  used.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="NOT_CLEAN">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Not clean</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The packaging needs to be
                  cleaned.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
