					<xsd:fractionDigits value="5"/>
				</xsd:restriction>
			</xsd:simpleType>
			<xsd:simpleType name="PaytSlipWthRefReference_GFN">
				<xsd:annotation>
					<xsd:documentation xml:lang="EN">POR Reference Number</xsd:documentation>
				</xsd:annotation>
				<xsd:restriction base="xsd:token">
