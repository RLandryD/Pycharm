                <xsd:element minOccurs="0" name="ITXEX">
                 <xsd:annotation>
                  <xsd:documentation>Text Exists for Infotype</xsd:documentation>
                 </xsd:annotation>
                 <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                   <xsd:maxLength value="1"/>
                  </xsd:restriction>
                 </xsd:simpleType>
                </xsd:element>
                <xsd:element minOccurs="0" name="REFEX">
                 <xsd:annotation>
                  <xsd:documentation>Reference Fields Exist (Primary/Secondary Costs)</xsd:documentation>
                 </xsd:annotation>
                 <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                   <xsd:maxLength value="1"/>
                  </xsd:restriction>
                 </xsd:simpleType>
                </xsd:element>
                <xsd:element minOccurs="0" name="ORDEX">
                 <xsd:annotation>
                  <xsd:documentation>Confirmation Fields Exist</xsd:documentation>
                 </xsd:annotation>
                 <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                   <xsd:maxLength value="1"/>
                  </xsd:restriction>
                 </xsd:simpleType>
                </xsd:element>
                <xsd:element minOccurs="0" name="ITBLD">
                 <xsd:annotation>
                  <xsd:documentation>Infotype Screen Control</xsd:documentation>
                 </xsd:annotation>
                 <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                   <xsd:maxLength value="2"/>
                  </xsd:restriction>
                 </xsd:simpleType>
                </xsd:element>
                <xsd:element minOccurs="0" name="PREAS">
                 <xsd:annotation>
