               <xsd:documentation xml:lang="en-US" source="Name">Apply a GS1 Serial Shipping
                  Container Label to the Shipping Containers</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The shipping container the
                  identified product is handled/transported in must be affixed with an SSCC
                  label.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="LIQ">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Trade Item Contains
                  Liquid</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Declaration that trade items
                  containing a liquid be stated. Some transportation companies do not allow
                  shipments containing liquids or require special handling. </xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="LYG">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Lying</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identified product(s)
                  should be kept in a lying position.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MF">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Multiple
                  Facings</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> The item has multiple
                  facings (views) for presentation in the shelf</xsd:documentation>
            </xsd:annotation>
