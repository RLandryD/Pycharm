               <xsd:documentation xml:lang="en-US" source="Name">Tautliner truck and furniture
                  trailer (GS1 Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">TA combined tautliner truck
                  and furniture trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="79">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Refrigerated truck and isothermic
                  trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined refrigerated truck
                  and isothermic trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="79E">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Tautliner truck with removable roof
                  and furniture trailer (GS1 Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined .tautliner truck
                  with removable roof and furniture trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="80">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Freezer truck and refrigerated
                  trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined freezer truck and
                  refrigerated trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="81">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Isothermic truck and refrigerated
                  trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined isothermic truck
                  and refrigerated trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="82">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Rigid truck with tank and tank
                  trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined rigid truck with
                  tank and tank trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="83">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Bulk truck and tank
                  trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined truck capable of
                  carrying liquids or bulk goods and a tank trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="84">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Rigid truck with tank and bulk
                  trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined rigid truck with
                  tank and a trailer capable of carrying liquids or bulk goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="85">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Bulk truck and bulk
                  trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined truck and a
                  trailer both capable of carrying liquids or bulk goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="86">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Tautliner truck and extendable
                  trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined tautliner truck
                  and extendable trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="87">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Tautliner truck with removable roof
                  and extendable trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined tautliner truck
                  with removable roof and extendable trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="88">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Truck with opening floor and
                  extendable trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined truck with opening
                  floor and extendable trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="89">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Bulk truck and extendable
                  trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined truck capable of
                  carrying liquids or bulk goods and an extendable trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="9">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Exceptional
                  transport</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Transport for which common
                  characteristics are not applicable (e.g. big transformers requiring special
                  wagons, special tackles, special routing etc.).</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="90">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Isothermic truck and freezer
                  trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined isothermic truck
                  and freezer trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="91">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Refrigerated truck and freezer
                  trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined refrigerated truck
                  and freezer trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="92">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Tip-up truck and gondola
                  trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined tip-up truck and
                  gondola trailer. A gondola trailer is a split level trailer suitable for the
                  transport of heavy machinery.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="93">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Tautliner truck and gondola
                  trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined tautliner truck
                  and gondola trailer. A gondola trailer is a split level trailer suitable for the
                  transport of heavy machinery.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="93E">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Truck and trailer with opening
                  floor (GS1 Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined truck and a
                  trailer with an opening floor.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="94">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Tautliner truck with removable roof
                  and gondola trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined tautliner truck
                  with removable roof and gondola trailer. A gondola trailer is a split level
                  trailer suitable for the transport of heavy machinery.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="95">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Truck with opening floor and
                  gondola trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined truck with opening
                  floor and gondola trailer. A gondola trailer is a split level trailer suitable for
                  the transport of heavy machinery.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="95E">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Tautliner truck and dolly trailer
                  (GS1 Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined tautliner truck
                  and a dolly trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="96">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Bulk truck and gondola
                  trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined truck capable of
                  carrying liquids or bulk goods and a gondola trailer. A gondola trailer is a split
                  level trailer suitable for the transport of heavy machinery.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="96E">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">A tautliner truck with removable
                  roof and a dolly trailer (GS1 Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined tautliner truck
                  with removable roof and a dolly trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="97">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Tip-up truck and extendable gondola
                  trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined tip-up truck with
                  extendable gondola trailer. An extendable gondola trailer is a trailer fitted with
                  a rear axle which can be extended to cater for variable length and is suitable for
                  the transport of heavy machinery.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="97E">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Truck with trailer (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Combined truck and
                  trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="98">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Tautliner truck and extendable
                  gondola trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined tautliner truck
                  and extendable gondola trailer. An extendable gondola trailer is a trailer fitted
                  with a rear axle which can be extended to cater for variable length and is
                  suitable for the transport of heavy machinery.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="98E">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Truck with crane for moving goods
                  without trailer (GS1 Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A truck with a crane that
                  enables to move goods, without trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="99">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Tautliner truck with removable roof
                  and extendable gondola trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A combined tautliner truck
                  with removable roof and extendable gondola trailer. An extendable gondola trailer
                  is a trailer fitted with a rear axle which can be extended to cater for variable
                  length and is suitable for the transport of heavy machinery.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="99E">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Truck with crane for moving goods
                  with trailer (GS1 Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A truck with a crane that
                  enables to move goods, with trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="TRAILER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Trailer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The general term for trailer
                  to be used where providing the details of a trailer is not relevant or not
                  practical.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="X01">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Truck with crane for lifting goods
                  without trailer (GS1 Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A truck with a crane that
                  enables to lift goods, without trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="X02">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Truck with crane for lifting goods
                  with trailer (GS1 Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A truck with a crane that
                  enables to lift goods, with trailer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="X15">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Armoured Car (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Armoured Car (GS1
                  Code)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="X3">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Truck up to 3,5 tons (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A truck with a total weight
                  up to 3,5 tons.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="X4">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Miscellaneous transport means (GS1
                  Code) </xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"/>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="TransportModeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:TransportModeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="00">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">This code should be
                  avoided</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">This code should be
                  avoided.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="10">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Maritime
                  transport</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">This code should be used
                  whenever the transport vehicle completes any part of ist journey by
                  sea.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="100">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Courier service (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A courier service used to
                  collect and deliver a consignment to its destination.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="20">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Rail transport</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Rail
                  transport</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="30">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Road transport</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Road
                  transport</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="40">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Air transport</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Air
                  transport</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="50">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Mail</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">(Actual mode of transport
                  unknown) - This code is provided for practical reasons, despite the fact that mail
                  is not a genuine mode of transport. In many countries, the value of merchandise
                  exported by mail is considerable, but the exporter or importer concerned would be
                  unable to state by which mode postal items had passed the national
                  border.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="60">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Multimodal
                  transport</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">This code is used when goods
                  are carried to their destination by at least two different modes on the basis of
                  one transport contract. (Local pick-up and delivery of goods out in the
                  performance of a unimodal transport contract shall not be considered as multimodal
                  transport.)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="70">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Fixed transport
                  installations</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">This code applies to
                  installations for continuous transport such as pipelines, ropeways and electric
                  power lines.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="80">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inland water
                  transport</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">This code is used only where
                  carriage is effected entirely by inland water transport.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="TransportPartyRoleCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:TransportPartyRoleCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="CARRIER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Carrier</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A company, which physically
                  transports goods from one place to another.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CONSIGNEE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Consignee</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The person, business, or
                  organisation who is usually the buyer of commodities.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CONSIGNOR">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Consignor</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Party requesting the shipment
                  of the freight/goods. Party responsible for origination of Motor Carrier Bill of
                  Lading.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RECEIVER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Receiver</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A party who engages in
                  receiving goods</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SHIPPER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Shipper</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A party who engages in
                  shipping goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="TransportPaymentMethodCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:TransportPaymentMethodCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="AA">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Cash on delivery service charge
                  paid by consignor</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An indication that the
                  consignor is responsible for the payment of the cash on delivery service
                  charge.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="AB">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Cash on delivery service charge
                  paid by consignee</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An indication that the
                  consignee is responsible for the payment of the cash on delivery service
                  charge.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="AC">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Insurance costs paid by
                  consignor</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An indication that the
                  consignor is responsible for the payment of the insurance
                  costs.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="AD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Insurance costs paid by
                  consignee</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An indication that the
                  consignee is responsible for the payment of the insurance
                  costs.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CA">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Advance collect</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The amount of freight or
                  other charge on a shipment advanced by one transportation line to another or to
                  the shipper, to be collected from consignee.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CC">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Collect</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A shipment on which freight
                  charges will be paid by consignee.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CF">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Collect, freight credited to
                  payment customer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The freight is collect but
                  has been paid by the shipper and will be credited to that
                  party.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DF">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Defined by buyer and
                  supplier</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The payment method for
                  transport charges have been defined by the buyer and seller.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MX">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Mixed</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The consignment is partially
                  collect and partially prepaid.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="NC">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Service freight, no
                  charge</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The consignment is shipped on
                  a service basis and there is no freight charge.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PC">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Prepaid but charged to
                  customer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Shipping charges have been
                  paid in advance of shipment but are charged back to consignee usually as line item
                  on invoice for the purchased goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PO">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Prepaid only</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment in advance of freight
                  and/or other charges prior to delivery of shipment at destination, usually by
                  shipper at point of origin.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PP">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Prepaid (by
                  seller)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Seller of goods makes payment
                  to carrier for freight charges prior to shipment</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PU">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Pickup</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Customer is responsible for
                  payment of pickup charges at shipping point.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RC">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Return container freight paid by
                  customer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The freight for returning the
                  container is paid by the customer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RF">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Return container freight
                  free</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">There is no freight charge
                  for returning the container.</xsd:documentation>
