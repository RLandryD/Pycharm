               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Despatching Manager</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="responsibility" minOccurs="0" maxOccurs="unbounded"
            type="Description70Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Responsibility</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Text further specifying the area of responsibility of the trade contact.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Transport co-ordination</xsd:documentation>
