<xsd:documentation>Boolean attribute identifying whether the leave event has a Payroll Effect.</xsd:documentation>
</xsd:annotation>
</xsd:element>
<xsd:element maxOccurs="1" minOccurs="0" name="Paid_Time_Off_Accrual_Effect" type="xsd:boolean">
