   <xsd:complexType name="InventorySubLocationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">An inventory sub location is a physical subdivision within a warehouse. Examples of physical subdivisions: dock, bin, rack, yard.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="gln" minOccurs="0" type="GLNType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gln</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The Global Location Number (GLN) used to identify the sub location.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="glnExtension" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gln Extension</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Text used to further identify internal physical locations within an inventory sub-location which is identified with a GLN.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="additionalPartyIdentification" minOccurs="0" maxOccurs="unbounded"
            type="AdditionalPartyIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Additional Party Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifier of the sub-location other than the GLN.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="inventorySubLocationTypeCode" minOccurs="0"
            type="InventorySubLocationTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inventory Sub Location Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the primary business function of the physical location.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="inventorySubLocationFunctionCode" minOccurs="0" maxOccurs="unbounded"
            type="InventorySubLocationFunctionCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inventory Sub Location Function Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code that further qualifiers the business function of the inventory sub location. For example frozen area.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="InventorySubLocationTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:InventorySubLocationTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 201</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying an inventory sub-location type. Allowed code values are specified in GS1 Code List InventorySubLocationTypeCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="InventorySubLocationTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="InvoiceDocumentReferenceType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information on an invoice that is referenced in another business document.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">Information identifying a piece of information, such as an object or document.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="entityIdentification">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Entity Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The unique identifier of the piece of information, such as the object id or the document id.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: ABCDE00001</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="contentOwner" minOccurs="0" type="Ecom_PartyIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Content Owner</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="creationDateTime" minOccurs="0" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Creation Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date and time of creation of the referenced document.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15T11:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="revisionNumber" minOccurs="0" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Revision Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number to be used for identification and referencing of subsequent updates to a business document.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="lineItemNumber" minOccurs="0" type="xsd:positiveInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Line Item Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number specifying a line in the referenced document.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="referencedDocumentUrl" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Referenced Document Url</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An URI pointing to the on-line location where the referenced document is stored.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: http://www.company/documentABC</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="invoiceTypeCode" type="InvoiceTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Invoice Type Code</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
