<?xml version="1.0" encoding="utf-8"?>
<wsdl:definitions targetNamespace="http://www.w3.org/2001/XMLSchema"
	xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/" xmlns:xsd="http://www.w3.org/2001/XMLSchema"
	xmlns:soap="http://schemas.xmlsoap.org/wsdl/soap/" xmlns:http="http://schemas.xmlsoap.org/wsdl/http/"
	xmlns:mime="http://schemas.xmlsoap.org/wsdl/mime/" xmlns:tns="http://www.w3.org/2001/XMLSchema"
	xmlns:wsp="http://schemas.xmlsoap.org/ws/2004/09/policy"
	xmlns:wsu="http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-wssecurity-utility-1.0.xsd"
	xmlns:n1="http://www.w3.org/2001/XMLSchema">

	<wsdl:documentation>Banking Services Network Operations - WSDL with no
		policies - meant to be used
		as abstract WSDL
	</wsdl:documentation>
	<wsdl:types>
		<xsd:schema attributeFormDefault="unqualified"
            elementFormDefault="unqualified" targetNamespace="http://www.w3.org/2001/XMLSchema"
			xmlns:xi0="http://www.w3.org/2001/XMLSchema" xmlns:xi1="http://www.w3.org/2001/XMLSchema/"
			xmlns="http://www.w3.org/2001/XMLSchema" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:tns="http://www.w3.org/2001/XMLSchema">
			<xsd:import namespace="http://sapcd.com/invoice" />
			<!--<xsd:element name="cXML" type="xsd:cXML" />-->
			<xsd:element name="cXML" type="cXMLType"/>
			<xsd:complexType name="cXMLType">
			<xsd:sequence>
					<xsd:element name="Header" type="HeaderType"/>
					<xsd:element name="Request" type="RequestType"/>
			</xsd:sequence>
			      <xsd:attribute ref="xml:lang"/>
      <xsd:attribute type="xsd:dateTime" name="timestamp"/>
      <xsd:attribute type="xsd:string" name="payloadID"/>
			</xsd:complexType>
			<xsd:complexType name="HeaderType">
			<xsd:sequence>
              <xsd:element name="From">
                <xsd:complexType>
                  <xsd:sequence>
                    <xsd:element name="Credential" maxOccurs="unbounded" minOccurs="0">
                      <xsd:complexType>
                        <xsd:sequence>
                          <xsd:element type="xsd:int" name="Identity"/>
                        </xsd:sequence>
                        <xsd:attribute type="xsd:string" name="domain" use="optional"/>
                      </xsd:complexType>
                    </xsd:element>
                  </xsd:sequence>
                </xsd:complexType>
              </xsd:element>
              <xsd:element name="To">
                <xsd:complexType>
                  <xsd:sequence>
                    <xsd:element name="Credential" maxOccurs="unbounded" minOccurs="0">
                      <xsd:complexType>
                        <xsd:sequence>
                          <xsd:element type="xsd:string" name="Identity"/>
                        </xsd:sequence>
                        <xsd:attribute type="xsd:string" name="domain" use="optional"/>
                      </xsd:complexType>
                    </xsd:element>
                  </xsd:sequence>
                </xsd:complexType>
              </xsd:element>
              <xsd:element name="Sender">
                <xsd:complexType>
                  <xsd:sequence>
                    <xsd:element name="Credential" maxOccurs="unbounded" minOccurs="0">
                      <xsd:complexType>
                        <xsd:sequence>
                          <xsd:element type="xsd:int" name="Identity"/>
                        </xsd:sequence>
                        <xsd:attribute type="xsd:string" name="domain" use="optional"/>
                      </xsd:complexType>
                    </xsd:element>
                    <xsd:element type="xsd:string" name="UserAgent"/>
                  </xsd:sequence>
                </xsd:complexType>
              </xsd:element>
			</xsd:sequence>
			</xsd:complexType>
			<xsd:complexType name="RequestType">
			<xsd:sequence>
              <xsd:element name="InvoiceDetailRequest">
                <xsd:complexType>
                  <xsd:sequence>
                    <xsd:element name="InvoiceDetailRequestHeader">
                      <xsd:complexType>
                        <xsd:sequence>
                          <xsd:element type="xsd:string" name="InvoiceDetailHeaderIndicator"/>
                          <xsd:element name="InvoiceDetailLineIndicator">
                            <xsd:complexType>
                              <xsd:simpleContent>
                                <xsd:extension base="xsd:string">
                                  <xsd:attribute type="xsd:string" name="isAccountingInLine"/>
                                  <xsd:attribute type="xsd:string" name="isDiscountInLine"/>
                                  <xsd:attribute type="xsd:string" name="isSpecialHandlingInLine"/>
                                  <xsd:attribute type="xsd:string" name="isTaxInLine"/>
                                </xsd:extension>
                              </xsd:simpleContent>
                            </xsd:complexType>
                          </xsd:element>
                          <xsd:element name="InvoicePartner" maxOccurs="unbounded" minOccurs="0">
                            <xsd:complexType>
                              <xsd:sequence>
                                <xsd:element name="Contact">
                                  <xsd:complexType>
                                    <xsd:sequence>
                                      <xsd:element name="Name">
                                        <xsd:complexType>
                                          <xsd:simpleContent>
                                            <xsd:extension base="xsd:string">
                                              <xsd:attribute ref="xml:lang"/>
                                            </xsd:extension>
                                          </xsd:simpleContent>
                                        </xsd:complexType>
                                      </xsd:element>
                                      <xsd:element name="PostalAddress">
                                        <xsd:complexType>
                                          <xsd:sequence>
                                            <xsd:element type="xsd:string" name="Street" maxOccurs="unbounded" minOccurs="0"/>
                                            <xsd:element type="xsd:string" name="City"/>
                                            <xsd:element type="xsd:string" name="State"/>
                                            <xsd:element type="xsd:string" name="PostalCode"/>
                                            <xsd:element name="Country">
                                              <xsd:complexType>
                                                <xsd:simpleContent>
                                                  <xsd:extension base="xsd:string">
                                                    <xsd:attribute type="xsd:string" name="isoCountryCode" use="optional"/>
                                                  </xsd:extension>
                                                </xsd:simpleContent>
                                              </xsd:complexType>
                                            </xsd:element>
                                          </xsd:sequence>
                                        </xsd:complexType>
                                      </xsd:element>
                                    </xsd:sequence>
                                    <xsd:attribute type="xsd:string" name="addressID" use="optional"/>
                                    <xsd:attribute type="xsd:string" name="role" use="optional"/>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element name="IdReference" minOccurs="0">
                                  <xsd:complexType>
                                    <xsd:simpleContent>
                                      <xsd:extension base="xsd:string">
                                        <xsd:attribute type="xsd:string" name="domain"/>
                                        <xsd:attribute type="xsd:string" name="identifier"/>
                                      </xsd:extension>
                                    </xsd:simpleContent>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:complexType>
                          </xsd:element>
                          <xsd:element name="Period">
                            <xsd:complexType>
                              <xsd:simpleContent>
                                <xsd:extension base="xsd:string">
                                  <xsd:attribute type="xsd:dateTime" name="endDate"/>
                                  <xsd:attribute type="xsd:dateTime" name="startDate"/>
                                </xsd:extension>
                              </xsd:simpleContent>
                            </xsd:complexType>
                          </xsd:element>
                          <xsd:element name="Extrinsic">
                            <xsd:complexType>
                              <xsd:simpleContent>
                                <xsd:extension base="xsd:string">
                                  <xsd:attribute type="xsd:string" name="name"/>
                                </xsd:extension>
                              </xsd:simpleContent>
                            </xsd:complexType>
                          </xsd:element>
                        </xsd:sequence>
                        <xsd:attribute type="xsd:dateTime" name="invoiceDate"/>
                        <xsd:attribute type="xsd:string" name="operation"/>
                        <xsd:attribute type="xsd:string" name="purpose"/>
                        <xsd:attribute type="xsd:string" name="invoiceID"/>
                      </xsd:complexType>
                    </xsd:element>
                    <xsd:element name="InvoiceDetailOrder">
                      <xsd:complexType>
                        <xsd:sequence>
                          <xsd:element name="InvoiceDetailOrderInfo">
                            <xsd:complexType>
                              <xsd:sequence>
                                <xsd:element name="OrderIDInfo">
                                  <xsd:complexType>
                                    <xsd:simpleContent>
                                      <xsd:extension base="xsd:string">
                                        <xsd:attribute type="xsd:long" name="orderID"/>
                                      </xsd:extension>
                                    </xsd:simpleContent>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:complexType>
                          </xsd:element>
                          <xsd:element name="InvoiceDetailItem" maxOccurs="unbounded" minOccurs="0">
                            <xsd:complexType>
                              <xsd:sequence>
                                <xsd:element type="xsd:string" name="UnitOfMeasure"/>
                                <xsd:element name="UnitPrice">
                                  <xsd:complexType>
                                    <xsd:sequence>
                                      <xsd:element name="Money">
                                        <xsd:complexType>
                                          <xsd:simpleContent>
                                            <xsd:extension base="xsd:float">
                                              <xsd:attribute type="xsd:string" name="currency" use="optional"/>
                                            </xsd:extension>
                                          </xsd:simpleContent>
                                        </xsd:complexType>
                                      </xsd:element>
                                    </xsd:sequence>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element name="InvoiceDetailItemReference">
                                  <xsd:complexType>
                                    <xsd:sequence>
                                      <xsd:element name="ItemID">
                                        <xsd:complexType>
                                          <xsd:sequence>
                                            <xsd:element type="xsd:string" name="SupplierPartID"/>
                                          </xsd:sequence>
                                        </xsd:complexType>
                                      </xsd:element>
                                      <xsd:element name="Description">
                                        <xsd:complexType>
                                          <xsd:simpleContent>
                                            <xsd:extension base="xsd:string">
                                              <xsd:attribute ref="xml:lang"/>
                                            </xsd:extension>
                                          </xsd:simpleContent>
                                        </xsd:complexType>
                                      </xsd:element>
                                    </xsd:sequence>
                                    <xsd:attribute type="xsd:byte" name="lineNumber" use="optional"/>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element name="SubtotalAmount">
                                  <xsd:complexType>
                                    <xsd:sequence>
                                      <xsd:element name="Money">
                                        <xsd:complexType>
                                          <xsd:simpleContent>
                                            <xsd:extension base="xsd:float">
                                              <xsd:attribute type="xsd:string" name="currency" use="optional"/>
                                            </xsd:extension>
                                          </xsd:simpleContent>
                                        </xsd:complexType>
                                      </xsd:element>
                                    </xsd:sequence>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element name="Tax">
                                  <xsd:complexType>
                                    <xsd:sequence>
                                      <xsd:element name="Money">
                                        <xsd:complexType>
                                          <xsd:simpleContent>
                                            <xsd:extension base="xsd:float">
                                              <xsd:attribute type="xsd:string" name="currency" use="optional"/>
                                            </xsd:extension>
                                          </xsd:simpleContent>
                                        </xsd:complexType>
                                      </xsd:element>
                                      <xsd:element name="Description">
                                        <xsd:complexType>
                                          <xsd:simpleContent>
                                            <xsd:extension base="xsd:string">
                                              <xsd:attribute ref="xml:lang"/>
                                            </xsd:extension>
                                          </xsd:simpleContent>
                                        </xsd:complexType>
                                      </xsd:element>
                                    </xsd:sequence>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element name="GrossAmount">
                                  <xsd:complexType>
                                    <xsd:sequence>
                                      <xsd:element name="Money">
                                        <xsd:complexType>
                                          <xsd:simpleContent>
                                            <xsd:extension base="xsd:float">
                                              <xsd:attribute type="xsd:string" name="currency" use="optional"/>
                                            </xsd:extension>
                                          </xsd:simpleContent>
                                        </xsd:complexType>
                                      </xsd:element>
                                    </xsd:sequence>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element name="NetAmount">
                                  <xsd:complexType>
                                    <xsd:sequence>
                                      <xsd:element name="Money">
                                        <xsd:complexType>
                                          <xsd:simpleContent>
                                            <xsd:extension base="xsd:float">
                                              <xsd:attribute type="xsd:string" name="currency" use="optional"/>
                                            </xsd:extension>
                                          </xsd:simpleContent>
                                        </xsd:complexType>
                                      </xsd:element>
                                    </xsd:sequence>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element name="Distribution">
                                  <xsd:complexType>
                                    <xsd:sequence>
                                      <xsd:element name="Accounting">
                                        <xsd:complexType>
                                          <xsd:sequence>
                                            <xsd:element name="AccountingSegment" maxOccurs="unbounded" minOccurs="0">
                                              <xsd:complexType>
                                                <xsd:sequence>
                                                  <xsd:element name="Name">
                                                    <xsd:complexType>
                                                      <xsd:simpleContent>
                                                        <xsd:extension base="xsd:string">
                                                          <xsd:attribute ref="xml:lang"/>
                                                        </xsd:extension>
                                                      </xsd:simpleContent>
                                                    </xsd:complexType>
                                                  </xsd:element>
                                                  <xsd:element name="Description">
                                                    <xsd:complexType>
                                                      <xsd:simpleContent>
                                                        <xsd:extension base="xsd:string">
                                                          <xsd:attribute ref="xml:lang"/>
                                                        </xsd:extension>
                                                      </xsd:simpleContent>
                                                    </xsd:complexType>
                                                  </xsd:element>
                                                </xsd:sequence>
                                                <xsd:attribute type="xsd:int" name="id" use="optional"/>
                                              </xsd:complexType>
                                            </xsd:element>
                                          </xsd:sequence>
                                          <xsd:attribute type="xsd:string" name="name" use="optional"/>
                                        </xsd:complexType>
                                      </xsd:element>
                                      <xsd:element name="Charge">
                                        <xsd:complexType>
                                          <xsd:sequence>
                                            <xsd:element name="Money">
                                              <xsd:complexType>
                                                <xsd:simpleContent>
                                                  <xsd:extension base="xsd:float">
                                                    <xsd:attribute type="xsd:string" name="currency" use="optional"/>
                                                  </xsd:extension>
                                                </xsd:simpleContent>
                                              </xsd:complexType>
                                            </xsd:element>
                                          </xsd:sequence>
                                        </xsd:complexType>
                                      </xsd:element>
                                    </xsd:sequence>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element name="Extrinsic">
                                  <xsd:complexType>
                                    <xsd:simpleContent>
                                      <xsd:extension base="xsd:string">
                                        <xsd:attribute type="xsd:string" name="name" use="optional"/>
                                      </xsd:extension>
                                    </xsd:simpleContent>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                              <xsd:attribute type="xsd:short" name="quantity" use="optional"/>
                              <xsd:attribute type="xsd:byte" name="invoiceLineNumber" use="optional"/>
                            </xsd:complexType>
                          </xsd:element>
                        </xsd:sequence>
                      </xsd:complexType>
                    </xsd:element>
                    <xsd:element name="InvoiceDetailSummary">
                      <xsd:complexType>
                        <xsd:sequence>
                          <xsd:element name="SubtotalAmount">
                            <xsd:complexType>
                              <xsd:sequence>
                                <xsd:element name="Money">
                                  <xsd:complexType>
                                    <xsd:simpleContent>
                                      <xsd:extension base="xsd:float">
                                        <xsd:attribute type="xsd:string" name="currency"/>
                                      </xsd:extension>
                                    </xsd:simpleContent>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:complexType>
                          </xsd:element>
                          <xsd:element name="Tax">
                            <xsd:complexType>
                              <xsd:sequence>
                                <xsd:element name="Money">
                                  <xsd:complexType>
                                    <xsd:simpleContent>
                                      <xsd:extension base="xsd:float">
                                        <xsd:attribute type="xsd:string" name="currency"/>
                                      </xsd:extension>
                                    </xsd:simpleContent>
                                  </xsd:complexType>
                                </xsd:element>
                                <xsd:element name="Description">
                                  <xsd:complexType>
                                    <xsd:simpleContent>
                                      <xsd:extension base="xsd:string">
                                        <xsd:attribute ref="xml:lang"/>
                                      </xsd:extension>
                                    </xsd:simpleContent>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:complexType>
                          </xsd:element>
                          <xsd:element name="GrossAmount">
                            <xsd:complexType>
                              <xsd:sequence>
                                <xsd:element name="Money">
                                  <xsd:complexType>
                                    <xsd:simpleContent>
                                      <xsd:extension base="xsd:float">
                                        <xsd:attribute type="xsd:string" name="currency"/>
                                      </xsd:extension>
                                    </xsd:simpleContent>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:complexType>
                          </xsd:element>
                          <xsd:element name="NetAmount">
                            <xsd:complexType>
                              <xsd:sequence>
                                <xsd:element name="Money">
                                  <xsd:complexType>
                                    <xsd:simpleContent>
                                      <xsd:extension base="xsd:float">
                                        <xsd:attribute type="xsd:string" name="currency"/>
                                      </xsd:extension>
                                    </xsd:simpleContent>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:complexType>
                          </xsd:element>
                          <xsd:element name="DueAmount">
                            <xsd:complexType>
                              <xsd:sequence>
                                <xsd:element name="Money">
                                  <xsd:complexType>
                                    <xsd:simpleContent>
                                      <xsd:extension base="xsd:float">
                                        <xsd:attribute type="xsd:string" name="currency"/>
                                      </xsd:extension>
                                    </xsd:simpleContent>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:complexType>
                          </xsd:element>
                        </xsd:sequence>
                      </xsd:complexType>
                    </xsd:element>
                  </xsd:sequence>
                </xsd:complexType>
              </xsd:element>
            </xsd:sequence>
            <xsd:attribute type="xsd:string" name="deploymentMode"/>
			</xsd:complexType>
		</xsd:schema>
	</wsdl:types>
	<wsdl:message name="cXML">
		<wsdl:documentation>Message for Invoice Scenario</wsdl:documentation>
		<wsdl:part element="xsd:cXML" name="cXML"/>
	</wsdl:message>

	<wsdl:portType name="invoiceInterface_In">
		<wsdl:operation name="invoiceOperation">
			<wsdl:input message="xsd:cXML" />
		</wsdl:operation>
	</wsdl:portType>
	<wsdl:binding name="invoiceBinding" type="xsd:invoiceInterface_In">
		<soap:binding transport="http://schemas.xmlsoap.org/soap/http"
			style="document" />
		<wsdl:operation name="invoiceOperation">
			<soap:operation soapAction="http://sap.com/xi/WebService/soap1.1" />
			<wsdl:input>
				<soap:body use="literal" />
			</wsdl:input>
		</wsdl:operation>
	</wsdl:binding>
	<wsdl:service name="invoiceService">
		<wsdl:port name="invoicePort" binding="xsd:invoiceBinding">
			<soap:address
				location="https://invoiceflow-hana.ondemand.com/Fieldglass/TS_Invoice" />
		</wsdl:port>
	</wsdl:service>
</wsdl:definitions>