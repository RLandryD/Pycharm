         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:DutyFeeTaxExemptionReasonCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: INTRA_COMMUNITY_DELIVERY</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="DutyFeeTaxExemptionReasonCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="DutyFeeTaxRegistrationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">The registration details of a party related to a particular duty, tax or fee.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="dutyFeeTaxRegistrationID" type="DutyFeeTaxRegistrationIdentifierType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Duty Fee Tax Registration I D</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: BE00369480068</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifier of the party for this particular duty, fee or tax.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dutyFeeTaxTypeCode" minOccurs="0" type="DutyFeeTaxTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Duty Fee Tax Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the type of duty, fee or tax.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dutyFeeTaxAgencyName" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Duty Fee Tax Agency Name</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Agency responsible for the collection of this duty, fee or tax.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Ministry of Finance</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dutyFeeTaxDescription" minOccurs="0" type="Description80Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Duty Fee Tax Description</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Additional description</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Textual description of this duty, fee or tax.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dutyFeeTaxRegistrationType" minOccurs="0"
            type="DutyFeeTaxRegistrationTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Duty Fee Tax Registration Type</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Specifies type of tax registration number assigned by national fiscal authorities. Allowed values come from DutyFeeTaxRegistrationTypeCode list.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="DutyFeeTaxRegistrationTypeCodeType">
      <xsd:simpleContent>
