               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the applicable charge category for this duty, fee or tax. For example low, high, exempt.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="customsWarehouseStatusCode" minOccurs="0"
            type="CustomsWarehouseStatusCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Customs Warehouse Status Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the customs warehouse status of the goods, for  example free circulation.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="customsLicenseCode" minOccurs="0" type="CodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Customs License Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the type of customs license that relates to the customs status of the goods. For example Entrepot Type E.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transactionalReference" minOccurs="0" maxOccurs="unbounded"
            type="TransactionalReferenceType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transactional Reference</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
