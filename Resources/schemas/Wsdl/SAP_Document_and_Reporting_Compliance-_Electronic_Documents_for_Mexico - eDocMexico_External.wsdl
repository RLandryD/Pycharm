   <xsd:import namespace="http://www.sat.gob.mx/sitio_internet/cfd/tipoDatos/tdCFDI"/>
   <xsd:element name="TimbreFiscalDigital">
    <xsd:complexType>
     <xsd:attribute name="Version" use="required" type="xsd:anySimpleType"/>
     <xsd:attribute name="UUID" use="required">
      <xsd:simpleType>
       <xsd:restriction base="xsd:string">
        <xsd:length value="36"/>
        <xsd:pattern value="[a-f0-9A-F]{8}-[a-f0-9A-F]{4}-[a-f0-9A-F]{4}-[a-f0-9A-F]{4}-[a-f0-9A-F]{12}"/>
        <xsd:whiteSpace value="collapse"/>
       </xsd:restriction>
      </xsd:simpleType>
     </xsd:attribute>
     <xsd:attribute name="FechaTimbrado" use="required" type="xi1:t_FechaH"/>
     <xsd:attribute name="RfcProvCertif" use="required" type="xi1:t_RFC_PM"/>
     <xsd:attribute name="Leyenda">
      <xsd:simpleType>
       <xsd:restriction base="xsd:string">
        <xsd:maxLength value="150"/>
        <xsd:minLength value="12"/>
        <xsd:pattern value="([A-Z]|[a-z]|[0-9]| |Ñ|ñ|!|&quot;|%|&amp;|&apos;|´|-|:|;|&gt;|=|&lt;|@|_|,|\{|\}|`|~|á|é|í|ó|ú|Á|É|Í|Ó|Ú|ü|Ü){1,150}"/>
        <xsd:whiteSpace value="collapse"/>
       </xsd:restriction>
      </xsd:simpleType>
     </xsd:attribute>
     <xsd:attribute name="SelloCFD" use="required">
      <xsd:simpleType>
       <xsd:restriction base="xsd:string">
        <xsd:whiteSpace value="collapse"/>
       </xsd:restriction>
      </xsd:simpleType>
     </xsd:attribute>
     <xsd:attribute name="NoCertificadoSAT" use="required">
      <xsd:simpleType>
       <xsd:restriction base="xsd:string">
        <xsd:length value="20"/>
        <xsd:pattern value="[0-9]{20}"/>
        <xsd:whiteSpace value="collapse"/>
       </xsd:restriction>
      </xsd:simpleType>
     </xsd:attribute>
     <xsd:attribute name="SelloSAT" use="required">
      <xsd:simpleType>
       <xsd:restriction base="xsd:string">
        <xsd:whiteSpace value="collapse"/>
       </xsd:restriction>
      </xsd:simpleType>
     </xsd:attribute>
    </xsd:complexType>
   </xsd:element>
  </xsd:schema>
  <xsd:schema targetNamespace="http://www.sat.gob.mx/sitio_internet/cfd/tipoDatos/tdCFDI" xmlns="http://www.sat.gob.mx/sitio_internet/cfd/tipoDatos/tdCFDI" xmlns:xi0="http://www.sat.gob.mx/TimbreFiscalDigital" xmlns:xi1="http://www.sat.gob.mx/sitio_internet/cfd/tipoDatos/tdCFDI">
   <xsd:simpleType name="t_FechaH">
    <xsd:restriction base="xsd:dateTime">
     <xsd:pattern value="(20[1-9][0-9])-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T(([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9])"/>
     <xsd:whiteSpace value="collapse"/>
    </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="t_RFC_PM">
    <xsd:restriction base="xsd:string">
     <xsd:minLength value="12"/>
     <xsd:pattern value="[A-Z&amp;Ñ]{3}[0-9]{2}(0[1-9]|1[012])(0[1-9]|[12][0-9]|3[01])[A-Z0-9]{2}[0-9A]"/>
     <xsd:whiteSpace value="collapse"/>
    </xsd:restriction>
   </xsd:simpleType>
