                  </xs:complexType>
                </xs:element>
                <xs:element name="Description.UnitOfMeasure" maxOccurs="1" minOccurs="0">
                  <xs:complexType>
                    <xs:sequence>
                      <xs:element name="UniqueName" type="xs:string" maxOccurs="1" minOccurs="0"/>
                    </xs:sequence>
                  </xs:complexType>
                </xs:element>
                <xs:element name="Supplier" maxOccurs="1" minOccurs="0">
                  <xs:complexType>
                    <xs:sequence>
                      <xs:element name="UniqueName" type="xs:unsignedInt" maxOccurs="1" minOccurs="0"/>
                      <xs:element name="Name" type="xs:string" maxOccurs="1" minOccurs="0"/>
                    </xs:sequence>
                  </xs:complexType>
                </xs:element>
                <xs:element name="Description.ShortName" type="xs:string" maxOccurs="1" minOccurs="0"/>
              </xs:choice>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element name="StatusString" type="xs:string" maxOccurs="1" minOccurs="0"/>
