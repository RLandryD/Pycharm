</xsd:annotation>
</xsd:element>
<xsd:element maxOccurs="1" minOccurs="0" name="Include_Employment_Information" type="xsd:boolean">
<xsd:annotation>
<xsd:documentation>Indicates if the Employment Data element is included in the response.</xsd:documentation>
</xsd:annotation>
