   <xsd:complexType name="SizeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">A code depicting the size of an object according to a specific code list. The applied code list is specified as additional information together with the size code.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="String80Type">
            <xsd:attribute name="sizeCodeListCode" use="required">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a size code list. Allowed code values are specified in GS1 Code List SizeCodeListCode.</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:SizeCodeListCode</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="80"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
            <xsd:attribute name="sizeCodeListDescription">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">A description of the size code list used to populate the size code for example National Retail Federation – Standard Colour &amp; Size Codes.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="80"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the specified Size Code List.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
            <xsd:attribute name="sizeCodeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">The applied version of the SizeCodeListCode code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="SizeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">The physical dimensions or proportions of an object depicted as a code or a description.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="descriptiveSize" minOccurs="0" type="Description80Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Descriptive Size</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: MEDIUM</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A description of the size of an object.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sizeCode" minOccurs="0" type="SizeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Size Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 42</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the size of an object and the size coding system being applied, for example L (buyer assigned).</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="StringRangeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Provides the difference or interval between a minimum and maximum text value.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="maximumValue" minOccurs="0" type="xsd:string">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Maximum Value</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Specifies the upper limit of the string range.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="minimumValue" minOccurs="0" type="xsd:string">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Minimum Value</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Specifies the lower limit of the string range.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="TargetMarketType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information specifying the geographical area where a trade item is intended to be sold.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="targetMarketCountryCode" type="CountryCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Target Market Country Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The code that identifies the target market. The target market is at country level or higher geographical definition and is where a trade-item is intended to be sold.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="targetMarketSubdivisionCode" minOccurs="0"
            type="CountrySubdivisionCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Target Market Subdivision Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The code for country sub-division definition used to indicate the geo-political subdivision of the target market (=country ).</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="TaxCategoryCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a tax category. Allowed code values are specified in GS1 Code List TaxCategoryCode.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:TaxCategoryCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: STANDARD</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="TaxCategoryCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="TemperatureMeasurementType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Provides temperature measurement value and associated unit of measure code.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="xsd:decimal">
            <xsd:attribute name="temperatureMeasurementUnitCode" use="required"
               type="TemperatureMeasurementUnitCode">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a temperature unit of measure. Allowed code values are specified in GS1 Code List TemperatureMeasurementUnitCode.</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:TemperatureMeasurementUnitCode</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: CEL</xsd:documentation>
               </xsd:annotation>
            </xsd:attribute>
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">The snapshot of the code list at a certain point in time.</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="TemperatureMeasurementUnitCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:TemperatureMeasurementUnitCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: CEL</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a temperature unit of measure. Allowed code values are specified in GS1 Code List TemperatureMeasurementUnitCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="TemperatureMeasurementUnitCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="TemperatureRangeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Provides the difference or interval between the minimum and maximum temperature.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="maximumTemperature" minOccurs="0" type="TemperatureMeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Maximum Temperature</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 28</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Specifies the upper limit of the temperature range.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="minimumTemperature" minOccurs="0" type="TemperatureMeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Minimum Temperature</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 15</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Specifies the lower limit of the temperature range.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="TimeMeasurementType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Provides time measurement value and an associated unit of measure code.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="xsd:decimal">
            <xsd:attribute name="timeMeasurementUnitCode" use="required"
               type="TimeMeasurementUnitCode">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">ode specifying a time unit of measure. Allowed code values are specified in GS1 Code List TimeMeasurementUnitCode.</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:TimeMeasurementUnitCode</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: DAY</xsd:documentation>
               </xsd:annotation>
            </xsd:attribute>
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">The snapshot of the code list at a certain point in time.</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="TimeMeasurementUnitCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">ode specifying a time unit of measure. Allowed code values are specified in GS1 Code List TimeMeasurementUnitCode.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:TimeMeasurementUnitCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: DAY</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="TimeMeasurementUnitCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="TradeItemClassificationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information specifying the product class to which a trade item belongs and the classification system being applied.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="gpcCategoryCode">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gpc Category Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a product category according to the GS1 Global Product Classification (GPC) standard.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="additionalTradeItemClassificationCode" minOccurs="0"
            maxOccurs="unbounded" type="AdditionalTradeItemClassificationCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Additional Trade Item Classification Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Category code based on alternate classification schema chosen in addition to the Global Product Classification (GPC).</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="gpcCategoryName" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gpc Category Name</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Name associated with the specified Global Product Classification (GPC) category code.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="gpcAttribute" minOccurs="0" maxOccurs="unbounded"
            type="GPCAttributeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gpc Attribute</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="TradeItemIdentificationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Provides the GTIN as the unique identifier for the item and optionally additional formats of non GTIN identifiers for the item.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="gtin" type="GTINType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gtin</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Global Trade Item Number (GTIN), the GS1 key used for the identification of trade items.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="additionalTradeItemIdentification" minOccurs="0" maxOccurs="unbounded"
            type="AdditionalTradeItemIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Additional Trade Item Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Alternative means to the Global Trade Item Number to identify a trade item.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="TypedEntityIdentificationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information identifying a piece of information such as an object or document, also specifying the type of information.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">Information identifying a piece of information, such as an object or document.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="entityIdentification">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Entity Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The unique identifier of the piece of information, such as the object id or the document id.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: ABCDE00001</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="contentOwner" minOccurs="0" type="PartyIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Content Owner</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Uniquely identifies the creator of the entity identification.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="entityTypeCode" type="EntityTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Entity Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the type of information being identified, for example a Despatch Advice.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="AdministrativeUnitType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">An organizational grouping used for internal planning, control and accounting purposes.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="administrativeUnitTypeCode" type="AdministrativeUnitTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Administrative Unit Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the type of this administrative unit.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="gln" minOccurs="0" type="GLNType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gln</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The Global Location Number (GLN) identifying this administrative unit.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="internalAdministrativeUnitIdentification" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Internal Administrative Unit Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Internal identifier of this administrative unit.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Sales 22</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="AdministrativeUnitTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:AdministrativeUnitTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: DIVISION</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying an administrative unit type. Allowed code values are specified in GS1 Code List AdministrativeUnitTypeCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="AdministrativeUnitTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="AllowanceChargeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Specifies allowances and charges specified to either the entire message or to individual line items contained in the message.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="allowanceChargeType" type="AllowanceChargeTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Allowance Charge Type</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identification of an allowance charge selected from a predefined list.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="allowanceOrChargeType" type="AllowanceOrChargeEnumerationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Allowance Or Charge Type</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying whether this is an allowance or a charge.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: CHARGE</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="settlementType" type="SettlementTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Settlement Type</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the type of settlement for the allowance or charge.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="allowanceChargeAmount" minOccurs="0" type="AmountType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Allowance Charge Amount</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 300</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Amount of allowance or charge applicable.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="allowanceChargePercentage" minOccurs="0" type="xsd:float">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Allowance Charge Percentage</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Allowance and charges can be expressed in different ways. By using percentage, they are expressed as a percentage of another amount, e.g. the base amount.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 5</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="amountPerUnit" minOccurs="0" type="AmountType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Amount Per Unit</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 15</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Allowance/charge per unit expressed as an amount.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="baseAmount" minOccurs="0" type="AmountType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Base Amount</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 60000</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The amount on which the calculation of the allowance or charge is based.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="baseNumberOfUnits" minOccurs="0" type="MeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Base Number Of Units</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 300</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number of units on which the allowance or charge is based.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="bracketIdentifier" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Bracket Identifier</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identification of the conditions that apply to the allowance or charge.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: N/A</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="effectiveDateType" minOccurs="0" type="EffectiveDateTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Effective Date Type</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the type of date that effectuates the allowance or charge.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sequenceNumber" minOccurs="0" type="xsd:nonNegativeInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sequence Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A unique number used to indicate the order in which the allowances or charges are to be calculated.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="specialServiceType" minOccurs="0" type="SpecialServiceTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Special Service Type</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="allowanceChargeDescription" minOccurs="0" type="MultiDescription70Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Allowance Charge Description</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A text explanation of the allowance or charge.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="AppointmentTimeMeasurementBasisTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying an appointment time measurement basis type. Allowed code values are specified in GS1 Code List AppointmentTimeMeasurementBasisTypeCode.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:AppointmentTimeMeasurementBasisTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: DEADLINE</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="AppointmentTimeMeasurementBasisTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="CargoTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a cargo type. Allowed code values are specified in GS1 Code List CargoTypeCode.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:CargoTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 8</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="CargoTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="CarrierPickUpDropOffDetailsType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information on the logistic service provider, the personnel, and the transport means and equipment that will be used to collect or deliver goods.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="carrier" minOccurs="0" type="TransactionalPartyType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Carrier</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The party that will collect, transport and deliver the goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transportResponsiblePerson" minOccurs="0" maxOccurs="unbounded"
            type="PersonType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transport Responsible Person</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The person responsible for the execution of this pick-up or drop-off, for example the driver.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transportMeans" minOccurs="0" type="TransportMeansType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transport Means</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Details on the transport means used for the transport.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transportEquipment" minOccurs="0" maxOccurs="unbounded"
            type="TransportEquipmentType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transport Equipment</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Details on the transport equipment used for the transport.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="CarrierTrackAndTraceInformationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Tracking and tracing information about the package, provided by the carrier.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="carrierTrackAndTraceURL" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Carrier Track And Trace U R L</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A URL where the carrier provides the tracking and tracing information about the package.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: http://deliverytracking/827456</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="packageTrackingNumber" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Package Tracking Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A unique package tracking number assigned by the carrier</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: ABC28756-k</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="ChildPackageLevelType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information about the hierarchical level and quantity of packaging.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="packageLevelCode" type="PackageLevelCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Package Level Code</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="childPackageLevelQuantity" type="xsd:nonNegativeInteger">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Child Package Level Quantity</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The number of unique trade items of the level specified in the package level code contained in this trade item</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 12</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="CollaborativeTradeItemType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Collaborative Trade Item identifies the product with the buyer and seller locations.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="tradeItemIdentification" type="Ecom_TradeItemIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Trade Item Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identification of this collaborative trade item.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="sellerLocation" type="Ecom_PartyIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Seller Location</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identification of the seller location for this collaborative trade item.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="buyerLocation" type="Ecom_PartyIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Buyer Location</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identification of the buyer location for this collaborative trade item.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="ConsignmentReferenceType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Reference to consignment information</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="consignmentIdentification" type="Ecom_ConsignmentIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Consignment Identification</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="consignor" minOccurs="0" type="Ecom_PartyIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Consignor</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The party despatching a consignment of goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="consignee" minOccurs="0" type="Ecom_PartyIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Consignee</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The party receiving a consignment of goods</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="CreditReasonCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a credit reason. Allowed code values are specified in GS1 Code List CreditReasonCode.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:CreditReasonCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: AGREED_SETTLEMENT</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="CreditReasonCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="CustomsWarehouseStatusCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:CustomsWarehouseStatusCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: BONDED</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a customs warehouse status. Allowed code values are specified in GS1 Code List CustomsWarehouseStatusCode.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="CustomsWarehouseStatusCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="DangerousGoodsAttributeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Hazardous instructions attribute details specific to a particular dangerous goods regulation.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="dangerousGoodsAttributeTypeCode"
            type="DangerousGoodsAttributeTypeCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dangerous Goods Attribute Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the type of dangerous goods attribute.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dangerousGoodsAttributeText" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dangerous Goods Attribute Text</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Textual value of the dangerous goods attribute.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Contains safety information</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dangerousGoodsAttributeMeasurement" minOccurs="0" type="MeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dangerous Goods Attribute Measurement</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 0.02</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Measurement value of the dangerous goods attribute.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dangerousGoodsAttributeIndicator" minOccurs="0" type="xsd:boolean">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dangerous Goods Attribute Indicator</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Boolean value of the dangerous goods attribute.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: True</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dangerousGoodsAttributeDateTime" minOccurs="0" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dangerous Goods Attribute Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date time value of the dangerous goods attribute.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15T11:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="DangerousGoodsAttributeTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a dangerous goods attribute type. Allowed code values are specified in GS1 Code List DangerousGoodsAttributeTypeCode.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:DangerousGoodsAttributeTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: SAFETY_INFORMATION</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="DangerousGoodsAttributeTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="DangerousGoodsInformationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Hazardous instructions applicable to delivered goods, such as where or how specified packages or containers are to be handled because of restriction from dangerous goods.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="dangerousGoodsUNIdentifier" type="IdentifierType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dangerous Goods U N Identifier</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 0049</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number to identify hazardous substances or articles, as defined by United Nations Committee of Experts on the Transport of Dangerous Goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dangerousGoodsShippingName" type="Description200Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dangerous Goods Shipping Name</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: P135</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Shipping name of the trade item (dangerous goods). Regulations provide a list of all acceptable proper shipping names.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dangerousGoodsTechnicalName" minOccurs="0" type="Description200Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dangerous Goods Technical Name</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: CARTRIDGES, FLASH</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A technical name provided for a hazardous good by an organisation or regulation.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dangerousGoodsDescription" minOccurs="0" type="Description1000Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dangerous Goods Description</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Describe dangerous goods</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Description of the hazardous materials.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="contact" minOccurs="0" maxOccurs="unbounded" type="ContactType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Contact</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A contact in relation to the handling of hazardous materials.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dangerousGoodsRegulationInformation" minOccurs="0" maxOccurs="unbounded"
            type="DangerousGoodsRegulationInformationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dangerous Goods Regulation Information</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="DangerousGoodsRegulationCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a dangerous goods regulation. Allowed code values are specified in GS1 Code List DangerousGoodsRegulationCode.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:DangerousGoodsRegulationCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: ADR</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="DangerousGoodsRegulationCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="DangerousGoodsRegulationInformationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Hazardous instructions applicable to delivered goods according to a particular dangerous goods regulation.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="dangerousGoodsRegulationCode" type="DangerousGoodsRegulationCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dangerous Goods Regulation Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An indication of the classification system of dangerous goods and/or the Agency responsible for it.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dangerousGoodsRegulationName" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dangerous Goods Regulation Name</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The name of the classification system of dangerous goods and/or the Agency responsible for it.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: European agreement regarding the total carriage of dangerous goods</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dangerousGoodsHazardClass">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dangerous Goods Hazard Class</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The name of the class within the classification of hazardous materials for example Class A.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Class A</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dangerousGoodsPackingGroup" minOccurs="0">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dangerous Goods Packing Group</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifies the degree of risk these dangerous goods present during transport according to the specified regulation.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: II</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="dangerousGoodsAttribute" minOccurs="0" maxOccurs="unbounded"
            type="DangerousGoodsAttributeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dangerous Goods Attribute</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="DataCarrierTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:DataCarrierTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: EAN_13</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a data carrier type. Allowed code values are specified in GS1 Code List DataCarrierTypeCode.</xsd:documentation>
      </xsd:annotation>
