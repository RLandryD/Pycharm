               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 25.5</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
