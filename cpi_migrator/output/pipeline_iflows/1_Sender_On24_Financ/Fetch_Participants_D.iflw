<?xml version="1.0" encoding="UTF-8"?>
<!--
  SCENARIO iFlow: Fetch Participants Data from Event Provider Platforms into SAP Marketing Cloud
  Display Name : OUT_Sender_On24_Fetch_Participants_D
  Package      : 1_Sender_On24_Finance
  Strategy     : GREENFIELD: Clean cloud-native rebuild. No legacy mapping reuse.
  Complexity   : HIGH (score: 77)
  Effort       : 23.6 day(s)
  Sender       : Sender (HTTPS)
  Receiver     : On24 (HTTP)
  Batch        : No
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Fetch_Participants_D"
             name="OUT_Sender_On24_Fetch_Participants_D">
  <process id="Fetch_Participants_D_process" ifl:type="IntegrationFlow">

    <startEvent id="Start_SC" name="From Interface Separation">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Fetch_Participants_D</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>



    <!-- PROCESSDIRECT: Forward to Outbound Delivery -->
    <serviceTask id="CallOutbound_1" name="→ Outbound Delivery" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/outbound/1_Sender_On24_Financ</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_SC"/>
    <sequenceFlow sourceRef="Start_SC" targetRef="CallOutbound_1"/>
    
    
    <sequenceFlow sourceRef="CallOutbound_1" targetRef="End_SC"/>
  </process>
</definitions>