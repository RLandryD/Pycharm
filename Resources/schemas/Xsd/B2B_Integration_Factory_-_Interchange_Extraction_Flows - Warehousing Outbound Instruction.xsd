            </xsd:annotation>
         </xsd:element>
         <xsd:element name="logisticUnitReference" minOccurs="0" maxOccurs="unbounded"
            type="LogisticUnitReferenceType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Logistic Unit Reference</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The logistic units that hold the trade item subject to the event.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
