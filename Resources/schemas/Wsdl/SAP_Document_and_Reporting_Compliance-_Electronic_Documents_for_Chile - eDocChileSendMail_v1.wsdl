	</wsdl:types>
	<wsdl:message name="SendMailRequest">
		<wsdl:part element="tns:SendMail" name="SendMailRequestParameters" />
	</wsdl:message>
	<wsdl:message name="SendMailResponse">
  </wsdl:message>
	<wsdl:portType name="eDocChileSendMail_v1">
		<wsdl:operation name="SendMail">
			<wsdl:input message="tns:SendMailRequest" />
			<wsdl:output message="tns:SendMailResponse" />
		</wsdl:operation>
	</wsdl:portType>
	<wsdl:binding name="eDocChileSendMail_v1SOAP" type="tns:eDocChileSendMail_v1">
		<soap:binding style="document"
			transport="http://schemas.xmlsoap.org/soap/http" />
