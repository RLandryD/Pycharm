                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A number used to identify
                  references related to third parties.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="XA8">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Credit card number (SWIFT
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A reference number
                  identifying a credit card.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="XB1">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Clearing number (SWIFT
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A reference number
                  identifying a clearing.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="XB5">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Tooling contract number (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number of the tooling
                  contract.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="XB6">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Formula number (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number of the
                  formula.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="XB7">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Pre-agreement number (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number identifying a
                  pre-agreement.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="XB9">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Customs purchase for re-export
                  agreement number (GS1 Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A number assigned to a
                  company by the customs authorities which allows the purchase within a country of
                  goods free of tax because they are to be re-exported immediately after the
                  purchase.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="XC1">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Product certification number (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number assigned by a
                  governing body (or their agents) to a product which certifies compliance with a
                  standard.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="XC3">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Consignment contract number (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Reference number identifying
                  a consignment contract.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="XC5">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Veterinary licence number allocated
                  by a national authority to a slaughterhouse</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Veterinary licence number
                  allocated by a national authority to a slaughterhouse </xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="YA1">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Product specification reference
                  number (GS1 Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number assigned by the issuer
                  to his product specification.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="YA3">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Numbering per year (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Financial statement should be
                  identified consecutively numbered per year.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="YA6">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Bank statement number (SWIFT
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A reference number
                  identifying a bank statement.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="YA9">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Payroll deduction advice reference
                  (GS1 Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A reference number
                  identifying a payroll deduction advice.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="YB4">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Order shipment grouping reference
                  (GS1 Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A reference number
                  identifying the grouping of purchase orders into one shipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="YB7">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Product directory (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A reference to a product
                  characteristics directory.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="YB8">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Debit Letter (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Reference number identifying
                  the letter of debit document.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="YB9">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inventory report request number
                  (GS1 Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Reference number assigned to
                  an inventory report request.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="YC1">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Additional party identification
                  (GS1 Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Reference number to an
                  additional party identification. This number may be the internal trading partner
                  identification number used by a party to identify its trading
                  parties.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="YC3">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Farm approval number (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Veterinary licence number
                  allocated by a national authority to an animal farm.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="YC4">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Cutting plant approval number (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Veterinary licence number
                  allocated by a national authority to a cutting plant.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="YC5">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Slaughterhouse approval number (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Veterinary licence number
                  allocated by a national authority to a slaughterhouse.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="YC6">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Packing Plant Approval number (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Packing Plant Approval number
                  (GS1 Code)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="TransportAppointmentStatusEnumeration">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:TransportAppointmentStatusEnumeration</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="ALLOCATED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Allocated</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Allocation of a pick-up/
                  drop-off slot without prior request.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CONFIRMED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Confirmed</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Confirmation of the pick-up/
                  drop-off slot requested in the Transport Pick-up Drop-off
                  Request.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PICK-UP_AND_DROP_OFF">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Pick-up and Drop
                  off</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The appointment is for both
                  pick-up and drop-off of goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="UPDATED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Updated</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Update of the pick-up/
                  drop-off slot requested in the Transport Pick-Up Dropp-Off
                  Request.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="TransportAppointmentTypeEnumeration">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:TransportAppointmentTypeEnumeration</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="DROP_OFF">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Drop off</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The appointment is for the
                  drop-off of goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PICK-UP">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Pick-up</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The appoinment is for the
                  pick-up of goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="TransportCapacityBookingStatusEnumeration">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:TransportCapacityBookingStatusEnumeration</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="BOOKING_ACCEPTED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Booking
                  Accepted</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The full amount of the
                  requested capacity can be supported.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="BOOKING_REJECTED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Booking
                  Rejected</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The requested capacity cannot
                  be supported.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="TransportChargesPaymentMethodCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:TransportChargesPaymentMethodCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="AA">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Cash on delivery service charge
                  paid by consignor</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An indication that the
                  consignor is responsible for the payment of the cash on delivery service
                  charge.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="AB">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Cash on delivery service charge
                  paid by consignee</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An indication that the
                  consignee is responsible for the payment of the cash on delivery service
                  charge.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="AC">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Insurance costs paid by
                  consignor</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An indication that the
                  consignor is responsible for the payment of the insurance
                  costs.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="AD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Insurance costs paid by
                  consignee</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An indication that the
                  consignee is responsible for the payment of the insurance
                  costs.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="AE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Goods collected from
                  store</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Customer collects goods from
                  the store.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CA">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Advance collect</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The amount of freight or
                  other charge on a shipment advanced by one transportation line to another or to
                  the shipper, to be collected from consignee.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CC">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Collect</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A shipment on which freight
                  charges will be paid by consignee.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CF">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Collect, freight credited to
                  payment customer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The freight is collect but
                  has been paid by the shipper and will be credited to that party. GS1 Description:
                  A shipment on which freight charges will be paid by the
                  consignee.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DF">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Defined by buyer and
                  supplier</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The payment method for
                  transport charges have been defined by the buyer and seller.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MX">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Mixed</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The consignment is partially
                  collect and partially prepaid.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="NC">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Service freight, no
                  charge</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The consignment is shipped on
                  a service basis and there is no freight charge. GS1 Description: No charge is due
                  owing to the use of service freight.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PC">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Prepaid but charged to
                  customer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Shipping charges have been
                  paid in advance of shipment but are charged back to consignee usually as line item
                  on invoice for the purchased goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PO">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Prepaid only</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment in advance of freight
                  and/or other charges prior to delivery of shipment at destination, usually by
                  shipper at point of origin.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PP">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Prepaid (by
                  seller)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Seller of goods makes payment
                  to carrier for freight charges prior to shipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PU">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Pickup</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Customer is responsible for
                  payment of pickup charges at shipping point.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RC">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Return container freight paid by
                  customer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The freight for returning the
                  container is paid by the customer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RF">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Return container freight
                  free</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">There is no freight charge
                  for returning the container.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Return container freight paid by
                  supplier</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The freight charge for
                  returning the container is paid by the supplier.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="TP">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Third party pay</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A third party, someone other
                  than buyer or seller, is identified as responsible for payment of shipping
                  charges.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="WD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Paid by
                  supplier</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Transport charges will be
                  paid by the supplier.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="WE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Paid by buyer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Transport charges will be
                  paid by the buyer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="TransportInstructionFunctionEnumeration">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:TransportInstructionFunctionEnumeration</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="CONSIGNMENT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Consignment</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The transport instruction
                  contains information on one or more consignments to be transported, and optionally
                  also on shipments contained.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SHIPMENT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Shipment</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The transport instruction
                  contains information on one or more shipments to be
                  transported.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="TransportInstructionResponseTypeEnumeration">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:TransportInstructionResponseTypeEnumeration</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="FULLY_ACCEPTED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Fully Accepted</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Fully accepted without
                  amendments (only header information needs to be sent)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="FULLY_ACCEPTED_WITH_AMENDMENTS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Fully Accepted With
                  Amendments</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Fully accepted with
                  amendments/completed details (header and detail information needs to be
                  sent).</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="FULLY_REJECTED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Fully Rejected</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Fully rejected (only header
                  information needs to be sent)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PARTIALLY_ACCEPTED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Partially
                  Accepted</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Partially accepted, partially
                  rejected (header and details information needs to be sent)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="TransportInstructionStatusEnumeration">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:TransportInstructionStatusEnumeration</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="CANCELLED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Cancelled</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The Logistic Services Buyer
                  cancels the instructed shipment/ consignment</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CONFIRMED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Confirmed</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The Logistic Services Seller
                  confirms the instructed shipment/consignment without changes</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MODIFIED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Modified</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The Logistic Services Seller
                  modifies the instructed shipment/ consignment.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="REJECTED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Rejected</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The Logistic Services Seller
                  rejects the instructed shipment/ consignment</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="TransportInstructionStatusReasonCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:TransportInstructionStatusReasonCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token"/>
   </xsd:simpleType>
   <xsd:simpleType name="TransportMeansTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:TransportMeansTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
