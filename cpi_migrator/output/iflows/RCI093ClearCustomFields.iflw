&lt;/span&gt;
&lt;p&gt;
&lt;b&gt;Company:&lt;/b&gt; 1
&lt;/p&gt;
&lt;p&gt;
&lt;b&gt;CPI Process:&lt;/b&gt; ${camelId}
&lt;/p&gt;
&lt;p&gt;
&lt;b&gt;Run Date/Time: ${property.DateTime} &lt;/b&gt; 
&lt;/p&gt;
 
&lt;p&gt;
&lt;b&gt;Error Reason: &lt;/b&gt; ${property.ALERT_REASON}
&lt;/p&gt;
&lt;p&gt;
&lt;b&gt;Error Message: &lt;/b&gt; ${exception.message}
&lt;/p&gt;
 
&lt;p&gt;&lt;i&gt;This is a system-generated email. Please do not reply to this email address.&lt;/i&gt;&lt;/p&gt;</value></ifl:property>
