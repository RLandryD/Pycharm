         <xsd:documentation xml:lang="en-US" source="Definition">Information used to identify an asset.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="giai" type="GIAIType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Giai</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="additionalIndividualAssetIdentification" minOccurs="0"
            maxOccurs="unbounded" type="AdditionalIndividualAssetIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Additional Individual Asset Identification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifier of the asset, specified in addition to the GIAI.</xsd:documentation>
            </xsd:annotation>
