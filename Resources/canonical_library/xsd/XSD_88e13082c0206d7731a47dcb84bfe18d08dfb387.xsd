              <xs:element name="phones">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element type="xs:long" name="number"/>
                    <xs:element type="xs:string" name="type"/>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element type="xs:dateTime" name="registered"/>
        <xs:element type="xs:string" name="socialProviders"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
</xs:schema>
