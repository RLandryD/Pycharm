					<xs:enumeration value="111" />
					<xs:enumeration value="112" />
				</xs:restriction>
			</xs:simpleType>
			<xs:simpleType name="MedioPagoType">
				<xs:annotation>
					<xs:documentation>Medios de Pago</xs:documentation>
