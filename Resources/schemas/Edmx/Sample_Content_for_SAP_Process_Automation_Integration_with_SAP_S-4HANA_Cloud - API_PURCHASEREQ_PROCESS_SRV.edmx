   <Annotations Target="API_PURCHASEREQ_PROCESS_SRV.API_PURCHASEREQ_PROCESS_SRV_Entities/Validate" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Core.Description" String="Performs validation checks on a purchase requisition"/>
    <Annotation Term="Core.LongDescription" String="Performs validation checks on a purchase requisition using the purchase requisition number provided, and returns errors, if any."/>
   </Annotations>
   <Annotations Target="API_PURCHASEREQ_PROCESS_SRV.API_PURCHASEREQ_PROCESS_SRV_Entities/EnableForPurchasing" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Core.Description" String="Transitions external processing status of purchase requisition items, and enables them for purchasing"/>
    <Annotation Term="Core.LongDescription" String="Transitions external processing status of purchase requisition items, and enables them for purchasing using the purchase requisition number and item number provided. If the item number is '00000', then the action is applied on all the items in the purchase requisition. This operation can only be applied on purchase requisition items with external processing status as In Process Externally."/>
   </Annotations>
   <Annotations Target="API_PURCHASEREQ_PROCESS_SRV.API_PURCHASEREQ_PROCESS_SRV_Entities/DiscardFromPurchasing" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Core.Description" String="Transitions external processing status of purchase requisition items, and discards them from purchasing"/>
    <Annotation Term="Core.LongDescription" String="Transitions external processing status of purchase requisition items, and discards them from purchasing using the purchase requisition number and item number provided. If the item number is '00000', then the action is applied on all the items in the purchase requisition. This operation can only be applied on purchase requisition items with external processing status as In Process Externally."/>
   </Annotations>
   <Annotations Target="API_PURCHASEREQ_PROCESS_SRV.API_PURCHASEREQ_PROCESS_SRV_Entities/A_PurchaseRequisitionHeader" xmlns="http://docs.oasis-open.org/odata/ns/edm">
    <Annotation Term="Capabilities.InsertRestrictions">
     <Record>
      <PropertyValue Property="Description" String="Creates a purchase requisition with one or more items"/>
      <PropertyValue Property="LongDescription" String="Creates a purchase requisition with one or more items. If &quot;PurReqnDoOnlyValidation&quot; is set to &quot;True&quot;, it simulates the creation of a purchase requisition, and validates the correctness of the payload. In case the validation fails, it returns the errors in the response."/>
     </Record>
    </Annotation>
   </Annotations>
