               <xsd:documentation xml:lang="en-US" source="Name">Passenger Category Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the role, function or other main characteristic categorizing the type of passenger.</xsd:documentation>
