<?xml version="1.0" encoding="UTF-8"?>
<!--
  PIPELINE STEP 3: Interface Separation iFlow
  Package  : 1_ERP_AribaNetwork_Finance
  Purpose  : Routes to the correct scenario-specific iFlow
             based on SAP_InterfaceName header set by Receiver Determination.
  Internal : ProcessDirect address /pd/InterfaceSeparation_1_ERP_AribaNetwork_F
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Interface_Separation_1_ERP_AribaNetwork_F"
             name="Interface_Separation_1_ERP_AribaNetwork_F">
  <process id="IfaceSep_1_ERP_AribaNetwork_F_process" ifl:type="IntegrationFlow">

    <startEvent id="Start_IS" name="From Receiver Determination">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/pd/InterfaceSeparation_1_ERP_AribaNetwork_F</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>

    <!-- ROUTER: Branch to scenario-specific iFlow -->
    <exclusiveGateway id="Router_1" name="Route by Interface Name"/>

    <sequenceFlow id="route_0" sourceRef="Router_1"
      targetRef="Call_Ariba_cXMLSynchronou_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Ariba_cXMLSynchronousOutboundAdapterMessage_Out' -->
    </sequenceFlow>
    <serviceTask id="Call_Ariba_cXMLSynchronou_1"
      name="→ Ariba_cXMLSynchronousOutboundAdapterMessage_Out" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Ariba_cXMLSynchronou</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_1" sourceRef="Router_1"
      targetRef="Call_Ariba_cXMLGetPending_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Ariba_cXMLGetPendingDataRequest_Out' -->
    </sequenceFlow>
    <serviceTask id="Call_Ariba_cXMLGetPending_1"
      name="→ Ariba_cXMLGetPendingDataRequest_Out" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Ariba_cXMLGetPending</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_IS"/>
    <sequenceFlow sourceRef="Start_IS" targetRef="Router_1"/>
  </process>
</definitions>