				</xs:annotation>
				<xs:attribute name="numero" use="required">
					<xs:annotation>
						<xs:documentation>
							Atributo requerido para expresar el número
							del
							documento aduanero que ampara la
							importación del bien.
						</xs:documentation>
					</xs:annotation>
					<xs:simpleType>
						<xs:restriction base="xs:string">
							<xs:minLength value="1" />
