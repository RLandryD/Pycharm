<?xml version="1.0" encoding="UTF-8"?>
<!--
  PIPELINE STEP 3: Interface Separation iFlow
  Package  : 1_S4_SubscriptionBilling__Finance
  Purpose  : Routes to the correct scenario-specific iFlow
             based on SAP_InterfaceName header set by Receiver Determination.
  Internal : ProcessDirect address /pd/InterfaceSeparation_1_S4_SubscriptionBil
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Interface_Separation_1_S4_SubscriptionBil"
             name="Interface_Separation_1_S4_SubscriptionBil">
  <process id="IfaceSep_1_S4_SubscriptionBil_process" ifl:type="IntegrationFlow">

    <startEvent id="Start_IS" name="From Receiver Determination">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/pd/InterfaceSeparation_1_S4_SubscriptionBil</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>

    <!-- ROUTER: Branch to scenario-specific iFlow -->
    <exclusiveGateway id="Router_1" name="Route by Interface Name"/>

    <sequenceFlow id="route_0" sourceRef="Router_1"
      targetRef="Call_BP_confirmation_from_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'BP confirmation from SAP S4HANA to SAP Subscription Billing' -->
    </sequenceFlow>
    <serviceTask id="Call_BP_confirmation_from_1"
      name="→ BP confirmation from SAP S4HANA to SAP Subscription Billing" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/BP_confirmation_from</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_IS"/>
    <sequenceFlow sourceRef="Start_IS" targetRef="Router_1"/>
  </process>
</definitions>