            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="40E">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Marked with unit net weight (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Indication that the net unit
                  weight has been marked on a package.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="41E">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Marked with packaging date (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Indication that the packaging
                  date has been marked on a package.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="41G">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Marked with GS1 Global Returnable
                  Asset Identifier (GS1 Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Indication that the GS1
                  Global Returnable Asset Identifier has been marked on the
                  package.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="X26">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Not marked with a GS1 code (GS1
                  Code)</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Indication that the package
                  is not marked with a GS1 code.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="PassengerCategoryCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:PassengerCategoryCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="ATTENDANT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Attendant</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Passenger is an attendant for
                  the transport.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DRIVER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Driver</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Passenger is a driver for the
                  transport.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="FAMILY_MEMBER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Family member</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Passenger does not have an
                  official role in the transport.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="GUARD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Guard</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Passenger is a guard for the
                  transport.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="PaymentFormatCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:PaymentFormatCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="CCD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Cash Concentration or
                  Disbursement</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Cash Concentration or
                  Disbursement can be either an ACH (Automated Clearing House) credit or debit where
                  funds are transferred between corporate entities. It is used for concentration of
                  funds between or within companies. CCD is the only corporate ACH format that does
                  not have space for additional addenda information.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CCP">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Cash Concentration / Disbursement
                  plus addenda</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Cash Concentration /
                  Disbursement plus addenda combines the CCD format with a single addendum record
                  that can carry 80 characters. Often referred to also as CCD+.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CTX">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Corporate Trade
                  Exchange</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Corporate Trade Exchange
                  supports transferring of funds, either credits or debits, within a trading partner
                  relationship. Unlike CCD and CCP, CTX is capable of transmitting extensive
                  remittance data along with transactions.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PPD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Prearranged Payment and Deposit
                  Entry</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Prearranged Payment and
                  Deposit Entry is a format by which consumers may authorize credits or debits to
                  their accounts by a company or Financial Institution use.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PPP">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Prearranged Payment and Deposit
                  plus Addenda</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Prearranged Payment and
                  Deposit plus Addenda combines the PPD format with a single addendum record that
                  can carry 80 characters. Often referred to also as PPD+.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="PaymentMethodCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:PaymentMethodCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="FUEL_CARD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Fuel card</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A payment card used most
                  commonly for gasoline, diesel, and other fuels at fuel
                  stations.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="BANK_CHEQUE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment by a pre-printed
                  form, which has been completed by a financial institution, on which instructions
                  are given to an account holder (a bank or building society) to pay a stated sum to
                  a named recipient.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="BANK_GIRO">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The payment was originally
                  made by bankgiro.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="BANKERS_DRAFT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Issue of a banker's draft in
                  payment of the funds.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="BOOKENTRY_CREDIT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">A credit entry between two accounts
                  at the same bank branch. Synonym</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">house
                  credit.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="BOOKENTRY_DEBIT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">A debit entry between two accounts
                  at the same bank branch. Synonym</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">house
                  debit.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="BOP">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Not
                  Available</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CASH">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment by currency
                  (including bills and coins) in circulation, including checking account
                  deposits.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CERTIFIED_CHEQUE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment by a pre-printed form
                  stamped with the paying bank's certification on which instructions are given to an
                  account holder (a bank or building society) to pay a stated sum to a named
                  recipient .</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CHEQUE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment by a pre-printed form
                  on which instructions are given to an account holder (a bank or building society)
                  to pay a stated sum to a named recipient.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CREDIT_CARD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment by means of a card
                  issued by a bank or other financial institution.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DEBIT_CARD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The amount is to be, or has
                  been, directly debited to the customer's bank account through a bank
                  card.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ELECTRONIC_CREDIT_ACH">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">A credit transaction made
                  through the automated clearing house system</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ELECTRONIC_DEBIT_ACH">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">A debit transaction made
                  through the automated clearing house system.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="FED_WIRE_NON_REPETITIVE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Fedwire is a real time gross
                  settlement funds transfer system operated by the Federal Reserve Banks that
                  enables financial institutions to electronically transfer funds between its
                  participants.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="FED_WIRE_REPETITIVE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Fedwire is a real time gross
                  settlement funds transfer system operated by the Federal Reserve Banks that
                  enables financial institutions to electronically transfer funds between its
                  participants.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="INTERNATIONAL_WIRE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Not
                  Available</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="LETTER_OF_CREDIT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The financial operation is a
                  letter of credit.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="OTHER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Other</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment method not specified
                  otherwise.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="POSTGIRO">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The financial operation has
                  been done by postgiro.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="WIRE_TRANSFER_CREDIT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Not
                  Available</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="WIRE_TRANSFER_DEBIT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Not
                  Available</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="PaymentTermsEventCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:PaymentTermsEventCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="AFTER_DATE_OF_DELIVERY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">After date of
                  delivery</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Any date after the date the
                  goods are delivered at agreed place of destination.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ANTICIPATED_DELIVERY_DATE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Anticipated delivery
                  date</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The date on which delivery is
                  anticipated to take place.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DATE_INVOICE_RECEIVED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Date invoice
                  received</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment time reference is
                  date of invoice received.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DATE_OF_DELIVERY_TO_SITE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Date of delivery to
                  site</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date the goods are delivered
                  at agreed place of destination.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DATE_OF_INVOICE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Date of invoice</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment time reference is
                  date of invoice.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DATE_OF_SHIPMENT_AS_EVIDENCED_BY_TRANSPORT_DOCUMENTS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Date of shipment as evidenced by
                  transport documents</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date of shipment as evidenced
                  by the transport document(s).</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="EFFECTIVE_DATE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Effective date</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The date on which an action
                  or event becomes effective.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="INVOICE_TRANSMISSION_DATE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Invoice transmission
                  date</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The date that the invoice is
                  transmitted from the invoicing party.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PRIOR_TO_DATE_OF_DELIVERY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Prior to date of
                  delivery</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Any date before the date the
                  goods are delivered at agreed place of destination.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RECEIPT_OF_GOODS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Receipt of
                  goods</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The date of the receipt of
                  goods by recipient.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="PaymentTermsTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:PaymentTermsTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="1">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Basic</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment conditions normally
                  applied.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="10">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Instant</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment term is due on
                  receipt of invoice.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="11">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Elective</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment term is to be chosen
                  by buyer (from options separately advised).</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="18">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Previously Agreed
                  Upon</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment term is previously
                  agreed upon.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="2">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">End Of Month</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment term is end of
                  month.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="20">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Penalty Terms</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment terms on which
                  penalties apply. Penalty terms apply in case of non compliance to agreed payment
                  terms.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="21">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Payment By
                  Installment</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment term is payment by
                  installment.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="22">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Discount</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment term is
                  discount.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="3">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Fixed Date</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment term is fixed
                  date.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="4">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Deferred</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment term is
                  deferred.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="5">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Discount Not
                  Applicable</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment term is discount not
                  applicable.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="6">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Mixed</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Different payment terms
                  negotiated under a documentary credit.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="7">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Extended</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment term is
                  extended.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="8">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Basic Discount
                  Offered</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment term is basic
                  discount offered.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="9">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Proximo</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment term is in the next
                  month after present.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="X11">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Valuta</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Value date, which is a
                  prolongation of the terms for payment</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="X12">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Discount After Deducting
                  Freight</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Payment term is discount
                  after deducting freight. (New code)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="X13">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">No Charge</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">There is no charge associated
                  to the payment term. (New code)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="PerformanceMeasureTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:PerformanceMeasureTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="FINISHED_GOODS_INVENTORY_COVER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Finished goods inventory
                  cover</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The amount of finished goods
                  inventory at the stocking location (or locations) in terms of the estimated daily
                  demand.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="FORECAST_ACCURACY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Forecast accuracy </xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The mean absolute percent
                  agreement of the forecast with the actual sales, receipt or shipment quantity,
                  expressed in unit volume or monetary terms.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="INVOICE_ACCURACY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Invoice
                  accuracy</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The percentage of seller
                  invoices deemed accurate out of all invoices received</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ITEM_DATA_SYNCHRONISATION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Item data
                  synchronisation</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The percentage of items
                  (including applicable trade item hierarchy) published and sold from the seller
                  that are synchronised by the buyer via the Global Data Synchronisation Network
                  (GDSN).</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ITEM_MASTER_DATA_ACCURACY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Item master data
                  accuracy</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The percentage of items with
                  accurate physically measured dimensions and weight attributes (as provided by the
                  seller) out of all items that were physically verified.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MARKDOWN">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Markdown</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The percentage of monetary
                  sales that were sold at below the normal retail price (that can include but not
                  exclusive to) seasonal clearance, discontinuation, employee discount, response to
                  competitive activity or other retailer-initiated price
                  reductions.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ON_TIME_DELIVERY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">On time
                  delivery</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The percentage of shipments
                  that arrived on the receiver's premises within the agreed date time out of all
                  shipments that were delivered. The first scheduled appointment date time is the
                  recommended agreed date time, and the complete agreed date time list is available
                  in the parameter table.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ON_TIME_PAYMENT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">On time payment</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The percentage of payments
                  made within a seller's terms of sale out of all payments
                  received.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ORDER_ITEM_QUANTITY_CHANGE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Order item quantity
                  change</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The percentage of orders
                  placed by the customer in the trading relationship that required changes in items
                  or item quantities prior to release.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ORDER_TO_DELIVERY_CYCLE_TIME">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Order to delivery cycle
                  time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The average length of time
                  between order placement (fax, phone, EDI) and the time product arrived and was
                  available for unloading at the agreed customer location.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="OUT_OF_STOCK">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Out of stock</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The percentage of items that
                  is not available at their expected stocking locations out of the set of item
                  stocking locations that were evaluated.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RETAIL_GROSS_PROFIT_MARGIN">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Retail gross profit
                  margin</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The average percentage amount
                  a Retailer will profit per item or group of items sold to a consumer after
                  deducting operating expenses.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RETAIL_ITEM_GROSS_MARGIN">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Retail item gross
                  margin</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The average percentage amount
                  a Retailer will earn for an item sold to a consumer before deducting operating
                  expenses</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SALES_GROWTH">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sales growth</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The percentage increase in
                  monetary or unit sales compared to an equivalent time period one year prior to the
                  period being measured</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SERVICE_LEVEL_FILL_RATE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Service level fill
                  rate</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The percentage of product
                  that a buyer received or the seller shipped compared to the original ordered
                  quantity</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SHARE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Share</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The percentage of sales of a
                  subset of items and / or locations in a broader market context, which can be
                  defined in terms of a product category, class of trade or
                  geography.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="UNSALEABLES">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Unsaleables</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The percentage of products
                  that were removed from the primary channel of distribution due to damage,
                  expiration, discontinuation, seasonality, promotion completion or
                  defects.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="PeriodicityTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:PeriodicityTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="DAY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Day</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">24-hour
                  day</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="HOUR">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Hour</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A period of time equal to
                  1/24th of a day</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MONTH">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Month</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Calendar
                  month</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="QUARTER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Quarter</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">3-month
                  period</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="WEEK">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Week</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Seven day
                  week</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="YEAR">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Year</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">12-month
                  period</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="PhysicalOrLogicalStateDescriptionCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:PhysicalOrLogicalStateDescriptionCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token"/>
   </xsd:simpleType>
   <xsd:simpleType name="PlanBucketSizeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:PlanBucketSizeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="DAY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Day</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information requested in
                  daily buckets.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MONTH">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Month</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information requested in
                  monthly buckets.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="QUARTER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Quarter</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information requested in
                  quarterly buckets.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="UNSPECIFIED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Unspecified</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information may be provided
                  in whatever time format that is available.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="WEEK">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Week</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information requested in
                  weekly buckets</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="YEAR">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Year</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Information requested in
                  yearly buckets.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="PlanCommitmentLevelCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:PlanCommitmentLevelCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="FLUID">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Fluid</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">No
                  commitment.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="FROZEN">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Frozen</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Quantities per bucket are now
                  fixed and should not change.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SLUSH">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Slush</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Some level of commitment that
                  quantities will not radically change.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="PrintingInstructionCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:PrintingInstructionCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="PRINT_ON_DELIVERY_NOTE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Print on delivery
                  note</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The provided text is to be
                  printed on the delivery note.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PRINT_ON_MANIFEST">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Print on
                  manifest</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The provided text is to be
                  printed on the manifest.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PRINT_ON_PACKING_LIST">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Print on packing
                  list</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The provided text is to be
                  printed on the packing list.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="ProductionMethodForFishAndSeafoodCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:ProductionMethodForFishAndSeafoodCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="AQUACULTURE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Aquaculture</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Refers to any technology or
                  facility used for the harvesting and/or production of aquatic resources within
                  controlled environments. Examples of aquaculture include fish, oyster and shrimp
                  farming, seaweed farming and aquaponics. The term aquaculture is mutually
                  exclusive with “Inland Fishery” and “Marine Fishery” given that aquaculture always
                  involves in a controlled environment and not catch or production in the
                  wild.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="INLAND_FISHERY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inland Fishery</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Any industrial or
                  small-scale/artisanal or recreational fishery devoted to the harvesting in the
                  wild of aquatic resources operating on inland freshwater ecosystems including both
                  fresh or limnetic waters. Inland freshwater ecosystems are any that include
                  natural flowing or lotic waters such as rivers or streams (including their smaller
                  elements such as springs, brooks, rivulets, or rills), artificial canals, and
                  static or lenitic waters such as natural lakes and tarns and artificial lakes or
                  reservoirs such as rivers, lakes, etc. </xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MARINE_FISHERY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Marine Fishery</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Any industrial or
                  small-scale/artisanal or recreational fishery devoted to the harvesting in the
                  wild of aquatic resources operating on marine saltwater ecosystems (i.e. open
                  sea/pelagic zone).</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="ProductRecallIncidentRiskLevelCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:ProductRecallIncidentRiskLevelCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="CLASS_1">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">not defined</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Class 1 recalls are for
                  dangerous or defective products that predictably could cause serious health
                  problems or death.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CLASS_2">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">not defined</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Class 2 recalls are for
                  products that might cause a temporary health problem, or pose only a slight threat
                  of a serious nature. One example is a drug that is under-strength but that is ot
                  used to treat life-threatening situations.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CLASS_3">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">not defined</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Class 3 recalls are for
                  products that are unlikely to cause any adverse health reaction, but that violate
                  FDA labeling or manufacturing regulations. Examples might be a container defect
                  (plastic material delaminatng or a lid that does not seal)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="ProductRecallNotificationStatusEnumeration">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:ProductRecallNotificationStatusEnumeration</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="CLOSED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Product Recall Notification,
                  Product Removal or Product Close Out which has been processed and closed
                  out.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DRAFT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Product Recall Notification,
                  Product Removal or Product Close Out which has not been approved for
                  issue.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ISSUED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Product Recall Notification,
                  Product Removal or Product Close Out which has been approved and
                  issued.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="ProductRecallNotificationVersionStatusEnumeration">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:ProductRecallNotificationVersionStatusEnumeration</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="INITIAL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">An initial PRN is issued to
                  initiate the product recall.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="UPDATE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">An update can be sent to
                  communicate changes to the initial PRN.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="ProductRecallReasonCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:ProductRecallReasonCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="ALLERGY_HAZARD_EGG">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  an allergy hazard which involves egg and egg products.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ALLERGY_HAZARD_FISH">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  an allergy hazard which involves fish and fish products.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ALLERGY_HAZARD_GLUTEN">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  an allergy hazard which involves gluten or gluten derived
                  products</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ALLERGY_HAZARD_MILK">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  an allergy hazard which involves milk and milk products.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ALLERGY_HAZARD_PEANUTS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  an allergy hazard which involves peanuts and peanut products.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ALLERGY_HAZARD_SHELLFISH">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  an allergy hazard which involves shellfish and shellfish
                  products.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ALLERGY_HAZARD_SOY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  an allergy hazard which involves soy and soy products.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ALLERGY_HAZARD_TREE_NUTS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  an allergy hazard which involves tree nuts and tree nut
                  products.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ALLERGY_HAZARD_WHEAT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  an allergy hazard which involves wheat and wheat products.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CHEMICAL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  due to chemical reasons.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DEIGN_FAULT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  due to a default in the design of the product.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DIRECTIVE_FROM_REGULATORY_AGENCY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  due to a directive from a regulatory agency.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MISLABELED_PRODUCT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  due to a mislabeled product.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="OTHER_PLEASE_SPECIFY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  other reasons.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PATHOGEN_BACTERIA_BOTULISM">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  the pathogen bacteria Botulism.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PATHOGEN_BACTERIA_ECOLI_STEC">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  the pathogen bacteria E. Coli (STEC).</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PATHOGEN_BACTERIA_LISTERIA_MONOCYTOGENES">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  the pathogen bacteria Listeria monocytogenes.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PATHOGEN_BACTERIA_OTHER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for this recall is
                  the pathogen bacteria not listed in this code list.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PATHOGEN_BACTERIA_SALMONELLA">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  the pathogen bacteria Salmonella</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PATHOGEN_BACTERIA_SHIGELLA">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  the pathogen bacteria Shigella</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PATHOGEN_VIRUS_HEPATITIS_A">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  the pathogen virus Hepatitus A.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PATHOGEN_VIRUS_OTHER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  the pathogen virus not listed in this code list.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PATHOGEN_VIRUS_OTHER_NOROVIRUS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  the pathogen virus Norovirus.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PHYSICAL_GLASS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  an physical hazard which involves glass and glass products.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PHYSICAL_METAL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  a physical hazard which involves metal and metal products.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PHYSICAL_OTHER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  a physical hazard which involves components not listed in this code
                  list.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PHYSICAL_PLASTIC">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  a physical hazard which involves plastic and plastic products.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PHYSICAL_WOOD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  a physical hazard which involves wood and wood products.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="QUALITY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  due to quality.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="TAMPERING">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  due to tampering</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="UNAUTHORIZED_DISTRIBUTION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  due to unauthorized distribution</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="UNKNOWN">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The reason for the recall is
                  either unknown or is not specified.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="ProductRecallReimbursementReasonCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:ProductRecallReimbursementReasonCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="DM_DEFECTIVE_MERCAHNDISE_OR_STORE_INSEPCTION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">When product or traceable
                  item has been damaged it is the reason for the return and
                  reimbursement.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DP_DEFECTIVE_PACKAGING">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">When product or traceable
                  item has damage to the container or package and is the reason it is being returned
                  for reimbursement.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DR_DEFECTIVE_MERCHANDISE_OR_RETURNED_BY_CUSTOMER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">When the user or customer of
                  a product or traceable item has brought back the product or trade
                  item,</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="LP_LABEL_PROBLEM">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">When a product or traceable
                  item has issues with the label it is a reason for it to be returned to the
                  supplier/manufacture.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SP_SHIPPED_PAST_CANCEL_DATE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The product or traceable item
                  has been returned to the supplier / manufacturer because it is outside the
                  delivery schedule and cannot be processed (used or sold) because the merchandise
                  was receive after the canceled delivery date.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="ProductRecallTrackingTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:ProductRecallTrackingTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="BATCH_LOT_CODE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">An alpha/numeric value
                  identifying a specific batch or lot of the traceable item.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="BEST_BEFORE_DATE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The date the traceable item's
                  quality or freshness can no longer be guaranteed. (synonym- Best Used
                  By)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CLOSED_CODE_DATE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The manufacture assigned
                  coded date.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="EXPIRY_DATE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The date the traceable item
                  should no longer be consumed</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="HARVEST_DATE_CODE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Date when traceable item was
                  harvested or picked</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="OTHER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Allows the user to specifiy
                  the tracking code type by being used on the traceable item.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PURCHASED_BY_DATE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The date the traceable item
                  is to be purchase by.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SELL_BY_DATE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The date the traceable item
                  is to be sold by.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SERIAL_NUMBER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">An alpha/numeric value
                  identifying a unique instance of the traceable item.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="PurchaseConditionsCommitmentTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:PurchaseConditionsCommitmentTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="DELIVERY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Committed to be
                  delivered.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PRODUCTION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Committed to be
                  produced.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="QualityControlCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:QualityControlCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="CHECK_AT_INBOUND">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Check At
                  Inbound</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Quality needs to be
                  controlled for incoming goods</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CHECK_AT_OUTBOUND">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Check At
                  Outbound</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Quality needs to be
                  controlled for outgoing goods</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="QUALITY_CONTROL_NOT_REQUIRED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Quality Control Not
                  Required</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Quality control is not
                  needed</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="QuantitySpecificationTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:QuantitySpecificationTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="IN_TRANSIT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">In transit</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Quantity of goods in transit
                  to recipient.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ON_HAND">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">On hand</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Quantity of goods physically
                  available</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ON_HOLD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">On hold</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Quantity of goods not
                  available for immediate release</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PRODUCED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Produced</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Quantity produced so
                  far.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RECEIVED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Received</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Quantity received so
                  far.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="TO_BE_DELIVERED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">To be delivered</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Quantity to be
                  delivered.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="TO_BE_DESPATCHED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">To be
                  despatched</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Quantity to be
                  despatched.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="TO_BE_PRODUCED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">To be produced</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Quantity to be
                  produced.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="ReadingMethodCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:ReadingMethodCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="CALCULATED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Calculated</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Metering unit consumption
                  value has been calculated</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MANUAL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Manual</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Metering unit consumption
                  value has been read by a human individual</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="ReasonCodeForCpvCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:ReasonCodeForCpvCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="ADD_ADDITIONAL_LANGUAGE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Add Additional
                  Language</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Used to identify the addition
                  of one or more languages to the product’s primary language.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ADDITIONAL_DECLARED_NET_CONTENT_UOM">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Additional Declared Net
                  Content</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Used to identify an
                  additional net content to provide an additional expression of the same net
                  content. </xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MARKETING_DECLARATIONS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Marketing
                  Declarations</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Used to identify a marketing
                  declaration such as “Improved Scent” and “Lasts 2x longer”… which are designed to
                  impact consumer decisions.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MINOR_ARTWORK_CHANGES">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Minor Artwork
                  Changes</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Used to identify an artwork
                  change to the package artwork to promote or market the
                  product.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MINOR_FORMULATION_CHANGE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Minor Formulation
                  Change</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Used to identify a small
                  change of formulation (example: a change to a type of oil that does not impact
                  allergen claims but may impact consumer decisions or online
                  information)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MINOR_PRODUCT_MARKETING_VARIATION_GENERAL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Minor Product Marketing Variation
                  General</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A minor change to the product
                  (physical artwork or digitally relevant) to the consumer that the manufacturer
                  would like to share end to end. </xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PACKAGING_WITH_MINOR_IMPACT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Packaging with Minor
                  Impact</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Used to identify a change to
                  the dimensions (H W D) of a product that is less than 20%. Changing packaging
                  dimensions less than 20% may still have an impact on consumer decision in certain
                  product categories.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PRODUCED_IN_DIFFERENT_LOCATIONS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Produced In Different
                  Locations</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Used to identify when a
                  country of origin must be distinguished and declared, but a new GTIN is not
                  required (apparel), CPV allows for that sharing. Likely to impact consumer
                  decisions in many product categories.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PRODUCT_NAME_AND_DESCRIPTION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Product Name and
                  Description</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Used to identify a change in
                  name or description of a product (example: from “Spicy” potato chips to “Bold and
                  Spicy”). Such a change may impact consumer decisions or online
                  information.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PRODUCTION_CHANGES_GENERAL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Production Changes
                  General</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Used to identify a minor
                  change to the configuration of physical package of a consumer unit that could
                  alter the physical supply chain efficiency or traceability end to
                  end.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RECONFIGURATION_OF_CONSUMER_PACK">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Reconfiguration of Consumer
                  Pack</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Used to identify a change in
                  the configuration of a package, for example from a 'sports top' to a twist off
                  cap. This could impact consumer decisions or online
                  information.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="REMOVAL_OF_ADDITIONAL_DECLARED_CONTENT_UOM">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Removial of Additional Declared
                  Content UOM</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Used to identify the removal
                  of an additional net content expression. </xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="TIME_CRITICAL_PROMOTION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Time Critical
                  Promotion</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Used to identify a
                  seasonal/time critical artwork/marketing declaration.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="VINTAGE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Vintage</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Particularly used for
                  high-volume/sell through wine who’s quality/price is not distinguishable by
                  vintage but that contains a year on the bottle (as this year may impact a consumer
                  decision).</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="ReceivingConditionCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:ReceivingConditionCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="ACCEPTED_IN_FULL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Accepted in
                  full</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Not
                  Available</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DAMAGED_PRODUCT_OR_CONTAINER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Damaged product or
                  container</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Not
                  Available</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="FALSE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">False</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The discount coupon
                  identified in the despatch advice is rejected because the coupon is
                  counterfeit</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="GOOD_CONDITION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Good condition</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Not
                  Available</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="HOLD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Hold</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Not
                  Available</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="INCORRECT_PRODUCT">
            <xsd:annotation>
