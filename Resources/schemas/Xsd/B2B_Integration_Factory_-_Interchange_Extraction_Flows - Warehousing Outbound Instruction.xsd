   </xsd:complexType>
   <xsd:complexType name="LanguageCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: The ISO 639-1code list can be acquired on the following website: www.iso.org</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: en</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="LanguageCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="LogisticUnitIdentificationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">The globally unique identification attached to a shipping container or shipping package and used for logistical and traceability purposes.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="sscc" type="SSCCType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sscc</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Serial Shipping Container Code (SSCC),the GS1 key used for the identification of logistic units.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="additionalLogisticUnitIdentification" minOccurs="0"
            maxOccurs="unbounded" type="AdditionalLogisticUnitIdentificationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Additional Logistic Unit Identification</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="MeasurementRangeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Provides the difference or interval between the minimum and maximum measurement including the associated unit of measure.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="maximumMeasurement" minOccurs="0" type="MeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Maximum Measurement</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 700</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Specifies the upper limit of the measurement range.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="minimumMeasurement" minOccurs="0" type="MeasurementType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Minimum Measurement</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 500</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Specifies the lower limit of the measurement range.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="MeasurementType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Provides measurement value and an associated unit of measure code.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="xsd:decimal">
            <xsd:attribute name="measurementUnitCode" use="required" type="MeasurementUnitCode">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Any standardized, reproducible unit that can be used to measure any physical property. Allowed code values are specified in UN/ECE Recommendation 20 - Fully Adopted by GS1.</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: UN/ECE Recommendation 20 - Fully Adopted by GS1. Information about the allowed code values for this code can be found at the  UN/ECE website: http://www.unece.org/tradewelcome/un-centre-for-trade-facilitation-and-e-business-uncefact/outputs/cefactrecommendationsrec-index/list-of-trade-facilitation-recommendations-n-16-to-20.html</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: KGM</xsd:documentation>
               </xsd:annotation>
            </xsd:attribute>
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Revision 6</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="MeasurementUnitCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found at the  UN/ECE website: http://www.unece.org/tradewelcome/un-centre-for-trade-facilitation-and-e-business-uncefact/outputs/cefactrecommendationsrec-index/list-of-trade-facilitation-recommendations-n-16-to-20.html</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: KGM</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a unit of measure. Allowed code values are specified in UN/ECE Recommendation 20 - Fully Adopted by GS1.</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="MeasurementUnitCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="MultiDescription70Type">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Provides multiple iterations of descriptive text with a maximum length of 70 and an associated language code.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="description" maxOccurs="unbounded" type="Description70Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Description</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Text content of the description.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="NutrientTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:NutrientTypeCode</xsd:documentation>
