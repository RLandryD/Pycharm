   <EntityType Name="WorkPackageFunction" sap:label="Work Package Functions" sap:content-version="1">
    <Key>
     <PropertyRef Name="ProjectID"/>
     <PropertyRef Name="WorkPackageID"/>
     <PropertyRef Name="WorkPackageName"/>
     <PropertyRef Name="WorkPackageFunctionId"/>
    </Key>
    <Property Name="ProjectID" Type="Edm.String" Nullable="false" MaxLength="40" sap:unicode="false" sap:label="Project ID" sap:heading="Customer Project ID" sap:quickinfo="Commercial Project ID" sap:updatable="false" sap:sortable="false">
     <Documentation>
      <Summary>Identifies a customer or internal project.</Summary>
      <LongDescription/>
     </Documentation>
    </Property>
    <Property Name="WorkPackageID" Type="Edm.String" Nullable="false" MaxLength="50" sap:unicode="false" sap:label="Work Package ID" sap:heading="Plan Item" sap:quickinfo="Plan Item" sap:updatable="false" sap:sortable="false"/>
    <Property Name="WorkPackageName" Type="Edm.String" Nullable="false" MaxLength="60" sap:unicode="false" sap:label="Work Package Name" sap:heading="Plan Item Description" sap:quickinfo="Plan Item Description" sap:updatable="false" sap:sortable="false"/>
    <Property Name="WorkPackageFunctionId" Type="Edm.String" Nullable="false" MaxLength="4" sap:unicode="false" sap:label="Work Package Function ID" sap:updatable="false">
     <Documentation>
      <Summary>Identifies the possible ways in which cost can be posted to a work package.</Summary>
      <LongDescription>Users can manage work packages by allowing or blocking cost posting.This field must be used together with the field Work Package Function is Blocked.</LongDescription>
     </Documentation>
    </Property>
    <Property Name="WorkPackageFunctionName" Type="Edm.String" Nullable="false" MaxLength="60" sap:unicode="false" sap:label="Work Package Function Name" sap:creatable="false" sap:updatable="false" sap:sortable="false"/>
    <Property Name="WorkPackageFunctionIsBlocked" Type="Edm.String" MaxLength="1" sap:unicode="false" sap:label="Work Package Function Is Blocked" sap:heading="Work Package Function is Blocked" sap:quickinfo="Work Package Function is Blocked">
     <Documentation>
      <Summary>Indicates whether a work package function is blocked.</Summary>
      <LongDescription>You use this field to manage cost posting on work packages. The possible values are:' '  - AllowedX  - BlockedThis field must be used together with the field Work Package Function ID. ‫ ‬</LongDescription>
     </Documentation>
    </Property>
   </EntityType>
   <EntityType Name="Project" sap:label="Project" sap:content-version="1">
    <Key>
     <PropertyRef Name="ProjectID"/>
    </Key>
    <Property Name="ProjectID" Type="Edm.String" Nullable="false" MaxLength="40" sap:unicode="false" sap:label="Project ID" sap:heading="Customer Project ID" sap:quickinfo="Commercial Project ID" sap:updatable="false">
     <Documentation>
      <Summary>Identifies a customer or internal project.</Summary>
      <LongDescription/>
     </Documentation>
