<?xml version="1.0" encoding="UTF-8"?><xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema" version="1.0">
  <xsd:element name="Inbound_Interface_Entitlement_Generation">
    <xsd:complexType>
      <xsd:sequence>
        <xsd:element maxOccurs="unbounded" name="Inbound_Interface_Entitlement_Generation">
          <xsd:complexType>
            <xsd:sequence>
              <xsd:element maxOccurs="1" minOccurs="1" name="SourceSystem" type="xsd:string"/>
              <xsd:element maxOccurs="1" minOccurs="0" name="GenerationMethod" type="xsd:string"/>
              <xsd:element maxOccurs="1" minOccurs="1" name="CustomerID" type="xsd:string"/>
              <xsd:element maxOccurs="1" minOccurs="0" name="CustomerName" type="xsd:string"/>
              <xsd:element maxOccurs="1" minOccurs="0" name="CreatedBy" type="xsd:string"/>
              <xsd:element maxOccurs="1" minOccurs="0" name="CreatedAt" type="xsd:date"/>
              <xsd:element maxOccurs="1" minOccurs="0" name="SalesOrganization" type="xsd:string"/>
              <xsd:element maxOccurs="1" minOccurs="0" name="SalesGroup" type="xsd:string"/>
