     </Documentation>
    </Property>
    <Property Name="CustMgmtPartnerIsMainPartner" Type="Edm.Boolean" sap:display-format="UpperCase" sap:label="Main Partner" sap:quickinfo="Main Partner (For Ambiguous Partner Functions)">
     <Documentation>
      <Summary>Specifies the main partner in a group of partners with the same partner function.</Summary>
      <LongDescription>When exactly one partner with this partner function is required, in partner determination for example, the system chooses the main partner.</LongDescription>
     </Documentation>
    </Property>
