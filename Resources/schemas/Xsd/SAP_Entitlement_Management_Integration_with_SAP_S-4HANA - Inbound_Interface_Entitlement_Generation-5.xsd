                    <xsd:element maxOccurs="1" minOccurs="0" name="ItemValidFrom" type="xsd:date"/>
                    <xsd:element maxOccurs="1" minOccurs="0" name="ItemValidTo" type="xsd:date"/>
                    <xsd:element maxOccurs="1" minOccurs="0" name="ParentItemNumber" type="xsd:string"/>
                    <xsd:element maxOccurs="1" minOccurs="0" name="BusinessEvent" type="xsd:string"/>
