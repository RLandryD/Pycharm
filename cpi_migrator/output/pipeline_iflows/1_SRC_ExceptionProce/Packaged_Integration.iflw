<?xml version="1.0" encoding="UTF-8"?>
<!--
  SCENARIO iFlow: Packaged Integration - SAP Fieldglass to  SAP SuccessFactors Employee Center
  Display Name : OUT_SRC_ExceptionProcessStat_Packaged_Integration
  Package      : 1_SRC_ExceptionProcessStat_Finance
  Strategy     : GREENFIELD: Clean cloud-native rebuild. No legacy mapping reuse.
  Complexity   : HIGH (score: 268)
  Effort       : 80.9 day(s)
  Sender       :  ()
  Receiver     : ExceptionProcessStateReceiver (SuccessFactors)
  Batch        : No
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Packaged_Integration"
             name="OUT_SRC_ExceptionProcessStat_Packaged_Integration">
  <process id="Packaged_Integration_process" ifl:type="IntegrationFlow">

    <startEvent id="Start_SC" name="From Interface Separation">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Packaged_Integration</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>



    <!-- PROCESSDIRECT: Forward to Outbound Delivery -->
    <serviceTask id="CallOutbound_1" name="→ Outbound Delivery" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/outbound/1_SRC_ExceptionProce</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_SC"/>
    <sequenceFlow sourceRef="Start_SC" targetRef="CallOutbound_1"/>
    
    
    <sequenceFlow sourceRef="CallOutbound_1" targetRef="End_SC"/>
  </process>
</definitions>