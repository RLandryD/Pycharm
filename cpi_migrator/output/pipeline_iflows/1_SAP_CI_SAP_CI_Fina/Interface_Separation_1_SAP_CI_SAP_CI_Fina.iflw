<?xml version="1.0" encoding="UTF-8"?>
<!--
  PIPELINE STEP 3: Interface Separation iFlow
  Package  : 1_SAP_CI_SAP_CI_Finance
  Purpose  : Routes to the correct scenario-specific iFlow
             based on SAP_InterfaceName header set by Receiver Determination.
  Internal : ProcessDirect address /pd/InterfaceSeparation_1_SAP_CI_SAP_CI_Fina
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Interface_Separation_1_SAP_CI_SAP_CI_Fina"
             name="Interface_Separation_1_SAP_CI_SAP_CI_Fina">
  <process id="IfaceSep_1_SAP_CI_SAP_CI_Fina_process" ifl:type="IntegrationFlow">

    <startEvent id="Start_IS" name="From Receiver Determination">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/pd/InterfaceSeparation_1_SAP_CI_SAP_CI_Fina</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>

    <!-- ROUTER: Branch to scenario-specific iFlow -->
    <exclusiveGateway id="Router_1" name="Route by Interface Name"/>

    <sequenceFlow id="route_0" sourceRef="Router_1"
      targetRef="Call_Workday_to_SAP_Signa_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Workday to SAP Signavio Process Intelligence - Replicate Interview' -->
    </sequenceFlow>
    <serviceTask id="Call_Workday_to_SAP_Signa_1"
      name="→ Workday to SAP Signavio Process Intelligence - Replicate Interview" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Workday_to_SAP_Signa</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_1" sourceRef="Router_1"
      targetRef="Call_Workday_to_SAP_Signa_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Workday to SAP Signavio Process Intelligence - Replicate Candidate' -->
    </sequenceFlow>
    <serviceTask id="Call_Workday_to_SAP_Signa_1"
      name="→ Workday to SAP Signavio Process Intelligence - Replicate Candidate" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Workday_to_SAP_Signa</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_2" sourceRef="Router_1"
      targetRef="Call_Workday_to_SAP_Signa_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Workday to SAP Signavio Process Intelligence - Replicate Job Requisition' -->
    </sequenceFlow>
    <serviceTask id="Call_Workday_to_SAP_Signa_1"
      name="→ Workday to SAP Signavio Process Intelligence - Replicate Job Requisition" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Workday_to_SAP_Signa</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_3" sourceRef="Router_1"
      targetRef="Call_Workday_to_SAP_Signa_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Workday to SAP Signavio Process Intelligence - Replicate Employee Contract' -->
    </sequenceFlow>
    <serviceTask id="Call_Workday_to_SAP_Signa_1"
      name="→ Workday to SAP Signavio Process Intelligence - Replicate Employee Contract" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Workday_to_SAP_Signa</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_4" sourceRef="Router_1"
      targetRef="Call_Workday_to_SAP_Signa_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Workday to SAP Signavio Process Intelligence - Replicate Job Family' -->
    </sequenceFlow>
    <serviceTask id="Call_Workday_to_SAP_Signa_1"
      name="→ Workday to SAP Signavio Process Intelligence - Replicate Job Family" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Workday_to_SAP_Signa</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_5" sourceRef="Router_1"
      targetRef="Call_Workday_to_SAP_Signa_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Workday to SAP Signavio Process Intelligence - Replicate Job Application' -->
    </sequenceFlow>
    <serviceTask id="Call_Workday_to_SAP_Signa_1"
      name="→ Workday to SAP Signavio Process Intelligence - Replicate Job Application" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Workday_to_SAP_Signa</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>
    <sequenceFlow id="route_6" sourceRef="Router_1"
      targetRef="Call_Workday_to_SAP_Signa_1">
      <!-- Condition: ${header.SAP_InterfaceName} = 'Workday to SAP Signavio Process Intelligence - Replicate Worker' -->
    </sequenceFlow>
    <serviceTask id="Call_Workday_to_SAP_Signa_1"
      name="→ Workday to SAP Signavio Process Intelligence - Replicate Worker" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Workday_to_SAP_Signa</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_IS"/>
    <sequenceFlow sourceRef="Start_IS" targetRef="Router_1"/>
  </process>
</definitions>