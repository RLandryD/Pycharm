<xsd:documentation>Indicates if the Reference element for the worker is included in the response.</xsd:documentation>
</xsd:annotation>
</xsd:element>
<xsd:element maxOccurs="1" minOccurs="0" name="Include_Personal_Information" type="xsd:boolean">
<xsd:annotation>
<xsd:documentation>Indicates if the Personal Data element is included in the response.</xsd:documentation>
</xsd:annotation>
</xsd:element>
<xsd:element maxOccurs="1" minOccurs="0" name="Include_Additional_Jobs" type="xsd:boolean">
