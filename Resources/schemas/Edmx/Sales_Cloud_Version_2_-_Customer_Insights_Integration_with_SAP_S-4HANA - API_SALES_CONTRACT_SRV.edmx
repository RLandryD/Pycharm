    </Annotation>
   </Annotations>
   <Annotations Target="API_SALES_CONTRACT_SRV.API_SALES_CONTRACT_SRV_Entities/A_SalesContractItemPrcgElmnt" xmlns="http://docs.oasis-open.org/odata/ns/edm">
