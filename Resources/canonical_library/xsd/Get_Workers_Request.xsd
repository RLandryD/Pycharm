<xsd:complexType name="Worker_by_National_ID_Request_CriteriaType">
<xsd:annotation>
<xsd:documentation>National Id request criteria.</xsd:documentation>
</xsd:annotation>
<xsd:sequence>
<xsd:element maxOccurs="1" name="Identifier_ID" type="xsd:string">
<xsd:annotation>
<xsd:documentation>The specific national ID value for the worker.</xsd:documentation>
</xsd:annotation>
</xsd:element>
<xsd:choice>
<xsd:element name="National_ID_Type_Reference" type="wd:National_ID_TypeObjectType">
<xsd:annotation>
<xsd:documentation>The type of national id for the worker. Either the type or the country need to be included.</xsd:documentation>
</xsd:annotation>
</xsd:element>
<xsd:element name="Country_Reference" type="wd:CountryObjectType">
<xsd:annotation>
<xsd:documentation>The Country Reference for the National ID.
You must enter either the National ID Type or the Country for the National ID.
Using the National ID Type is more explicit -if a country is entered, then it is possible that there are multiple workers who have the same ID value but with different national id types within that country.</xsd:documentation>
</xsd:annotation>
</xsd:element>
</xsd:choice>
</xsd:sequence>
</xsd:complexType>
</xsd:schema>