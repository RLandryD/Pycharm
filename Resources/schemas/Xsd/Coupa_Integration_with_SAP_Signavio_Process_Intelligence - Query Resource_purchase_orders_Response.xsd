<?xml version="1.0" encoding="UTF-8"?>
<xs:schema version="1.0" elementFormDefault="qualified" xmlns:xs="http://www.w3.org/2001/XMLSchema">
    <xs:element name="order-headers">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="order-header" maxOccurs="unbounded">
                    <xs:complexType>
                        <xs:sequence>
                            <xs:element name="acknowledged-at" type="xs:string" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>acknowledged_at</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element name="acknowledged-flag" type="xs:boolean" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Has PO been acknowledged by Supplier?</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element name="attachments" minOccurs="0">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element name="attachment" minOccurs="0" maxOccurs="unbounded" type="Attachment"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element name="change-type" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Last type of change on PO, it represents whether PO was changed through change request or through revise</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:enumeration value="change"/>
                                        <xs:enumeration value="revision"/>
                                        <xs:enumeration value="confirmation"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element name="classification" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Classification</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:enumeration value="msp"/>
                                        <xs:enumeration value="supplier"/>
                                        <xs:enumeration value="vms"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element name="confirm-by-hrs" type="xs:integer" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Confirm by</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element name="coupa-accelerate-status" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Status indicating whether the invoice has discount payment terms via Static Discounting</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:enumeration value="accelerated"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element name="created-at" type="xs:string" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Date record was created in Coupa.</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element name="created-by" type="UserSimple" minOccurs="0"/>
                            <xs:element name="currency" type="Currency" minOccurs="0"/>
                            <xs:element name="current-integration-history-records" minOccurs="0">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element name="current-integration-history-record" minOccurs="0" maxOccurs="unbounded" type="IntegrationHistoryRecord"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element name="estimated-tax-amount" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Estimated Tax Amount</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:decimal">
                                        <xs:totalDigits value="30"/>
                                        <xs:fractionDigits value="6"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element name="exported" type="xs:boolean" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Indicates if transaction has been exported</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element name="hide-price" type="OrderHeader" minOccurs="0"/>
                            <xs:element name="id" type="xs:integer" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Coupa's internal ID</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element name="internal-revision" type="xs:integer" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Internal Revision Number - Increases each time a change is made to a PO whether that change is internal or causes the PO to be resent to the supplier.</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element name="invoice-stop" type="xs:boolean" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Invoice Stop flag</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element name="last-exported-at" type="xs:string" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Date and time transaction was last exported in the format YYYY-MM-DDTHH:MM:SS+HH:MMZ</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element name="milestones" minOccurs="0">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element name="milestone" minOccurs="0" maxOccurs="unbounded" type="Procurement-Milestone"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element name="order-confirmation-level" type="xs:string" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Confirmation Level</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element name="order-header-confirmations" minOccurs="0">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element name="order-header-confirmation" minOccurs="0" maxOccurs="unbounded" type="OrderHeaderConfirmation"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element name="order-lines" minOccurs="0">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element name="order-line" minOccurs="0" maxOccurs="unbounded" type="OrderLine"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element name="payment-method" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>payment_method</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element name="payment-term" type="PaymentTerm" minOccurs="0"/>
                            <xs:element name="pcard" type="Pcard" minOccurs="0"/>
                            <xs:element name="po-number" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>PO Number</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="20"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element name="price-hidden" type="xs:boolean" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Hide Price from supplier. True or False</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element name="reason-insight-events" minOccurs="0">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element name="reason-insight-event" minOccurs="0" maxOccurs="unbounded" type="OrderHeader"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element name="recurring-rules" minOccurs="0">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element name="recurring-rule" minOccurs="0" maxOccurs="unbounded" type="Procurement-RecurringRule"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element name="requester" type="UserSimple" minOccurs="0"/>
                            <xs:element name="requisition-header" type="RequisitionHeader" minOccurs="0"/>
                            <xs:element name="ship-to-address" type="Address" minOccurs="0"/>
                            <xs:element name="ship-to-attention" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Ship to attention</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element name="ship-to-user" type="UserSimple" minOccurs="0"/>
                            <xs:element name="shipping-term" type="ShippingTerm" minOccurs="0"/>
                            <xs:element name="status" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>PO Status</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:enumeration value="buyer_hold"/>
                                        <xs:enumeration value="cancelled"/>
                                        <xs:enumeration value="closed"/>
                                        <xs:enumeration value="currency_hold"/>
                                        <xs:enumeration value="draft"/>
                                        <xs:enumeration value="error"/>
                                        <xs:enumeration value="expensed"/>
                                        <xs:enumeration value="issued"/>
                                        <xs:enumeration value="supplier_hold"/>
                                        <xs:enumeration value="supplier_window_hold"/>
                                        <xs:enumeration value="exported"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element name="supplier" type="Supplier" minOccurs="0"/>
                            <xs:element name="supplier-site" type="SupplierSite" minOccurs="0"/>
                            <xs:element name="total-with-estimated-tax" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Total With Estimated Tax</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:decimal">
                                        <xs:totalDigits value="30"/>
                                        <xs:fractionDigits value="6"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element name="transmission-emails" type="xs:string" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Tranmission Email comma seperated list</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element name="transmission-method-override" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Transmission Method Override</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:enumeration value="supplier_default"/>
                                        <xs:enumeration value="email"/>
                                        <xs:enumeration value="do_not_transmit"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element name="transmission-status" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Transmission Status</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:enumeration value="created"/>
                                        <xs:enumeration value="deferred"/>
                                        <xs:enumeration value="deferred_processing"/>
                                        <xs:enumeration value="pending_manual"/>
                                        <xs:enumeration value="pending_manual_cancel"/>
                                        <xs:enumeration value="awaiting_online_purchase"/>
                                        <xs:enumeration value="scheduled_for_email"/>
                                        <xs:enumeration value="sent_via_email"/>
                                        <xs:enumeration value="scheduled_for_cxml"/>
                                        <xs:enumeration value="scheduled_for_xml"/>
                                        <xs:enumeration value="sent_via_cxml"/>
                                        <xs:enumeration value="sent_via_xml"/>
                                        <xs:enumeration value="sent_manually"/>
                                        <xs:enumeration value="purchased_online"/>
                                        <xs:enumeration value="transmission_failure"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element name="type" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Type of Order</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:enumeration value="ExternalOrderHeader"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element name="updated-at" type="xs:string" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>Last Updated at Date</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element name="updated-by" type="UserSimple" minOccurs="0"/>
                            <xs:element name="user-group-members" minOccurs="0">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element name="user-group-member" minOccurs="0" maxOccurs="unbounded" type="UserGroup"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element name="user-members" minOccurs="0">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element name="user-member" minOccurs="0" maxOccurs="unbounded" type="UserSimple"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element name="version" type="xs:integer" minOccurs="0">
                                <xs:annotation>
                                    <xs:documentation>PO Supplier Version Number - Increase each time a PO is changed and triggers a resend to the supplier.</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element name="custom-fields" minOccurs="0">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element name="purchaseorderscustomfield" type="xs:string" minOccurs="0"/>
                                        <xs:element name="sap_integration_messages" type="xs:string" minOccurs="0"/>
                                        <xs:element name="patient_id" type="LookupValue" minOccurs="0"/>
                                        <xs:element name="custom_field_7" type="LookupValue" minOccurs="0"/>
                                        <xs:element name="bill_only" type="xs:boolean" minOccurs="0"/>
                                        <xs:element name="spend_load_id" type="xs:string" minOccurs="0"/>
                                        <xs:element name="sap_document_number" type="xs:string" minOccurs="0"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                        </xs:sequence>
                    </xs:complexType>
                </xs:element>
            </xs:sequence>
        </xs:complexType>
    </xs:element>
    <xs:complexType name="Attachment">
        <xs:sequence>
            <xs:element name="created-at" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Automatically created by Coupa in the format YYYY-MM-DDTHH:MM:SS+HH:MMZ</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="created-by" type="UserSimple1" minOccurs="0"/>
            <xs:element name="file" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>file</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:string">
                        <xs:maxLength value="255"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element name="file-content-type" minOccurs="0">
