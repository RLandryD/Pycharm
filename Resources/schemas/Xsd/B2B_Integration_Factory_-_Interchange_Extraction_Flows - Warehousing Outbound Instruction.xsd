         <xsd:element name="newHolderRegistration" minOccurs="0" type="IdentifierType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">New Holder Registration</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: VJK99876</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identification of the party the returnable packaging is being transferred to.</xsd:documentation>
