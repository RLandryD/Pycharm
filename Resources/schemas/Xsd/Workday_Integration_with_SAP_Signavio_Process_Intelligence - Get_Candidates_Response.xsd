</xsd:annotation>
</xsd:element>
<xsd:element maxOccurs="1" minOccurs="0" name="Last_Name" type="xsd:string">
<xsd:annotation>
<xsd:documentation>The Last Name (Family Name) for a candidate.</xsd:documentation>
</xsd:annotation>
</xsd:element>
<xsd:element maxOccurs="1" minOccurs="0" name="Secondary_Last_Name" type="xsd:string">
