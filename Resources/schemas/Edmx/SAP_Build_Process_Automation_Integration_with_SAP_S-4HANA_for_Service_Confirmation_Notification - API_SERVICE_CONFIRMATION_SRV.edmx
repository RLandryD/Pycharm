      <LongDescription/>
     </Documentation>
    </Property>
    <Property Name="ServiceConfirmationItem" Type="Edm.String" Nullable="false" MaxLength="6" sap:display-format="NonNegative" sap:label="Item Number in Doc." sap:heading="Item Number in Document" sap:quickinfo="Shortened Item Number in Document"/>
    <Property Name="ServiceReferenceEquipment" Type="Edm.String" Nullable="false" MaxLength="18" sap:display-format="UpperCase" sap:label="Equipment" sap:quickinfo="Equipment Number">
     <Documentation>
      <Summary>Number by which a piece of equipment can be clearly identified.</Summary>
      <LongDescription/>
     </Documentation>
    </Property>
    <Property Name="ServiceRefFunctionalLocation" Type="Edm.String" Nullable="false" MaxLength="40" sap:display-format="UpperCase" sap:label="Functional Location">
     <Documentation>
      <Summary>Label that uniquely identifies a functional location.</Summary>
      <LongDescription>If alternative labels exist for a functional location, you can define in your user profile which label should be displayed in this field.</LongDescription>
     </Documentation>
    </Property>
    <Property Name="SrvcRefObjIsMainObject" Type="Edm.Boolean" sap:display-format="UpperCase" sap:label="Main Ref. Object" sap:heading="M" sap:quickinfo="Main Reference Object"/>
   </EntityType>
