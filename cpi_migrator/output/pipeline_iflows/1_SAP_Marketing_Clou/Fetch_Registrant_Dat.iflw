<?xml version="1.0" encoding="UTF-8"?>
<!--
  SCENARIO iFlow: Fetch Registrant Data from GoToWebinar Platform
  Display Name : OUT_SAP_Marketing_Cloud_Marketing_Events_Reg_Fetch_Registrant_Dat
  Package      : 1_SAP_Marketing_Cloud_Marketing_Events_Reg_Finance
  Strategy     : GREENFIELD: Clean cloud-native rebuild. No legacy mapping reuse.
  Complexity   : HIGH (score: 106)
  Effort       : 32.3 day(s)
  Sender       : SAP_Marketing_Cloud (HTTPS)
  Receiver     : Marketing_Events_Registrants (OpenConnectors)
  Batch        : No
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Fetch_Registrant_Dat"
             name="OUT_SAP_Marketing_Cloud_Marketing_Events_Reg_Fetch_Registrant_Dat">
  <process id="Fetch_Registrant_Dat_process" ifl:type="IntegrationFlow">

    <startEvent id="Start_SC" name="From Interface Separation">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Fetch_Registrant_Dat</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>



    <!-- PROCESSDIRECT: Forward to Outbound Delivery -->
    <serviceTask id="CallOutbound_1" name="→ Outbound Delivery" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/outbound/1_SAP_Marketing_Clou</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_SC"/>
    <sequenceFlow sourceRef="Start_SC" targetRef="CallOutbound_1"/>
    
    
    <sequenceFlow sourceRef="CallOutbound_1" targetRef="End_SC"/>
  </process>
</definitions>