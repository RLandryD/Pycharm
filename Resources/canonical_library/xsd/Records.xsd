                      <xs:element name="AmountInReportingCurrency" type="xs:decimal"  maxOccurs="1" minOccurs="0"/>
                      <xs:element name="ApproxAmountInBaseCurrency" type="xs:decimal"  maxOccurs="1" minOccurs="0"/>
                      <xs:element name="Amount" type="xs:decimal"  maxOccurs="1" minOccurs="0"/>
                      <xs:element name="ConversionDate" type="xs:dateTime"  maxOccurs="1" minOccurs="0"/>
