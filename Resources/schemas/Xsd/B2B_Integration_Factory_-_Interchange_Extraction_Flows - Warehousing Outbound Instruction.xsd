               <xsd:documentation xml:lang="en-US" source="Name">Current Holder Registration</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: VDG700</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identification of the current administrative holder of the returnable packaging.</xsd:documentation>
