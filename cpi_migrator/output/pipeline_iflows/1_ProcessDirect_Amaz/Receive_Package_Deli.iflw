<?xml version="1.0" encoding="UTF-8"?>
<!--
  SCENARIO iFlow: Receive Package Delivery Cancel from Amazon
  Display Name : OUT_ProcessDirect_Amazon_S4HANA_SalesOrderCan_Receive_Package_Deli
  Package      : 1_ProcessDirect_Amazon_S4HANA_SalesOrderCan_Logistics
  Strategy     : GREENFIELD: Clean cloud-native rebuild. No legacy mapping reuse.
  Complexity   : HIGH (score: 121)
  Effort       : 36.8 day(s)
  Sender       : ProcessDirect_AmazonBwP (ProcessDirect)
  Receiver     : S4HANA_SalesOrderCancel_PATCH (HCIOData)
  Batch        : No
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Receive_Package_Deli"
             name="OUT_ProcessDirect_Amazon_S4HANA_SalesOrderCan_Receive_Package_Deli">
  <process id="Receive_Package_Deli_process" ifl:type="IntegrationFlow">

    <startEvent id="Start_SC" name="From Interface Separation">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Receive_Package_Deli</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>



    <!-- PROCESSDIRECT: Forward to Outbound Delivery -->
    <serviceTask id="CallOutbound_1" name="→ Outbound Delivery" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/outbound/1_ProcessDirect_Amaz</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_SC"/>
    <sequenceFlow sourceRef="Start_SC" targetRef="CallOutbound_1"/>
    
    
    <sequenceFlow sourceRef="CallOutbound_1" targetRef="End_SC"/>
  </process>
</definitions>