            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inventory Event Reason Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the reason for this event.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="inventoryEventReasonDescription" minOccurs="0" type="Description70Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inventory Event Reason Description</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Textual description of the reason for this event.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="inventorySubLocation" type="InventorySubLocationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inventory Sub Location</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The inventory sub location related to the event.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
