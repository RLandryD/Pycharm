               <xsd:documentation xml:lang="en-US" source="Name">End Date</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date specifying the last day for the date time range.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15</xsd:documentation>
