ation><Summary>PerPhone</Summary><LongDescription>Contains information about an employee's phone numbers.</LongDescription><sap:tagcollection><sap:tag>Employee Central (EC)</sap:tag><sap:tag>EC - Personal Information</sap:tag></sap:tagcollection></Documentation></EntitySet><EntitySet Name="EmpPayCompRecurring" EntityType="SFOData.EmpPayCompRecurring" sap:label="Compensation" sap:creatable="false" sap:updatable="false" sap:upsertable="true" sap:deletable="false"><Documentation><Summary>EmpPayCompRecurring</Summary><LongDescription>Contains recurring compensation information for an employee.</LongDescription><sap:tagcollection><sap:tag>Employee Central (EC)</sap:tag><sap:tag>EC - Compensation Information</sap:tag></sap:tagcollection></Documentation></EntitySet><EntitySet Name="ExternalLearnerPhoneInfo" EntityType="SFOData.ExternalLearnerPhoneInfo" sap:label="Phone Information" sap:creatable="true" sap:updatable="false" sap:upsertable="true" sap:deletable="false" sap:support-elm="true"><Documentation><Summary>ExternalLearnerPhoneInfo</Summary><LongDescription>Phone information of external learner, such as phone type and phone number.</LongDescription><sap:tagcollection><sap:tag>Foundation/Platform (PLT)</sap:tag></sap:tagcollection></Documentation></EntitySet><EntitySet Name="Background_InsideWorkExperience" EntityType="SFOData.Background_InsideWorkExperience" sap:label="Background_InsideWorkExperience" sap:creatable="true" sap:updatable="true" sap:upsertable="true" sap:deletable="true"><Documentation><Summary>Background*</Summary><LongDescription>Background objects are customizable to store general background information about an employee. Representative definitions include education and outside work experience</LongDescription><sap:tagcollection><sap:tag>Employee Central (EC)</sap:tag><sap:tag>EC - Employee Profile</sap:tag></sap:tagcollection></Documentation></EntitySet><EntitySet Name="CalibrationSessionSubject" EntityType="SFOData.CalibrationSessionSubject" sap:la