         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:ForecastPurposeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="ORDER_FORECAST">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The forecast is for the
                  expected receipt of items at the location.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SALES_FORECAST">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The forecast is for the
                  expected sales or consumption of items at the location.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SHIPMENT_FORECAST">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The forecast is for shipments
                  to the location.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="ForecastTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:ForecastTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="BASE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The forecast includes only
                  baseline (non-promoted) demand</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PROMOTIONAL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The forecast includes only
                  promotional demand</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SEASONAL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The forecast includes only
                  the seasonal component of total demand</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="TOTAL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The forecast includes all
                  types of demand</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="GenderEnumeration">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:GenderEnumeration</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="FEMALE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Female</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Female</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MALE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Male</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Male</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="GoodsReceiptReportingCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:GoodsReceiptReportingCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="CONFIRMATION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Confirmation</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Not
                  available</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="EXCEPTIONS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Exceptions</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Not
                  available</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="FULL_DETAILS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Full details</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Not
                  available</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="GoodsRequirementsTypeEnumeration">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:GoodsRequirementsTypeEnumeration</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="ACTUAL_SALES">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Actual goods
                  sales</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="FORECAST">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Forcasted goods
                  sales</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="GROSS_REQUIREMENTS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Planned material
                  consumption</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="NET_REQUIREMENTS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Planned material consumption
                  corrected for available inventory</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="GraphicElementTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:GraphicElementTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="DESIGN_GRAPHIC">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Design graphic</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Graphic specifically designed
                  for a brand, product or product family.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="HAZARD_SYMBOL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Symbol that is used to
                  communicate a product hazard.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ICON">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Icon</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Symbol or icon that is used
                  globally.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ICON_WITH_VARIABLE_TEXT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">The number of laundry loads
                  to be shown inside of a measuring-cup icon (varies by package
                  size).</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="KOSHER_SYMBOL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Kosher symbol</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Symbol that is used to
                  communicate accordance of food products with Jewish religious
                  practices.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="LOCAL_ICON">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Local icon</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Symbol or icon that is
                  specific to the market. These are often added per local regulatory
                  requirements.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RECYCLING_SYMBOL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Recycling
                  symbol</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Symbol that is used to
                  designate recyclable materials.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="REGIONAL_ICON">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Regional icon</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Symbol or icon that is used
                  across a region (e.g. a common packaging symbol used across multiple local labels
                  within the EU).</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="USDA_SYMBOL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Usda symbol</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"/>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="HarmonizedSystemCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:HarmonizedSystemCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token"/>
   </xsd:simpleType>
   <xsd:simpleType name="IdentityDocumentTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:IdentityDocumentTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="DRIVERS_LICENSE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Drivers license</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A license authorizing the
                  bearer to drive a motor vehicle driver's licence</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="EMPLOYEE_CARD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Employee card</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A card identifying employees
                  of an organisation.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="NATIONAL_IDENTITY_CARD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">National identity
                  card</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A personal identification
                  card, which some countries require their citizens to carry.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PASSPORT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Passport</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Number assigned to a
                  passport.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="IncidentTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:IncidentTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="ACCIDENT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Accident</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The incident type is accident
                  – an incidental and unplanned event.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ASSAULT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Assault</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The incident type is assault
                  – a physical attack.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="IncotermsCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:IncotermsCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token"/>
   </xsd:simpleType>
   <xsd:simpleType name="InventoryActivityTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:InventoryActivityTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="DAMAGED_IN_FACILITY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Damaged in
                  facility</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A decrease or increase due to
                  product being damaged in the warehouse or warehouse location.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DAMAGED_IN_TRANSIT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Damaged in
                  transit</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A decrease or increase due to
                  product being damaged during transfer or transportation in-bound or out-bound to a
                  warehouse or warehouse location.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DESPATCH_DISCREPANCY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Despatch
                  discrepancy</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A decrease or increase in
                  inventory as a result of shipping product to or from the warehouse or warehouse
                  location.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DESPATCHES">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Despatches</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A decrease or increase of
                  inventory because of shipment of goods to another location.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DESTROYED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Destroyed</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A decrease or increase due to
                  product being dumped or destroyed and physically no longer
                  exists.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DISTRESSED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Distressed</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A decrease or increase for
                  product in inventory that is about to expire.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="EXPIRATION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Expiration</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A decrease or increase for
                  product in inventory that has expired.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ON_HOLD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">On hold</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A decrease or increase due to
                  product being placed on hold.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PHYSICAL_COUNT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Physical count</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A decrease or increase due to
                  the result of a physical count of inventory.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="QUARANTINE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Quarantine</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A decrease or increase in a
                  status of product that has been produced, but has not yet cleared quality
                  /performance testing and is therefore not available for transport or
                  sale.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RECALL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Recall</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A decrease or increase for
                  inventory received back to the warehouse or warehouse
                  location.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RECEIPT_DISCREPANCY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Receipt
                  discrepancy</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A decrease or increase in
                  inventory as a result of discrepancies made at receipt of product at the warehouse
                  or warehouse location.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RECEIPTS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Receipts</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A decrease or increase in
                  inventory because of shipment of goods from another location.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RECOUP_REWORK_OF_DAMAGED_PRODUCT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Recoup rework of damaged
                  product</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A decrease or increase in
                  inventory as a result of restoring damaged product.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="REIDENTIFICATION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Reidentification</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A decrease or increase in
                  inventory as a result of changing the identification of a product; e.g. regarding,
                  stock number change, material identification change.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="TRANSFER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transfer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A decrease or increase in
                  inventory as a result of moving inventory between warehouses, warehouse locations,
                  or cost centres.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="InventoryBusinessStepCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:InventoryBusinessStepCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="accepting">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a specific activity
                  within a business process where an object (i.e. product, shipment or asset)
                  arrives into a location causing a change of possession and/or
                  responsibility.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="arriving">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Shipment is arriving at a
                  location</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="assembling">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes an activity within a
                  business process whereby one or more trade item(s) or identifiable component parts
                  are combined with other objects creating a new finished
                  product.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="collecting">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a specific activity
                  within a business process where an object (i.e. product, asset, shipment or
                  container) is picked up and collected for future disposal, recycling or
                  reused.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="commissioning">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Process of associating an EPC
                  with a particular object (product, shipment, asset or container). A tag may have
                  been encoded and applied in this step, or may have been previously
                  encoded.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="counting">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a physical counting
                  activity of the objects. Note: added for Warehousing project</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="decommissioning">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Process of disassociating an
                  EPC with an object (i.e. product, shipment, asset or container). EPC may be
                  re-commissioned at some point in the future and read again – however only with new
                  information.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="departing">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Shipment is leaving a
                  location on its way to a destination</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="destroying">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Process of terminating an
                  object (i.e. product, shipment, asset or shipping container) The object and its
                  EPC should not be the subject of subsequent events that require a physical
                  observation; subsequent physical observations are likely indicative of error (such
                  as a stray read of a tag inside an incinerator)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="disassembling">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a specific activity
                  within a business process where a trade item is broken down into separate,
                  uniquely identified component parts.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="encoding">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Process of writing an EPC
                  code to a tag. EPC is not associated with an object (i.e. product, shipment, asset
                  or container) at this step in the process.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="entering_exiting">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a specific activity
                  within a business at the Entrance/Exit door of a facility. Customers are either
                  leaving with purchased product or entering with product to be returned to the
                  facility.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="holding">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a specific activity
                  within a business process where an object (i.e. product, shipment, asset, or
                  containers) is being segregated for further review.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="inspecting">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Process of reviewing product
                  to address potential product or documentation defects</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="installing">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a specific activity
                  within a business process where part or component is put into a composite product
                  or piece of equipment or machinery.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="killing">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Process of terminating an EPC
                  RFID tag previously associated with an object. The object and its EPC code may
                  continue to exist and be the subject of subsequent events (via a bar code, manual
                  data entry, replacement tag, etc)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="loading">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a specific activity
                  within a business process where an object (i.e. product, shipment, asset, or
                  container) is loaded into shipping conveyance.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="other">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">A business step not
                  identified by any of the values listed in the core business
                  vocabulary</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="packing">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a specific activity
                  within a business process that includes putting product (individuals, inners,
                  cases, pallets) into a larger container – usually for shipping. Aggregation of one
                  unit to another typically occurs at this point.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="picking">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a specific activity
                  within a business process that includes the selecting of product to fill an
                  order</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="receiving">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a specific activity
                  within a business process that indicates that an object (i.e. product, shipment or
                  asset), is being received at a location and is added to the receiver's
                  inventory.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="removing">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a specific activity
                  within a business process where a part or component is taken out of a composite
                  product, or piece of equipment or machinery.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="repackaging">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a specific activity
                  within a business process where an object’s packaging configuration is
                  changed.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="repairing">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a specific activity
                  within a business process where a malfunctioning product is repaired (typically by
                  a post-sales service), without replacing it by a new one.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="replacing">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a specific activity
                  within a business process where an object (part, product, asset, container) is
                  substituted or exchanged for another object.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="reserving">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Process for an EPC number
                  manager to provide a set of EPC numbers for use by another
                  party.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="retail_selling">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a specific activity
                  within a business process at a point-of-sale for the purpose of transferring
                  ownership to a customer in exchange for something of value (currency, credit,
                  etc).</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="shipping">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Indicates the overall process
                  of picking, staging, loading and departing. It may be used when more granular
                  process step information is unknown or inaccessible. It may indicate a final event
                  from a shipping point. The use of shipping is mutually exclusive from the use of
                  departing, staging, or loading.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="staging_outbound">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a specific activity
                  within a business process associated with the movement of an object (i.e. product,
                  shipment, asset, container) from a facility to an area where it will await
                  transport pick-up</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="status_changing">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes an activity that
                  leads to an administrative change of the objects, without being moved physically.
                  Note: added for Warehousing project</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="stocking">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a specific activity
                  within a business process within a location to make a product available to the
                  customer or for order fulfillment within a DC</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="storing">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a specific activity
                  within a business process where objects are moved into and out of storage within a
                  location</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="transferring">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a physical move of
                  the object within the warehouse or between different warehouses. Note: added for
                  Warehousing project</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="transforming">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Denotes a specific activity
                  within a business process where one or more objects are an input into a process
                  that irreversibly changes that object / those objects into a new object or
                  objects; the output has a new identity and characteristics.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="InventoryDispositionCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:InventoryDispositionCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="active">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Commissioned objects
                  (product, shipment, asset, or container) introduced into the supply
                  chain</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="container_closed">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Object (product, shipment,
                  asset,) has been loaded onto a container, the doors have been closed and the
                  shipment sealed.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="destroyed">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Object (product, shipment,
                  asset, or container) and/or EPC on packaging have been fully rendered
                  nonusable</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="encoded">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">EPCs have been written to a
                  tag</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="in_progress">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Default disposition for
                  object (product, shipment, asset, or container) proceeding through points in the
                  supply chain.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="in_transit">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Object (product, shipment,
                  asset, or container) being shipped between two trading
                  partners</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="inactive">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Decommissioned object
                  (product, shipment, asset, or container) that may be reintroduced to the supply
                  chain</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="non_sellable_damaged">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Product that cannot be sold
                  because it has a flaw</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="non_sellable_disposed">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Product is non-sellable
                  because it has been returned for disposal</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="non_sellable_expired">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Product is non-sellable
                  because current date is past expiration date</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="non_sellable_no_pedigree_match">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">In validating the pedigree
                  for the product, no match was found, causing the product to be quarantined for
                  further investigation and disposition</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="non_sellable_other">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Product cannot be sold to a
                  customer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="non_sellable_quarantined">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Product is non-sellable
                  because it has been quarantined, for example awaiting quality inspection. Note:
                  Added for the warehousing project.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="non_sellable_recalled">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Product is non-sellable
                  because of public safety reasons.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="reserved">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">EPCs have been allocated by
                  an EPC number manager for a third party</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="retail_sold">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Product has been purchased by
                  a customer</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="returned">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Object (product, shipment,
                  asset, or container) has been sent back for various reasons. It may or may not be
                  sellable.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="sellable_accessible">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Product can be sold as is and
                  customer can access product for purchase</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="sellable_not_accessible">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Product can be sold as is,
                  but customer cannot access product for purchase</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="sellable_recirculation">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Product (ATM slot, cassette)
                  is in function: "reycling"; articles (banknote / coin) are payed-in and payed-out
                  (sellable)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="unknown">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Product condition is not
                  known</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="InventoryEventReasonCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:InventoryEventReasonCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="ADMINISTRATIVE_TRANSFER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">administrative
                  transfer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Inventory adjustment due to
                  goods changing administrative status, for example changing from consigned to
                  non-consigned stock.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DAMAGED_IN_WAREHOUSE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">damaged in
                  warehouse</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Inventory adjustment due to
                  damage that occurred in the warehouse. </xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DESPATCH_DISCREPANCY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">despatch
                  discrepancy</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Inventory adjustment due to a
                  discrepancy noticed during goods despatch.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="INTER_WAREHOUSE_TRANSFER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">inter warehouse
                  transfer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Inventory adjustment due to
                  goods being moved to another warehouse.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MATERIAL_SCRAPPED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">material
                  scrapped</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Inventory adjustment due to
                  goods being scrapped. </xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PHYSICAL_COUNT_DIFFERENCE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">physical count
                  difference</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Inventory adjustment due to a
                  discrepancy noticed during physical counting.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="QUALITY_INSPECTION_DIFFERENCE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">quality inspection
                  difference</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Inventory adjustment due to a
                  discrepancy noticed during quality inspection.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RECEIPT_DISCREPANCY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">receipt
                  discrepancy</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Inventory adjustment due to a
                  discrepancy noticed during goods receipt.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="WAREHOUSE_TRANSFER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">warehouse
                  transfer</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Inventory adjustment due to
                  goods being moved to another location within the warehouse.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="InventoryMeasurementBasisTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:InventoryMeasurementBasisTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="ON_HAND_ONLY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Only the current on-hand
                  balance is included in the inventory cover calculation</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ON_HAND_PLUS_PIPELINE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Both the current on-hand
                  balance as well as inbound inventory in the distribution pipeline is included in
                  the inventory cover calculation</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="InventoryMovementTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:InventoryMovementTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="DECREASE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Decrease</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The quantity of a particular
                  trade item, held at a specified location, with a specified status, is decreased.
                  Release notes: Added in version 2</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="INCREASE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Increase</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The quantity of a particular
                  trade item, held at a specified location, with a specified status, is increased.
                  Release notes: Added in version 2</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MOVING_INVENTORY_INTO_INVENTORY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Moving Inventory Into
                  Inventory</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An inventory or product
                  movement into the place where item is stored.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MOVING_INVENTORY_OUT_OF_INVENTORY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Moving Inventory Out Of
                  Inventory</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">An inventory or product
                  movement out of the place where item is stored.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="InventoryReportTypeEnumeration">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:InventoryReportTypeEnumeration</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="INVENTORY_ACTIVITY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Inventory Activity is used to
                  report on all the changes on the inventory level per item.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="INVENTORY_STATUS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Inventory Status is used to
                  report on the actual inventory per item.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="INVENTORY_STATUS_AND_ACTIVITY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"/>
               <xsd:documentation xml:lang="en-US" source="Definition">Inventory Status is used to
                  report on both the actual inventory per item and all the changes on the inventory
                  level per item.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="InventoryStatusCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:InventoryStatusCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="ALLOCATED_FOR_ORDER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Allocated for
                  order</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Inventory designated to
                  fulfil a shipment request.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="AVAILABLE_FOR_SALE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Available for
                  sale</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Inventory designated to
                  fulfil future shipment requests.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="BLOCKED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Blocked</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Inventory that has been
                  identified and categorized as blocked.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DAMAGED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Damaged</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Inventory that has been
                  identified and categorized as damaged.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="EXPIRED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Expired</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Inventory that has been
                  identified as exceeding the maximum durability date of an
                  item.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="IN_TRANSIT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">In transit</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Inventory being transferred
                  or transported either in-bound or out-bound to the warehouse or warehouse
                  location.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="LIMITED_LIFETIME">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Limited
                  lifetime</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The product has limited life
                  cycle</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MAXIMUM_STOCK">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Maximum stock</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Maximum stock target quantity
                  in storage location in order to trigger action if this is exceeded.
               </xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MINIMUM_STOCK">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Minimum stock</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Minimum stock target quantity
                  in storage location in order to trigger actions if this is exceeded.
               </xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="NEARING_EXPIRATION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Nearing
                  expiration</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The product is nearing the
                  end of their its life cycle</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ON_CONSIGNMENT_ON_HAND">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">On consignment on
                  hand</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Total quantity of all
                  inventory for a warehouse or warehouse location. To be used in a Consignment Stock
                  process, meaning goods in stock with agreement on payment when goods are sold or
                  consumed out of this stock. Goods or products are owned by the vendor until they
                  are sold or consumed by the buyer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ON_CONSIGNMENT_ON_HOLD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">On consignment on
                  hold</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Total quantity of
                  non-shippable or non-saleable inventory in a warehouse or warehouse location. This
                  status is temporary. As an example this is product that has promotion, sales, or
                  damage hold reasons. To be used in a Consignment Stock process, meaning goods in
                  stock with agreement on payment when goods are sold or consumed out of this stock.
                  Goods or products are owned by the vendor until they are sold or consumed by the
                  buyer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ON_CONSIGNMENT_QUARANTINED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">On consignment
                  quarantined</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Status of product in a
                  warehouse or warehouse location that has been produced, but has not yet cleared
                  quality /performance testing and is therefore not available for transport or sale.
                  To be used in a Consignment Stock process, meaning goods in stock with agreement
                  on payment when goods are sold or consumed out of this stock. Goods or products
                  are owned by the vendor until they are sold or consumed by the buyer.
               </xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ON_CONSIGNMENT_RESTRICTED_USE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">On consignment restricted
                  use</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Status for items that are
                  going through a specific check outside of the quarantined process. For example: If
                  an item is nearing its expiration date, it is available for controlled use and is
                  identified by a restricted status. To be used in a Consignment Stock process,
                  meaning goods in stock with agreement on payment when goods are sold or consumed
                  out of this stock. Goods or products are owned by the vendor until they are sold
                  or consumed by the buyer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ON_HAND">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">On hand</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The total quantity of all
                  inventory for a warehouse or warehouse location.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ON_HOLD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">On hold</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The total quantity of
                  non-shippable or non-saleable inventory in a warehouse or warehouse location. This
                  status is temporary. As an example this is product that has promotion, sales, or
                  damage hold reasons.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="QUARANTINED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Quarantined</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Status of product in a
                  warehouse or warehouse location that has been produced, but has not yet cleared
                  quality /performance testing and is therefore not available for transport or
                  sale.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RECALLED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Recalled</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Product in inventory that has
                  been withdrawn from circulation.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RESTRICTED_USE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Restricted use</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Items that are going through
                  a specific check outside of the quarantined process. For example: If an item is
                  nearing its expiration date, it is available for controlled use and is identified
                  by a restricted status. </xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RETURNED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Returned</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Product in inventory that has
                  been returned from the buyer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="InventorySubLocationFunctionCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:InventorySubLocationFunctionCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="401">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Electronics</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> A specific area within the
                  store for holding electronic products such as TV's, DVD players,
                  etc.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="402">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Cold storage</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> A specific area or room that
                  maintains a temperature above freezing but below ambient room
                  temperature.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="403">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Shelf</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> A specified internal
                  location for holding product.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="404">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Frozen</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> A specific area or room that
                  maintains a temperature at or below freezing</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="405">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Fresh</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> A specific area or room that
                  maintains a specified temperature and/or humidity to preserve stored
                  product</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="406">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Promotion</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> A specific area or room that
                  is used to hold special purchased product.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="407">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">End Cap</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> A specific internal location
                  on the sales floor, typically at the end of an aisle, for displaying
                  product.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="408">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Point of Sale</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area in a retail location
                  where sales transactions occur</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="409">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Security</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> A designated internal
                  location for the purpose of minimizing direct access to the
                  product</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="411">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">General
                  Merchandise</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area where typically –
                  non-food products other than perishable, dry groceries and health and beauty care
                  products that are displayed in stores on standard shelving. Examples include
                  household cleaning products, paper napkins, laundry detergents, and insect
                  repellents</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="412">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Grocery</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area where typically -
                  food products that are displayed in stores on standard shelving. Examples include
                  canned goods, produce, meats.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="413">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Box Crusher</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> A Baler used to compact
                  recycled materials (e.g. corrugated boxes, slip sheets and packaging
                  material)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="414">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dock / Door</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> One or more doors where
                  trucks or rail cars are loaded (shipping) or unloaded (receiving). Used to load or
                  unload trailers or vans.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="415">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Conveyor Belt</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> A continuous moving strip or
                  surface that is used for transporting single cartons or a load of objects from one
                  place to another</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="416">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Pallet Wrapper</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area where any automatic
                  or manual method using bands of plastic film applied to product used to encase
                  palletized loads prior to shipment to protect against product
                  damage.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="417">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Fixed Reader</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> Any fixed read point
                  configuration (reader and antennas) for the purpose of capturing EPC data (e.g.
                  Door way or conveyor read point)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="418">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Mobile Reader</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> Any non-fixed (portable)
                  reader configuration (reader and antennas) for the purpose of capturing EPC data
                  (e.g. Hand held or forklift reader)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="419">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Shelf/Storage</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> Where the product is stored
                  on the sales floor, not accessible to the customer, until it can be moved, making
                  it accessible to the consumer.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="420">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Returns</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area within a store or
                  retailer DC for holding or consolidating product to be sent back to the supplier,
                  shipper or designated location.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="421">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Staging</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area within a DC or
                  Manufacturing Facility which the receiving and shipping docks use to gather and
                  check inbound and outbound loads.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="422">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Assembly</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area where components are
                  put together into an end product, appropriate to the process
                  concerned.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="423">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Lay-Away</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area within a store for
                  holding or consolidating customer purchases for final payment and
                  pickup</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="424">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Dispenser</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> Tablet, caplet or capsule
                  dispensing machine in which bulk product has been placed to be dispensed on a
                  prescription basis.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="425">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Quarantine</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area at a Manufacturing,
                  Distribution or Retail facility to hold product that may not be suitable for
                  consumption until further inspection</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="426">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Controlled
                  Substance</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> A caged and locked area in
                  which regulated, controlled substance pharmaceuticals are held while awaiting
                  shipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="427">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Recalled
                  Product</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area in which recalled
                  product is stored pending shipment back to the manufacturer or the manufacturer’s
                  designated returns centre for final disposition</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="428">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Quality Control</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area in which any product
                  not meeting quality standards is held pending further
                  evaluation.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="429">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Printing Room</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area which provides
                  printed labels/tags for the goods/cartons/pallets within a DC or Manufacturing
                  Facility. Please note: this supports the process where an EPC tag is encoded off
                  the line and is later commissioned and associated with a particular product.
               </xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="430">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Truck Dock</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> A parking bay, partly
                  enclosed by a raised platform, at which trucks are loaded and unloaded, e.g. in a
                  warehouse site.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="431">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Entrance Gate</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> A point of transport access
                  into a yard or other arriving area.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="432">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Exit Gate</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> A point of transport exit
                  from a yard or other departing area.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="433">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gate</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> A point of transport within
                  a facility – not indicated specifically as an entrance or an exit
                  point.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="434">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Read Point Verification
                  Spot</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> A point at which a tagged
                  object's location has been verified by an associated read of a separate fixed
                  location tag. Read Point Verification Spot would be used when there is a business
                  process to capture the current location of an object at rest (typically with a
                  mobile reader).</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="InventorySubLocationTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:InventorySubLocationTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="201">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Backroom</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area within a store (all
                  formats - club, etc) used to hold product until it is purchased or can be moved to
                  the sales floor</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="202">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Storage Area</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area where product is
                  kept within a facility to fulfil future need. Reserve rack or bulk stacking. A
                  location where the product is stored until it is needed in selection aisles making
                  it accessible to the consumer. Reserve slots may contain one or multiple pallet
                  loads, as well as multiple items within them For a retail store Secondary storage
                  area associated with a store (may not be in the physical location) Potential to
                  use this more broadly and add attributes to make distinction</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="203">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sales Floor</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area within a store (all
                  formats - club, etc) where product is displayed for customer
                  purchase</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="207">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Returns Area</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area within a facility
                  for holding or consolidating product to be sent back to the supplier, shipper or
                  designated location</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="208">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Production Area</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area within a facility
                  where the conversion of materials and or assembly of components to manufacture
                  goods, products or services takes place.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="209">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Receiving Area</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area within a facility
                  where incoming merchandise is unloaded and checked for condition and
                  completeness</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="210">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Shipping Area</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area within a facility
                  where outgoing merchandise is checked for condition and completeness and loaded
                  onto a conveyance for transport</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="211">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sales Floor Transition
                  Area</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area within a store
                  between two physical locations (e.g. Backroom and Sales Floor) - used for a read
                  point only</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="212">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Customer Pick-Up
                  Area</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area designated at a
                  store for customer to take possession of purchased product.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="213">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Yard</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area outside of the main
                  building used for holding product (e.g. Trailer or container)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="214">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Container Deck</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area on board a shipping
                  vessel where containers are loaded.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="215">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Cargo Terminal</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area where cargo may get
                  transferred between carriers. Cargo terminals provide the interface between modes
                  of transportation.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="251">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Packaging Area</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area within a facility
                  where product is packaged.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="252">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Picking Area</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area within a facility in
                  which product is picked to fulfill an order.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="253">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Pharmacy Area</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> An area within a facility
                  where prescription products are stored, dispensed and/or sold.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="299">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Undefined</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition"> Any sub-site type not
                  identified by any of the listed values</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="InvoiceTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:InvoiceTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="AGREED_TERMS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Agreed terms</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Claim for payment of goods or
                  services based upon terms agreed on a bi-lateral basis between the trading
                  partners.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CORRECTED_INVOICE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Corrected
                  invoice</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Claim for payment of goods
                  and services that includes revised information differing from an earlier
                  submission of the same claim for payment.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CREDIT_NOTE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Credit note</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Credit correction of an
                  earlier exchanged claim for payment by an invoice or any other claim for an
                  identified and agreed financial discrepancy.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DEBIT_NOTE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Debit note</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Debit correction of an
                  earlier exchanged claim for payment by an invoice or any other claim for an
                  identified and agreed financial discrepancy.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="INVOICE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Invoice</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Claim for payment for goods
                  or services supplied under conditions agreed between the seller and the buyer,
                  seller originated.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="OTHER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Other</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Type of invoice not covered
                  by other codes.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PRO_FORMA_INVOICE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Pro forma
                  invoice</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Document or message serving
                  as a preliminary invoice, containing – on the whole - the same information as the
                  final invoice, but not actually claiming payment.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SELF_BILLED_CREDIT_NOTE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Self billed credit
                  note</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Credit correction of an
                  earlier exchanged claim for payment by a (Self Billed) invoice or any other claim
                  for an identified and agreed financial discrepancy, buyer
                  originated.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SELF_BILLED_INVOICE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Self billed
                  invoice</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Claim for payment for goods
                  or services supplied under conditions agreed between the seller and the buyer,
                  buyer originated.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="TAX_INVOICE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Tax invoice</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Claim for payment for goods
                  or services supplied under conditions agreed between the seller and the buyer,
                  seller originated for taxation purposes.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="ItemScopeTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:ItemScopeTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="BRAND">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Brand</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All products of a specific
                  brand</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CLASS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Class</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All products that fall within
                  a global product class or category</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="COLOUR">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Colour</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All products of a specific
                  colour</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DEPARTMENT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Department</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All products that fall within
                  a retailer's department</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="FLAVOUR">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Flavour</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All products of a specific
                  flavour</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="GPC">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gpc</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A component of GS1 GDSN. It
                  provides the required global framework for trade item categorisation supporting
                  global data synchronisation.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="GTIN">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Gtin</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The GS1 Identification Key
                  used to identify trade items. The key comprises a GS1 Company Prefix followed by
                  an Item Reference Number and a Check Digit.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ITEM">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Item</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All of the style, colour,
                  size, flavour and variety variations of a specific product</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="LINE_OF_BUSINESS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Line of
                  business</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All products that fall within
                  a supplier's line of business</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RETAIL_CATEGORY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Retail category</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All products that fall within
                  a retailer's item category</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SIZE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Size</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All products of a specific
                  size</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SKU">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sku</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All products that are
                  equivalent from a retailer's stocking perspective</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="STYLE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Style</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All products of a specific
                  style</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SUBCLASS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Subclass</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All products that fall within
                  a global product subclass or subcategory</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="TOTAL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Total</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All
                  products</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="TRADING_RELATIONSHIP">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Trading
                  relationship</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All of the supplier's
                  products that the customer distributes</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="VARIETY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Variety</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All products of a specific
                  variety</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="ItemSourceCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:ItemSourceCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="CROSSDOCKING">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Crossdocking</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Shipment must be executed
                  using another Crossdocking order.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="WAREHOUSE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Warehouse</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Shipment must be executed
                  from existing warehouse stock.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="WAREHOUSE_OR_CROSSDOCK">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name"> Warehouse Or
                  Crossdock</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Shipment may be executed from
                  existing warehouse stock or using another Crossdocking order.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="ItemTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:ItemTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="CONSUMER_UNIT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Consumer Unit</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The package size of a product
                  or products agreed by trading partners as the size sold at the retail point of
                  sale</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DESPATCH_UNIT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Despatch Unit </xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The package size of a product
                  or products which may be shipped when fulfilling an order</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="INVOICING_UNIT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Invoicing Unit </xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The package size of a product
                  or products which will be used as the unit on which the buyer is
                  invoiced</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ORDERING_UNIT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Ordering Unit </xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Indication that the current
                  product is an ordering unit (ordering unit will not normally equal invoicing
                  unit)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="LanguageCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:LanguageCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token"/>
   </xsd:simpleType>
   <xsd:simpleType name="LegalRegistrationCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:LegalRegistrationCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="BUSINESS_REGISTRATION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Business
                  registration</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Not
                  available</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CHAMBER_OF_COMMERCE_REGISTRATION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Chamber of commerce
                  registration</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Not
                  available</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="LineItemActionCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:LineItemActionCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="ADDITION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Addition</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">This line item is to be added
                  to the original purchase order as a new or additional item. All required data must
                  be transmitted.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CHANGED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Changed</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">This line item is to be
                  changed. The data transmitted replaces the previously held information for the
                  order line item.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DELETED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Deleted</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">This line item is to be
                  deleted from the referenced purchase order. No other data for the line item needs
                  to be transmitted.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="NOT_AMENDED">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Not amended</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">This line item has not been
                  changed and is included for information.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PENDING">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Pending</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">This line item has not been
                  changed and is included since discussion is required on the action to be
                  taken.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="LocationScopeParameterTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:LocationScopeParameterTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="CUSTOMER_DESTINATION_LOCATION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Customer destination
                  location</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Filters the location scope
                  specified by a RECEIVING_LOCATION to include only those locations of a certain
                  type. For example, if the RECEIVING_LOCATION is CHAIN (normally all locations
                  within the chain), CUSTOMER_DESTINATION_LOCATION can be set to DISTRIBUTION_CENTRE
                  to indicate that the locations should only include the distribution centres within
                  the chain, not other types of locations (such as stores). Because it is a filter,
                  CUSTOMER_DESTINATION_LOCATION does not have a corresponding
                  locatio</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="LOCATION_CONTEXT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Location
                  context</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Defines the overall range of
                  locations from which a selection of locations may be made. For example, the
                  location context could be set to COUNTRY with a value of “FR” (France). Then if
                  the LOCATION_SELECTION is set to CHAIN with the corporate GLN value of a retailer,
                  the result is that only those retailer chain locations within France would be
                  within the scope of the calculation.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="LOCATION_SELECTION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Location
                  selection</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Describes the specific set of
                  locations to be measured within a broader location context. For example, if the
                  LOCATION_CONTEXT is CHANNEL, with a value of Grocery, and the LOCATION_SELECTION
                  is POSTAL_CODE, with a value of 01742, only grocery stores within the 01742 postal
                  code would be within the scope of the calculation.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RECEIVING_LOCATION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Receiving
                  location</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifies the facility or a
                  range of facilities that are at the destination of a delivery.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SHIPPING_LOCATION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Shipping
                  location</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Identifies the facility or a
                  range of facilities that are at the origin of a delivery.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="VENDOR_LOCATION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Vendor location</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Filters the location scope
                  specified by a SHIPPING_LOCATION to include only those facilities of a certain
                  type. For example, if the SHIPPING_LOCATION is SUPPLIER (normally all locations
                  within the supplier), VENDOR_LOCATION can be set to PLANT to indicate that the
                  locations should only include the plant shipments from the supplier, not shipments
                  from distribution centres. Because it is a filter, VENDOR_LOCATION does not have a
                  corresponding location value.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
      </xsd:restriction>
   </xsd:simpleType>
   <xsd:simpleType name="LocationScopeTypeCode">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Note">urn:gs1:gdd:cl:LocationScopeTypeCode</xsd:documentation>
      </xsd:annotation>
      <xsd:restriction base="xsd:token">
         <xsd:minLength value="1"/>
         <xsd:maxLength value="80"/>
         <xsd:enumeration value="AREA">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Area</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All store regions within an
                  area</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CHAIN">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Chain</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All locations within a retail
                  chain</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CHANNEL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Channel</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All locations within a
                  specific class of trade</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="CITY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">City</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All locations within the
                  boundaries of a city</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="COUNTRY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Country</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All locations within a
                  country</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DISTRIBUTION_CENTRE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Distribution
                  centre</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A specific distribution
                  centre location</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="DIVISION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Division</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A specific division
                  location.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="GEOGRAPHICAL_REGION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Geographical
                  region</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All locations within a
                  specified geographic region</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="GEOGRAPHICAL_SUBREGION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Geographical
                  subregion</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All locations within a
                  specified geographic subregion</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="GLN">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">GLN</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The GS1 Identification Key
                  used to identify physical locations or legal entities. The key comprises a GS1
                  Company Prefix, Location Reference, and Check Digit.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="LANE_OR_ROUTE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Lane or route</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A specific transportation
                  lane or route</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PLANT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Plant</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A specific production plant
                  or factory location</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="POSTAL_CODE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Postal code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All locations within a
                  specific postal code</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="STATE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">State</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">All locations within a state
                  or province</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="STOCKING_LOCATION">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Stocking
                  location</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A specific stocking location
                  (e.g. shelf, display) within a store</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="STORE">
