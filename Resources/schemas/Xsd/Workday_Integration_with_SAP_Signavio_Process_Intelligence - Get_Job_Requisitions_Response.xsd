<xsd:documentation>The additional job posting locations for the job requisition.</xsd:documentation>
</xsd:annotation>
</xsd:element>
<xsd:element minOccurs="0" name="Time_Type_Reference" type="wd:Position_Time_TypeObjectType">
<xsd:annotation>
<xsd:documentation>The Position Time Type for the Job Requisition.</xsd:documentation>
</xsd:annotation>
</xsd:element>
<xsd:element minOccurs="0" name="Employee_Contract_Type_Reference" type="wd:Employee_Contract_TypeObjectType">
<xsd:annotation>
<xsd:documentation>The Employee Contract Type for the Job Requisition.</xsd:documentation>
</xsd:annotation>
