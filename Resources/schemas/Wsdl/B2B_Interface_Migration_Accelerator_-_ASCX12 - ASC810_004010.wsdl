="D_750"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c629e61ff311e185df0026b9aa16ff</xsd:appinfo><xsd:documentation>PID02| Product/Process Characteristic Code</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="2"/><xsd:maxLength value="3"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_559"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c629e71ff311e19a1c0026b9aa16ff</xsd:appinfo><xsd:documentation>PID03| Agency Qualifier Code. NOTES: Use PID03 to indicate the organization that publishes the code list being referred to.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_751"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c629e81ff311e1a4e40026b9aa16ff</xsd:appinfo><xsd:documentation>PID04| Product Description Code. NOTES: C0403 - If PID04 is present, then PID03 is required. R0405 - At least one of PID04 or PID05 is required. PID04 should be used for industry-specific product description codes.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="12"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_352"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c629e91ff311e193480026b9aa16ff</xsd:appinfo><xsd:documentation>PID05| Description</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="80"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_752"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c629ea1ff311e18be70026b9aa16ff</xsd:appinfo><xsd:documentation>PID06| Surface/Layer/Position Code. NOTES: Use PID06 when necessary to refer to the product surface or layer being described in the segment.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="2"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_822"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c629eb1ff311e19e920026b9aa16ff</xsd:appinfo><xsd:documentation>PID07| Source Subqualifier. NOTES: C0703 - If PID07 is present, then PID03 is required. PID07 specifies the individual code list of the agency specified in PID03.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="1"/><xsd:maxLength value="15"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_1073"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c629ec1ff311e1a2370026b9aa16ff</xsd:appinfo><xsd:documentation>PID08| Yes/No Condition or Response Code. NOTES: C0804 - If PID08 is present, then PID04 is required. PID08 describes the physical characteristics of the product identified in PID04. A "Y" indicates that the specified attribute applies to this ite...</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:length value="1"/></xsd:restriction></xsd:simpleType></xsd:element><xsd:element minOccurs="0" name="D_819"><xsd:annotation><xsd:appinfo source="http://sap.com/xi/TextID">b6c629ed1ff311e1cb080026b9aa16ff</xsd:appinfo><xsd:documentation>PID09| Language Code. NOTES: C0905 - If PID09 is present, then PID05 is required. PID09 is used to identify the language being used in PID05.</xsd:documentation></xsd:annotation><xsd:simpleType><xsd:restriction base="xsd:string"><xsd:minLength value="2"/><xsd:maxLength value="3"/></xsd:restriction></xsd:simpleType></xsd:element></xsd:sequence></xsd:complexType></xsd:element></xsd:sequence></xsd:complexType></xsd:element><xsd:element minOccurs="0" name="S_CTT"><xsd:annotation><xsd:appinfo sourc