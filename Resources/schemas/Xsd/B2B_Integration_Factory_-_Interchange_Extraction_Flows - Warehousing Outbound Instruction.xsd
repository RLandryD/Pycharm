         <xsd:enumeration value="MOV">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Move</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identified product is to
                  be moved according to instructions specified.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="MP">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Potential Marine
                  Pollutant</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identified product is a
                  potential marine pollutant.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="NES">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Nestable</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A package which can be
                  stacked into similar package types e.g. applies for dishes, plates, bowls or
                  buckets.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="NSD">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Nesting Depth</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The item can be stacked into
                  each other (e.g. plates, bowls or buckets). The nesting refers to the depth of the
                  item's facing (main view).</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="NSH">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Nesting Height</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The item can be stacked into
                  each other (e.g. plates, bowls or buckets). The nesting refers to the height of
                  the item's facing (main view).</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="NSW">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Nesting Width</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The item can be stacked into
                  each other (e.g. plates, bowls or buckets). The nesting refers to the width of the
                  item's facing (main view).</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="NWP">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Newspapers,
                  magazines</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Newspapers, magazines (GS1
                  Code)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ODO_A">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Absorbs Odour</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identified product
                  absorbs odour.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ODO_E">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Emits Odour</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identified product emits
                  odour.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="ODO_N">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Odour Neutral</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identified product is
                  odour neutral.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="OHG">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Overhang item</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Overhang item (GS1
                  Code)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="OSB">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Stow Below Deck</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identified product must
                  be stowed below deck when transported on a cargo ship.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="OTC">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Temperature
                  Control</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Temperature control applies
                  during handling transport and storage of the identified product from production to
                  consumption within defined temperature range.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PACE">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Pack</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identified product is to
                  be packed according to the instructions provided.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PCB">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Put the Cap Back on Carefully After
                  Use</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">To keep the intrinsic
                  qualities of the product users must put the cap back on carefully after
                  use</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Perishable
                  Cargo</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Perishable cargo (GS1
                  Code)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PFH">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Protect From
                  Heat</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identified product must
                  be protected from heat.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PFS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Prepare for
                  Shipment</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identified product(s)
                  is(are) to be prepared for shipment.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PG">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Poisonous Gas</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identified product
                  is/contains poisonous gas.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PHR">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Per Hour Rate
                  Applies</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">A per-hour rate applies for
                  handling the identified product.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PI">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Poisonous by
                  Inhalation</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identified product is
                  poisonous by inhalation.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PIC">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Pick</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identified product is to
                  be picked.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PKS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Pick in
                  Sequence</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The identified product is to
                  be picked according to a specific sequence.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PRS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">The Solution Must be Prepared
                  Immediately Before Use</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">To keep the intrinsic
                  qualities of the product the solution must be prepared immediately before
                  use</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="PSC">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Pest
                  Controlling</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Pest
                  controlling</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RCY">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Recyclable
                  Packaging</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Recyclable
                  packaging</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RES">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Reserve</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Reserve identified goods
                  according to specified instructions.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RFG">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Flammable Compressed
                  Gas</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Flammable compressed
                  gas</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RFL">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Flammable
                  Liquid</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Flammable
                  liquid</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RFS">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Flammable Solid</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Flammable
                  solid</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="RPB">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Poison </xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Poison</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SAC">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Store Away From
                  Cold</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The product must be stored
                  away from cold</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SAN">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sandwich Pallet
                  Allowed</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Sandwich pallet
                  allowed.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SCB">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Ships to Consumer in
                  Bag</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The product is shipped direct
                  to consumer in a bag.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SER">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Serial Number</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Product managed by serial
                  number .</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SGU">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Storage General
                  Use</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Product is to be stored
                  according to instructions specified (GS1 Code)</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SHP">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Trade Item Shippable Package </xsd:documentation>
