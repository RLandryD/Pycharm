					<xsd:element name="SuplrInvcDeliveryCostCndnStep" type="SuplrInvcDeliveryCostCndnStep_GFN" minOccurs="0"/>
					<xsd:element name="SuplrInvcDeliveryCostCndnType" type="SuplrInvcDeliveryCostCndnType_GFN" minOccurs="0"/>
				</xsd:sequence>
			</xsd:complexType>
