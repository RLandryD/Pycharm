			element="tns1:CFDGetStatusRequest">
		</wsdl:part>
	</wsdl:message>
	<!-- <wsdl:message name="CertProviderResponse"> <wsdl:part name="parameters" 
		element="cfdi:PACResponse"></wsdl:part> </wsdl:message> -->
	<wsdl:portType name="CFDIeDocuments">
		<wsdl:operation name="SubmitEdoc">
			<wsdl:input message="tns1:SubmitEdocRequest" />
			<wsdl:output message="tns1:CertProviderResponse" />
		</wsdl:operation>
		<wsdl:operation name="CancelEdoc">
			<wsdl:input message="tns1:CancelEdocRequest"></wsdl:input>
			<wsdl:output message="tns1:CertProviderResponse"></wsdl:output>
		</wsdl:operation>
		<wsdl:operation name="GetStatus">
