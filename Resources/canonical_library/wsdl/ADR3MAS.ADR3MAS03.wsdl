							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="1" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="HOME_FLAG" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Recipient address in this communication type
								(mail sys.grp)</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="1" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="CONSNUMBER" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Sequence number</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="3" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="URI_PART1" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Universal Resource Identifier (URI): Parts 1-8
							</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="250" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="URI_PART2" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Universal Resource Identifier (URI): Parts 1-8
							</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="250" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="URI_PART3" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Universal Resource Identifier (URI): Parts 1-8
							</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="250" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="E1BPADURI1" type="ADR3MAS03.E1BPADURI1"
