               <xsd:documentation xml:lang="en-US" source="Definition">Day of the month applied in case of monthly billing cycles to determine in which month the transaction will be billed.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 15</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="netPaymentDue" minOccurs="0" type="PaymentTimePeriodType">
