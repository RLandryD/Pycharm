            <xs:element minOccurs="0" name="type">
                <xs:annotation>
                    <xs:documentation>type</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:string">
                        <xs:maxLength value="255"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
            <xs:element minOccurs="0" name="updated-at" type="xs:string">
                <xs:annotation>
                    <xs:documentation>Automatically created by Coupa in the format YYYY-MM-DDTHH:MM:SS+HH:MMZ</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element minOccurs="0" name="updated-by" type="UserSimple1"/>
            <xs:element minOccurs="0" name="url">
                <xs:annotation>
                    <xs:documentation>url</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                    <xs:restriction base="xs:string">
                        <xs:maxLength value="255"/>
                    </xs:restriction>
                </xs:simpleType>
            </xs:element>
