               <xsd:documentation xml:lang="en-US" source="Name">Inventory Movement Type Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying whether the reported activity leads to an increase or decrease of the inventory quantity.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
