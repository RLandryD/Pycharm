   <xsd:complexType name="InventoryStatusQuantitySpecificationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Supplies the inventory status information with the quantity and the inventory status type.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="inventoryStatusType" type="InventoryStatusCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Inventory Status Type</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the inventory status of the goods.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="quantityOfUnits" type="QuantityType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Quantity Of Units</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Quantity of goods with the specified inventory status.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 15</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="transactionalItemData" minOccurs="0" maxOccurs="unbounded"
