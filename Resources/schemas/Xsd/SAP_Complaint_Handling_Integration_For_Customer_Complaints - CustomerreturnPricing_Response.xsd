													<xs:element minOccurs="0" maxOccurs="1" name="ConditionCalculationType" type="xs:string"/>
													<xs:element minOccurs="0" maxOccurs="1" name="ConditionCurrency" type="xs:string"/>
												</xs:sequence>
											</xs:complexType>
										</xs:element>
									</xs:sequence>
								</xs:complexType>
							</xs:element>
							<xs:element minOccurs="0" maxOccurs="unbounded" name="headerPricing">
								<xs:complexType>
									<xs:sequence>
										<xs:element minOccurs="0" maxOccurs="1" name="ConditionType" type="xs:string"/>
