		</xsd:schema>
	</wsdl:types>
	<wsdl:message name="SubmitEdocRequest">
		<wsdl:part name="parameters" element="tns1:CFDSubmitRequest" />
	</wsdl:message>
	<wsdl:message name="CertProviderResponse">
		<wsdl:part element="tns1:PACResponse" name="parameters" />
	</wsdl:message>
	<wsdl:message name="CancelEdocRequest">
		<wsdl:part name="parameters" element="tns1:CFDCancelRequest"></wsdl:part>
	</wsdl:message>
