    		<xsd:element name="regionCity" type="xsd:string" maxOccurs="1" minOccurs="0"></xsd:element>
    		<xsd:element name="street" type="xsd:string" maxOccurs="1" minOccurs="0"></xsd:element>
    		<xsd:element name="buildingNumber" type="xsd:string" maxOccurs="1" minOccurs="0"></xsd:element>
    		<xsd:element name="postalCode" type="xsd:string" maxOccurs="1" minOccurs="0"></xsd:element>
    		<xsd:element name="floor" type="xsd:string" maxOccurs="1" minOccurs="0"></xsd:element>
    		<xsd:element name="room" type="xsd:string" maxOccurs="1" minOccurs="0"></xsd:element>
    		<xsd:element name="landmark" type="xsd:string" maxOccurs="1" minOccurs="0"></xsd:element>
