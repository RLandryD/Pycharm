            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="DeliveryTermsType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">The applicable legal, customs, financial and insurance terms that have been agreed for a goods delivery.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="incotermsCode" minOccurs="0" type="IncotermsCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Incoterms Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the incoterms. Incoterms is an abbreviation for International Commercial Terms. The International Chamber of Commerce manages the Incoterms codes and their definitions.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="alternateDeliveryTermsCode" minOccurs="0" type="CodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Alternate Delivery Terms Code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Alternate code</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Code specifying the delivery terms according to a system other than the Incoterms.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="deliveryInstructions" minOccurs="0" type="Description500Type">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Delivery Instructions</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: Instructions for delivey</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Instructions on the final delivery of the goods.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="deliveryCostPayment" minOccurs="0"
            type="TransportChargesPaymentMethodCodeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Delivery Cost Payment</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="deliveryTermsLocation" minOccurs="0" type="LogisticLocationType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Delivery Terms Location</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Location that is applicable to these delivery terms, such as the Free On Board (FOB) destination location.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="DeliveryTimeMeasurementBasisTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a delivery time measurement basis type. Allowed code values are specified in GS1 Code List DeliveryTimeMeasurementBasisTypeCode.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:DeliveryTimeMeasurementBasisTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: FIRST_APPOINTMENT_DATE_TIME</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="DeliveryTimeMeasurementBasisTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="DeliveryTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a delivery type. Allowed code values are specified in GS1 Code List DeliveryTypeCode.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:DeliveryTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: COMPLETE_DELIVERY</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="DeliveryTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="DemandEstimationTypeCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying a demand estimation type. Allowed code values are specified in GS1 Code List DemandEstimationTypeCode.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 External references: Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GDD URN: http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:DemandEstimationTypeCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: FORECAST_BASIS</xsd:documentation>
      </xsd:annotation>
      <xsd:simpleContent>
         <xsd:extension base="DemandEstimationTypeCode">
            <xsd:attribute name="codeListVersion">
               <xsd:annotation>
                  <xsd:documentation xml:lang="en-US" source="Name">Code List Version</xsd:documentation>
                  <xsd:documentation xml:lang="en-US" source="Definition">Identification of the applied version of the code list.</xsd:documentation>
               </xsd:annotation>
               <xsd:simpleType>
                  <xsd:restriction base="xsd:string">
                     <xsd:minLength value="1"/>
                     <xsd:maxLength value="35"/>
                  </xsd:restriction>
               </xsd:simpleType>
            </xsd:attribute>
         </xsd:extension>
      </xsd:simpleContent>
   </xsd:complexType>
   <xsd:complexType name="DespatchInformationType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Information with regards to the despatching or shipping of goods.</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
      </xsd:annotation>
      <xsd:sequence>
         <xsd:element name="actualShipDateTime" minOccurs="0" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Actual Ship Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The date and time the goods were shipped.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15T11:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="despatchDateTime" minOccurs="0" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Despatch Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date/time on which the goods are or are expected to be despatched or shipped.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15T11:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="estimatedDeliveryDateTime" minOccurs="0" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Estimated Delivery Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The estimated date and time of delivery.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15T11:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="estimatedDeliveryDateTimeAtUltimateConsignee" minOccurs="0"
            type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Estimated Delivery Date Time At Ultimate Consignee</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The estimated date and time of delivery at the ultimate consignee.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15T11:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="loadingDateTime" minOccurs="0" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Loading Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The date and time when the goods are loaded for transport.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15T11:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="pickUpDateTime" minOccurs="0" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Pick Up Date Time</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date/time at which the cargo is picked up.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15T11:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="releaseDateTimeOfSupplier" minOccurs="0" type="xsd:dateTime">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Release Date Time Of Supplier</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date/Time when the supplier released the goods.</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2012-06-15T11:00:00.000</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="estimatedDeliveryPeriod" minOccurs="0" type="DateTimeRangeType">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Estimated Delivery Period</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">Date time range in which the goods are expected to be delivered.</xsd:documentation>
            </xsd:annotation>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:complexType name="DiscountAgreementCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Code specifying base for discount, fee reduction or bonus. Allowed code values are specified in GS1 Code List DiscountAgreementCode. Information about the allowed code values for this code can be found in the GS1 Global Data Dictionary http://apps.gs1.org/GDD/Pages/clDetails.aspx?semanticURN=urn:gs1:gdd:cl:DiscountAgreementCode</xsd:documentation>
         <xsd:documentation xml:lang="en-US" source="Note">Generic code data type not linked to a specific code list. Besides the code value the GS1 code data type allows to specify the code list version.</xsd:documentation>
      </xsd:annotation>
      <xsd:sequence/>
   </xsd:complexType>
   <xsd:complexType name="DutyFeeTaxExemptionReasonCodeType">
      <xsd:annotation>
         <xsd:documentation xml:lang="en-US" source="Definition">Specifies the reason for exemption of duty, fee or tax.</xsd:documentation>
