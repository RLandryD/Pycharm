<?xml version="1.0" encoding="UTF-8"?>
<!--
  SCENARIO iFlow: Relationship from SAP Subscription Billing to SAP S4HANA
  Display Name : OUT_SRC_SubscriptionBilling_Relationship_from_SA
  Package      : 1_SRC_SubscriptionBilling_Finance
  Strategy     : BROWNFIELD: Lift-and-shift. Mapping '' ported directly.
  Complexity   : MEDIUM (score: 11)
  Effort       : 3 day(s)
  Sender       :  ()
  Receiver     : SubscriptionBilling (HTTP)
  Batch        : No
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Relationship_from_SA"
             name="OUT_SRC_SubscriptionBilling_Relationship_from_SA">
  <process id="Relationship_from_SA_process" ifl:type="IntegrationFlow">

    <startEvent id="Start_SC" name="From Interface Separation">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Relationship_from_SA</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>



    <!-- PROCESSDIRECT: Forward to Outbound Delivery -->
    <serviceTask id="CallOutbound_1" name="→ Outbound Delivery" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/outbound/1_SRC_SubscriptionBi</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_SC"/>
    <sequenceFlow sourceRef="Start_SC" targetRef="CallOutbound_1"/>
    
    
    <sequenceFlow sourceRef="CallOutbound_1" targetRef="End_SC"/>
  </process>
</definitions>