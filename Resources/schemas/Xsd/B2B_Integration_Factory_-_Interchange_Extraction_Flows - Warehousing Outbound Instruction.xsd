               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 1.2</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
         </xsd:element>
         <xsd:element name="calorificValue" minOccurs="0" type="xsd:decimal">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Calorific Value</xsd:documentation>
