						<ccts:CategoryCode xmlns:ccts="urn:un:unece:uncefact:documentation:1.1">UDT</ccts:CategoryCode>
						<ccts:DictionaryEntryName xmlns:ccts="urn:un:unece:uncefact:documentation:1.1">Indicator. Type</ccts:DictionaryEntryName>
						<ccts:VersionID xmlns:ccts="urn:un:unece:uncefact:documentation:1.1">1.0</ccts:VersionID>
						<ccts:Definition xmlns:ccts="urn:un:unece:uncefact:documentation:1.1">A list of two mutually exclusive Boolean values that express the only possible states of a property.</ccts:Definition>
