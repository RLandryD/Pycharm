<?xml version="1.0" encoding="UTF-8"?><xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified" version="1.0">
    <xs:element name="invoice-headers">
        <xs:complexType>
            <xs:sequence>
                <xs:element maxOccurs="unbounded" name="invoice-header">
                    <xs:complexType>
                        <xs:sequence>
                            <xs:element minOccurs="0" name="abandon-reason" type="ReasonInsight"/>
                            <xs:element minOccurs="0" name="account-type" type="AccountType"/>
                            <xs:element minOccurs="0" name="advance-payment-received-amount">
                                <xs:annotation>
                                    <xs:documentation>Amount of advance payment received</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:decimal">
                                        <xs:totalDigits value="30"/>
                                        <xs:fractionDigits value="4"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="amount-due" type="xs:decimal">
                                <xs:annotation>
                                    <xs:documentation>Amount due to the supplier - Invoice Total without withholding and customer accounting taxes</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="amount-due-less-discount" type="xs:decimal">
                                <xs:annotation>
                                    <xs:documentation>Amount due after applying the discount</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="amount-of-advance-payment">
                                <xs:annotation>
                                    <xs:documentation>Amount Of Advance Payment</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:decimal">
                                        <xs:totalDigits value="46"/>
                                        <xs:fractionDigits value="20"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="approvals">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="unbounded" minOccurs="0" name="approval" type="Approval"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element minOccurs="0" name="archive-entity-id" type="xs:integer">
                                <xs:annotation>
                                    <xs:documentation>Archive Entity Id</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="attachments">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="unbounded" minOccurs="0" name="attachment" type="InvoiceHeader"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element minOccurs="0" name="bill-to-address" type="Address"/>
                            <xs:element minOccurs="0" name="buyer-representative-name">
                                <xs:annotation>
                                    <xs:documentation>Buyer Representative Name</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="buyer-tax-registration" type="TaxRegistration"/>
                            <xs:element minOccurs="0" name="canceled" type="xs:boolean">
                                <xs:annotation>
                                    <xs:documentation>Indicates if transaction has been canceled</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="cash-accounting-scheme-reference">
                                <xs:annotation>
                                    <xs:documentation>Note if using cash accounting scheme</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="cash-register-operator">
                                <xs:annotation>
                                    <xs:documentation>Cash Register Operator</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="channel">
                                <xs:annotation>
                                    <xs:documentation>How the invoice was delivered to Coupa</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="80"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="clearance-document" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>Clearance document attachment file name. Accessible via /retrieve_clearance_document</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="comments">
                                <xs:annotation>
                                    <xs:documentation>comments</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="compliant" type="xs:boolean">
                                <xs:annotation>
                                    <xs:documentation>Invoice compliance indicator</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="confirmation">
                                <xs:annotation>
                                    <xs:documentation>Confirmation</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="content-validation" type="xs:boolean">
                                <xs:annotation>
                                    <xs:documentation>Invoice Content Validation Indicator</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="contract" type="Contract"/>
                            <xs:element minOccurs="0" name="correct-value-of-supply">
                                <xs:annotation>
                                    <xs:documentation>Correct Value of Supply</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:decimal">
                                        <xs:totalDigits value="46"/>
                                        <xs:fractionDigits value="20"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="coupa-accelerate-status">
                                <xs:annotation>
                                    <xs:documentation>Status indicating whether the invoice has discount payment terms via Static Discounting</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:enumeration value="accelerated"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="created-at" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>Automatically created by Coupa in the format YYYY-MM-DDTHH:MM:SS+HH:MMZ</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="created-by" type="UserSimple"/>
                            <xs:element minOccurs="0" name="credit-note-differences-with-original-invoice">
                                <xs:annotation>
                                    <xs:documentation>Credit Note Differences With Original Invoice</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:decimal">
                                        <xs:totalDigits value="30"/>
                                        <xs:fractionDigits value="4"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="credit-reason">
                                <xs:annotation>
                                    <xs:documentation>The reason of creating the credit</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="currency" type="Currency"/>
                            <xs:element minOccurs="0" name="currency-id" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>Internal ID of the invoice currency</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="currency-tax-rounding-mode">
                                <xs:annotation>
                                    <xs:documentation>Currency Tax Rounding Method</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="current-integration-history-records">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="unbounded" minOccurs="0" name="current-integration-history-record" type="IntegrationHistoryRecord"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element minOccurs="0" name="customer-accounting-tax" type="xs:decimal">
                                <xs:annotation>
                                    <xs:documentation>Customer accounting tax</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="customer-accounting-tax-less-discount" type="xs:decimal">
                                <xs:annotation>
                                    <xs:documentation>Customer accounting tax after applying the discount</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="customs-declaration-date" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>Customs Declaration Date</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="customs-declaration-number">
                                <xs:annotation>
                                    <xs:documentation>Customs Declaration Number</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="60"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="customs-office" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>Customs Office</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="date-of-discovery-of-facts-decisive-for-correction" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>Date of Discovery of Facts Decisive for Correction</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="date-received" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>Date Received in the format YYYY-MM-DDTHH:MM:SS+HH:MMZ</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="delivery-date" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>Date of Supply</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="delivery-number">
                                <xs:annotation>
                                    <xs:documentation>Delivery Number</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="destination-country" type="Country"/>
                            <xs:element minOccurs="0" name="discount-amount">
                                <xs:annotation>
                                    <xs:documentation>Discount Amount provided by supplier</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:decimal">
                                        <xs:totalDigits value="32"/>
                                        <xs:fractionDigits value="4"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="discount-due-date" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>Discount Due Date calculated based on the discount payment terms</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="discount-percent" type="xs:decimal">
                                <xs:annotation>
                                    <xs:documentation>Discount %</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="dispute-method">
                                <xs:annotation>
                                    <xs:documentation>Dispute Method</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="10"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="dispute-reasons">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="unbounded" minOccurs="0" name="dispute-reason" type="InvoiceHeader"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element minOccurs="0" name="document-type" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>Invoice or Credit Note</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="early-payment-provisions">
                                <xs:annotation>
                                    <xs:documentation>Early payment incentives (This field has been deprecated)</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="endorsement-on-invoices">
                                <xs:annotation>
                                    <xs:documentation>Endorsement On Invoices</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="exchange-rate">
                                <xs:annotation>
                                    <xs:documentation>Exchange Rate</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:decimal">
                                        <xs:totalDigits value="30"/>
                                        <xs:fractionDigits value="9"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="exported" type="xs:boolean">
                                <xs:annotation>
                                    <xs:documentation>Indicates if transaction has been exported</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="failed-tolerances">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="unbounded" minOccurs="0" name="failed-tolerance" type="Invoice-FailedTolerance"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element minOccurs="0" name="folio-number">
                                <xs:annotation>
                                    <xs:documentation>Folio Number</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="form-of-payment">
                                <xs:annotation>
                                    <xs:documentation>Payment Form</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="10"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="freight-type">
                                <xs:annotation>
                                    <xs:documentation>Freight Type</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="gross-total" type="xs:decimal">
                                <xs:annotation>
                                    <xs:documentation>Gross Total</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="gross-total-less-discount" type="xs:decimal">
                                <xs:annotation>
                                    <xs:documentation>Invoice total after applying the discount</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="handling-amount">
                                <xs:annotation>
                                    <xs:documentation>Handling amount</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:decimal">
                                        <xs:totalDigits value="32"/>
                                        <xs:fractionDigits value="4"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="id" type="xs:integer">
                                <xs:annotation>
                                    <xs:documentation>Coupa unique identifier</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="image-scan">
                                <xs:annotation>
                                    <xs:documentation>Invoice Image Scan attachment filename</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="image-scan-content-type">
                                <xs:annotation>
                                    <xs:documentation>Content type of image scan</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="191"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="image-scan-file-name">
                                <xs:annotation>
                                    <xs:documentation>File name of the image scan</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="image-scan-file-size">
                                <xs:annotation>
                                    <xs:documentation>Size of image scan file in MB</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="12"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="image-scan-url">
                                <xs:annotation>
                                    <xs:documentation>Invoice Image Scan URL. Must begin with 'http://' or 'https://'.</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="inbound-invoice" type="InvoiceHeader"/>
                            <xs:element minOccurs="0" name="inbox-name" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>Inbox Name</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="internal-note" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>Internal Note</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="invoice-charges">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="unbounded" minOccurs="0" name="invoice-charge" type="InvoiceCharge"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element minOccurs="0" name="invoice-date" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>Date of Invoice</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="invoice-from-address" type="SupplierRemitTo"/>
                            <xs:element minOccurs="0" name="invoice-issuance-time">
                                <xs:annotation>
                                    <xs:documentation>Invoice Issuance Time</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="invoice-lines">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="unbounded" minOccurs="0" name="invoice-line" type="InvoiceLine"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element minOccurs="0" name="invoice-number">
                                <xs:annotation>
                                    <xs:documentation>Invoice number</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="40"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="invoice-payment-receipts">
                                <xs:complexType>
                                    <xs:sequence>
                                        <xs:element maxOccurs="unbounded" minOccurs="0" name="invoice-payment-receipt" type="InvoiceHeader"/>
                                    </xs:sequence>
                                </xs:complexType>
                            </xs:element>
                            <xs:element minOccurs="0" name="invoice-reference-number">
                                <xs:annotation>
                                    <xs:documentation>Invoice Reference Number (IRN)</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="is-credit-note" type="xs:boolean">
                                <xs:annotation>
                                    <xs:documentation>Document Type Credit Note</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="is-ers-invoice" type="xs:boolean">
                                <xs:annotation>
                                    <xs:documentation>Indicates if Invoice created against ERS Order</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="issuance-place">
                                <xs:annotation>
                                    <xs:documentation>Issuance Place</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="last-exported-at" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>Date and time transaction was last exported in the format YYYY-MM-DDTHH:MM:SS+HH:MMZ</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="late-payment-penalties">
                                <xs:annotation>
                                    <xs:documentation>Late Payment Penalties</xs:documentation>
                                </xs:annotation>
                                <xs:simpleType>
                                    <xs:restriction base="xs:string">
                                        <xs:maxLength value="255"/>
                                    </xs:restriction>
                                </xs:simpleType>
                            </xs:element>
                            <xs:element minOccurs="0" name="legal-destination-country" type="Country"/>
                            <xs:element minOccurs="0" name="line-count" type="xs:string">
                                <xs:annotation>
                                    <xs:documentation>Number of lines on this invoice</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="line-level-taxation" type="xs:boolean">
                                <xs:annotation>
                                    <xs:documentation>Flag indicating whether taxes are provided at line level in this invoice</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="lock-version-key" type="xs:integer">
                                <xs:annotation>
                                    <xs:documentation>Lock Version</xs:documentation>
                                </xs:annotation>
                            </xs:element>
                            <xs:element minOccurs="0" name="margin-scheme">
                                <xs:annotation>
                                    <xs:documentation>Reason for using margin scheme</xs:documentation>
                                </xs:annotation>
