<?xml version="1.0" encoding="UTF-8"?>
<!--
  SCENARIO iFlow: Chile Sign Delivery Note Ledger
  Display Name : OUT_Sender_TGT_Chile_Sign_Delivery_
  Package      : 1_Sender_TGT_Finance
  Strategy     : BROWNFIELD: Lift-and-shift. Mapping '' ported directly.
  Complexity   : MEDIUM (score: 22)
  Effort       : 3 day(s)
  Sender       : Sender (SOAP)
  Receiver     :  ()
  Batch        : No
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Chile_Sign_Delivery_"
             name="OUT_Sender_TGT_Chile_Sign_Delivery_">
  <process id="Chile_Sign_Delivery__process" ifl:type="IntegrationFlow">

    <startEvent id="Start_SC" name="From Interface Separation">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Chile_Sign_Delivery_</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>



    <!-- PROCESSDIRECT: Forward to Outbound Delivery -->
    <serviceTask id="CallOutbound_1" name="→ Outbound Delivery" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/outbound/1_Sender_TGT_Finance</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_SC"/>
    <sequenceFlow sourceRef="Start_SC" targetRef="CallOutbound_1"/>
    
    
    <sequenceFlow sourceRef="CallOutbound_1" targetRef="End_SC"/>
  </process>
</definitions>