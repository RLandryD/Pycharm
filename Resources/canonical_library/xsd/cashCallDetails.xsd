                <xs:element name="jointVenture" type="xs:string" minOccurs="0"/>
                <xs:element name="fundCurrency" type="xs:string" minOccurs="0"/>
                <xs:element name="invoiceType" type="xs:string" minOccurs="0"/>
                <xs:element name="processType" type="xs:string" minOccurs="0"/>
            </xs:sequence>
         </xs:complexType>
        </xs:element>
        <xs:element minOccurs="0" maxOccurs="unbounded" name="cashCallInformation">
