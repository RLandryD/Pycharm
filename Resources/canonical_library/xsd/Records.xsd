          <xs:complexType>
            <xs:sequence>
              <xs:element name="Date" type="xs:dateTime"  maxOccurs="1" minOccurs="0"/>
              <xs:element name="RealUser" type="xs:string"  maxOccurs="1" minOccurs="0"/>
              <xs:element name="User">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="UniqueName" type="xs:string"  maxOccurs="1" minOccurs="0"/>
                    <xs:element name="PasswordAdapter" type="xs:string"  maxOccurs="1" minOccurs="0"/>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element name="LineItems" maxOccurs="unbounded" minOccurs="0">
          <xs:complexType>
            <xs:sequence>
              <xs:choice maxOccurs="unbounded">
                <xs:element name="Description.CommonCommodityCode" maxOccurs="1" minOccurs="0">
