<?xml version="1.0" encoding="UTF-8"?>
<!--
  SCENARIO iFlow: Update Employee Email from C4C to YaaS
  Display Name : OUT_C4C_AccountService_Update_Employee_Emai
  Package      : 1_C4C_AccountService_Logistics
  Strategy     : BROWNFIELD: Lift-and-shift. Mapping '' ported directly.
  Complexity   : MEDIUM (score: 15)
  Effort       : 3 day(s)
  Sender       : C4C (HTTPS)
  Receiver     : AccountService (HTTP)
  Batch        : No
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:ifl="http:///com.sap.ifl.model/Ifl.xsd"
             id="Update_Employee_Emai"
             name="OUT_C4C_AccountService_Update_Employee_Emai">
  <process id="Update_Employee_Emai_process" ifl:type="IntegrationFlow">

    <startEvent id="Start_SC" name="From Interface Separation">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/scenario/Update_Employee_Emai</ifl:value>
        </ifl:property>
      </extensionElements>
    </startEvent>



    <!-- PROCESSDIRECT: Forward to Outbound Delivery -->
    <serviceTask id="CallOutbound_1" name="→ Outbound Delivery" ifl:type="RequestReply">
      <extensionElements>
        <ifl:property><ifl:key>Transport</ifl:key><ifl:value>ProcessDirect</ifl:value></ifl:property>
        <ifl:property><ifl:key>Address</ifl:key>
          <ifl:value>/outbound/1_C4C_AccountService</ifl:value>
        </ifl:property>
      </extensionElements>
    </serviceTask>

    <endEvent id="End_SC"/>
    <sequenceFlow sourceRef="Start_SC" targetRef="CallOutbound_1"/>
    
    
    <sequenceFlow sourceRef="CallOutbound_1" targetRef="End_SC"/>
  </process>
</definitions>