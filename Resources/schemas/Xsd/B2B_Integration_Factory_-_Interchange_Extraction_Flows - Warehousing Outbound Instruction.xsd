                  self packaged shipping container. The trade item does not need to be re-packaged
                  to ship to end consumer. </xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SID">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Store in the
                  Daylight</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The product must be stored in
                  the daylight</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SLT">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Sensitive to
                  Light</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Definition">The product is sensitive to
                  light.</xsd:documentation>
            </xsd:annotation>
         </xsd:enumeration>
         <xsd:enumeration value="SNM">
            <xsd:annotation>
               <xsd:documentation xml:lang="en-US" source="Name">Transmit a Ship Notice/Manifest
                  Transaction Set</xsd:documentation>
