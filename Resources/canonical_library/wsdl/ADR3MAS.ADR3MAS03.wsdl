						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="CALLER_NO" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Telephone number for determining caller
							</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="30" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="STD_RECIP" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Indicator: Telephone is SMS-Enabled
							</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="1" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="R_3_USER" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Indicator: Telephone is a Mobile Telephone
							</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="1" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="HOME_FLAG" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Recipient address in this communication type
								(mail sys.grp)</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="1" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="CONSNUMBER" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Sequence number</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="3" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="ERRORFLAG" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Flag: Record not processed</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="1" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="FLG_NOUSE" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Flag: This Communication Number is Not Used
							</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="1" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="VALID_FROM" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Communication Data: Valid From
								(YYYYMMDDHHMMSS)</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="14" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="VALID_TO" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Communication Data: Valid To (YYYYMMDDHHMMSS)
							</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="14" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
				</xsd:sequence>
				<xsd:attribute name="SEGMENT" type="xsd:string" fixed="1"
					use="required" />
			</xsd:complexType>
			<xsd:complexType name="ADR3MAS03.E1BPAD3VL">
				<xsd:annotation>
					<xsd:documentation>Return structure for the address of a person in
						a company</xsd:documentation>
				</xsd:annotation>
				<xsd:sequence>
					<xsd:element name="ADDR_VERS" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>International address version ID
							</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="1" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="FROM_DATE" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Valid-from date - in current Release only
								00010101 possible</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="8" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="TO_DATE" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Valid-to date in current Release only 99991231
								possible</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="8" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="TITLE_P" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Form-of-Address Key</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="4" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="FIRSTNAME" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>First name</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="40" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="LASTNAME" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Last name</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="40" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="BIRTH_NAME" minOccurs="0">
						<xsd:annotation>
							<xsd:documentation>Name of person at birth</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="xsd:string">
								<xsd:maxLength value="40" />
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<xsd:element name="MIDDLENAME" minOccurs="0">
