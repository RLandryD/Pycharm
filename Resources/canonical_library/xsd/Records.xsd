        <xs:element name="AreOrdersStuck" type="xs:boolean" maxOccurs="1" minOccurs="0"/>
        <xs:element name="CreateDate" type="xs:dateTime" maxOccurs="1" minOccurs="0"/>
        <xs:element name="TimeUpdated" type="xs:dateTime" maxOccurs="1" minOccurs="0"/>
        <xs:element name="LastModified" type="xs:dateTime" maxOccurs="1" minOccurs="0"/>
        <xs:element name="TotalCost" maxOccurs="1" minOccurs="0">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="AmountInReportingCurrency" type="xs:decimal" maxOccurs="1" minOccurs="0"/>
              <xs:element name="ApproxAmountInBaseCurrency" type="xs:decimal" maxOccurs="1" minOccurs="0"/>
              <xs:element name="Amount" type="xs:decimal" maxOccurs="1" minOccurs="0"/>
              <xs:element name="ConversionDate" type="xs:dateTime" maxOccurs="1" minOccurs="0"/>
              <xs:element name="Currency" maxOccurs="1" minOccurs="0">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="UniqueName" type="xs:string" maxOccurs="1" minOccurs="0"/>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element name="ApprovalRequests" maxOccurs="unbounded" minOccurs="0">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="AssignedTo" maxOccurs="1" minOccurs="0"/>
              <xs:element name="AssignedDate" maxOccurs="1" minOccurs="0"/>
              <xs:element name="ApprovedBy" maxOccurs="1" minOccurs="0"/>
              <xs:element name="ApprovalRequired" type="xs:boolean" maxOccurs="1" minOccurs="0" />
              <xs:element name="Approver" maxOccurs="1" minOccurs="0">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="UniqueName" type="xs:string" maxOccurs="1" minOccurs="0"/>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
              <xs:element name="ActivationDate" type="xs:string" maxOccurs="1" minOccurs="0"/>
              <xs:element name="ApproverComment" maxOccurs="1" minOccurs="0"/>
              <xs:element name="RuleName" type="xs:string" maxOccurs="1" minOccurs="0"/>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element name="Requester" maxOccurs="1" minOccurs="0">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="UniqueName" type="xs:string" maxOccurs="1" minOccurs="0"/>
              <xs:element name="PasswordAdapter" type="xs:string" maxOccurs="1" minOccurs="0"/>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element name="UniqueName" type="xs:string" maxOccurs="1" minOccurs="0"/>
        <xs:element name="Preparer" maxOccurs="1" minOccurs="0">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="UniqueName" type="xs:string" maxOccurs="1" minOccurs="0"/>
              <xs:element name="PasswordAdapter" type="xs:string" maxOccurs="1" minOccurs="0"/>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
</xs:schema>