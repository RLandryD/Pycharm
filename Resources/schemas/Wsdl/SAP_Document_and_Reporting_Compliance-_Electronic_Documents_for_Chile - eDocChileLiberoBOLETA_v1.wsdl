<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<wsdl:definitions xmlns:soap="http://schemas.xmlsoap.org/wsdl/soap/"
	xmlns:tns="http://www.sap.com/eDocument/Chile/LiberoBOLETA/v1.0"
	xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/" xmlns:xsd="http://www.w3.org/2001/XMLSchema"
	name="eDocChileLiberoBOLETA_v1"
	targetNamespace="http://www.sap.com/eDocument/Chile/LiberoBOLETA/v1.0">

	<wsdl:types>
		<xsd:schema targetNamespace="http://www.sap.com/eDocument/Chile/LiberoBOLETA/v1.0">
			<xsd:element name="SignMonthlyBoletaSummary">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element name="LibroBoleta">
							<xsd:annotation>
								<xsd:documentation>Informacion Electronica de Libros de Boletas
								</xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:sequence>
									<xsd:element name="EnvioLibro">
										<xsd:annotation>
											<xsd:documentation>Identificacion, Resumen y Detalles del
												Libro
												Electronico
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<xsd:element name="Caratula">
													<xsd:annotation>
														<xsd:documentation>Identificacion del Envio del Libro
															Electronico
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="RutEmisorLibro" type="tns:RUTType">
																<xsd:annotation>
																	<xsd:documentation>RUT del Emisor del Libro Electronico
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="RutEnvia" type="tns:RUTType">
																<xsd:annotation>
																	<xsd:documentation>RUT que Realiza el Envio del Libro
																		Electronico
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="PeriodoTributario" type="xsd:gYearMonth">
																<xsd:annotation>
																	<xsd:documentation>Periodo Tributario del Libro
																		Electronico (AAAA-MM)
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="FchResol" type="xsd:date">
																<xsd:annotation>
																	<xsd:documentation>Fecha de Resolucion que Autoriza el
																		Envio de Libros (AAAA-MM-DD)
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="NroResol">
																<xsd:annotation>
																	<xsd:documentation>Numero de Resolucion que Autoriza el
																		Envio de Libros
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:nonNegativeInteger">
																		<xsd:totalDigits value="6" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="TipoLibro">
																<xsd:annotation>
																	<xsd:documentation>Tipo de Libro al que Corresponde el
																		Envio
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:maxLength value="10" />
																		<xsd:enumeration value="ESPECIAL" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="TipoEnvio" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Tipo de Envio del Libro Electronico
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:enumeration value="PARCIAL">
																			<xsd:annotation>
																				<xsd:documentation>Indica que es un Envio Parcial del
																					Libro y que Faltan Otros para Completar el Libro
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="FINAL">
																			<xsd:annotation>
																				<xsd:documentation>Indica que es el Ultimo Envio
																					Parcial. Con Esto se Completa el Libro.
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="TOTAL">
																			<xsd:annotation>
																				<xsd:documentation>Indica que es el Unico Envio que
																					Compone el Libro
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="AJUSTE">
																			<xsd:annotation>
																				<xsd:documentation>Indica que es un Envio con
																					Informacion para Corregir un Libro Previamente
																					Enviado
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="NroSegmento" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Correlativo del Segmento de Libro
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:totalDigits value="6" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="FolioNotificacion">
																<xsd:annotation>
																	<xsd:documentation>Folio de la Notificacion con que se
																		Solicita el Libro Especial
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:totalDigits value="18" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="ResumenSegmento" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Resumen del Segmento de Informacion
															Enviado
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="TotalesSegmento" maxOccurs="2">
																<xsd:annotation>
																	<xsd:documentation>Totales de Control, por Tipo de
																		Documento, Tipo de Servicio y Periodo de Devengo, Para
																		el Segmento
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:complexType>
																	<xsd:sequence>
																		<xsd:element name="TpoDoc" type="tns:DoctoType">
																			<xsd:annotation>
																				<xsd:documentation>Tipo de Documento Resumido
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="TotAnulado" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Total de Folios Anulados
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:integer">
																					<xsd:totalDigits value="10" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="TotalesServicio"
																			minOccurs="0" maxOccurs="9">
																			<xsd:annotation>
																				<xsd:documentation>Totales de Control por Tipo de
																					Servicio y Periodo de Devengo
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:complexType>
																				<xsd:sequence>
																					<xsd:element name="TpoServ">
																						<xsd:annotation>
																							<xsd:documentation>Tipo de Servicio Resumido
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:simpleType>
																							<xsd:restriction base="xsd:positiveInteger">
																								<xsd:totalDigits value="1" />
																								<xsd:enumeration value="1">
																									<xsd:annotation>
																										<xsd:documentation>Servicio Periodico
																										</xsd:documentation>
																									</xsd:annotation>
																								</xsd:enumeration>
																								<xsd:enumeration value="2">
																									<xsd:annotation>
																										<xsd:documentation>Servicio Periodico
																											Domiciliario
																										</xsd:documentation>
																									</xsd:annotation>
																								</xsd:enumeration>
																								<xsd:enumeration value="3">
																									<xsd:annotation>
																										<xsd:documentation>Venta y Servicio
																										</xsd:documentation>
																									</xsd:annotation>
																								</xsd:enumeration>
																								<xsd:enumeration value="4">
																									<xsd:annotation>
																										<xsd:documentation>Boleta de Espectáculo
																											emitida
																											por cuenta de Terceros
																										</xsd:documentation>
																									</xsd:annotation>
																								</xsd:enumeration>
																							</xsd:restriction>
																						</xsd:simpleType>
																					</xsd:element>
																					<xsd:element name="PeriodoDevengo" type="xsd:gYearMonth"
																						minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Periodo (AAAA-MM) en que Vencen
																								los Documentos
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="TotDoc">
																						<xsd:annotation>
																							<xsd:documentation>Numero de Documentos del Tipo
																								Incluidos en el Libro Electronico
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:simpleType>
																							<xsd:restriction base="xsd:integer">
																								<xsd:totalDigits value="10" />
																							</xsd:restriction>
																						</xsd:simpleType>
																					</xsd:element>
																					<xsd:element name="TotMntExe" type="tns:MontoType"
																						minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Total de los Montos Exentos
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="TotMntTotal" type="tns:MontoType">
																						<xsd:annotation>
																							<xsd:documentation>Total de los Montos Totales
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="TotMntNoFact" type="tns:ValorType"
																						minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Total Monto No Facturable
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="TotMntPeriodo" type="tns:ValorType"
																						minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Total Monto Periodo
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="TotSaldoAnt" type="tns:ValorType"
																						minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Total Saldo Anterior
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="TotVlrPagar" type="tns:ValorType"
																						minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Total Valor a Pagar
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="TotTicket" minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Total de Ticket informados en
																								el
																								Segmento
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:simpleType>
																							<xsd:restriction base="tns:MontoType">
																								<xsd:totalDigits value="7" />
																							</xsd:restriction>
																						</xsd:simpleType>
																					</xsd:element>
																				</xsd:sequence>
																			</xsd:complexType>
																		</xsd:element>
																	</xsd:sequence>
																</xsd:complexType>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="ResumenPeriodo" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>Resumen Para el Periodo Tributario
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="TotalesPeriodo" maxOccurs="2">
																<xsd:annotation>
																	<xsd:documentation>Totales de Control, por Tipo de
																		Documento, Tipo de Servicio y Periodo de Devengo, Para
																		el Periodo Tributario
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:complexType>
																	<xsd:sequence>
																		<xsd:element name="TpoDoc" type="tns:DoctoType">
																			<xsd:annotation>
																				<xsd:documentation>Tipo de Documento Resumido
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:element>
																		<xsd:element name="TotAnulado" minOccurs="0">
																			<xsd:annotation>
																				<xsd:documentation>Total de Folios Anulados
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:simpleType>
																				<xsd:restriction base="xsd:positiveInteger">
																					<xsd:totalDigits value="10" />
																				</xsd:restriction>
																			</xsd:simpleType>
																		</xsd:element>
																		<xsd:element name="TotalesServicio"
																			maxOccurs="9">
																			<xsd:annotation>
																				<xsd:documentation>Totales de Control por Tipo de
																					Servicio y Periodo de Devengo
																				</xsd:documentation>
																			</xsd:annotation>
																			<xsd:complexType>
																				<xsd:sequence>
																					<xsd:element name="TpoServ">
																						<xsd:annotation>
																							<xsd:documentation>Tipo de Servicio Resumido
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:simpleType>
																							<xsd:restriction base="xsd:positiveInteger">
																								<xsd:totalDigits value="1" />
																								<xsd:enumeration value="1">
																									<xsd:annotation>
																										<xsd:documentation>Servicio Periodico
																										</xsd:documentation>
																									</xsd:annotation>
																								</xsd:enumeration>
																								<xsd:enumeration value="2">
																									<xsd:annotation>
																										<xsd:documentation>Servicio Periodico
																											Domiciliario
																										</xsd:documentation>
																									</xsd:annotation>
																								</xsd:enumeration>
																								<xsd:enumeration value="3">
																									<xsd:annotation>
																										<xsd:documentation>Venta y Servicio
																										</xsd:documentation>
																									</xsd:annotation>
																								</xsd:enumeration>
																								<xsd:enumeration value="4">
																									<xsd:annotation>
																										<xsd:documentation>Boleta de Espectáculo
																											emitida
																											por cuenta de Terceros
																										</xsd:documentation>
																									</xsd:annotation>
																								</xsd:enumeration>
																							</xsd:restriction>
																						</xsd:simpleType>
																					</xsd:element>
																					<xsd:element name="PeriodoDevengado"
																						type="xsd:gYearMonth" minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Periodo (AAAA-MM) en que Vencen
																								lod Documentos
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="TotDoc" type="xsd:positiveInteger">
																						<xsd:annotation>
																							<xsd:documentation>Numero de Documentos del Tipo
																								Incluidos en el Libro Electronico
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="TotMntExe" type="tns:MontoType"
																						minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Total de los Montos Exentos
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="TotMntNeto" type="tns:MontoType">
																						<xsd:annotation>
																							<xsd:documentation>Total de los Montos Netos
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="TasaIVA" type="tns:PctType"
																						minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Tasa de IVA Aplicada a los
																								Documentos
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="TotMntIVA" type="tns:MontoType">
																						<xsd:annotation>
																							<xsd:documentation>Total de los Montos de IVA
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="TotMntTotal" type="tns:MontoType">
																						<xsd:annotation>
																							<xsd:documentation>Total de los Montos Totales
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="TotMntNoFact" type="tns:ValorType"
																						minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Total Monto No Facturable
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="TotMntPeriodo" type="tns:ValorType"
																						minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Total Monto Periodo
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="TotSaldoAnt" type="tns:MontoType"
																						minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Total Saldo Anterior
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="TotVlrPagar" type="tns:MontoType"
																						minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Total Valor a Pagar
																							</xsd:documentation>
																						</xsd:annotation>
																					</xsd:element>
																					<xsd:element name="TotTicket" minOccurs="0">
																						<xsd:annotation>
																							<xsd:documentation>Total de Ticket informados en
																								el
																								Periodo
																							</xsd:documentation>
																						</xsd:annotation>
																						<xsd:simpleType>
																							<xsd:restriction base="tns:MontoType">
																								<xsd:totalDigits value="7" />
																							</xsd:restriction>
																						</xsd:simpleType>
																					</xsd:element>
																				</xsd:sequence>
																			</xsd:complexType>
																		</xsd:element>
																	</xsd:sequence>
																</xsd:complexType>
															</xsd:element>
														</xsd:sequence>
													</xsd:complexType>
												</xsd:element>
												<xsd:element name="Detalle" minOccurs="0"
													maxOccurs="unbounded">
													<xsd:annotation>
														<xsd:documentation>Detalle de Documentos que Componen el
															Libro Electronico
														</xsd:documentation>
													</xsd:annotation>
													<xsd:complexType>
														<xsd:sequence>
															<xsd:element name="TpoDoc" type="tns:DoctoType">
																<xsd:annotation>
																	<xsd:documentation>Tipo de Boleta</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="FolioDoc">
																<xsd:annotation>
																	<xsd:documentation>Folio de la Boleta</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:totalDigits value="10" />
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="Anulado" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Indica que el Estado de la Boleta es
																		Anulado
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:string">
																		<xsd:enumeration value="A">
																			<xsd:annotation>
																				<xsd:documentation>Documento Anulado
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="TpoServ" minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Tipo de Servicio de la Boleta
																	</xsd:documentation>
																</xsd:annotation>
																<xsd:simpleType>
																	<xsd:restriction base="xsd:positiveInteger">
																		<xsd:totalDigits value="1" />
																		<xsd:enumeration value="1">
																			<xsd:annotation>
																				<xsd:documentation>Servicio Periodico
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="2">
																			<xsd:annotation>
																				<xsd:documentation>Servicio Periodico Domiciliario
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="3">
																			<xsd:annotation>
																				<xsd:documentation>Venta y Servicio
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																		<xsd:enumeration value="4">
																			<xsd:annotation>
																				<xsd:documentation>Boleta de Espectáculo emitida por
																					cuenta de Terceros
																				</xsd:documentation>
																			</xsd:annotation>
																		</xsd:enumeration>
																	</xsd:restriction>
																</xsd:simpleType>
															</xsd:element>
															<xsd:element name="FchEmiDoc" type="xsd:date"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Fecha de Emision del Documento
																		(AAAA-MM-DD)
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="FchVencDoc" type="xsd:date"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Fecha de Vencimiento del Documento
																		(AAAA-MM-DD)
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
															<xsd:element name="PeriodoDesde" type="xsd:date"
																minOccurs="0">
																<xsd:annotation>
																	<xsd:documentation>Inicio de Periodo de Cobro
																	</xsd:documentation>
																</xsd:annotation>
															</xsd:element>
