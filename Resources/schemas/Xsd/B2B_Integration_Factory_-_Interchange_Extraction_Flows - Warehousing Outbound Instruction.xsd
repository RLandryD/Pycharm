               <xsd:documentation xml:lang="en-US" source="Note">GS1 Example value: 2016-08-20T09:30:00.000</xsd:documentation>
               <xsd:documentation xml:lang="en-US" source="Note">GS1 Filter: </xsd:documentation>
            </xsd:annotation>
