										<xs:restriction base="xs:string">
											<xs:minLength value="1" />
											<xs:whiteSpace value="collapse" />
											<xs:pattern
												value="[A-Za-z0-9_]+([\-+\.][A-Za-z0-9_]+)*@[A-Za-z0-9_]+([\-\.][A-Za-z0-9_]+)*\.[A-Za-z0-9_]+([\-\.][A-Za-z0-9_]+)*" />
