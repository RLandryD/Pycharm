    <End Type="API_SALES_CONTRACT_SRV.A_SalesContractItemPrcgElmntType" Multiplicity="*" Role="ToRole_assoc_CBD6E44D3CB028CA9CFD9823722374DA"/>
   </Association>
   <Association Name="assoc_6813D03AD1FCDC0FB826FBB5C31D3BAC" sap:content-version="1">
    <End Type="API_SALES_CONTRACT_SRV.A_SalesContractItemType" Multiplicity="1" Role="FromRole_assoc_6813D03AD1FCDC0FB826FBB5C31D3BAC"/>
    <End Type="API_SALES_CONTRACT_SRV.A_SalesContractType" Multiplicity="1" Role="ToRole_assoc_6813D03AD1FCDC0FB826FBB5C31D3BAC"/>
   </Association>
   <Association Name="assoc_C05926A8B1CF11C57783DA64800F0711" sap:content-version="1">
    <End Type="API_SALES_CONTRACT_SRV.A_SalesContractPartnerType" Multiplicity="1" Role="FromRole_assoc_C05926A8B1CF11C57783DA64800F0711"/>
    <End Type="API_SALES_CONTRACT_SRV.A_SalesContractType" Multiplicity="1" Role="ToRole_assoc_C05926A8B1CF11C57783DA64800F0711"/>
   </Association>
   <Association Name="assoc_F7E2B6E189FE18642F3F53B5FCF940C4" sap:content-version="1">
    <End Type="API_SALES_CONTRACT_SRV.A_SalesContractType" Multiplicity="1" Role="FromRole_assoc_F7E2B6E189FE18642F3F53B5FCF940C4"/>
    <End Type="API_SALES_CONTRACT_SRV.A_SalesContractPartnerType" Multiplicity="*" Role="ToRole_assoc_F7E2B6E189FE18642F3F53B5FCF940C4"/>
   </Association>
   <Association Name="assoc_166710B494E28D183E54DF569E31D6A8" sap:content-version="1">
    <End Type="API_SALES_CONTRACT_SRV.A_SalesContractType" Multiplicity="1" Role="FromRole_assoc_166710B494E28D183E54DF569E31D6A8"/>
