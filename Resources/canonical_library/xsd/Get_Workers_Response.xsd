<xsd:documentation>Boolean attribute identifying whether the leave event has a Continuous</xsd:documentation>
</xsd:annotation>
</xsd:element>
<xsd:element maxOccurs="1" minOccurs="0" name="Stock_Vesting_Effect" type="xsd:boolean">
<xsd:annotation>
<xsd:documentation>Boolean attribute identifying whether the leave event has a Stock Vesting</xsd:documentation>
</xsd:annotation>
</xsd:element>
<xsd:element minOccurs="0" name="Leave_Type_Reason_Reference" type="wd:Leave_Type_ReasonObjectType">
<xsd:annotation>
<xsd:documentation>Leave Type Reason</xsd:documentation>
</xsd:annotation>
</xsd:element>
