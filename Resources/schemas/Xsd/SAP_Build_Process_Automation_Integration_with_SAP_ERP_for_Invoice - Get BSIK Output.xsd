    <xs:complexType>
      <xs:sequence>
        <xs:element name="documentList" maxOccurs="unbounded" minOccurs="0">
          <xs:complexType>
            <xs:sequence>
                    <xs:element type="xs:int" name="accountingDocumentNo"/>
                    <xs:element type="xs:byte" name="companyCode"/>
                    <xs:element type="xs:short" name="fishcalYear"/>
                    <xs:element type="xs:int" name="invoiceDate"/>
                    <xs:element type="xs:int" name="reference"/>
                    <xs:element type="xs:int" name="vendorNumber"/>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
</xs:schema>